# Copy to .env.test.local (or export in shell) for isolated PostgreSQL test runs.
# Use a dedicated database (e.g. getpro_test), never production or a shared dev DB.

GETPRO_TEST_DB=1
TEST_DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/getpro_test

# Optional: match local Postgres SSL (see README / GETPRO_PG_SSL in pool.js)
# GETPRO_PG_SSL=off
