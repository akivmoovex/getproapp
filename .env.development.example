# pronline.org — test / demo / staging (not getproapp.org production).
# Set these in Hostinger (or merge a local `.env` when NODE_ENV is not production).
#
# Admin → DB tools — pick ONE:
#   Option A: NODE_ENV=development (or staging) — tools on; omit fixture flags below.
#   Option B: NODE_ENV=production — set BOTH to exactly 1 in the panel (required together):
#             GETPRO_ALLOW_DB_FIXTURES=1
#             GETPRO_ALLOW_DB_FIXTURES_IN_PRODUCTION=1

NODE_ENV=production
BASE_DOMAIN=pronline.org
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
ADMIN_PASSWORD=REPLACE_ME
PUBLIC_SCHEME=https
PORT=3000
HOST=0.0.0.0
GETPRO_PG_SSL=no-verify
TRUST_PROXY=1

# Field agent IP rate limits (optional; per client IP incl. authed POSTs — shared NAT shares one cap; see docs/CONFIG_AND_DEPLOYMENT.md)
# GETPRO_LOGIN_RATE_WINDOW_MS=900000
# GETPRO_FIELD_AGENT_LOGIN_RATE_MAX=30
# GETPRO_FIELD_AGENT_AUTHED_POST_RATE_MAX=30

# Branding (pronline.org — Pro-online lockup; omit GETPRO_HTML_DATA_BRAND or set proonline)
GETPRO_PRODUCT_NAME=Pro-online
GETPRO_PRODUCT_NAME_GETPRO=GetPro
GETPRO_HTML_DATA_BRAND=proonline

# Option B only: uncomment both on the pronline.org host (never on getproapp.org).
# GETPRO_ALLOW_DB_FIXTURES=1
# GETPRO_ALLOW_DB_FIXTURES_IN_PRODUCTION=1
