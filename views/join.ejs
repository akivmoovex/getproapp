<!doctype html>
<% var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<% var _f = typeof ctaVoice !== 'undefined' && ctaVoice && ctaVoice.form ? ctaVoice.form : null; %>
<% var _onb = _f && _f.onboarding ? _f.onboarding : {}; %>
<% var _gen = _f && _f.generic ? _f.generic : {}; %>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof htmlDir !== 'undefined' ? htmlDir : 'ltr' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/seo_meta', {
      seoTitle: typeof seoTitle !== 'undefined' ? seoTitle : ('Become a ' + _bn + ' Partner | ' + _bn),
      seoDescription: typeof seoDescription !== 'undefined' ? seoDescription : ('Become a ' + _bn + ' Partner — list your professional services and grow your business with a clear profile.'),
      canonicalUrl: typeof canonicalUrl !== 'undefined' ? canonicalUrl : '',
      ogUrl: typeof ogUrl !== 'undefined' ? ogUrl : '',
      ogType: typeof ogType !== 'undefined' && ogType ? ogType : 'website',
      noindex: typeof noindex !== 'undefined' && noindex,
      hreflangAlternates: typeof hreflangAlternates !== 'undefined' ? hreflangAlternates : []
    }) %>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="join-page <%= tenant.themeClass %><%= typeof joinEmbedModal !== 'undefined' && joinEmbedModal ? ' join-page--embed-modal' : '' %>" data-screen-role="support">
    <% if (!(typeof joinEmbedModal !== 'undefined' && joinEmbedModal)) { %>
    <div class="join-topbar-row">
      <%- include('partials/brand_lockup_getpro', { tenant, brandLockupVariant: 'join', brandLockupHref: tenantHomeHref }) %>
    </div>
    <% } %>

    <section class="join-hero" id="join-hero">
      <div class="ds-container join-hero-inner">
        <h1>Become a <%= _bn %> Partner</h1>
        <p class="join-lead">
          Tell us what you do and where you operate. <%= _bn %> helps people in Zambia find trusted professionals — join the directory and we’ll walk you through the next steps.
        </p>

        <div class="join-tiles" aria-label="Why partner with <%= _bn %>">
          <div class="join-tiles-grid">
            <article class="join-tile">
              <div class="join-tile-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
              </div>
              <h3 class="join-tile-title">Reach the right clients</h3>
              <p class="join-tile-text">Show up when people search your profession and city — your profile is built for discovery.</p>
              <p class="join-tile-more">Appear in filtered results so homeowners and businesses find you when they need your trade — not random traffic.</p>
            </article>
            <article class="join-tile">
              <div class="join-tile-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="18" x="3" y="3" rx="2" />
                  <path d="M3 9h18" />
                  <path d="M9 21V9" />
                </svg>
              </div>
              <h3 class="join-tile-title">One clear profile</h3>
              <p class="join-tile-text">Keep services, contact options, and your story in one professional page — easy for customers to trust.</p>
              <p class="join-tile-more">One link to share everywhere — your services, areas, and contact methods stay consistent and easy to scan.</p>
            </article>
            <article class="join-tile">
              <div class="join-tile-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              </div>
              <h3 class="join-tile-title">Quality-first directory</h3>
              <p class="join-tile-text">We review partner applications so the marketplace stays credible for homeowners and businesses.</p>
              <p class="join-tile-more">Listings are vetted so visitors trust who they contact — better for serious enquiries and your reputation.</p>
            </article>
            <article class="join-tile">
              <div class="join-tile-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </div>
              <h3 class="join-tile-title">Leads that fit you</h3>
              <p class="join-tile-text">Visitors can reach you directly from your profile — fewer missed opportunities, clearer conversations.</p>
              <p class="join-tile-more">Phone, email, or forms on your page — people choose how to reach you, so you get enquiries that match how you work.</p>
            </article>
            <article class="join-tile">
              <div class="join-tile-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M12 6v6l4 2" />
                </svg>
              </div>
              <h3 class="join-tile-title">Fast to start</h3>
              <p class="join-tile-text">Short registration, then our team follows up with onboarding — no endless forms on day one.</p>
              <p class="join-tile-more">Tell us what you do and where you work first — we help you polish the rest when you’re ready.</p>
            </article>
            <article class="join-tile">
              <div class="join-tile-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
                  <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
                  <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
                  <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
                </svg>
              </div>
              <h3 class="join-tile-title">Partner support</h3>
              <p class="join-tile-text">We’re here to help you present your business well and make the most of your listing on <%= _bn %>.</p>
              <p class="join-tile-more">Questions about your profile or how to get more from the directory — our team is on your side.</p>
            </article>
          </div>
        </div>

        <%- include('partials/components/button', { variant: 'primary', type: 'button', label: (_onb.start || 'Get Started'), id: 'join-get-started', className: 'join-get-started' }) %>

        <div class="join-wizard-frame" id="join-wizard-frame" hidden>
          <section class="join-wizard join-wizard--hidden" id="join-wizard" aria-hidden="true">
            <div class="join-wizard-inner" id="join-wizard-inner">
              <div class="join-progress-wrap" id="join-progress-wrap">
                <div class="join-progress" role="status" aria-live="polite">
                  Step <span id="join-step-num">1</span> of 3
                </div>
                <div class="join-progress-track" aria-hidden="true">
                  <div class="join-progress-fill" id="join-progress-fill"></div>
                </div>
              </div>

              <div id="join-panels">
                <div class="join-step-panel" id="join-step-1" data-step="1">
                  <div class="form-step">
                    <div class="form-step__header">
                      <h2 class="form-step__title">What service do you provide?</h2>
                      <p class="form-step__subtitle">Choose the main service customers should find you under.</p>
                    </div>
                    <div class="form-step__body">
                      <div class="join-field join-field--ac input-field input-field--search">
                        <label for="join-profession" class="input-field__label">Service or profession</label>
                        <div
                          class="pro-ac join-pro-ac input-field__control"
                          data-ac-list="service"
                          data-watermark-rotate="<%= typeof joinProfessionWatermarkRotate !== 'undefined' && joinProfessionWatermarkRotate ? joinProfessionWatermarkRotate : 'Search:' %>"
                        >
                          <input
                            id="join-profession"
                            class="pro-ac-input input-field__control"
                            type="text"
                            autocomplete="off"
                            role="combobox"
                            aria-autocomplete="list"
                            aria-expanded="false"
                            aria-controls="join-profession-dropdown"
                            aria-describedby="join-profession-msg"
                            required
                          />
                          <input type="hidden" class="pro-ac-hidden" id="join-profession-hid" value="" />
                          <ul class="pro-ac-dropdown" id="join-profession-dropdown" role="listbox" hidden></ul>
                          <p class="pro-ac-msg input-field__error" id="join-profession-msg" hidden></p>
                        </div>
                      </div>
                    </div>
                    <div class="form-step__actions">
                      <div class="join-wizard-actions join-wizard-actions--split">
                        <%- include('partials/components/button', { variant: 'primary', type: 'button', label: (_onb.continue || 'Continue'), id: 'join-next-1' }) %>
                        <%- include('partials/components/button', { variant: 'secondary', type: 'button', label: 'Cancel', id: 'join-cancel-1' }) %>
                      </div>
                    </div>
                  <p class="input-field__error" id="join-error-1" hidden role="alert"></p>
                  </div>
                </div>

                <div class="join-step-panel" id="join-step-2" data-step="2" hidden>
                  <div class="form-step">
                    <div class="form-step__header">
                      <h2 class="form-step__title">Which city or town do you work in?</h2>
                      <p class="form-step__subtitle">Type a few letters. City suggestions appear below, same as on the home search.</p>
                    </div>
                    <div class="form-step__body">
                      <div class="join-field join-field--ac input-field input-field--search">
                        <label for="join-city" class="input-field__label">City</label>
                        <div
                          class="pro-ac join-pro-ac input-field__control"
                          data-ac-list="city"
                          data-watermark-rotate="<%= joinCityWatermarkRotate %>"
                        >
                          <input
                            id="join-city"
                            class="pro-ac-input input-field__control"
                            type="text"
                            autocomplete="off"
                            role="combobox"
                            aria-autocomplete="list"
                            aria-expanded="false"
                            aria-controls="join-city-dropdown"
                            aria-describedby="join-city-msg"
                            required
                          />
                          <input type="hidden" class="pro-ac-hidden" id="join-city-hid" value="" />
                          <ul class="pro-ac-dropdown" id="join-city-dropdown" role="listbox" hidden></ul>
                          <p class="pro-ac-msg input-field__error" id="join-city-msg" hidden></p>
                        </div>
                      </div>
                    </div>
                    <div class="form-step__actions">
                      <div class="join-wizard-actions join-wizard-actions--split">
                        <%- include('partials/components/button', { variant: 'primary', type: 'button', label: (_onb.continue || 'Continue'), id: 'join-next-2' }) %>
                        <%- include('partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'join-back-2' }) %>
                      </div>
                    </div>
                  <p class="input-field__error" id="join-error-2" hidden role="alert"></p>
                  </div>
                </div>

                <div class="join-step-panel" id="join-step-3" data-step="3" hidden>
                  <div id="join-step-3-form" class="form-step">
                    <div class="form-step__header">
                      <h2 class="form-step__title">Your contact details</h2>
                      <p class="form-step__subtitle">We’ll use these details to contact you about your listing.</p>
                    </div>
                    <div class="form-step__body">
                      <div class="join-field input-field">
                        <label for="join-name" class="input-field__label">Full name</label>
                        <input
                          id="join-name"
                          name="name"
                          class="join-plain-input input-field__control"
                          type="text"
                          autocomplete="name"
                          placeholder="e.g. Jane Banda"
                          required
                        />
                      </div>
                      <div class="join-field input-field">
                        <label for="join-phone" class="input-field__label">Phone number</label>
                        <input
                          id="join-phone"
                          name="phone"
                          class="join-plain-input input-field__control"
                          type="tel"
                          autocomplete="tel"
                          placeholder="<%= tenant.slug === 'zm' ? 'e.g. 0977 123 456' : 'e.g. 0977 123 456' %>"
                          required
                        />
                      </div>
                    </div>
                    <div class="form-step__actions">
                      <div class="join-wizard-actions join-wizard-actions--split">
                        <%- include('partials/components/button', { variant: 'primary', type: 'button', label: (_onb.submit || 'Send application'), id: 'join-submit' }) %>
                        <%- include('partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'join-back-3' }) %>
                      </div>
                    </div>
                    <p class="input-field__error" id="join-error-3" hidden role="alert"></p>
                  </div>
                  <div
                    id="join-step-3-thanks"
                    class="join-step-thanks"
                    role="status"
                    aria-live="polite"
                    hidden
                  >
                    <div class="join-thanks-animation" aria-hidden="true">
                      <div class="join-thanks-success-ring">
                        <svg class="join-thanks-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path class="join-thanks-check-path" d="M20 6 9 17l-5-5" />
                        </svg>
                      </div>
                      <div class="join-thanks-verify-scene">
                        <svg class="join-thanks-doc" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 80" fill="none" aria-hidden="true">
                          <rect x="8" y="4" width="48" height="64" rx="4" stroke="currentColor" stroke-width="2" />
                          <path d="M16 20h32M16 28h24M16 36h28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                        <svg class="join-thanks-magnifier" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                          <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="2.5" />
                          <path d="m30 30 10 10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                        </svg>
                      </div>
                    </div>
                    <p class="join-step-thanks-message">
                      Thank you. We’ve received your application and your details are being verified. Our team will contact you shortly.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <div
      class="m3-modal-overlay join-modal-layer"
      id="join-disabled-city-modal"
      hidden
      role="dialog"
      aria-modal="true"
      aria-labelledby="join-disabled-city-title"
    >
      <div class="m3-modal-overlay__backdrop" data-join-modal-dismiss="disabled-city"></div>
      <div class="m3-modal m3-modal--join join-modal join-modal--wide">
        <header class="m3-modal__header">
          <h2 class="m3-modal__title join-modal-title" id="join-disabled-city-title">City not open yet</h2>
          <button type="button" class="m3-modal__close" id="join-disabled-city-x" aria-label="Close">×</button>
        </header>
        <div class="m3-modal__body join-modal__scroll">
          <div class="join-modal-panel" id="join-disabled-city-panel">
            <div class="form-step">
              <div class="form-step__body">
                <p class="join-modal-text" id="join-disabled-city-intro">
                  We’re validating trusted partners in <strong id="join-disabled-city-label"></strong>. Leave your details and we’ll keep you updated.
                </p>
                <div class="join-modal-fields input-field">
                  <div class="input-field">
                    <label class="join-modal-label input-field__label" for="join-disabled-city-name">Full name</label>
                    <input
                      class="join-plain-input join-modal-input input-field__control"
                      id="join-disabled-city-name"
                      type="text"
                      autocomplete="name"
                    />
                  </div>
                  <div class="input-field">
                    <label class="join-modal-label input-field__label" for="join-disabled-city-phone">Phone number</label>
                    <input
                      class="join-plain-input join-modal-input input-field__control"
                      id="join-disabled-city-phone"
                      type="tel"
                      autocomplete="tel"
                    />
                  </div>
                </div>
                <p class="join-modal-error input-field__error" id="join-disabled-city-error" hidden role="alert"></p>
              </div>
              <div class="form-step__actions">
                <div class="join-modal-actions join-modal-actions--split">
                  <%- include('partials/components/button', { variant: 'primary', type: 'button', label: (_gen.submit || 'Submit'), id: 'join-disabled-city-submit', disabled: true }) %>
                  <%- include('partials/components/button', { variant: 'secondary', type: 'button', label: 'Cancel', id: 'join-disabled-city-dismiss', disabled: true }) %>
                </div>
              </div>
            </div>
          </div>
          <div class="join-modal-panel" id="join-disabled-city-thanks" hidden>
            <div class="form-step">
              <div class="form-step__body">
                <h2 class="join-modal-title">Thank you</h2>
                <p class="join-modal-text">We’ll keep you updated as we expand coverage in this area.</p>
              </div>
              <div class="form-step__actions">
                <div class="join-modal-actions">
                  <%- include('partials/components/button', { variant: 'primary', type: 'button', label: 'OK', id: 'join-disabled-city-close', disabled: true }) %>
                </div>
              </div>
            </div>
          </div>
        </div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>

    <div
      class="m3-modal-overlay join-modal-layer"
      id="join-exit-modal"
      hidden
      role="dialog"
      aria-modal="true"
      aria-labelledby="join-exit-modal-title"
    >
      <div class="m3-modal-overlay__backdrop" data-join-modal-dismiss="exit"></div>
      <div class="m3-modal m3-modal--join join-modal">
        <header class="m3-modal__header">
          <h2 class="m3-modal__title join-modal-title" id="join-exit-modal-title">Need Help?</h2>
          <button type="button" class="m3-modal__close" id="join-exit-modal-x" aria-label="Close">×</button>
        </header>
        <div class="m3-modal__body join-modal__scroll">
          <div class="join-modal-panel" id="join-exit-modal-q">
            <div class="form-step">
              <div class="form-step__body">
                <p class="join-modal-text">We can still reach out if you’d like a call.</p>
              </div>
              <div class="form-step__actions">
                <div class="join-modal-actions join-modal-actions--split">
                  <%- include('partials/components/button', { variant: 'primary', type: 'button', label: 'Call Me', id: 'join-exit-modal-call' }) %>
                  <%- include('partials/components/button', { variant: 'secondary', type: 'button', label: 'Close', id: 'join-exit-modal-dismiss' }) %>
                </div>
              </div>
            </div>
          </div>
          <div class="join-modal-panel join-modal-panel--form" id="join-exit-modal-form" hidden>
            <div class="form-step">
              <div class="form-step__body">
                <p class="join-modal-text">We’ll use this to call you back.</p>
                <div class="join-modal-fields input-field">
                  <div class="input-field">
                    <label class="join-modal-label input-field__label" for="join-exit-modal-name">Full name</label>
                    <input
                      class="join-plain-input join-modal-input input-field__control"
                      id="join-exit-modal-name"
                      type="text"
                      autocomplete="name"
                    />
                  </div>
                  <div class="input-field">
                    <label class="join-modal-label input-field__label" for="join-exit-modal-phone">Phone number</label>
                    <input
                      class="join-plain-input join-modal-input input-field__control"
                      id="join-exit-modal-phone"
                      type="tel"
                      autocomplete="tel"
                    />
                  </div>
                </div>
                <p class="join-modal-error input-field__error" id="join-exit-modal-error" hidden role="alert"></p>
              </div>
              <div class="form-step__actions">
                <div class="join-modal-actions join-modal-actions--split">
                  <%- include('partials/components/button', { variant: 'primary', type: 'button', label: (_gen.submit || 'Submit'), id: 'join-exit-modal-submit' }) %>
                  <%- include('partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'join-exit-modal-back' }) %>
                </div>
              </div>
            </div>
          </div>
        </div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>

    <script>
      window.__GETPRO_TENANT_SLUG__ = "<%= tenant.slug %>";
      window.__GETPRO_TENANT_ID__ = <%= tenant.id %>;
      window.__GETPRO_HOME__ = "<%= tenantHomeHref %>";
      window.__GETPRO_TENANT_CITIES__ = <%- JSON.stringify(joinTenantCities || []) %>;
      window.__GETPRO_PHONE_RULES__ = <%- JSON.stringify(typeof phoneRulesPublic !== 'undefined' ? phoneRulesPublic : { slug: tenant.slug, strict: false, regex: null, normalizationMode: 'generic_digits', regexBroken: false }) %>;
    </script>
    <script src="<%= asset('autocomplete') %>" defer></script>
    <script src="<%= asset('join') %>" defer></script>
    <%- include('partials/theme_prefs') %>
  </body>
</html>
