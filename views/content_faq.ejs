<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <%- include('partials/seo_meta', { seoTitle, seoDescription, canonicalUrl, ogUrl, ogType: 'website' }) %>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
    <% if (typeof jsonLdFaq !== 'undefined' && jsonLdFaq) { %>
    <script type="application/ld+json"><%- jsonLdFaq %></script>
    <% } %>
  </head>
  <body class="page-support-content <%= tenant.themeClass %>" data-screen-role="support">
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix }) %>

      <div class="app-layout__main">
        <main class="container content-faq-page" style="padding: 1.5rem 0 3rem; max-width: 720px">
      <% if (typeof previewBanner !== 'undefined' && previewBanner) { %>
        <p class="card" style="padding: 0.75rem 1rem; margin-bottom: 1rem; background: var(--color-surface-container-high, #eee)">
          <strong>Draft preview</strong> — this page is not published to the public yet.
        </p>
      <% } %>
      <nav class="pro-company-profile__breadcrumb" aria-label="Breadcrumb" style="margin-bottom: 1rem">
        <a href="<%= tenantHomeHref %>">Home</a>
        <span class="pro-company-profile__bc-sep" aria-hidden="true">/</span>
        <a href="<%= tenantUrlPrefix %>/answers">Questions &amp; answers</a>
        <span class="pro-company-profile__bc-sep" aria-hidden="true">/</span>
        <span class="pro-company-profile__bc-current">Q&amp;A</span>
      </nav>

      <article class="content-prose">
        <h1 class="section-title section-title--flush" style="font-size: 1.5rem"><%= row.title %></h1>
        <div class="content-prose__body"><%- answerHtml %></div>
      </article>

      <p style="margin-top: 2rem">
        <a href="<%= tenantUrlPrefix %>/directory">Browse professionals →</a>
      </p>
        </main>

        <%- include('partials/site_footer', { tenantUrlPrefix }) %>
      </div>
    </div>
    <script src="/scripts.js?v=<%= stylesVersion %>" defer></script>
  </body>
</html>
