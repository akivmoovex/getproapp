<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/seo_meta', {
      seoTitle: typeof seoTitle !== 'undefined' ? seoTitle : (category.name + ' | Directory | Pro-online'),
      seoDescription: typeof seoDescription !== 'undefined' ? seoDescription : ('Browse ' + category.name + ' professionals on Pro-online.'),
      canonicalUrl: typeof canonicalUrl !== 'undefined' ? canonicalUrl : '',
      ogUrl: typeof ogUrl !== 'undefined' ? ogUrl : '',
      ogType: 'website'
    }) %>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="<%= tenant.themeClass %>" data-screen-role="results">
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix }) %>

      <div class="app-layout__main">
        <div class="container directory-page directory-page-toolbar">
      <div class="pro-directory-top-band">
        <div class="pro-directory-toolbar pro-directory-toolbar--category" role="region" aria-label="Category browse">
          <%- include('partials/pro_search_form', {
            variant: 'directory',
            tenantUrlPrefix,
            formId: 'category-toolbar',
            idPrefix: 'cat',
            searchQuery: '',
            cityQuery: '',
            showCategoryFilter: true,
            selectedCategory: category.slug,
            categories: typeof categories !== 'undefined' ? categories : [],
            ariaLabel: 'Search by category, service, and city',
          }) %>
          <div class="pro-directory-toolbar__meta" aria-live="polite">
            <span class="pro-directory-toolbar__count">
              <strong><%= (companies || []).length %></strong>
              <%= (companies || []).length === 1 ? 'listing' : 'listings' %>
            </span>
            <span class="pro-directory-toolbar__hint muted">One-page company sites in this category.</span>
          </div>
        </div>
        <% if ((companies || []).length > 0) { %>
        <p class="pro-directory-results-helper" role="note">Browse trusted professionals in your area. Click on card to view more details.</p>
        <% } %>
      </div>

      <%- include('partials/refine_search_fab', { toolbarAnchorId: 'category-toolbar' }) %>

      <div class="pro-directory-main">
        <% if ((companies || []).length === 0) { %>
          <%- include('partials/directory_empty_state', {
            tenantUrlPrefix,
            tenant,
            emptyStateMode: 'category',
            categoryName: category.name,
            category,
            toolbarAnchorId: 'category-toolbar',
            emptyAltCategories: typeof emptyAltCategories !== 'undefined' ? emptyAltCategories : [],
            emptyAltCities: typeof emptyAltCities !== 'undefined' ? emptyAltCities : [],
          }) %>
        <% } else { %>
          <%- include('partials/directory_company_cards', { companies, baseDomain, companyMiniSiteHref }) %>
        <% } %>
      </div>
    </div>

        <%- include('partials/site_footer', { tenantUrlPrefix }) %>
      </div>
    </div>
    <script src="/scripts.js?v=<%= stylesVersion %>" defer></script>
    <%- include('partials/autocomplete_defer_bootstrap') %>
    <% if ((companies || []).length === 0) { %>
    <script src="/directory-empty-callback.js?v=<%= stylesVersion %>" defer></script>
    <% } %>
  </body>
</html>
