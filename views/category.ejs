<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= category.name %> | Directory | GetPro</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="<%= tenant.themeClass %>">
    <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>

    <div class="container directory-page directory-page-toolbar">
      <div class="pro-directory-toolbar pro-directory-toolbar--category" role="region" aria-label="Category browse">
        <div class="pro-directory-toolbar__fields pro-directory-toolbar__fields--category-only">
          <div class="pro-directory-toolbar__category pro-directory-toolbar__category--grow">
            <label class="pro-directory-toolbar__label" for="category-page-select">Category</label>
            <select
              id="category-page-select"
              class="pro-directory-toolbar__select"
              aria-label="Switch category"
              onchange="if (this.value) window.location.href = this.value;"
            >
              <option value="<%= tenantUrlPrefix %>/directory">All categories</option>
              <% (categories || []).forEach(function(cat) { %>
              <option value="<%= tenantUrlPrefix %>/category/<%= cat.slug %>"<%= category.slug === cat.slug ? ' selected' : '' %>><%= cat.name %></option>
              <% }); %>
            </select>
          </div>
        </div>
        <div class="pro-directory-toolbar__meta" aria-live="polite">
          <span class="pro-directory-toolbar__count">
            <strong><%= (companies || []).length %></strong>
            <%= (companies || []).length === 1 ? 'listing' : 'listings' %>
          </span>
          <span class="pro-directory-toolbar__hint muted">One-page company sites in this category.</span>
        </div>
      </div>

      <div class="pro-directory-main">
        <% if ((companies || []).length === 0) { %>
          <%- include('partials/directory_empty_state', {
            tenantUrlPrefix,
            tenant,
            emptyStateMode: 'category',
            categoryName: category.name,
            category,
          }) %>
        <% } else { %>
          <%- include('partials/directory_company_cards', { companies, baseDomain, companyMiniSiteHref }) %>
        <% } %>
      </div>
    </div>

    <%- include('partials/site_footer', { tenantUrlPrefix }) %>
    <script src="/scripts.js?v=<%= stylesVersion %>" defer></script>
    <% if ((companies || []).length === 0) { %>
    <script src="/directory-empty-callback.js?v=<%= stylesVersion %>" defer></script>
    <% } %>
  </body>
</html>
