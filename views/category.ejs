<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= category.name %> | Directory | GetPro</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="<%= tenant.themeClass %>">
    <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>

    <div class="container">
      <div style="margin:18px 0;">
        <div class="section-title" style="margin-top:0;"><%= category.name %></div>
        <div class="muted" style="line-height:1.6;">
          One-page company sites in this category. Each company has a unique subdomain.
        </div>
      </div>

      <div class="hero-grid pro-directory-layout">
        <div class="card">
          <div style="font-weight:900;margin-bottom:12px;">All Categories</div>
          <div class="list">
            <% categories.forEach(function(cat) { %>
              <a
                href="<%= tenantUrlPrefix %>/category/<%= cat.slug %>"
                class="btn"
                style="justify-content:flex-start;width:100%;<%= category.slug === cat.slug ? 'border-color:var(--wf-primary);background:var(--primary-soft-bg);' : '' %>"
              >
                <%= cat.name %>
              </a>
            <% }) %>
          </div>
        </div>

        <div>
          <% if (companies.length === 0) { %>
            <div class="card pro-directory-empty muted">No professionals found.</div>
          <% } else { %>
            <%- include('partials/directory_company_cards', { companies, baseDomain, companyMiniSiteHref }) %>
          <% } %>
        </div>
      </div>
    </div>

    <%- include('partials/site_footer', { tenantUrlPrefix }) %>
    <script src="/scripts.js?v=<%= stylesVersion %>"></script>
  </body>
</html>
