<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>Lead · <%= detail.project_code %> | Company portal</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="company-portal-page <%= typeof tenant !== 'undefined' && tenant ? tenant.themeClass : 'tenant-zm' %>">
    <%- include('partials/company_portal_shell_start', {
      activeCompanyNav: typeof activeCompanyNav !== 'undefined' ? activeCompanyNav : 'leads',
      companyName: typeof companyName !== 'undefined' ? companyName : '',
    }) %>
    <main class="company-portal-main" id="main-content">
      <p class="company-portal-back"><a class="btn btn--text" href="/company/leads">← Active leads</a></p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="flash" role="alert"><%= error %></div>
      <% } %>
      <% if (typeof notice !== 'undefined' && notice) { %>
        <div class="flash flash--success" role="status"><%= notice %></div>
      <% } %>
      <h1 class="company-portal-page-title">Project <%= detail.project_code %></h1>
      <div class="card company-lead-detail-card">
        <dl class="company-lead-detail-dl">
          <div><dt>Your response</dt><dd><strong><%= typeof assignmentStatusLabelForPortal === 'function' ? assignmentStatusLabelForPortal(detail.assignment_status) : detail.assignment_status %></strong></dd></div>
          <div><dt>Project status</dt><dd><%= typeof projectStatusLabel !== 'undefined' ? projectStatusLabel : detail.project_status %></dd></div>
          <div><dt>City</dt><dd><%= detail.city || '—' %></dd></div>
          <div><dt>Neighborhood</dt><dd><%= detail.neighborhood || '—' %></dd></div>
          <% if (detail.estimated_budget_value != null && detail.estimated_budget_value !== '') { %>
          <div><dt>Budget</dt><dd>
            <% var _bp = typeof budget !== 'undefined' && budget ? budget.displayPrefix : ''; %>
            <%= _bp ? _bp + ' ' : '' %><%= detail.estimated_budget_value %>
            <% if (detail.estimated_budget_currency) { %> <span class="muted"><%= detail.estimated_budget_currency %></span><% } %>
          </dd></div>
          <% } %>
          <div><dt>Received</dt><dd class="muted"><%- include('partials/event_time', { at: detail.project_created_at }) %></dd></div>
          <% if (detail.assignment_responded_at) { %>
          <div><dt>Last updated</dt><dd class="muted"><%- include('partials/event_time', { at: detail.assignment_responded_at }) %></dd></div>
          <% } %>
          <% if (detail.assignment_response_note && String(detail.assignment_response_note).trim()) { %>
          <div><dt>Your note</dt><dd><%= detail.assignment_response_note %></dd></div>
          <% } %>
        </dl>
      </div>

      <% var _st = String(detail.assignment_status || '').toLowerCase(); %>
      <% var _canInt = _st === 'pending'; %>
      <% var _canDecl = _st === 'pending' || _st === 'interested' || _st === 'callback_requested'; %>
      <% var _canCb = _st === 'pending' || _st === 'interested'; %>
      <% if (_canInt || _canDecl || _canCb) { %>
      <div class="card company-lead-actions card--mb-block">
        <h2 class="company-lead-detail__h2">Your actions</h2>
        <p class="muted company-lead-actions__hint">Optional note is saved with the action you choose (max 400 characters).</p>
        <form method="post" action="/company/leads/<%= detail.assignment_id %>/action" class="form company-lead-actions-form">
          <div class="input-field company-lead-actions__note">
            <label class="input-field__label" for="lead_action_note">Note (optional)</label>
            <textarea id="lead_action_note" name="note" class="input-field__control" rows="2" maxlength="400"></textarea>
          </div>
          <div class="company-lead-actions__row">
            <% if (_canInt) { %>
            <button type="submit" name="action" value="interested" class="btn btn--primary">Interested</button>
            <% } %>
            <% if (_canCb) { %>
            <button type="submit" name="action" value="callback" class="btn btn--secondary">Request callback</button>
            <% } %>
            <% if (_canDecl) { %>
            <button type="submit" name="action" value="decline" class="btn btn--text" onclick="return confirm('Decline this lead?');">Decline</button>
            <% } %>
          </div>
        </form>
      </div>
      <% } %>
      <% if (images && images.length) { %>
        <h2 class="company-lead-detail__h2">Photos</h2>
        <ul class="company-lead-detail__images" role="list">
          <% images.forEach(function (im) { %>
            <li>
              <a href="/company/project-files/<%= im.id %>" target="_blank" rel="noopener noreferrer" class="company-lead-detail__img-link">
                <img src="/company/project-files/<%= im.id %>" alt="" class="company-lead-detail__img" loading="lazy" width="320" height="240" />
                <span class="visually-hidden">Open full size</span>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </main>
    <%- include('partials/company_portal_shell_end') %>
  </body>
</html>
