<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>Lead · <%= detail.project_code %> | Company portal</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <% var _pb = typeof providerPortalBasePath !== 'undefined' && providerPortalBasePath ? String(providerPortalBasePath).replace(/\/$/, '') : '/company'; %>
  <body class="company-portal-page <%= typeof tenant !== 'undefined' && tenant ? tenant.themeClass : 'tenant-zm' %>">
    <%- include('partials/company_portal_shell_start', {
      activeCompanyNav: typeof activeCompanyNav !== 'undefined' ? activeCompanyNav : 'leads',
      companyName: typeof companyName !== 'undefined' ? companyName : '',
      companyPersonnel: typeof companyPersonnel !== 'undefined' ? companyPersonnel : null,
      providerPortalBasePath: typeof providerPortalBasePath !== 'undefined' ? providerPortalBasePath : '/company',
    }) %>
    <main class="company-portal-main" id="main-content">
      <p class="company-portal-back"><%- include('partials/components/button', { variant: 'text', href: _pb + '/leads', label: '← Active leads' }) %></p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="flash" role="alert"><%= error %></div>
      <% } %>
      <% if (typeof notice !== 'undefined' && notice) { %>
        <div class="flash flash--success" role="status"><%= notice %></div>
      <% } %>
      <% var _bc = typeof blocked_credit !== 'undefined' && blocked_credit; %>
      <% var _accept = typeof can_accept_lead_actions === 'undefined' || can_accept_lead_actions; %>
      <% if (_bc) { %>
      <p class="company-portal-credit-hold flash" role="status">
        <strong>Credit hold.</strong> You can read this lead, but you cannot mark <strong>Interested</strong> or <strong>Request callback</strong> until your account balance is above the threshold.
      </p>
      <% } %>
      <header class="company-lead-detail__masthead">
        <h1 class="company-portal-page-title company-lead-detail__title">Project <%= detail.project_code %></h1>
        <p class="company-lead-detail__lead-price muted" aria-label="Budget estimate not shown to providers"><%= detail.lead_price_display %></p>
      </header>
      <div class="card company-lead-detail-card">
        <dl class="company-lead-detail-dl">
          <div><dt>Your response</dt><dd><strong><%= typeof assignmentStatusLabelForPortal === 'function' ? assignmentStatusLabelForPortal(detail.assignment_status) : detail.assignment_status %></strong></dd></div>
          <div><dt>Project status</dt><dd><%= typeof projectStatusLabel !== 'undefined' ? projectStatusLabel : detail.project_status %></dd></div>
          <div><dt>City</dt><dd><%= detail.city || '—' %></dd></div>
          <div><dt>Neighborhood</dt><dd><%= detail.neighborhood || '—' %></dd></div>
          <div><dt>Received</dt><dd class="muted"><%- include('partials/event_time', { at: detail.project_created_at }) %></dd></div>
          <% if (detail.assignment_responded_at) { %>
          <div><dt>Last updated</dt><dd class="muted"><%- include('partials/event_time', { at: detail.assignment_responded_at }) %></dd></div>
          <% } %>
          <% if (detail.assignment_response_note && String(detail.assignment_response_note).trim()) { %>
          <div><dt>Your note</dt><dd><%= detail.assignment_response_note %></dd></div>
          <% } %>
        </dl>
      </div>

      <% var _st = String(detail.assignment_status || '').toLowerCase(); %>
      <% var _projClosed = String(detail.project_status || '').toLowerCase() === 'closed'; %>
      <% var _canInt = _accept && !_projClosed && (_st === 'pending' || _st === 'allocated' || _st === 'viewed'); %>
      <% var _canDecl = !_projClosed && (_st === 'pending' || _st === 'allocated' || _st === 'viewed' || _st === 'interested' || _st === 'callback_requested'); %>
      <% var _canCb = _accept && !_projClosed && (_st === 'pending' || _st === 'allocated' || _st === 'viewed' || _st === 'interested'); %>
      <% if (_canInt || _canDecl || _canCb) { %>
      <div class="card company-lead-actions card--mb-block">
        <h2 class="company-lead-detail__h2">Your actions</h2>
        <p class="muted company-lead-actions__hint">Optional note is saved with the action you choose (max 400 characters).</p>
        <form method="post" action="<%= _pb %>/leads/<%= detail.assignment_id %>/action" class="form company-lead-actions-form">
          <div class="input-field company-lead-actions__note">
            <label class="input-field__label" for="lead_action_note">Note (optional)</label>
            <textarea id="lead_action_note" name="note" class="input-field__control" rows="2" maxlength="400"></textarea>
          </div>
          <div class="company-lead-actions__row">
            <% if (_canInt) { %>
            <%- include('partials/components/button', { variant: 'primary', type: 'submit', label: 'Interested', name: 'action', value: 'interested' }) %>
            <% } %>
            <% if (_canCb) { %>
            <%- include('partials/components/button', { variant: 'secondary', type: 'submit', label: 'Request callback', name: 'action', value: 'callback' }) %>
            <% } %>
            <% if (_canDecl) { %>
            <%- include('partials/components/button', { variant: 'text', type: 'submit', label: 'Decline', name: 'action', value: 'decline', extraAttrs: 'onclick="return confirm(\'Decline this lead?\');"' }) %>
            <% } %>
          </div>
        </form>
      </div>
      <% } %>
      <% if (images && images.length) { %>
        <h2 class="company-lead-detail__h2">Photos</h2>
        <ul class="company-lead-detail__images" role="list">
          <% images.forEach(function (im) { %>
            <li>
              <a href="<%= _pb %>/project-files/<%= im.id %>" target="_blank" rel="noopener noreferrer" class="company-lead-detail__img-link">
                <img src="<%= _pb %>/project-files/<%= im.id %>" alt="" class="company-lead-detail__img" loading="lazy" width="320" height="240" />
                <span class="visually-hidden">Open full size</span>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>

      <% var _elig = typeof deal_review_eligible !== 'undefined' && deal_review_eligible; %>
      <% var _prDone = typeof provider_review_submitted !== 'undefined' && provider_review_submitted; %>
      <% var _crDone = typeof client_review_submitted !== 'undefined' && client_review_submitted; %>
      <% if (_elig || _prDone || _crDone) { %>
      <section class="company-portal-deal-review card card--mb-block" aria-labelledby="company-deal-review-heading">
        <h2 id="company-deal-review-heading" class="company-lead-detail__h2">After the job</h2>
        <% if (_elig && !_prDone) { %>
        <p class="muted">The project is <strong>closed</strong>. Share a quick rating and optional comment about your experience with the client (1–5).</p>
        <form method="post" action="<%= _pb %>/leads/<%= detail.assignment_id %>/review" class="form company-portal-deal-review__form">
          <div class="input-field">
            <label class="input-field__label" for="deal_review_rating">Rating</label>
            <select id="deal_review_rating" name="rating" class="input-field__control" required>
              <option value="" disabled selected>Choose…</option>
              <option value="5">5 — Excellent</option>
              <option value="4">4</option>
              <option value="3">3</option>
              <option value="2">2</option>
              <option value="1">1 — Poor</option>
            </select>
          </div>
          <div class="input-field">
            <label class="input-field__label" for="deal_review_body">Comment (optional)</label>
            <textarea id="deal_review_body" name="body" class="input-field__control" rows="3" maxlength="4000" placeholder="Optional feedback"></textarea>
          </div>
          <%- include('partials/components/button', { variant: 'primary', type: 'submit', label: 'Submit review' }) %>
        </form>
        <% } else if (_prDone) { %>
        <p class="muted">Thank you — you submitted your review for this job.</p>
        <% } %>
        <% if (_crDone) { %>
        <p class="muted company-portal-deal-review__client-note" role="status">The client has submitted their public review of your company.</p>
        <% } else if (_elig && _prDone) { %>
        <p class="muted">Waiting for the client to review your company (they use the project link and phone).</p>
        <% } %>
      </section>
      <% } %>
    </main>
    <%- include('partials/company_portal_shell_end') %>
    <%- include('partials/page_nav_loading') %>
  </body>
</html>
