<%#
  ============================================================================
  Search form — PUBLIC ENTRY for homepage / directory / category search ONLY.
  Wraps the system SearchBar (components/search_bar.ejs) in <form>.

  Pages: from views/*.ejs use path partials/pro_search_form — do not pull in
  partials/components/search_bar (or components/search_bar from partials/) directly;
  the <form> wrapper must stay paired with the bar.

  Placeholder contract (do not blur without an intentional product change):
  - Universal hero copy is DOUBLE-GATED: (1) approvedMarketingHeroPlaceholders === primitive true ONLY on
    views/index.ejs, AND (2) form action URL contains home_featured= (homepage featured-directory contract).
  - Portal/directory/category/docs/demo: omit approvedMarketingHeroPlaceholders; always ctaVoice placeholders.
  - Do not pass approvedMarketingHeroPlaceholders from new includes without product approval; a second hero
    requires updating the allowlist below (action check + comment).
  - Booleans: primitive true only; typeof must be boolean. "true", 1, new Boolean(true), undefined, null → off.

  Props (pass through to SearchBar + used for form):
  - variant, tenantUrlPrefix, formAction, formId, searchQuery, cityQuery,
    showCategoryFilter, selectedCategory, categories, ariaLabel, idPrefix, formExtraAttrs,
    preserveDirectoryFeatured — when true, adds hidden home_featured=1 (keep featured-only directory searches)
  - approvedMarketingHeroPlaceholders — optional; omit everywhere except approved index hero (see contract)
  ============================================================================
-%>
<%
  var _v = typeof variant !== 'undefined' ? String(variant) : 'directory';
  var _tp = typeof tenantUrlPrefix !== 'undefined' ? String(tenantUrlPrefix || '') : '';
  var _action = typeof formAction !== 'undefined' && formAction ? String(formAction) : (_tp.replace(/\/$/, '') + '/directory');
  var _fid = typeof formId !== 'undefined' ? String(formId || '') : (_v === 'directory' ? 'directory-toolbar' : '');
  var _aria = typeof ariaLabel !== 'undefined' ? String(ariaLabel) : 'Search by service and city';
  var _formExtra = typeof formExtraAttrs !== 'undefined' && formExtraAttrs ? String(formExtraAttrs) : '';
  var _preserveFeat = typeof preserveDirectoryFeatured !== 'undefined' && preserveDirectoryFeatured;
  var _submitLabel = typeof submitLabel !== 'undefined' && submitLabel ? String(submitLabel).trim() : '';
  if (!_submitLabel) {
    var _formSearch = typeof ctaVoice !== 'undefined' && ctaVoice && ctaVoice.form && ctaVoice.form.search ? ctaVoice.form.search : null;
    var _hpSearch = typeof ctaVoice !== 'undefined' && ctaVoice && ctaVoice.homepage ? ctaVoice.homepage : null;
    _submitLabel = (_formSearch && _formSearch.primary) ? String(_formSearch.primary) : ((_hpSearch && _hpSearch.primary_search) ? String(_hpSearch.primary_search) : '');
  }
  var _sr = typeof ctaVoice !== 'undefined' && ctaVoice && ctaVoice.searchRefinement ? ctaVoice.searchRefinement : null;
  /* Hero copy: primitive boolean true only (see header). new Boolean(true) is typeof object → rejected. */
  var _heroBool =
    typeof approvedMarketingHeroPlaceholders !== 'undefined' &&
    typeof approvedMarketingHeroPlaceholders === 'boolean' &&
    approvedMarketingHeroPlaceholders === true;
  /* Allowlist: homepage hero posts to featured directory; portal/other heroes use different actions. */
  var _heroActionOk = /[?&]home_featured=/.test(String(_action || ''));
  var _useHomePh = _heroBool && _heroActionOk;
  var _svcPh;
  var _cityPh;
  if (_useHomePh) {
    _svcPh = 'Search for a service (e.g electrician, tutor)';
    _cityPh = 'City or town';
  } else {
    _svcPh = (_sr && _sr.service_placeholder) ? String(_sr.service_placeholder) : '';
    _cityPh = (_sr && _sr.city_placeholder) ? String(_sr.city_placeholder) : '';
  }
  var _tenantForMeta = (typeof tenant !== 'undefined' && tenant && tenant.slug) ? String(tenant.slug) : 'global';
  var _metaPopular = (_sr && _sr.popular && _sr.popular.length) ? _sr.popular : ['Electrician', 'Plumber', 'Tutor', 'Cleaner', 'Mechanic'];
  var _metaRecentLabel = (_sr && _sr.recent_label) ? String(_sr.recent_label) : 'Recent searches';
  var _metaTrendingLabel = (_sr && _sr.trending_label) ? String(_sr.trending_label) : 'Trending categories';
  var _metaPopularLabel = (_sr && _sr.popular_label) ? String(_sr.popular_label) : 'Popular searches';
  var _searchMetaJson = JSON.stringify({
    tenantSlug: _tenantForMeta,
    labels: { recent: _metaRecentLabel, trending: _metaTrendingLabel, popular: _metaPopularLabel },
    popular: _metaPopular,
  });
%>
<form
  <% if (_fid) { %>id="<%= _fid %>"<% } %>
  class="pro-search-form gp-search-bar c-search-bar"
  action="<%= _action %>"
  method="get"
  role="search"
  aria-label="<%= _aria %>"
  data-search-meta="<%= encodeURIComponent(_searchMetaJson) %>"
  <%- _formExtra %>
>
<% if (_preserveFeat) { %>
<input type="hidden" name="home_featured" value="1" />
<% } %>
<%- include('components/search_bar', {
  variant: typeof variant !== 'undefined' ? variant : 'directory',
  tenantUrlPrefix: typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : '',
  showCategoryFilter: typeof showCategoryFilter !== 'undefined' ? showCategoryFilter : false,
  selectedCategory: typeof selectedCategory !== 'undefined' ? selectedCategory : '',
  categories: typeof categories !== 'undefined' ? categories : [],
  ariaLabel: typeof ariaLabel !== 'undefined' ? ariaLabel : '',
  idPrefix: typeof idPrefix !== 'undefined' ? idPrefix : '',
  searchQuery: typeof searchQuery !== 'undefined' ? searchQuery : '',
  cityQuery: typeof cityQuery !== 'undefined' ? cityQuery : '',
  submitLabel: _submitLabel,
  servicePlaceholder: _svcPh,
  cityPlaceholder: _cityPh,
}) %>
<% if (_sr && _sr.helper) { %>
<p class="pro-search-form__helper muted" role="note"><%= _sr.helper %></p>
<% } %>
</form>
