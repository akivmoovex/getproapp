<%#
  ============================================================================
  Search form — PUBLIC ENTRY for homepage / directory / category search ONLY.
  Wraps the system SearchBar (components/search_bar.ejs) in <form>.

  Pages: from views/*.ejs use path partials/pro_search_form — do not pull in
  partials/components/search_bar (or components/search_bar from partials/) directly;
  the <form> wrapper must stay paired with the bar.

  Props (pass through to SearchBar + used for form):
  - variant, tenantUrlPrefix, formAction, formId, searchQuery, cityQuery,
    showCategoryFilter, selectedCategory, categories, ariaLabel, idPrefix, formExtraAttrs
  ============================================================================
-%>
<%
  var _v = typeof variant !== 'undefined' ? String(variant) : 'directory';
  var _tp = typeof tenantUrlPrefix !== 'undefined' ? String(tenantUrlPrefix || '') : '';
  var _action = typeof formAction !== 'undefined' && formAction ? String(formAction) : (_tp.replace(/\/$/, '') + '/directory');
  var _fid = typeof formId !== 'undefined' ? String(formId || '') : (_v === 'directory' ? 'directory-toolbar' : '');
  var _aria = typeof ariaLabel !== 'undefined' ? String(ariaLabel) : 'Search by service and city';
  var _formExtra = typeof formExtraAttrs !== 'undefined' && formExtraAttrs ? String(formExtraAttrs) : '';
%>
<form
  <% if (_fid) { %>id="<%= _fid %>"<% } %>
  class="pro-search-form gp-search-bar c-search-bar"
  action="<%= _action %>"
  method="get"
  role="search"
  aria-label="<%= _aria %>"
  <%- _formExtra %>
>
<%- include('components/search_bar', {
  variant: typeof variant !== 'undefined' ? variant : 'directory',
  tenantUrlPrefix: typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : '',
  showCategoryFilter: typeof showCategoryFilter !== 'undefined' ? showCategoryFilter : false,
  selectedCategory: typeof selectedCategory !== 'undefined' ? selectedCategory : '',
  categories: typeof categories !== 'undefined' ? categories : [],
  ariaLabel: typeof ariaLabel !== 'undefined' ? ariaLabel : '',
  idPrefix: typeof idPrefix !== 'undefined' ? idPrefix : '',
  searchQuery: typeof searchQuery !== 'undefined' ? searchQuery : '',
  cityQuery: typeof cityQuery !== 'undefined' ? cityQuery : '',
}) %>
</form>
