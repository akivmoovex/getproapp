<% var tp = typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : ''; %>
<% var tpHome = tp ? tp + '/' : '/'; %>
<% var _joinModalSrc = (tp ? String(tp).replace(/\/$/, '') : '') + '/join'; %>
<% var _bnHeader = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<% var ten = typeof tenant !== 'undefined' ? tenant : null; %>
<% var _renderRegionPickerTrigger = typeof renderRegionPickerTrigger !== 'undefined' ? !!renderRegionPickerTrigger : false; %>
<% var _showRegionPickerUi = typeof showRegionPickerUi !== 'undefined' ? !!showRegionPickerUi : false; %>
<% var _regionBtnLabel = 'Region'; %>
<% var _regionAria = 'Choose region'; %>
<% if (ten && ten.slug === 'global') { _regionBtnLabel = 'Select region'; _regionAria = 'Select region'; } else if (ten && String(ten.name || '').trim()) { _regionBtnLabel = String(ten.name).trim(); _regionAria = 'Region: ' + _regionBtnLabel; } %>
<header class="app-top-app-bar" role="banner">
  <div class="ds-container app-top-app-bar__inner">
    <div class="app-top-app-bar__brand-block">
      <div class="app-top-app-bar__brand-row">
        <%- include('brand_lockup_getpro', { tenant: ten, brandLockupVariant: 'nav', brandLockupHref: tpHome }) %>
      </div>
      <p class="app-top-app-bar__tagline"><%= brandPublicTagline %></p>
    </div>

    <div class="app-top-app-bar__actions">
      <% if (_renderRegionPickerTrigger && _showRegionPickerUi) { %>
      <button
        type="button"
        class="wf-home-region-trigger"
        id="wf-region-open"
        aria-label="<%= _regionAria %>"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="wf-region-sheet"
      >
        <svg
          class="wf-home-region-globe"
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
        </svg>
        <span class="wf-home-region-label"><%= _regionBtnLabel %></span>
      </button>
      <% } %>

      <%- include('components/button', {
        variant: 'secondary',
        text: 'Join Us',
        className: 'app-top-app-bar__join',
        id: 'wf-join-us-header',
        extraAttrs: 'type="button" data-wf-join-us-open aria-haspopup="dialog" aria-controls="wf-join-us-modal"',
      }) %>

      <button
        type="button"
        class="app-menu-toggle"
        id="wf-app-nav-toggle"
        aria-label="Open navigation"
        aria-controls="wf-app-nav-drawer"
        aria-expanded="false"
      >
        <svg
          class="app-menu-icon app-menu-icon--hamburger"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.25"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 6h16" />
          <path d="M4 12h16" />
          <path d="M4 18h16" />
        </svg>
        <svg
          class="app-menu-icon app-menu-icon--close"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.25"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>

<div
  id="wf-join-us-modal"
  class="m3-modal-overlay wf-join-us-modal"
  hidden
  aria-hidden="true"
  data-join-src="<%= _joinModalSrc %>"
>
  <div class="m3-modal-overlay__backdrop" data-wf-join-us-dismiss tabindex="-1"></div>
  <div
    class="m3-modal m3-modal--settings-iframe wf-join-us-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="wf-join-us-title"
  >
    <header class="m3-modal__header">
      <h2 id="wf-join-us-title" class="m3-modal__title">List your business</h2>
      <button type="button" class="m3-modal__close" data-wf-join-us-dismiss aria-label="Close">×</button>
    </header>
    <div class="m3-modal__body m3-modal__body--iframe wf-join-us-modal__body">
      <iframe id="wf-join-us-iframe" title="<%= _bnHeader %> — join" src="about:blank"></iframe>
    </div>
    <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
  </div>
</div>
