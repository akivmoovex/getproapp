<% 
  var tp = typeof tenantUrlPrefix !== 'undefined' ? String(tenantUrlPrefix || '') : '';
  var showAdmin = typeof showAdmin !== 'undefined' ? !!showAdmin : false;
  var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online';
%>

<nav class="wf-home-sidebar-nav wf-home-sidebar-nav--primary" aria-label="Primary">
  <a class="wf-home-nav-btn wf-home-nav-btn--ghost" href="<%= tp %>/directory">Search directory</a>
  <a class="wf-home-nav-btn wf-home-nav-btn--ghost" href="<%= tp %>/directory#directory-toolbar">Categories</a>
  <a class="wf-home-nav-btn wf-home-nav-btn--ghost" href="<%= tp %>/join">List your business</a>
  <a class="wf-home-nav-btn wf-home-nav-btn--ghost" href="<%= tp %>/field-agent/login">Field agent</a>
  <a class="wf-home-nav-btn wf-home-nav-btn--ghost wf-home-nav-btn--my-getpro" href="/admin">
    <span class="wf-home-nav-btn__text">My <%= _bn %></span>
    <span class="wf-home-nav-btn__sub">Admin console</span>
  </a>
</nav>

<nav class="wf-home-sidebar-nav wf-home-sidebar-nav--secondary" aria-label="Quick links">
  <a class="wf-home-nav-btn wf-home-nav-btn--ghost" href="<%= tp %>/answers">Help &amp; answers</a>
  <a class="wf-home-nav-btn wf-home-nav-btn--ghost" href="<%= tp %>/articles">Articles &amp; tips</a>
  <a class="wf-home-nav-btn wf-home-nav-btn--ghost" href="#footer-terms">Terms</a>
  <% if (showAdmin) { %>
    <a class="wf-home-nav-btn wf-home-nav-btn--ghost app-nav-menu__admin" href="<%= tp %>/getpro-admin"><%= _bn %> Admin</a>
  <% } %>
</nav>

