<% 
  var _tp = typeof tenantUrlPrefix !== 'undefined' ? String(tenantUrlPrefix || '') : '';
  var _active = typeof faActiveNav !== 'undefined' ? String(faActiveNav || '') : '';
  var _faq = typeof faIncludeFaq !== 'undefined' && faIncludeFaq;
  var _deskLogout = typeof faShowLogoutDesktop !== 'undefined' ? !!faShowLogoutDesktop : (_active === 'dashboard');
%>
<div class="field-agent-console">
  <input type="checkbox" id="field-agent-console-nav" class="field-agent-console__check" autocomplete="off" tabindex="-1" />
  <div class="field-agent-console__bar">
    <label for="field-agent-console-nav" class="field-agent-console__burger">
      <span class="field-agent-console__burger-icon" aria-hidden="true"></span>
      <span class="field-agent-console__burger-label">Menu</span>
    </label>
    <nav class="field-agent-console__tabs" aria-label="Field agent console">
      <a
        href="<%= _tp %>/field-agent/add-contact"
        class="admin-nav__link <%= _active === 'add_contact' ? 'admin-nav__link--active' : '' %>"
      >New contact</a>
      <a
        href="<%= _tp %>/field-agent/dashboard"
        class="admin-nav__link <%= _active === 'dashboard' ? 'admin-nav__link--active' : '' %>"
      >Dashboard</a>
      <a
        href="<%= _tp %>/field-agent/statements"
        class="admin-nav__link <%= _active === 'statements' ? 'admin-nav__link--active' : '' %>"
      >Statements</a>
      <a
        href="<%= _tp %>/field-agent/disputes"
        class="admin-nav__link <%= _active === 'disputes' ? 'admin-nav__link--active' : '' %>"
      >Disputes</a>
      <a
        href="<%= _tp %>/field-agent/adjustments"
        class="admin-nav__link <%= _active === 'adjustments' ? 'admin-nav__link--active' : '' %>"
      >Adjustments</a>
      <a
        href="<%= _tp %>/field-agent/call-me-back"
        class="admin-nav__link <%= _active === 'callback' ? 'admin-nav__link--active' : '' %>"
      >Call me back</a>
      <% if (_faq) { %>
      <a
        href="<%= _tp %>/field-agent/faq"
        class="admin-nav__link <%= _active === 'faq' ? 'admin-nav__link--active' : '' %>"
      >FAQ</a>
      <% } %>
    </nav>
    <% if (_deskLogout) { %>
    <form method="post" action="<%= _tp %>/field-agent/logout" class="field-agent-console__logout field-agent-console__logout--desktop">
      <%- include('components/button', { variant: 'default', type: 'submit', label: 'Sign out', className: 'admin-nav__btn' }) %>
    </form>
    <% } %>
  </div>
  <label for="field-agent-console-nav" class="field-agent-console__scrim" aria-hidden="true" tabindex="-1"></label>
  <aside class="field-agent-console__drawer" aria-label="Field agent menu">
    <div class="field-agent-console__drawer-top">
      <span class="field-agent-console__drawer-title">Field agent</span>
      <label for="field-agent-console-nav" class="field-agent-console__drawer-close" aria-label="Close menu">&times;</label>
    </div>
    <nav class="field-agent-console__drawer-nav" aria-label="Field agent console">
      <a href="<%= _tp %>/field-agent/add-contact" class="field-agent-console__drawer-link <%= _active === 'add_contact' ? 'is-active' : '' %>">New contact</a>
      <a href="<%= _tp %>/field-agent/dashboard" class="field-agent-console__drawer-link <%= _active === 'dashboard' ? 'is-active' : '' %>">Dashboard</a>
      <a href="<%= _tp %>/field-agent/statements" class="field-agent-console__drawer-link <%= _active === 'statements' ? 'is-active' : '' %>">Statements</a>
      <a href="<%= _tp %>/field-agent/disputes" class="field-agent-console__drawer-link <%= _active === 'disputes' ? 'is-active' : '' %>">Disputes</a>
      <a href="<%= _tp %>/field-agent/adjustments" class="field-agent-console__drawer-link <%= _active === 'adjustments' ? 'is-active' : '' %>">Adjustments</a>
      <a href="<%= _tp %>/field-agent/call-me-back" class="field-agent-console__drawer-link <%= _active === 'callback' ? 'is-active' : '' %>">Call me back</a>
      <% if (_faq) { %>
      <a href="<%= _tp %>/field-agent/faq" class="field-agent-console__drawer-link <%= _active === 'faq' ? 'is-active' : '' %>">FAQ</a>
      <% } %>
    </nav>
    <form method="post" action="<%= _tp %>/field-agent/logout" class="field-agent-console__logout field-agent-console__logout--drawer">
      <%- include('components/button', { variant: 'default', type: 'submit', label: 'Sign out', className: 'admin-nav__btn field-agent-console__logout-btn' }) %>
    </form>
  </aside>
</div>
