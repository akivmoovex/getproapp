<% 
  var _tp = typeof tenantUrlPrefix !== 'undefined' ? String(tenantUrlPrefix || '') : '';
  var _active = typeof faActiveNav !== 'undefined' ? String(faActiveNav || '') : '';
  var _faq = typeof faIncludeFaq !== 'undefined' && faIncludeFaq;
  var _deskLogout = typeof faShowLogoutDesktop !== 'undefined' ? !!faShowLogoutDesktop : (_active === 'dashboard');
%>
<div class="field-agent-console">
  <div class="field-agent-console__bar">
    <nav class="field-agent-console__tabs" aria-label="Field agent console">
      <a
        href="<%= _tp %>/field-agent/add-contact"
        class="admin-nav__link <%= _active === 'add_contact' ? 'admin-nav__link--active' : '' %>"
      >New contact</a>
      <a
        href="<%= _tp %>/field-agent/dashboard"
        class="admin-nav__link <%= _active === 'dashboard' ? 'admin-nav__link--active' : '' %>"
      >Dashboard</a>
      <a
        href="<%= _tp %>/field-agent/statements"
        class="admin-nav__link <%= _active === 'statements' ? 'admin-nav__link--active' : '' %>"
      >Statements</a>
      <a
        href="<%= _tp %>/field-agent/disputes"
        class="admin-nav__link <%= _active === 'disputes' ? 'admin-nav__link--active' : '' %>"
      >Disputes</a>
      <a
        href="<%= _tp %>/field-agent/adjustments"
        class="admin-nav__link <%= _active === 'adjustments' ? 'admin-nav__link--active' : '' %>"
      >Adjustments</a>
      <a
        href="<%= _tp %>/field-agent/call-me-back"
        class="admin-nav__link <%= _active === 'callback' ? 'admin-nav__link--active' : '' %>"
      >Call me back</a>
      <% if (_faq) { %>
      <a
        href="<%= _tp %>/field-agent/faq"
        class="admin-nav__link <%= _active === 'faq' ? 'admin-nav__link--active' : '' %>"
      >FAQ</a>
      <% } %>
    </nav>
    <% if (_deskLogout) { %>
    <form method="post" action="<%= _tp %>/field-agent/logout" class="field-agent-console__logout field-agent-console__logout--desktop">
      <%- include('components/button', { variant: 'default', type: 'submit', label: 'Sign out', className: 'admin-nav__btn' }) %>
    </form>
    <% } %>
  </div>

  <div class="app-nav-backdrop" id="wf-app-nav-backdrop" hidden></div>

  <aside
    class="app-nav-drawer"
    id="wf-app-nav-drawer"
    aria-label="Field agent menu"
    aria-hidden="true"
  >
    <div class="app-nav-drawer-top">
      <button
        type="button"
        class="wf-home-sidebar-close app-nav-drawer-close"
        id="wf-app-nav-close"
        aria-label="Close menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>

    <div class="app-nav-drawer-body">
      <nav class="wf-home-sidebar-nav wf-home-sidebar-nav--primary" aria-label="Field agent console">
        <a
          href="<%= _tp %>/field-agent/add-contact"
          class="wf-home-nav-btn <%= _active === 'add_contact' ? 'wf-home-nav-btn--primary' : 'wf-home-nav-btn--ghost' %>"
        >New contact</a>
        <a
          href="<%= _tp %>/field-agent/dashboard"
          class="wf-home-nav-btn <%= _active === 'dashboard' ? 'wf-home-nav-btn--primary' : 'wf-home-nav-btn--ghost' %>"
        >Dashboard</a>
        <a
          href="<%= _tp %>/field-agent/statements"
          class="wf-home-nav-btn <%= _active === 'statements' ? 'wf-home-nav-btn--primary' : 'wf-home-nav-btn--ghost' %>"
        >Statements</a>
        <a
          href="<%= _tp %>/field-agent/disputes"
          class="wf-home-nav-btn <%= _active === 'disputes' ? 'wf-home-nav-btn--primary' : 'wf-home-nav-btn--ghost' %>"
        >Disputes</a>
        <a
          href="<%= _tp %>/field-agent/adjustments"
          class="wf-home-nav-btn <%= _active === 'adjustments' ? 'wf-home-nav-btn--primary' : 'wf-home-nav-btn--ghost' %>"
        >Adjustments</a>
        <a
          href="<%= _tp %>/field-agent/call-me-back"
          class="wf-home-nav-btn <%= _active === 'callback' ? 'wf-home-nav-btn--primary' : 'wf-home-nav-btn--ghost' %>"
        >Call me back</a>
        <% if (_faq) { %>
        <a
          href="<%= _tp %>/field-agent/faq"
          class="wf-home-nav-btn <%= _active === 'faq' ? 'wf-home-nav-btn--primary' : 'wf-home-nav-btn--ghost' %>"
        >FAQ</a>
        <% } %>
      </nav>
      <form method="post" action="<%= _tp %>/field-agent/logout" class="field-agent-console__logout field-agent-console__logout--drawer">
        <%- include('components/button', { variant: 'default', type: 'submit', label: 'Sign out', className: 'admin-nav__btn field-agent-console__logout-btn' }) %>
      </form>
    </div>
  </aside>
</div>
