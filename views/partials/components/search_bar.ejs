<%#
  SearchBar is a system component. Do not duplicate or modify per-page.
  All changes must be done here.

  Entry: pages use partials/pro_search_form.ejs only (it wraps this partial in <form>
  with action/method). From views/partials/, include as components/search_bar — same
  file as partials/components/search_bar.ejs from the views root.

  Props (safe if undefined; no globals):
  - variant              : 'home' | 'directory' (default id prefix: home | dir)
  - tenantUrlPrefix      : consumed by pro_search_form for action URL (passed through; unused here)
  - showCategoryFilter   : boolean
  - selectedCategory     : slug string
  - categories           : array of { slug, name }
  - ariaLabel            : consumed by pro_search_form on <form> (passed through; unused here)
  - idPrefix             : override field id prefix (sanitized)
  - searchQuery, cityQuery : controlled input values
  - servicePlaceholder, cityPlaceholder : optional native placeholders (from ctaVoice.searchRefinement)
  - serviceWatermarkRotate : optional pipe-separated rotate phrases for service field (defaults if empty)
  Form shell props (pro_search_form only): formAction, formId
-%>
<%
  var _v = typeof variant !== 'undefined' ? String(variant) : 'directory';
  var _pre = _v === 'home' ? 'home' : 'dir';
  if (typeof idPrefix !== 'undefined' && idPrefix) {
    _pre = String(idPrefix).replace(/[^a-z0-9_-]/gi, '') || _pre;
  }
  var _q = typeof searchQuery !== 'undefined' ? String(searchQuery || '') : '';
  var _city = typeof cityQuery !== 'undefined' ? String(cityQuery || '') : '';
  var _showCat = typeof showCategoryFilter !== 'undefined' && showCategoryFilter;
  var _selCat = typeof selectedCategory !== 'undefined' ? String(selectedCategory || '').trim() : '';
  var _cats = typeof categories !== 'undefined' && categories ? categories : [];
  var _submitBtn = typeof submitLabel !== 'undefined' && String(submitLabel || '').trim() ? String(submitLabel).trim() : 'Search';
  var _svcPh = typeof servicePlaceholder !== 'undefined' ? String(servicePlaceholder || '') : '';
  var _cityPh = typeof cityPlaceholder !== 'undefined' ? String(cityPlaceholder || '') : '';
  var _wmSvc = typeof serviceWatermarkRotate !== 'undefined' && String(serviceWatermarkRotate || '').trim()
    ? String(serviceWatermarkRotate).trim()
    : 'Electrician|Plumber|Carpenter';
%>
<% if (_showCat && _cats && _cats.length) { %>
  <div class="pro-search-form__category input-field">
    <label class="pro-search-form__label input-field__label" for="<%= _pre %>-category-filter">Category</label>
    <select id="<%= _pre %>-category-filter" name="category" class="pro-search-form__select input-field__control" aria-label="Filter by category">
      <option value=""<%= !_selCat ? ' selected' : '' %>>All categories</option>
      <% _cats.forEach(function (cat) { %>
      <option value="<%= cat.slug %>"<%= _selCat === cat.slug ? ' selected' : '' %>><%= cat.name %></option>
      <% }); %>
    </select>
  </div>
<% } else if (_selCat) { %>
  <input type="hidden" name="category" value="<%= _selCat %>" />
<% } %>

  <div class="pro-search-form__toolbar-row">
    <div class="pro-search-form__fields">
      <div class="pro-search-form__field input-field input-field--search">
        <label class="pro-search-form__label input-field__label" for="<%= _pre %>-search-q">Service or profession</label>
        <div
          class="pro-ac"
          data-ac-list="service"
          data-ac-typeahead="1"
          data-watermark-rotate="<%= _wmSvc %>"
        >
          <input
            id="<%= _pre %>-search-q"
            class="pro-ac-input input-field__control"
            type="text"
            value="<%= _q %>"
            placeholder="<%= _svcPh %>"
            autocomplete="off"
            role="combobox"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="<%= _pre %>-search-q-dropdown"
          />
          <input type="hidden" class="pro-ac-hidden" name="q" id="<%= _pre %>-search-q-value" value="<%= _q %>" />
          <ul class="pro-ac-dropdown" id="<%= _pre %>-search-q-dropdown" role="listbox" hidden></ul>
          <p class="pro-ac-msg input-field__error" hidden></p>
        </div>
      </div>
      <div class="pro-search-form__field input-field input-field--search">
        <label class="pro-search-form__label input-field__label" for="<%= _pre %>-search-city">City</label>
        <div
          class="pro-ac"
          data-ac-list="city"
          data-watermark-rotate="Lusaka|Ndola|Kitwe"
        >
          <input
            id="<%= _pre %>-search-city"
            class="pro-ac-input input-field__control"
            type="text"
            value="<%= _city %>"
            placeholder="<%= _cityPh %>"
            autocomplete="off"
            role="combobox"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="<%= _pre %>-search-city-dropdown"
          />
          <input type="hidden" class="pro-ac-hidden" name="city" id="<%= _pre %>-search-city-value" value="<%= _city %>" />
          <ul class="pro-ac-dropdown" id="<%= _pre %>-search-city-dropdown" role="listbox" hidden></ul>
          <p class="pro-ac-msg input-field__error" hidden></p>
        </div>
      </div>
    </div>
    <%- include('button', {
      variant: 'primary',
      type: 'submit',
      text: _submitBtn,
      icon: 'search',
      className: 'pro-search-form__submit',
    }) %>
  </div>
