<%
  var href = typeof brandLockupHref !== 'undefined' ? brandLockupHref : '/';
  var v = typeof brandLockupVariant !== 'undefined' ? brandLockupVariant : 'home';
  var tn = typeof tenant !== 'undefined' ? tenant : null;
  var slug = tn && tn.slug ? String(tn.slug) : '';
  var showLockup = tn && slug && slug !== 'global';
  var aria = showLockup && tn.name ? ('GetPro ' + String(tn.name)) : 'GetPro home';
  var rootClass = v === 'home' ? 'wf-home-topbar-brand' : v === 'join' ? 'join-top-brand' : 'wf-nav-brand';
%>
<a href="<%= href %>" class="<%= rootClass %>"<%= v === 'join' ? ' id="join-top-brand"' : '' %> aria-label="<%= aria %>">
  <span class="wf-brand-lockup-root">
    <span class="wf-brand-lockup-product">GetPro</span>
    <% if (showLockup) { %>
    <span class="wf-brand-lockup-region">
      <span class="wf-brand-lockup-flag" aria-hidden="true"><%= tn.flagEmoji %></span>
      <span class="wf-brand-lockup-name"><%= tn.name %></span>
    </span>
    <% } %>
  </span>
</a>
