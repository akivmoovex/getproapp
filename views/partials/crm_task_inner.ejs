<% var _ov = typeof overlayMode !== 'undefined' && overlayMode; %>
<div class="crm-task-shell<%= _ov ? ' crm-task-shell--panel' : '' %>">
  <header class="crm-task-hero card">
    <% if (_ov) { %>
    <p class="crm-task-hero__eyebrow">Task #<%= task.id %></p>
    <% } %>
    <div class="crm-task-hero__row">
      <span class="crm-task-pill"><%= typeof crmTaskStatusLabel === 'function' ? crmTaskStatusLabel(task.status) : task.status %></span>
      <% if (task.owner_username) { %>
        <span class="crm-task-hero__assignee muted">Assignee: <strong><%= task.owner_username %></strong></span>
      <% } else { %>
        <span class="crm-task-hero__assignee muted"><em>Unassigned</em></span>
      <% } %>
    </div>
    <h1 class="crm-task-hero__title"><%= task.title %></h1>
  </header>

  <section class="crm-task-section card">
    <h2 class="crm-task-section__h">Description</h2>
    <% if (task.description) { %>
      <div class="crm-task-prose"><%= task.description %></div>
    <% } else { %>
      <p class="muted" style="margin: 0">No description.</p>
    <% } %>
    <% var _att = task.attachment_url && String(task.attachment_url).trim(); %>
    <% if (_att) { %>
      <div class="crm-task-attach">
        <span class="muted">Attachment</span>
        <a class="crm-task-attach__link" href="<%= _att %>" rel="noopener noreferrer" target="_blank"><%= _att %></a>
      </div>
    <% } %>
    <p class="crm-task-meta muted">
      Created <%= task.created_at %><% if (task.creator_username) { %> · <%= task.creator_username %><% } %>
      · Updated <%= task.updated_at %>
    </p>
  </section>

  <% if (canEdit) { %>
  <section class="crm-task-section card crm-task-section--form">
    <h2 class="crm-task-section__h">Edit task</h2>
    <p class="crm-task-section__lead muted">Title, description, and optional file link.</p>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/fields" class="form crm-task-form">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <div>
        <label for="crm_edit_title">Title</label>
        <input id="crm_edit_title" name="title" required maxlength="200" value="<%= task.title %>" />
      </div>
      <div>
        <label for="crm_edit_desc">Description</label>
        <textarea id="crm_edit_desc" name="description" rows="4" placeholder="Details…"><%= task.description || '' %></textarea>
      </div>
      <div>
        <label for="crm_edit_attachment">Attachment link</label>
        <input
          id="crm_edit_attachment"
          name="attachment_url"
          type="url"
          maxlength="2000"
          placeholder="https://…"
          value="<%= _att || '' %>"
        />
      </div>
      <div class="crm-task-form__actions">
        <button class="btn btn-primary" type="submit">Save details</button>
      </div>
    </form>
  </section>
  <% } %>

  <% if (showClaim && canClaimCrmTasks) { %>
  <section class="crm-task-section card crm-task-section--callout">
    <p class="crm-task-section__lead" style="margin: 0 0 12px">This task is unassigned.</p>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/claim">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <button class="btn btn-primary" type="submit">Assign to me</button>
    </form>
  </section>
  <% } %>

  <% if (typeof isSuperCrm !== 'undefined' && isSuperCrm) { %>
  <section class="crm-task-section card crm-task-section--form">
    <h2 class="crm-task-section__h">Reassign</h2>
    <p class="crm-task-section__lead muted">Super admin — move to another user or unassign.</p>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/reassign" class="form crm-task-form">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <div>
        <label for="crm_reassign">Assign to</label>
        <select id="crm_reassign" name="owner_id">
          <option value="">— Unassign (returns to New) —</option>
          <% (tenantUsersForReassign || []).forEach(function(u) { %>
            <option value="<%= u.id %>" <%= task.owner_id && Number(task.owner_id) === Number(u.id) ? 'selected' : '' %>><%= u.username %></option>
          <% }); %>
        </select>
      </div>
      <div class="crm-task-form__actions">
        <button class="btn btn-primary" type="submit">Save assignment</button>
      </div>
    </form>
  </section>
  <% } %>

  <% if (canEdit) { %>
  <section class="crm-task-section card crm-task-section--form">
    <h2 class="crm-task-section__h">Status</h2>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/status" class="form crm-task-form crm-task-form--inline">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <div class="crm-task-form__inline">
        <label for="crm_status" class="sr-only">Status</label>
        <select id="crm_status" name="status" required>
          <% (CRM_TASK_STATUSES || []).forEach(function(st) { %>
            <option value="<%= st %>" <%= currentStatus === st ? 'selected' : '' %>><%= typeof crmTaskStatusLabel === 'function' ? crmTaskStatusLabel(st) : st %></option>
          <% }); %>
        </select>
        <button class="btn btn-primary" type="submit">Update</button>
      </div>
    </form>
  </section>
  <% } else if (canMutateCrm && !isOwner && task.owner_id) { %>
  <p class="muted crm-task-note">Only <strong><%= task.owner_username || 'the owner' %></strong> or a super admin can change this task’s status.</p>
  <% } %>

  <% if (canMutateCrm) { %>
  <section class="crm-task-section card">
    <h2 class="crm-task-section__h">Comments</h2>
    <% if (comments && comments.length) { %>
      <ul class="crm-task-comments">
        <% comments.forEach(function(c) { %>
          <li class="crm-task-comments__item">
            <div class="crm-task-comments__meta muted">
              <span><%= c.author_username || '—' %></span>
              <span><%= c.created_at %></span>
            </div>
            <div class="crm-task-comments__body"><%= c.body %></div>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p class="muted" style="margin: 0">No comments yet.</p>
    <% } %>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/comments" class="form crm-task-form crm-task-form--comment">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <label for="crm_comment_body">Add a comment</label>
      <textarea id="crm_comment_body" name="body" rows="3" required maxlength="4000" placeholder="Write a note…"></textarea>
      <div class="crm-task-form__actions">
        <button class="btn btn-primary" type="submit">Post</button>
      </div>
    </form>
  </section>
  <% } %>

  <section class="crm-task-section card crm-task-section--history">
    <h2 class="crm-task-section__h">History</h2>
    <% if (!auditLogs || auditLogs.length === 0) { %>
      <p class="muted" style="margin: 0">No audit entries yet.</p>
    <% } else { %>
      <ul class="crm-task-audit">
        <% auditLogs.forEach(function(a) { %>
          <li class="crm-task-audit__row">
            <div class="crm-task-audit__meta">
              <span class="crm-task-audit__time"><%= a.created_at %></span>
              <span><%= a.actor_username || '—' %></span>
              <span class="crm-task-audit__badge"><%= a.action_type %></span>
            </div>
            <div class="crm-task-audit__details muted"><%= a.details %></div>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </section>
</div>
