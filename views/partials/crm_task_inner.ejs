<% var _ov = typeof overlayMode !== 'undefined' && overlayMode; %>
<div class="crm-task-shell<%= _ov ? ' crm-task-shell--panel' : '' %>">
  <header class="crm-task-hero card">
    <% if (_ov) { %>
    <p class="crm-task-hero__eyebrow">Task #<%= task.id %></p>
    <% } %>
    <div class="crm-task-hero__top">
      <span class="crm-task-pill"><%= typeof crmTaskStatusLabel === 'function' ? crmTaskStatusLabel(task.status) : task.status %></span>
      <% if (task.owner_username) { %>
        <span class="crm-task-hero__assignee muted">Assignee: <strong><%= task.owner_username %></strong></span>
      <% } else { %>
        <span class="crm-task-hero__assignee muted"><em>Unassigned</em></span>
      <% } %>
    </div>
    <h1 class="crm-task-hero__title"><%= task.title %></h1>
    <p class="crm-task-hero__meta muted">
      <span>
        <%- include('event_time', { at: task.created_at }) %>
        <% if (task.creator_username) { %> · <%= task.creator_username %><% } %>
      </span>
      <span aria-hidden="true"> · </span>
      <span>Updated <%- include('event_time', { at: task.updated_at }) %></span>
    </p>
  </header>

  <div class="crm-task-layout">
    <div class="crm-task-layout__primary">
      <section class="crm-task-section card">
        <h2 class="crm-task-section__h">Description</h2>
        <% if (task.description) { %>
          <div class="crm-task-prose"><%= task.description %></div>
        <% } else { %>
          <p class="muted crm-task-empty">No description.</p>
        <% } %>
        <% var _att = task.attachment_url && String(task.attachment_url).trim(); %>
        <% if (_att) { %>
          <div class="crm-task-attach">
            <span class="muted crm-task-attach__label">Attachment</span>
            <a class="crm-task-attach__link" href="<%= _att %>" rel="noopener noreferrer" target="_blank"><%= _att %></a>
          </div>
        <% } %>
      </section>

      <% if (typeof fieldAgentProviderSubmission !== 'undefined' && fieldAgentProviderSubmission) { %>
      <% var _fas = fieldAgentProviderSubmission; %>
      <% var _faWeb = String(task.source_type || '') === 'field_agent_website_listing'; %>
      <section class="crm-task-section card crm-task-section--field-agent" data-field-agent-submission="<%= _fas.id %>">
        <% if (_faWeb) { %>
        <h2 class="crm-task-section__h">Website / directory listing review</h2>
        <p class="muted crm-task-hero__meta">
          Submission #<%= _fas.id %> · Approved
          <% if (_fas.field_agent_username) { %> · Agent: <strong><%= _fas.field_agent_username %></strong><% } %>
        </p>
        <p class="crm-task-prose">
          Call the service provider, review and edit listing text, then <strong>publish</strong> to create the directory listing and mini-site (photos can be added later).
        </p>
        <div class="crm-task-prose crm-task-fa-summary">
          <p><strong>Name:</strong> <%= _fas.first_name %> <%= _fas.last_name %> · <strong>Phone:</strong> <%= _fas.phone_raw %></p>
        </div>
        <p class="crm-task-form__actions">
          <%- include('components/button', { variant: 'primary', href: '/admin/field-agent/submissions/' + _fas.id + '/website-listing-review', label: 'Open review & publish' }) %>
        </p>
        <% } else { %>
        <h2 class="crm-task-section__h">Field agent provider submission</h2>
        <% var _faSt = String(_fas.status || '');
           var _faLbl = _faSt === 'info_needed' ? 'Info needed' : (_faSt === 'appealed' ? 'Appealed' : _faSt); %>
        <p class="muted crm-task-hero__meta">
          Submission #<%= _fas.id %> · Status: <strong><%= _faLbl %></strong>
          <% if (_fas.field_agent_username) { %> · Agent: <strong><%= _fas.field_agent_username %></strong><% } %>
        </p>
        <div class="crm-task-prose crm-task-fa-summary">
          <p><strong>Name:</strong> <%= _fas.first_name %> <%= _fas.last_name %></p>
          <p><strong>Profession:</strong> <%= _fas.profession %></p>
          <p><strong>City:</strong> <%= _fas.city %></p>
          <p><strong>Phone:</strong> <%= _fas.phone_raw %></p>
          <p><strong>WhatsApp:</strong> <%= _fas.whatsapp_raw || '—' %></p>
          <p><strong>PACRA:</strong> <%= _fas.pacra || '—' %></p>
          <p><strong>Commission recorded:</strong> <%= _fas.commission_amount != null ? _fas.commission_amount : '—' %></p>
          <% if (_fas.rejection_reason && String(_fas.rejection_reason).trim() && (_fas.status === 'rejected' || _fas.status === 'appealed' || _fas.status === 'info_needed')) { %>
          <p><strong>Rejection / notes:</strong> <%= _fas.rejection_reason %></p>
          <% } %>
        </div>
        <% if (canMutateCrm) { %>
          <% if (_fas.status === 'pending' || _fas.status === 'info_needed' || _fas.status === 'appealed') { %>
          <div class="crm-task-fa-actions">
            <form method="post" action="/admin/crm/tasks/<%= task.id %>/field-agent-submission/approve" class="form crm-task-form crm-task-form--inline">
              <% if (_ov) { %>
              <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
              <% } %>
              <div class="input-field">
                <label for="fa_approve_commission" class="input-field__label">Commission on approve (optional)</label>
                <input id="fa_approve_commission" name="commission_amount" type="number" min="0" step="0.01" class="input-field__control" placeholder="0.00" />
              </div>
              <div class="crm-task-form__actions">
                <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Approve submission' }) %>
              </div>
            </form>
            <form method="post" action="/admin/crm/tasks/<%= task.id %>/field-agent-submission/reject" class="form crm-task-form">
              <% if (_ov) { %>
              <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
              <% } %>
              <div class="input-field">
                <label for="fa_reject_reason" class="input-field__label">Reject — reason (required)</label>
                <textarea id="fa_reject_reason" name="rejection_reason" class="input-field__control" rows="2" required maxlength="4000" placeholder="Why this submission is rejected…"></textarea>
              </div>
              <div class="crm-task-form__actions">
                <%- include('components/button', { variant: 'secondary', type: 'submit', label: 'Reject submission' }) %>
              </div>
            </form>
            <% if (_fas.status === 'pending' || _fas.status === 'appealed') { %>
            <form method="post" action="/admin/crm/tasks/<%= task.id %>/field-agent-submission/info-needed" class="form crm-task-form">
              <% if (_ov) { %>
              <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
              <% } %>
              <div class="input-field">
                <label for="fa_info_request" class="input-field__label">Information needed from field agent (required)</label>
                <textarea id="fa_info_request" name="info_request" class="input-field__control" rows="2" required maxlength="4000" placeholder="Describe what the field agent must provide or fix…"></textarea>
              </div>
              <div class="crm-task-form__actions">
                <%- include('components/button', { variant: 'default', type: 'submit', label: _fas.status === 'appealed' ? 'Request more info' : 'Mark info needed' }) %>
              </div>
            </form>
            <% } %>
          </div>
          <% } else if (_fas.status === 'rejected') { %>
          <div class="crm-task-fa-actions">
            <form method="post" action="/admin/crm/tasks/<%= task.id %>/field-agent-submission/appeal" class="form crm-task-form crm-task-form--inline">
              <% if (_ov) { %>
              <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
              <% } %>
              <div class="crm-task-form__actions">
                <%- include('components/button', { variant: 'default', type: 'submit', label: 'Mark as appealed (reopen)' }) %>
              </div>
            </form>
          </div>
          <% } else if (_fas.status === 'approved') { %>
          <form method="post" action="/admin/crm/tasks/<%= task.id %>/field-agent-submission/commission" class="form crm-task-form">
            <% if (_ov) { %>
            <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
            <% } %>
            <div class="input-field">
              <label for="fa_commission_edit" class="input-field__label">Commission amount</label>
              <input id="fa_commission_edit" name="commission_amount" type="number" min="0" step="0.01" class="input-field__control" required value="<%= _fas.commission_amount != null ? _fas.commission_amount : 0 %>" />
            </div>
            <div class="crm-task-form__actions">
              <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Update commission' }) %>
            </div>
          </form>
          <% } %>
        <% } else { %>
          <p class="muted crm-task-empty">Read-only — moderation actions require CRM edit access.</p>
        <% } %>
        <% } %>
      </section>
      <% } %>

      <% if (canEdit) { %>
      <section class="crm-task-section card crm-task-section--form">
        <h2 class="crm-task-section__h">Edit task</h2>
        <form method="post" action="/admin/crm/tasks/<%= task.id %>/fields" class="form crm-task-form">
          <% if (_ov) { %>
            <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
          <% } %>
          <div class="input-field">
            <label for="crm_edit_title" class="input-field__label">Title</label>
            <input id="crm_edit_title" name="title" class="input-field__control" required maxlength="200" value="<%= task.title %>" />
          </div>
          <div class="input-field">
            <label for="crm_edit_desc" class="input-field__label">Description</label>
            <textarea id="crm_edit_desc" name="description" class="input-field__control" rows="3" placeholder="Details…"><%= task.description || '' %></textarea>
          </div>
          <div class="input-field">
            <label for="crm_edit_attachment" class="input-field__label">Attachment link</label>
            <input
              id="crm_edit_attachment"
              name="attachment_url"
              class="input-field__control"
              type="url"
              maxlength="2000"
              placeholder="https://…"
              value="<%= _att || '' %>"
            />
          </div>
          <div class="crm-task-form__actions">
            <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Save details' }) %>
          </div>
        </form>
      </section>
      <% } %>

      <% if (canMutateCrm) { %>
      <section class="crm-task-section card">
        <h2 class="crm-task-section__h">Comments</h2>
        <% if (comments && comments.length) { %>
          <ul class="crm-task-comments">
            <% comments.forEach(function(c) { %>
              <li class="crm-task-comments__item">
                <div class="crm-task-comments__meta muted">
                  <span><%= c.author_username || '—' %></span>
                  <span><%- include('event_time', { at: c.created_at }) %></span>
                </div>
                <div class="crm-task-comments__body"><%= c.body %></div>
              </li>
            <% }); %>
          </ul>
        <% } else { %>
          <p class="muted crm-task-empty">No comments yet.</p>
        <% } %>
        <form method="post" action="/admin/crm/tasks/<%= task.id %>/comments" class="form crm-task-form crm-task-form--comment">
          <% if (_ov) { %>
            <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
          <% } %>
          <div class="input-field">
            <label for="crm_comment_body" class="input-field__label">Add a comment</label>
            <textarea id="crm_comment_body" name="body" class="input-field__control" rows="2" required maxlength="4000" placeholder="Write a note…"></textarea>
          </div>
          <div class="crm-task-form__actions">
            <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Post' }) %>
          </div>
        </form>
      </section>
      <% } %>

      <section class="crm-task-section card crm-task-section--history">
        <h2 class="crm-task-section__h">History</h2>
        <% if (!auditLogs || auditLogs.length === 0) { %>
          <p class="muted crm-task-empty">No audit entries yet.</p>
        <% } else { %>
          <ul class="crm-task-audit">
            <% auditLogs.forEach(function(a) { %>
              <li class="crm-task-audit__row">
                <div class="crm-task-audit__meta">
                  <span class="crm-task-audit__time"><%- include('event_time', { at: a.created_at }) %></span>
                  <span><%= a.actor_username || '—' %></span>
                  <span class="crm-task-audit__badge"><%= a.action_type %></span>
                </div>
                <div class="crm-task-audit__details muted"><%= a.details %></div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </section>
    </div>

    <aside class="crm-task-layout__aside" aria-label="Task actions">
      <% if (showClaim && canClaimCrmTasks) { %>
      <section class="crm-task-section card crm-task-section--callout">
        <p class="crm-task-aside__title">Unassigned</p>
        <form method="post" action="/admin/crm/tasks/<%= task.id %>/claim">
          <% if (_ov) { %>
            <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
          <% } %>
          <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Assign to me', className: 'btn-block', fullWidth: true }) %>
        </form>
      </section>
      <% } %>

      <% if (typeof isSuperCrm !== 'undefined' && isSuperCrm) { %>
      <section class="crm-task-section card crm-task-section--form">
        <h2 class="crm-task-section__h">Reassign</h2>
        <form method="post" action="/admin/crm/tasks/<%= task.id %>/reassign" class="form crm-task-form">
          <% if (_ov) { %>
            <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
          <% } %>
          <div class="input-field">
            <label for="crm_reassign" class="input-field__label">Assign to</label>
            <select id="crm_reassign" name="owner_id" class="input-field__control">
              <option value="">— Unassign —</option>
              <% (tenantUsersForReassign || []).forEach(function(u) { %>
                <option value="<%= u.id %>" <%= task.owner_id && Number(task.owner_id) === Number(u.id) ? 'selected' : '' %>><%= u.username %></option>
              <% }); %>
            </select>
          </div>
          <div class="crm-task-form__actions">
            <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Save', className: 'btn-block', fullWidth: true }) %>
          </div>
        </form>
      </section>
      <% } %>

      <% if (canEdit) { %>
      <section class="crm-task-section card crm-task-section--form">
        <h2 class="crm-task-section__h">Status</h2>
        <form method="post" action="/admin/crm/tasks/<%= task.id %>/status" class="form crm-task-form">
          <% if (_ov) { %>
            <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
          <% } %>
          <div class="input-field">
            <label for="crm_status" class="input-field__label crm-task-aside__label">Workflow</label>
            <select id="crm_status" name="status" class="input-field__control" required>
              <% (CRM_TASK_STATUSES || []).forEach(function(st) { %>
                <option value="<%= st %>" <%= currentStatus === st ? 'selected' : '' %>><%= typeof crmTaskStatusLabel === 'function' ? crmTaskStatusLabel(st) : st %></option>
              <% }); %>
            </select>
          </div>
          <div class="crm-task-form__actions">
            <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Update status', className: 'btn-block', fullWidth: true }) %>
          </div>
        </form>
      </section>
      <% } else if (canMutateCrm && !isOwner && task.owner_id) { %>
      <p class="muted crm-task-note crm-task-note--aside">Only <strong><%= task.owner_username || 'the owner' %></strong> or a super admin can change status.</p>
      <% } %>
    </aside>
  </div>
</div>
