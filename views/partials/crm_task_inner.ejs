<% var _ov = typeof overlayMode !== 'undefined' && overlayMode; %>
<% if (_ov) { %>
<h2 class="admin-crm-overlay__task-title">Task #<%= task.id %></h2>
<% } %>
<p class="admin-intro muted admin-crm-detail__meta">
  <span class="admin-crm-detail__meta-item"
    >Status: <strong><%= typeof crmTaskStatusLabel === 'function' ? crmTaskStatusLabel(task.status) : task.status %></strong></span
  >
  <span class="admin-crm-detail__meta-sep" aria-hidden="true">·</span>
  <% if (task.owner_username) { %>
    <span class="admin-crm-detail__meta-item">Owner: <strong><%= task.owner_username %></strong></span>
  <% } else { %>
    <span class="admin-crm-detail__meta-item"><em>Unassigned</em></span>
  <% } %>
</p>

<div class="card admin-crm-panel admin-crm-detail__block">
  <h2 class="admin-crm-section__title">Details</h2>
  <p class="admin-crm-detail__task-title"><%= task.title %></p>
  <% if (task.description) { %>
    <div class="admin-crm-detail__body"><%= task.description %></div>
  <% } else { %>
    <p class="muted">No description.</p>
  <% } %>
  <% var _att = task.attachment_url && String(task.attachment_url).trim(); %>
  <% if (_att) { %>
    <p class="admin-crm-detail__attachment" style="margin-top: 12px">
      <span class="muted">Attachment: </span>
      <a href="<%= _att %>" rel="noopener noreferrer" target="_blank"><%= _att %></a>
    </p>
  <% } %>
  <p class="muted admin-crm-detail__timestamps">
    Created <%= task.created_at %><% if (task.creator_username) { %> · <%= task.creator_username %><% } %>
    · Updated <%= task.updated_at %>
  </p>
</div>

<% if (canEdit) { %>
  <div class="card admin-form-card admin-crm-panel admin-crm-detail__block">
    <h2 class="admin-crm-section__title">Edit task</h2>
    <p class="muted admin-crm-section__lead">Title, description, and optional link to a file (https://…).</p>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/fields" class="form">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <div>
        <label for="crm_edit_title">Title</label>
        <input id="crm_edit_title" name="title" required maxlength="200" value="<%= task.title %>" />
      </div>
      <div>
        <label for="crm_edit_desc">Description</label>
        <textarea id="crm_edit_desc" name="description" rows="4" placeholder="Details…"><%= task.description || '' %></textarea>
      </div>
      <div>
        <label for="crm_edit_attachment">Attachment link</label>
        <input
          id="crm_edit_attachment"
          name="attachment_url"
          type="url"
          maxlength="2000"
          placeholder="https://…"
          value="<%= _att || '' %>"
        />
        <div class="muted" style="margin-top: 6px; font-size: 12px; line-height: 1.55">Paste a URL to a document or file (Google Drive, Dropbox, etc.).</div>
      </div>
      <div class="admin-gate-actions">
        <button class="btn btn-primary" type="submit">Save details</button>
      </div>
    </form>
  </div>
<% } %>

<% if (showClaim && canClaimCrmTasks) { %>
  <div class="card admin-form-card admin-crm-panel admin-crm-detail__block">
    <p class="admin-crm-detail__lead">This task is unassigned.</p>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/claim">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <div class="admin-gate-actions">
        <button class="btn btn-primary" type="submit">Assign to me</button>
      </div>
    </form>
  </div>
<% } %>

<% if (typeof isSuperCrm !== 'undefined' && isSuperCrm) { %>
  <div class="card admin-form-card admin-crm-panel admin-crm-detail__block">
    <h2 class="admin-crm-section__title">Reassign (super admin)</h2>
    <p class="muted admin-crm-section__lead">Move this task to another user in this region, or unassign it.</p>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/reassign" class="form">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <div>
        <label for="crm_reassign">Assign to</label>
        <select id="crm_reassign" name="owner_id">
          <option value="">— Unassign (returns to New) —</option>
          <% (tenantUsersForReassign || []).forEach(function(u) { %>
            <option value="<%= u.id %>" <%= task.owner_id && Number(task.owner_id) === Number(u.id) ? 'selected' : '' %>><%= u.username %></option>
          <% }); %>
        </select>
      </div>
      <div class="admin-gate-actions">
        <button class="btn btn-primary" type="submit">Save assignment</button>
      </div>
    </form>
  </div>
<% } %>

<% if (canEdit) { %>
  <div class="card admin-form-card admin-crm-panel admin-crm-detail__block">
    <h2 class="admin-crm-section__title">Update status</h2>
    <p class="muted admin-crm-section__lead">Change workflow status for this task.</p>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/status" class="form">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <div>
        <label for="crm_status">Status</label>
        <select id="crm_status" name="status" required>
          <% (CRM_TASK_STATUSES || []).forEach(function(st) { %>
            <option value="<%= st %>" <%= currentStatus === st ? 'selected' : '' %>><%= typeof crmTaskStatusLabel === 'function' ? crmTaskStatusLabel(st) : st %></option>
          <% }); %>
        </select>
      </div>
      <div class="admin-gate-actions">
        <button class="btn btn-primary" type="submit">Save status</button>
      </div>
    </form>
  </div>
<% } else if (canMutateCrm && !isOwner && task.owner_id) { %>
  <p class="muted admin-crm-detail__block">Only <strong><%= task.owner_username || 'the owner' %></strong> or a super admin can change this task’s status.</p>
<% } %>

<% if (canMutateCrm) { %>
  <div class="card admin-crm-panel admin-crm-detail__block">
    <h2 class="admin-crm-section__title">Comments</h2>
    <% if (comments && comments.length) { %>
      <ul class="admin-crm-comments">
        <% comments.forEach(function(c) { %>
          <li class="admin-crm-comments__item">
            <div class="admin-crm-comments__meta muted">
              <span class="admin-crm-comments__author"><%= c.author_username || '—' %></span>
              <span class="admin-crm-comments__time"><%= c.created_at %></span>
            </div>
            <div class="admin-crm-comments__body"><%= c.body %></div>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p class="muted">No comments yet.</p>
    <% } %>
    <form method="post" action="/admin/crm/tasks/<%= task.id %>/comments" class="form admin-crm-comments__form">
      <% if (_ov) { %>
        <input type="hidden" name="next" value="/admin/crm?openTask=<%= task.id %>" />
      <% } %>
      <div>
        <label for="crm_comment_body">Add a comment</label>
        <textarea id="crm_comment_body" name="body" rows="4" required maxlength="4000" placeholder="Write a note for your team…"></textarea>
      </div>
      <div class="admin-gate-actions">
        <button class="btn btn-primary" type="submit">Post comment</button>
      </div>
    </form>
  </div>
<% } %>

<div class="card admin-crm-panel admin-crm-detail__block">
  <h2 class="admin-crm-section__title">History</h2>
  <% if (!auditLogs || auditLogs.length === 0) { %>
    <p class="muted">No audit entries yet.</p>
  <% } else { %>
    <ul class="admin-crm-audit">
      <% auditLogs.forEach(function(a) { %>
        <li class="admin-crm-audit__row">
          <div class="admin-crm-audit__meta">
            <span class="admin-crm-audit__time"><%= a.created_at %></span>
            <span class="admin-crm-audit__actor"><%= a.actor_username || '—' %></span>
            <span class="kbd"><%= a.action_type %></span>
          </div>
          <div class="admin-crm-audit__details"><%= a.details %></div>
        </li>
      <% }); %>
    </ul>
  <% } %>
</div>
