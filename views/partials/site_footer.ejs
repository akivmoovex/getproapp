<% var tp = typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : ''; %>
<% var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<% var _op = typeof opsHref === 'function' ? opsHref : function (p) { return (tp || '') + p; }; %>
<%# Optional contact locals (getproPhone, getproEmail, getproAddress) are not passed by every parent view. Normalize here so missing vars never throw at render time. %>
<% var _gpPhone = typeof getproPhone !== 'undefined' ? String(getproPhone || '').trim() : ''; %>
<% var _gpEmail = typeof getproEmail !== 'undefined' ? String(getproEmail || '').trim() : ''; %>
<% var _gpAddr = typeof getproAddress !== 'undefined' ? String(getproAddress || '').trim() : ''; %>
<footer class="wf-footer" id="footer-terms">
  <div class="wf-footer-cta">
    <div class="ds-container wf-footer-cta-inner">
      <h2 class="wf-footer-cta-title">Find the right professional in one place</h2>
      <p class="wf-footer-cta-lead">Search the directory, filter by category, and reach businesses through clear one-page profiles.</p>
      <%- include('components/button', { variant: 'default', href: _op('/directory'), label: 'Open directory', className: 'btn-footer-solid' }) %>
    </div>
  </div>
  <div class="wf-footer-main">
  <div class="ds-container">
    <div class="pro-footer-grid">
      <div class="pro-footer-col">
        <strong><%= _bn %></strong>
        <p class="pro-footer-col__lead">
          Find vetted professionals and browse one-page business profiles in our directory.
        </p>
      </div>
      <div class="pro-footer-col">
        <strong>Directory</strong>
        <ul>
          <li><a href="<%= _op('/directory') %>">Browse professionals</a></li>
          <li><a href="<%= _op('/join') %>">List your business</a></li>
          <li><a href="<%= _op('/answers') %>">Help &amp; answers</a></li>
        </ul>
      </div>
      <div class="pro-footer-col">
        <strong>Contact</strong>
        <ul>
          <% if (_gpPhone) { %>
            <li><a href="tel:<%= _gpPhone %>"><%= _gpPhone %></a></li>
          <% } %>
          <% if (_gpEmail) { %>
            <li><a href="mailto:<%= _gpEmail %>"><%= _gpEmail %></a></li>
          <% } %>
          <% if (typeof getproWhatsapp !== 'undefined' && getproWhatsapp) { %>
            <li>
              <% if (typeof getproWhatsappHref !== 'undefined' && getproWhatsappHref) { %>
                <a href="<%= getproWhatsappHref %>" rel="noopener noreferrer" target="_blank">WhatsApp <%= getproWhatsapp %></a>
              <% } else { %>
                WhatsApp <%= getproWhatsapp %>
              <% } %>
            </li>
          <% } %>
          <% if (_gpAddr) { %>
            <li><%= _gpAddr %></li>
          <% } %>
          <% if (!_gpPhone && !_gpEmail && !_gpAddr && !(typeof getproWhatsapp !== 'undefined' && getproWhatsapp)) { %>
            <li class="pro-footer-col__placeholder">Configure contact details via environment variables.</li>
          <% } %>
        </ul>
      </div>
      <div class="pro-footer-col">
        <strong>Learn more</strong>
        <ul>
          <li><a href="<%= tp %>/directory">Browse by category</a></li>
          <li><a href="<%= tp %>/articles">Articles &amp; tips</a></li>
        </ul>
      </div>
    </div>
    <div class="pro-footer-bottom">
      <span>© <%= new Date().getFullYear() %> <%= _bn %> · getproapp.org</span>
      <span><a href="#footer-terms">Terms of use</a> · <a href="#">Accessibility</a> · <a href="<%= tp %>/directory">Site map</a></span>
    </div>
  </div>
  </div>
</footer>
