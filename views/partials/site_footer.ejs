<% var tp = typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : '/zm'; %>
<footer class="wf-footer" id="footer-terms">
  <div class="wf-footer-cta">
    <div class="container wf-footer-cta-inner">
      <h2 class="wf-footer-cta-title">Find the right professional in one place</h2>
      <p class="wf-footer-cta-lead">Search the directory, filter by category, and reach businesses through clear one-page profiles.</p>
      <a class="btn btn-footer-solid" href="<%= tp %>/directory">Open directory</a>
    </div>
  </div>
  <div class="wf-footer-main">
  <div class="container">
    <div class="pro-footer-grid">
      <div class="pro-footer-col">
        <strong>GetPro</strong>
        <p style="margin:0;line-height:1.55;color:rgba(255,255,255,0.75);">
          Find vetted professionals and browse one-page business profiles in our directory.
        </p>
      </div>
      <div class="pro-footer-col">
        <strong>Directory</strong>
        <ul>
          <li><a href="<%= tp %>/directory">All listings</a></li>
          <li><a href="/admin/login">List your business</a></li>
        </ul>
      </div>
      <div class="pro-footer-col">
        <strong>Contact</strong>
        <ul>
          <% if (getproPhone) { %>
            <li><a href="tel:<%= getproPhone %>"><%= getproPhone %></a></li>
          <% } %>
          <% if (getproEmail) { %>
            <li><a href="mailto:<%= getproEmail %>"><%= getproEmail %></a></li>
          <% } %>
          <% if (getproAddress) { %>
            <li><%= getproAddress %></li>
          <% } %>
          <% if (!getproPhone && !getproEmail && !getproAddress) { %>
            <li style="color:rgba(255,255,255,0.55);">Configure contact details via environment variables.</li>
          <% } %>
        </ul>
      </div>
      <div class="pro-footer-col">
        <strong>Quality &amp; oversight</strong>
        <ul>
          <li><a href="<%= tp %>/directory">Browse by category</a></li>
          <li><a href="/admin/login">Partner login</a></li>
        </ul>
      </div>
    </div>
    <div class="pro-footer-bottom">
      <span>© <%= new Date().getFullYear() %> GetPro · getproapp.org</span>
      <span><a href="#footer-terms">Terms of use</a> · <a href="#">Accessibility</a> · <a href="<%= tp %>/directory">Site map</a></span>
    </div>
  </div>
  </div>
</footer>
