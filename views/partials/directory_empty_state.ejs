<% var _tp = typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : ''; %>
<% var _mode = typeof emptyStateMode !== 'undefined' ? emptyStateMode : 'directory'; %>
<% var _dirFeatOnly = typeof directoryFeaturedOnly !== 'undefined' && directoryFeaturedOnly; %>
<% var _toolbarId = typeof toolbarAnchorId !== 'undefined' && toolbarAnchorId ? String(toolbarAnchorId) : 'directory-toolbar'; %>
<% var _hasAltCats = typeof emptyAltCategories !== 'undefined' && emptyAltCategories && emptyAltCategories.length; %>
<% var _hasAltCities = typeof emptyAltCities !== 'undefined' && emptyAltCities && emptyAltCities.length; %>
<% 
  var q = String(typeof searchQuery !== 'undefined' && searchQuery ? searchQuery : '').trim();
  var city = String(typeof cityQuery !== 'undefined' && cityQuery ? cityQuery : '').trim();
  var catLabel = String(typeof activeCatLabel !== 'undefined' && activeCatLabel ? activeCatLabel : '').trim();
  var _catName = String(typeof categoryName !== 'undefined' && categoryName ? categoryName : '').trim();
  if (_mode === 'category' && !_catName && typeof category !== 'undefined' && category && category.name) {
    _catName = String(category.name).trim();
  }
  var _tenant = typeof tenant !== 'undefined' ? tenant : null;
  var _tid = _tenant && _tenant.id ? Number(_tenant.id) : 0;
  var _tslug = _tenant && _tenant.slug ? String(_tenant.slug) : '';
%>
<% var _es = (typeof ctaVoice !== 'undefined' && ctaVoice && ctaVoice.emptyState) ? ctaVoice.emptyState : {}; %>
<% var _sr = (typeof ctaVoice !== 'undefined' && ctaVoice && ctaVoice.searchRefinement) ? ctaVoice.searchRefinement : null; %>
<% var _fcb = (typeof ctaVoice !== 'undefined' && ctaVoice && ctaVoice.form && ctaVoice.form.contact && ctaVoice.form.contact.sending_loading) ? ctaVoice.form.contact.sending_loading : ((_es.callback_loading) ? _es.callback_loading : 'Sending request…'); %>
<% 
  var _title = '';
  var _body = '';
  var _ctaLabel = '';
  var _ctaHref = _tp + '/directory';
  var _showInlineCta = false;
  if (_dirFeatOnly && _mode === 'directory') {
    _title = (_es.no_featured && _es.no_featured.title) ? _es.no_featured.title : 'No featured service providers match';
    _body = (_es.no_featured && _es.no_featured.body) ? _es.no_featured.body : '';
    _ctaLabel = (_es.no_featured && _es.no_featured.cta) ? _es.no_featured.cta : '';
    _showInlineCta = !!_ctaLabel;
  } else if (_mode === 'category') {
    _title = (_es.no_category_results && _es.no_category_results.title) ? _es.no_category_results.title : 'No listings in this category yet';
    _body = (_es.no_category_results && _es.no_category_results.body) ? _es.no_category_results.body : '';
  } else if (q && city) {
    var _tic = (_es.no_service_in_city && _es.no_service_in_city.title) ? _es.no_service_in_city.title : 'No {service} found in {city}';
    _title = String(_tic).replace(/\{service\}/g, q).replace(/\{city\}/g, city);
    _body = (_es.no_results && _es.no_results.body) ? _es.no_results.body : '';
    _ctaLabel = (_es.no_results && _es.no_results.cta) ? _es.no_results.cta : '';
    _showInlineCta = !!_ctaLabel;
  } else if (q && !city) {
    var _tso = (_es.no_service_only && _es.no_service_only.title) ? _es.no_service_only.title : 'No results for {service}';
    _title = String(_tso).replace(/\{service\}/g, q);
    _body = (_es.no_results && _es.no_results.body) ? _es.no_results.body : '';
    _ctaLabel = (_es.no_results && _es.no_results.cta) ? _es.no_results.cta : '';
    _showInlineCta = !!_ctaLabel;
  } else if (!q && city && catLabel) {
    var _tcc = (_es.no_category_city && _es.no_category_city.title) ? _es.no_category_city.title : 'No {category} found in {city}';
    _title = String(_tcc).replace(/\{category\}/g, catLabel).replace(/\{city\}/g, city);
    _body = (_es.no_category_city && _es.no_category_city.body) ? _es.no_category_city.body : '';
    _ctaLabel = (_es.no_category_city && _es.no_category_city.cta) ? _es.no_category_city.cta : '';
    _showInlineCta = !!_ctaLabel;
  } else if (!q && city && !catLabel) {
    _title = (_es.no_city_results && _es.no_city_results.title) ? _es.no_city_results.title : 'No professionals found in ' + city;
    _body = (_es.no_city_results && _es.no_city_results.body) ? _es.no_city_results.body : '';
    _ctaLabel = (_es.no_city_results && _es.no_city_results.cta) ? _es.no_city_results.cta : '';
    _ctaHref = '#' + _toolbarId;
    _showInlineCta = !!_ctaLabel;
  } else if (!q && !city && catLabel) {
    var _twn = (_es.no_category_results && _es.no_category_results.title_with_name) ? _es.no_category_results.title_with_name : '';
    _title = _twn
      ? String(_twn).replace(/\{category\}/g, catLabel)
      : ((_es.no_category_results && _es.no_category_results.title) ? _es.no_category_results.title : ('No ' + catLabel + ' listings yet'));
    _body = (_es.no_category_results && _es.no_category_results.body) ? _es.no_category_results.body : '';
    _ctaLabel = (_es.no_category_results && _es.no_category_results.cta) ? _es.no_category_results.cta : '';
    _showInlineCta = !!_ctaLabel;
  } else {
    _title = (_es.no_results && _es.no_results.title) ? _es.no_results.title : 'No professionals found for your search';
    _body = (_es.no_results && _es.no_results.body) ? _es.no_results.body : '';
    _ctaLabel = (_es.no_results && _es.no_results.cta) ? _es.no_results.cta : '';
    _showInlineCta = !!_ctaLabel;
  }
%>
<% 
  var ctxParts = ['dir_nores'];
  if (_mode === 'category' && _catName) ctxParts.push('cat:' + _catName.replace(/\|/g, ' '));
  if (q) ctxParts.push('q:' + q.replace(/\|/g, ' '));
  if (city) ctxParts.push('city:' + city.replace(/\|/g, ' '));
  if (catLabel) ctxParts.push('lbl:' + catLabel.replace(/\|/g, ' '));
  var contextPayload = ctxParts.join('|').slice(0, 120);
  var interestPayload = '';
  if (_mode === 'category' && _catName) {
    interestPayload = ('Category — ' + _catName + ' — no listings').slice(0, 120);
  } else {
    var bits = [];
    if (q) bits.push(q);
    if (city) bits.push(city);
    if (catLabel) bits.push(catLabel);
    var tail = bits.join(' · ');
    interestPayload = (tail ? ('Directory — no match: ' + tail) : 'Directory — no match').slice(0, 120);
  }
%>
<div class="card pro-directory-empty pro-directory-empty--rich" role="status">
  <div class="pro-directory-empty__inner">
    <div id="directory-empty-message-block">
      <h2 class="pro-directory-empty__title"><%= _title %></h2>

    <% if (_body) { %>
      <p class="pro-directory-empty__hint pro-directory-empty__body muted"><%= _body %></p>
    <% } %>

    <% if (!_dirFeatOnly) { %>
    <p class="pro-directory-empty__hint muted"><%= (_es.lead_capture_hint) ? _es.lead_capture_hint : 'Leave your details and we&rsquo;ll help connect you with a suitable professional.' %></p>
    <% } %>

    <% if (_mode === 'directory' && _showInlineCta && _ctaLabel) { %>
    <p class="pro-directory-empty__primary-cta muted">
      <a href="<%= _ctaHref %>" class="pro-directory-empty__cta-link"><%= _ctaLabel %></a>
    </p>
    <% } %>

    <p class="pro-directory-empty__edit-search muted">
      <a class="pro-directory-empty__edit-search-link" href="#<%= _toolbarId %>"><%= (_es.jump_to_search) ? _es.jump_to_search : 'Jump to search' %></a>
      <%= (_es.jump_to_search_suffix) ? _es.jump_to_search_suffix : 'to change your filters.' %>
    </p>

    <% if (_sr && _sr.suggestions && _sr.suggestions.title && _sr.suggestions.examples && _sr.suggestions.examples.length) { %>
    <div class="pro-directory-empty__refine-suggestions muted" aria-label="Search ideas">
      <p class="pro-directory-empty__refine-suggestions-title"><%= _sr.suggestions.title %></p>
      <ul class="pro-directory-empty__refine-suggestions-list">
        <% _sr.suggestions.examples.forEach(function (ex) { %>
        <li><a href="<%= _tp %>/directory?q=<%= encodeURIComponent(ex) %>"><%= ex %></a></li>
        <% }); %>
      </ul>
    </div>
    <% } %>
    <% if (_sr && _sr.refinement_hints && _sr.refinement_hints.length) { %>
    <ul class="pro-directory-empty__refine-hints muted" aria-label="Refinement tips">
      <% _sr.refinement_hints.forEach(function (h) { %>
      <li><%= h %></li>
      <% }); %>
    </ul>
    <% } %>

    <% if (_mode === 'category' && (_hasAltCats || _hasAltCities)) { %>
    <div class="pro-directory-empty__suggestions" aria-label="Suggested searches">
      <p class="pro-directory-empty__suggestions-label muted">Try also</p>
      <div class="pro-directory-empty__suggestion-chips">
        <% if (_hasAltCats) { %>
          <% emptyAltCategories.forEach(function (cat) { %>
            <a class="pro-directory-empty__chip" href="<%= _tp %>/directory?category=<%= encodeURIComponent(cat.slug) %>"><%= cat.name %></a>
          <% }); %>
        <% } %>
        <% if (_hasAltCities) { %>
          <% emptyAltCities.forEach(function (cityName) { %>
            <a class="pro-directory-empty__chip" href="<%= _tp %>/directory?city=<%= encodeURIComponent(cityName) %>"><%= cityName %></a>
          <% }); %>
        <% } %>
      </div>
    </div>
    <% } %>

    <% if (_mode === 'directory' && (q || city || catLabel)) { %>
      <div class="pro-directory-empty__summary muted" aria-label="Current search">
        <% if (q) { %><span class="pro-directory-empty__summary-item"><span class="pro-directory-empty__summary-k">Service</span> <span class="pro-directory-empty__summary-v"><%= q %></span></span><% } %>
        <% if (city) { %><span class="pro-directory-empty__summary-item"><span class="pro-directory-empty__summary-k">City</span> <span class="pro-directory-empty__summary-v"><%= city %></span></span><% } %>
        <% if (catLabel) { %><span class="pro-directory-empty__summary-item"><span class="pro-directory-empty__summary-k">Category</span> <span class="pro-directory-empty__summary-v"><%= catLabel %></span></span><% } %>
      </div>
    <% } else if (_mode === 'category' && _catName) { %>
      <div class="pro-directory-empty__summary muted" aria-label="Category">
        <span class="pro-directory-empty__summary-item"><span class="pro-directory-empty__summary-k">Category</span> <span class="pro-directory-empty__summary-v"><%= _catName %></span></span>
      </div>
    <% } %>
    </div>

    <% if (_tid > 0 && _tslug) { %>
    <form
      id="directory-empty-callback-form"
      class="pro-directory-empty__callback"
      data-tenant-id="<%= _tid %>"
      data-tenant-slug="<%= _tslug %>"
      novalidate
    >
      <input type="hidden" name="context" value="<%= contextPayload %>" />
      <input type="hidden" name="interest_label" value="<%= interestPayload %>" />
      <div class="pro-directory-empty__callback-panel" id="directory-empty-callback-panel">
        <%- include('components/loading_block', {
          id: 'directory-empty-callback-loading',
          message: _fcb,
          hidden: true,
          compact: true,
          extraClass: 'pro-directory-empty__callback-loading'
        }) %>
        <div class="form-step">
          <div class="form-step__body">
            <div class="join-modal-fields pro-directory-empty__fields input-field">
              <label class="join-modal-label input-field__label" for="directory-empty-callback-name">Full name</label>
              <input
                class="join-plain-input join-modal-input input-field__control"
                id="directory-empty-callback-name"
                name="name"
                type="text"
                autocomplete="name"
                maxlength="120"
                required
              />
              <label class="join-modal-label input-field__label" for="directory-empty-callback-phone">Phone number</label>
              <input
                class="join-plain-input join-modal-input input-field__control"
                id="directory-empty-callback-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                maxlength="40"
                required
              />
            </div>
            <p class="join-modal-error input-field__error status-message status-message--error" id="directory-empty-callback-error" hidden role="alert"></p>
          </div>
          <div class="form-step__actions">
            <div class="join-modal-actions pro-directory-empty__callback-actions">
              <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Request a call', id: 'directory-empty-callback-submit' }) %>
            </div>
          </div>
        </div>
      </div>
      <div class="pro-directory-empty__callback-success state-block state-block--success" id="directory-empty-callback-success" hidden role="status" tabindex="-1">
        <h2 class="pro-directory-empty__title pro-directory-empty__callback-success-title state-block__title">Request received</h2>
        <p class="pro-directory-empty__callback-success-lead state-block__body">Thanks—we&rsquo;ve received your details.</p>
        <p class="pro-directory-empty__callback-success-muted state-block__body state-block__body--muted muted">We shall call back, soon</p>
      </div>
    </form>
    <% } %>

    <% if (_mode === 'category') { %>
    <div class="pro-directory-empty__actions" id="directory-empty-footer-actions">
      <%- include('components/button', { variant: 'text', href: _tp + '/directory', label: ((_es.no_category_results && _es.no_category_results.cta) ? _es.no_category_results.cta : 'All categories') }) %>
      <%- include('components/button', { variant: 'secondary', href: '#' + _toolbarId, label: (_es.refine_search) ? _es.refine_search : 'Refine search' }) %>
    </div>
    <% } %>
  </div>
</div>
