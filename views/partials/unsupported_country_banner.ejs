<% if (typeof showUnsupportedCountryBanner !== 'undefined' && showUnsupportedCountryBanner) { %>
<div class="gp-geo-coming-soon-banner" role="region" aria-label="Regional availability">
  <div class="ds-container gp-geo-coming-soon-banner__inner">
    <p class="gp-geo-coming-soon-banner__text">
      Full service in your country is coming soon. You can still browse our provider directory below.
    </p>
    <button type="button" class="c-button btn btn--secondary gp-geo-coming-soon-banner__join" data-wf-join-us-open>
      Join Us
    </button>
  </div>
</div>
<% } %>
