<%#
  Shared monthly statement content (frozen snapshot). Expects:
  - detail: object from buildStatementDetailFromSnapshotRow
  - tenantRegionLabel: optional string (region / tenant display)
  - showTenantLine: boolean
%>
<% if (typeof detail !== 'undefined' && detail) { %>
<section class="fa-statement-doc">
  <% if (typeof omitDocumentTitle === 'undefined' || !omitDocumentTitle) { %>
  <h1 class="fa-statement-doc__title">Monthly statement</h1>
  <% } %>
  <% if (typeof showTenantLine !== 'undefined' && showTenantLine && typeof tenantRegionLabel === 'string' && tenantRegionLabel) { %>
    <p class="fa-statement-doc__meta"><strong>Region:</strong> <%= tenantRegionLabel %></p>
  <% } %>
  <p class="fa-statement-doc__meta"><strong>Field agent:</strong> <%= detail.fieldAgentName || '—' %></p>
  <p class="fa-statement-doc__meta"><strong>Period:</strong> <%= detail.periodLabel %></p>
  <p class="fa-statement-doc__meta">
    <strong>Status:</strong>
    <% if (detail.status === 'approved') { %>Approved for processing<% } else if (detail.status === 'paid') { %>Marked as paid<% } else if (detail.status === 'draft') { %>Draft snapshot<% } else if (detail.status === 'locked') { %>Locked — values frozen<% } else { %><%= detail.status %><% } %>
  </p>
  <% if (detail.approvedAt) { %>
    <p class="fa-statement-doc__muted">Approved <%= new Date(detail.approvedAt).toLocaleString() %></p>
  <% } %>
  <% if (detail.paidAt) { %>
    <p class="fa-statement-doc__muted">Paid (record) <%= new Date(detail.paidAt).toLocaleString() %></p>
  <% } %>

  <p class="fa-statement-doc__disclaimer">This statement is based on a frozen pay-run snapshot. Rolling dashboard estimates may differ.</p>

  <h2 class="fa-statement-doc__h2">Amounts (snapshot)</h2>
  <dl class="fa-statement-doc__dl">
    <div class="fa-statement-doc__row"><dt>Earned SP commission</dt><dd><%= detail.earnedSpDisplay %></dd></div>
    <div class="fa-statement-doc__row"><dt>SP high-rating bonus</dt><dd><%= detail.spBonusDisplay %></dd></div>
    <div class="fa-statement-doc__row"><dt>SP withheld</dt><dd><%= detail.spWithheldDisplay %></dd></div>
    <div class="fa-statement-doc__row"><dt>SP payable</dt><dd><%= detail.spPayableDisplay %></dd></div>
    <div class="fa-statement-doc__row"><dt>Earned EC commission</dt><dd><%= detail.earnedEcDisplay %></dd></div>
    <div class="fa-statement-doc__row"><dt>EC withheld</dt><dd><%= detail.ecWithheldDisplay %></dd></div>
    <div class="fa-statement-doc__row"><dt>EC payable</dt><dd><%= detail.ecPayableDisplay %></dd></div>
    <div class="fa-statement-doc__row"><dt>Recruitment commission</dt><dd><%= detail.recruitmentDisplay %></dd></div>
    <div class="fa-statement-doc__row fa-statement-doc__row--total"><dt>Base payable (SP + EC + recruitment)</dt><dd><%= typeof detail.basePayableTotalDisplay !== 'undefined' ? detail.basePayableTotalDisplay : detail.totalPayableDisplay %></dd></div>
  </dl>

  <% if (typeof detail.appliedAdjustmentCount !== 'undefined' && detail.appliedAdjustmentCount > 0) { %>
  <h2 class="fa-statement-doc__h2">Applied adjustments</h2>
  <p class="fa-statement-doc__muted">Adjustments are recorded separately and carried into this pay run. They do not change the original component lines above.</p>
  <dl class="fa-statement-doc__dl">
    <div class="fa-statement-doc__row"><dt>Applied adjustments<% if (detail.adjustmentSummaryLabel) { %> (<%= detail.adjustmentSummaryLabel %>)<% } %></dt><dd><%= detail.appliedAdjustmentsDisplay %></dd></div>
    <div class="fa-statement-doc__row fa-statement-doc__row--total"><dt>Net payable</dt><dd><%= detail.netPayableDisplay %></dd></div>
  </dl>
  <% } else { %>
  <dl class="fa-statement-doc__dl" style="margin-top:0.5rem;">
    <div class="fa-statement-doc__row fa-statement-doc__row--total"><dt>Net payable</dt><dd><%= detail.netPayableDisplay %></dd></div>
  </dl>
  <% } %>

  <% if (detail.qualityStatusLabelSp || detail.qualityStatusLabelEc) { %>
  <h2 class="fa-statement-doc__h2">Quality labels (snapshot)</h2>
  <p class="fa-statement-doc__muted">SP: <%= detail.qualityStatusLabelSp || '—' %> · EC: <%= detail.qualityStatusLabelEc || '—' %></p>
  <% } %>
</section>
<% } %>
