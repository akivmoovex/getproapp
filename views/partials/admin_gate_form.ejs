<% var _cancel = typeof cancelHref !== 'undefined' && cancelHref != null && String(cancelHref).trim() !== '' ? cancelHref : '/login'; %>
<% var _action = typeof formAction !== 'undefined' ? formAction : '/admin/login'; %>
<% var _gateErr = typeof error !== 'undefined' && error != null && String(error).trim() !== '' ? String(error).trim() : ''; %>
<% if (_gateErr) { %>
  <div class="flash" role="alert"><%= _gateErr %></div>
<% } %>
<form method="post" action="<%= _action %>" class="form admin-gate-form">
  <div class="form-step form-step--admin">
    <div class="form-step__body">
      <%- include('components/input', {
        id: 'admin_gate_username',
        name: 'username',
        type: 'text',
        label: 'Username',
        required: true,
        autocomplete: 'username',
      }) %>
      <%- include('components/input', {
        id: 'admin_gate_password',
        name: 'password',
        type: 'password',
        label: 'Password',
        required: true,
        autocomplete: 'current-password',
      }) %>
    </div>
    <div class="form-step__actions admin-gate-actions">
      <%- include('components/button', { variant: 'primary', type: 'submit', label: 'Login' }) %>
      <%- include('components/button', { variant: 'text', href: _cancel, label: 'Cancel' }) %>
    </div>
  </div>
</form>
