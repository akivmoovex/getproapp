<% 
  const _adminBn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online';
  const nav = typeof adminNav !== 'undefined' ? adminNav : {};
  const isViewer = !!nav.isViewer;
  const isSuper = !!nav.isSuper;
  const canEdit = !!nav.canEditDirectory;
  const canUsers = !!nav.canManageUsers;
  const canCrm = !!nav.canAccessCrm;
  const canProjectIntake = !!nav.canAccessProjectIntake;
  const canSettings = !!nav.canAccessTenantSettings;
  const canHub = !!nav.canAccessSettingsHub;
  const scoped = !!nav.tenantScoped;
  const title = typeof navTitle !== 'undefined' ? navTitle : '';
  const scopeTenant = typeof adminScopeTenant !== 'undefined' && adminScopeTenant ? adminScopeTenant : null;
  const regionSwitch = typeof adminRegionSwitch !== 'undefined' && adminRegionSwitch ? adminRegionSwitch : null;
  const isEmbed = typeof embed !== 'undefined' && embed;
%>
<% if (!isEmbed) { %>
<header class="admin-header" role="banner">
  <div class="container admin-header__inner">
    <div class="admin-header__top">
      <a href="/admin/dashboard" class="admin-header__brand">
        <div class="logo" aria-hidden="true"></div>
        <span class="admin-header__brand-text">
          <span class="admin-header__product"><%= _adminBn %></span>
          <span class="admin-header__badge">Admin</span>
        </span>
      </a>
      <% if (title) { %>
        <p class="admin-header__subtitle"><%= title %></p>
      <% } %>
    </div>
    <% if (isSuper && scopeTenant) { %>
    <div class="admin-scope-banner" role="status">
      <div class="admin-scope-banner__text">
        <span>Directory data: <strong><%= scopeTenant.name %></strong> <span class="admin-scope-banner__slug">(<%= scopeTenant.slug %>)</span></span>
        <% if (typeof adminScopeIsSession !== 'undefined' && !adminScopeIsSession) { %>
          <span class="admin-scope-banner__hint">Default region — switch in Super admin if you need another tenant.</span>
        <% } %>
      </div>
      <a class="admin-scope-banner__link" href="/admin/super#act-as-region">Change region</a>
    </div>
    <% } %>
    <% if (!isSuper && regionSwitch && regionSwitch.options && regionSwitch.options.length > 1) { %>
    <div class="admin-scope-banner admin-scope-banner--tenant" role="region">
      <form method="post" action="/admin/tenant-scope" class="admin-region-switch">
        <% if (isEmbed) { %><input type="hidden" name="embed" value="1" /><% } %>
        <label class="admin-region-switch__label" for="admin-region-select">Region</label>
        <select id="admin-region-select" name="tenant_id" class="admin-region-switch__select" aria-label="Switch region">
          <% regionSwitch.options.forEach(function (opt) { %>
            <option value="<%= opt.id %>" <%= Number(regionSwitch.currentId) === Number(opt.id) ? 'selected' : '' %>><%= opt.name %> (<%= opt.slug %>)</option>
          <% }); %>
        </select>
        <%- include('components/button', { variant: 'default', type: 'submit', label: 'Switch', className: 'admin-region-switch__btn' }) %>
      </form>
    </div>
    <% } %>
    <nav class="admin-nav" aria-label="Admin navigation">
      <% if (isSuper) { %>
        <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'super' ? 'admin-nav__link--active' : '' %>" href="/admin/super">Super</a>
        <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'super_users' ? 'admin-nav__link--active' : '' %>" href="/admin/super/users">All users</a>
      <% } %>
      <% if (scoped) { %>
        <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'dashboard' ? 'admin-nav__link--active' : '' %>" href="/admin/dashboard">Dashboard</a>
        <% if (isViewer || canEdit || canCrm) { %>
          <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'leads' ? 'admin-nav__link--active' : '' %>" href="/admin/leads">Leads</a>
        <% } %>
        <% if (canProjectIntake) { %>
          <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'project_intake' ? 'admin-nav__link--active' : '' %>" href="/admin/project-intake">New project</a>
          <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'projects' ? 'admin-nav__link--active' : '' %>" href="/admin/projects">Projects</a>
          <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && (activeNav === 'client_lead_status' || activeNav === 'project_status') ? 'admin-nav__link--active' : '' %>" href="/admin/client-lead-status">Client Lead Status</a>
        <% } %>
        <% if (canCrm) { %>
          <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'crm' ? 'admin-nav__link--active' : '' %>" href="/admin/crm">CRM</a>
          <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'field_agent_analytics' ? 'admin-nav__link--active' : '' %>" href="/admin/field-agent-analytics">Field agents</a>
        <% } %>
        <% if (scoped) { %>
          <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'articles' ? 'admin-nav__link--active' : '' %>" href="/admin/content?kind=article&edit=1">Articles</a>
        <% } %>
        <% if (canHub) { %>
          <a class="admin-nav__link <%= typeof activeNav !== 'undefined' && activeNav === 'settings' ? 'admin-nav__link--active' : '' %>" href="/admin/settings">Settings</a>
        <% } %>
      <% } %>
      <form method="post" action="/admin/logout" class="admin-nav__logout">
        <%- include('components/button', { variant: 'default', type: 'submit', label: 'Logout', className: 'admin-nav__btn' }) %>
      </form>
    </nav>
  </div>
</header>
<% } %>
