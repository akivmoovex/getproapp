<!doctype html>
<% var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof htmlDir !== 'undefined' ? htmlDir : 'ltr' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/seo_meta', {
      seoTitle: typeof seoTitle !== 'undefined' ? seoTitle : ('Directory | ' + _bn),
      seoDescription: typeof seoDescription !== 'undefined' ? seoDescription : ('Browse verified professionals on ' + _bn + '.'),
      canonicalUrl: typeof canonicalUrl !== 'undefined' ? canonicalUrl : '',
      ogUrl: typeof ogUrl !== 'undefined' ? ogUrl : '',
      ogImage: typeof ogImage !== 'undefined' ? ogImage : '',
      ogType: typeof ogType !== 'undefined' && ogType ? ogType : 'website',
      noindex: typeof noindex !== 'undefined' && noindex,
      hreflangAlternates: typeof hreflangAlternates !== 'undefined' ? hreflangAlternates : []
    }) %>
    <% if (typeof jsonLdDirectory !== 'undefined' && jsonLdDirectory) { %>
    <script type="application/ld+json"><%- jsonLdDirectory %></script>
    <% } %>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="<%= tenant.themeClass %>" data-screen-role="results">
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix }) %>

      <div class="app-layout__main">
        <%- include('partials/unsupported_country_banner') %>
        <%- include('partials/components/container_start', { extraClass: 'directory-page directory-page-toolbar' }) %>
      <% if (typeof directoryPageH1 !== 'undefined' && directoryPageH1) { %>
        <h1 class="section-title section-title--flush" style="margin-bottom: 0.75rem; font-size: clamp(1.25rem, 2.5vw, 1.5rem)"><%= directoryPageH1 %></h1>
      <% } %>
      <% var activeCatLabel = ''; %>
      <% if (typeof selectedCategory !== 'undefined' && selectedCategory) { %>
        <% (categories || []).forEach(function(c) { if (c.slug === selectedCategory) activeCatLabel = c.name; }); %>
      <% } %>
      <div class="pro-directory-top-band">
        <div class="pro-directory-toolbar">
          <div id="site-search-bar" class="c-search-bar-shell gp-home-search gp-home-search-card" aria-label="Directory search">
          <%- include('partials/pro_search_form', {
            variant: 'directory',
            tenantUrlPrefix,
            searchQuery: typeof searchQuery !== 'undefined' ? searchQuery : '',
            cityQuery: typeof cityQuery !== 'undefined' ? cityQuery : '',
            showCategoryFilter: false,
            selectedCategory: typeof selectedCategory !== 'undefined' ? selectedCategory : '',
            categories: typeof categories !== 'undefined' ? categories : [],
            preserveDirectoryFeatured: typeof directoryFeaturedOnly !== 'undefined' && directoryFeaturedOnly,
          }) %>
          </div>
          <div class="pro-directory-toolbar__meta" aria-live="polite">
            <span class="pro-directory-toolbar__count">
              <strong><%= (companies || []).length %></strong>
              <%= (companies || []).length === 1 ? 'result' : 'results' %>
            </span>
            <span class="pro-directory-toolbar__filters">
              <% if (activeCatLabel) { %>
                <span class="pro-directory-toolbar__chip"><%= activeCatLabel %></span>
              <% } %>
              <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                <span class="pro-directory-toolbar__chip">“<%= searchQuery %>”</span>
              <% } %>
              <% if (typeof cityQuery !== 'undefined' && cityQuery) { %>
                <span class="pro-directory-toolbar__chip"><%= cityQuery %></span>
              <% } %>
              <% if (!activeCatLabel && !(typeof searchQuery !== 'undefined' && searchQuery) && !(typeof cityQuery !== 'undefined' && cityQuery)) { %>
                <span class="pro-directory-toolbar__hint muted">Browse trusted professionals in your area</span>
              <% } %>
            </span>
          </div>
        </div>
        <% if ((companies || []).length > 0) { %>
        <p class="pro-directory-results-helper" role="note">Browse trusted professionals in your area. Click on card to view more details.</p>
        <% } %>
      </div>

      <%- include('partials/refine_search_fab', { toolbarAnchorId: 'directory-toolbar' }) %>

      <div class="pro-directory-main">
        <% if ((companies || []).length === 0) { %>
          <%- include('partials/directory_empty_state', {
            tenantUrlPrefix,
            tenant,
            emptyStateMode: 'directory',
            directoryFeaturedOnly: typeof directoryFeaturedOnly !== 'undefined' && directoryFeaturedOnly,
            searchQuery: typeof searchQuery !== 'undefined' ? searchQuery : '',
            cityQuery: typeof cityQuery !== 'undefined' ? cityQuery : '',
            selectedCategory: typeof selectedCategory !== 'undefined' ? selectedCategory : '',
            activeCatLabel: activeCatLabel,
            toolbarAnchorId: 'directory-toolbar',
            emptyAltCategories: typeof emptyAltCategories !== 'undefined' ? emptyAltCategories : [],
            emptyAltCities: typeof emptyAltCities !== 'undefined' ? emptyAltCities : [],
          }) %>
        <% } else { %>
          <%- include('partials/directory_company_cards', { companies, baseDomain, companyMiniSiteHref }) %>
        <% } %>
      </div>
        <%- include('partials/components/container_close') %>

        <%- include('partials/site_footer', { tenantUrlPrefix }) %>
      </div>
    </div>
    <script src="<%= asset('scripts') %>" defer></script>
    <%- include('partials/theme_prefs') %>
    <%- include('partials/autocomplete_defer_bootstrap') %>
    <% if ((companies || []).length === 0) { %>
    <script>
      window.__GETPRO_PHONE_RULES__ = <%- JSON.stringify(typeof phoneRulesPublic !== 'undefined' ? phoneRulesPublic : { strict: false, regex: null, normalizationMode: 'generic_digits', regexBroken: false }) %>;
    </script>
    <script src="<%= asset('directory-empty-callback') %>" defer></script>
    <% } %>
  </body>
</html>
