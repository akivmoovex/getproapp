<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Directory | GetPro</title>
    <link rel="stylesheet" href="/styles.css?v=20260320g" />
  </head>
  <body>
    <%- include('partials/site_header') %>

    <div class="container" style="padding: 20px 0 8px;">
      <form class="pro-search pro-search--directory" action="/directory" method="get" role="search" style="max-width:100%;margin-bottom:20px;">
        <input type="search" name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" placeholder="Field: Electrician, Plumber…" />
        <input type="search" name="city" value="<%= typeof cityQuery !== 'undefined' ? cityQuery : '' %>" placeholder="City: Lusaka, Kafue…" />
        <button type="submit" class="pro-search-dir-btn">
          <span>Search professional</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="m21 21-4.3-4.3" />
          </svg>
        </button>
      </form>
      <div style="margin:0 0 18px;">
        <div class="section-title" style="margin-top:0;">
          <% if (selectedCategory) { %>
            Category: <%= selectedCategory %>
          <% } else if ((typeof searchQuery !== 'undefined' && searchQuery) || (typeof cityQuery !== 'undefined' && cityQuery)) { %>
            Search
            <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>: “<%= searchQuery %>”<% } %>
            <% if (typeof cityQuery !== 'undefined' && cityQuery) { %><% if (typeof searchQuery !== 'undefined' && searchQuery) { %> · <% } else { %>: <% } %>City: <%= cityQuery %><% } %>
          <% } else { %>
            Browse categories
          <% } %>
        </div>
      </div>

      <div class="hero-grid" style="grid-template-columns: 0.9fr 1.1fr;">
        <div class="card">
          <div style="font-weight:900;margin-bottom:12px;">Categories</div>
          <div class="list">
            <a href="/directory" class="btn" style="justify-content:flex-start;width:100%;">All</a>
            <% categories.forEach(function(cat) { %>
              <a
                href="/directory?category=<%= cat.slug %>"
                class="btn"
                style="justify-content:flex-start;width:100%;<%= selectedCategory === cat.slug ? 'border-color:var(--wf-primary);background:var(--primary-soft-bg);' : '' %>"
              >
                <%= cat.name %>
              </a>
            <% }) %>
          </div>
        </div>

        <div>
          <div class="list">
            <% if (companies.length === 0) { %>
              <div class="card">No companies found.</div>
            <% } else { %>
              <% companies.forEach(function(c) { %>
                <a class="card" href="<%= buildCompanyUrl({ baseDomain: baseDomain, subdomain: c.subdomain }) %>" target="_blank" rel="noreferrer" style="display:block;">
                  <div class="row-between" style="gap:8px;">
                    <div style="font-weight:900;font-size:16px;"><%= c.name %></div>
                    <div class="muted" style="font-size:12px;">@<%= c.subdomain %></div>
                  </div>
                  <% if (c.headline) { %>
                    <div class="muted" style="margin-top:6px;line-height:1.5;"><%= c.headline %></div>
                  <% } %>
                </a>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/site_footer') %>
    <script src="/scripts.js"></script>
  </body>
</html>

