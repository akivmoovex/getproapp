<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Edit admin user | Super</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app">
    <%- include('../partials/admin_nav', { navTitle: 'Edit user (any tenant)', activeNav: 'super_users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% if (error) { %>
        <div class="flash" role="alert"><%= error %></div>
      <% } %>

      <div class="card admin-form-card">
        <form method="post" action="/admin/super/users/<%= user.id %>" class="form">
          <div>
            <label for="se_username">Username</label>
            <input id="se_username" name="username" value="<%= user.username %>" autocomplete="username" required />
          </div>
          <div>
            <label for="se_password">New password (optional)</label>
            <input id="se_password" name="password" type="password" autocomplete="new-password" minlength="8" />
            <div class="muted" style="margin-top:6px;font-size:12px;">Leave blank to keep current hash. Min 8 characters if set.</div>
          </div>
          <div>
            <label for="se_role">Role</label>
            <select id="se_role" name="role">
              <% (roles || []).forEach(function(r) { %>
                <option value="<%= r %>" <%= user.role === r ? 'selected' : '' %>><%= r %></option>
              <% }) %>
            </select>
          </div>

          <div class="super-user-tenant-block" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
            <div>
              <label for="tenant_name_display">Tenant name</label>
              <input
                id="tenant_name_display"
                type="text"
                readonly
                tabindex="-1"
                value="<%= typeof currentTenantLabel !== 'undefined' ? currentTenantLabel : '—' %>"
                style="background:var(--bg);color:var(--text);cursor:default;"
                aria-describedby="tenant-assign-hint"
              />
            </div>
            <div style="margin-top:12px;">
              <label for="se_tenant">Assign or change tenant</label>
              <select id="se_tenant" name="tenant_id">
                <option value="" <%= user.tenant_id == null ? 'selected' : '' %>>— None (super admin only) —</option>
                <% (tenants || []).forEach(function(t) { %>
                  <option
                    value="<%= t.id %>"
                    data-tenant-name="<%= t.name %>"
                    data-tenant-slug="<%= t.slug %>"
                    <%= user.tenant_id === t.id ? 'selected' : '' %>
                  ><%= t.name %> — <%= t.slug %> · <%= t.stage %></option>
                <% }) %>
              </select>
              <p id="tenant-assign-hint" class="muted" style="margin-top:8px;font-size:12px;line-height:1.5;">
                Super admin: leave <strong>None</strong>. Other roles must belong to a tenant. You can move this user to any tenant.
              </p>
            </div>
          </div>

          <div>
            <label class="form-check">
              <input type="checkbox" name="enabled" value="1" <%= user.enabled !== 0 ? 'checked' : '' %> />
              Account enabled
            </label>
          </div>
          <div class="admin-gate-actions">
            <button class="btn btn-primary" type="submit">Save</button>
            <a class="btn" href="/admin/super/users">Cancel</a>
          </div>
        </form>

        <% if (typeof currentUserId !== 'undefined' && user.id !== currentUserId) { %>
        <form method="post" action="/admin/super/users/<%= user.id %>/delete" style="margin-top:22px;" onsubmit="return confirm('Delete this user?');">
          <button class="btn" type="submit" style="border-color: var(--flash-error-border); color: var(--flash-error-text);">Delete user</button>
        </form>
        <% } %>
      </div>
      </div>
    </main>
    <script>
      (function () {
        var sel = document.getElementById("se_tenant");
        var display = document.getElementById("tenant_name_display");
        if (!sel || !display) return;
        function sync() {
          var opt = sel.options[sel.selectedIndex];
          if (!opt || !sel.value) {
            display.value = "— (super admin — no tenant)";
            return;
          }
          var n = opt.getAttribute("data-tenant-name") || "";
          var s = opt.getAttribute("data-tenant-slug") || "";
          display.value = n ? n + " (" + s + ")" : opt.textContent;
        }
        sel.addEventListener("change", sync);
        sync();
      })();
    </script>
  </body>
</html>
