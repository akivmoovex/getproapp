<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= company.name %> · Mini-site | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app admin-workspace-page<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Mini-site editor', activeNav: 'companies' }) %>
    <main class="admin-main admin-workspace">
      <div class="container admin-workspace__shell-wrap">
        <div class="admin-workspace__shell">
        <div class="admin-workspace__toolbar" role="toolbar" aria-label="Mini-site actions">
          <div class="admin-workspace__toolbar-left">
            <%- include('../partials/components/button', { variant: 'default', href: '/admin/companies?edit=1', label: '← Back' }) %>
            <%- include('../partials/components/button', { variant: 'default', href: '/admin/companies/' + company.id + '/portal-users', label: 'Portal logins' }) %>
            <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Edit', hidden: true, className: 'admin-workspace__btn-edit u-hidden' }) %>
            <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Preview', hidden: true, className: 'admin-workspace__btn-preview u-hidden' }) %>
            <%- include('../partials/components/button', { variant: 'default', type: 'button', label: 'Close', hidden: true, className: 'admin-workspace__btn-close u-hidden' }) %>
            <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Publish', hidden: true, className: 'admin-workspace__btn-publish u-hidden' }) %>
            <%- include('../partials/components/button', { variant: 'default', type: 'button', label: 'Back to edit', hidden: true, className: 'admin-workspace__btn-back-edit u-hidden' }) %>
            <span class="admin-workspace__toolbar-meta muted">
              <span class="kbd"><%= typeof miniSiteLabel !== 'undefined' && miniSiteLabel ? miniSiteLabel : company.subdomain %></span>
            </span>
          </div>
        </div>

        <% if (typeof portalCreditUiActive !== 'undefined' && portalCreditUiActive) { %>
        <%- include('../partials/admin_company_portal_credits', {
          company,
          portalCreditBlocked,
          portalCreditBalance,
          recentLedgerEntries,
          paymentMethodOptions,
          defaultPaymentDate,
          portalCreditNotice,
          portalCreditError,
        }) %>
        <% } %>

        <div class="admin-workspace__stage">
          <div class="admin-workspace__preview-wrap" data-ws-preview-wrap>
            <iframe
              class="admin-workspace__iframe"
              title="Mini-site preview"
              data-ws-iframe
              src="<%= previewFramePath %>"
            ></iframe>
          </div>

          <div class="admin-workspace__edit card admin-form-card" data-ws-edit-panel hidden>
            <h2 class="admin-workspace__edit-title">Edit mini-site content</h2>
            <p class="muted admin-workspace__edit-lead">
              Use the table below, then <strong>Preview</strong> to see the mini-site layout with your unsaved changes.
              <strong>Publish</strong> saves to the live mini-site (after preview). Customer reviews and ratings are not edited here.
            </p>

            <div class="admin-workspace__table-wrap">
              <table class="admin-workspace__table">
                <tbody>
                  <tr>
                    <th scope="row">Company name</th>
                    <td><input type="text" class="input-grow" data-f="name" required /></td>
                  </tr>
                  <tr>
                    <th scope="row">Subdomain (URL path)</th>
                    <td><input type="text" class="input-grow" data-f="subdomain" required /></td>
                  </tr>
                  <tr>
                    <th scope="row">Category</th>
                    <td>
                      <select data-f="category_id">
                        <option value="">Uncategorized</option>
                        <% categories.forEach(function(cat) { %>
                          <option value="<%= cat.id %>"><%= cat.name %></option>
                        <% }) %>
                      </select>
                    </td>
                  </tr>
                  <tr>
                    <th scope="row">Logo URL</th>
                    <td><input type="text" class="input-grow" data-f="logo_url" placeholder="https://…" /></td>
                  </tr>
                  <tr>
                    <th scope="row">Headline</th>
                    <td><input type="text" class="input-grow" data-f="headline" /></td>
                  </tr>
                  <tr>
                    <th scope="row">About</th>
                    <td><textarea data-f="about" rows="4"></textarea></td>
                  </tr>
                  <tr>
                    <th scope="row">Services (one per line)</th>
                    <td><textarea data-f="services" rows="4"></textarea></td>
                  </tr>
                  <tr>
                    <th scope="row">Phone</th>
                    <td><input type="text" class="input-grow" data-f="phone" /></td>
                  </tr>
                  <tr>
                    <th scope="row">Email</th>
                    <td>
                      <input type="text" class="input-grow" data-f="email" inputmode="email" autocomplete="email" />
                      <div class="muted admin-workspace__form-hint">Use a real address customers can reply to (e.g. name@business.com).</div>
                    </td>
                  </tr>
                  <tr>
                    <th scope="row">Location / address</th>
                    <td><input type="text" class="input-grow" data-f="location" /></td>
                  </tr>
                  <tr>
                    <th scope="row">Years in business</th>
                    <td><input type="number" min="0" max="999" data-f="years_experience" /></td>
                  </tr>
                  <tr>
                    <th scope="row">Service areas</th>
                    <td><textarea data-f="service_areas" rows="3"></textarea></td>
                  </tr>
                  <tr>
                    <th scope="row">Hours</th>
                    <td><textarea data-f="hours_text" rows="3"></textarea></td>
                  </tr>
                  <tr>
                    <th scope="row">CTA label</th>
                    <td><input type="text" class="input-grow" data-f="featured_cta_label" /></td>
                  </tr>
                  <tr>
                    <th scope="row">CTA phone</th>
                    <td><input type="text" class="input-grow" data-f="featured_cta_phone" /></td>
                  </tr>
                  <tr>
                    <th scope="row">Pictures (URLs)</th>
                    <td>
                      <textarea data-f="gallery_text" rows="6" placeholder="https://…|caption"></textarea>
                      <div class="muted admin-workspace__form-hint">One per line. Optional caption after |</div>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        </div>
      </div>
    </main>

    <div
      id="ws_leave_modal"
      class="m3-modal-overlay admin-workspace-leave-m3"
      data-ws-dialog
      hidden
      aria-hidden="true"
    >
      <div class="m3-modal-overlay__backdrop" data-ws-dialog-dismiss tabindex="-1"></div>
      <div class="m3-modal m3-modal--workspace-confirm" role="dialog" aria-modal="true" aria-labelledby="ws_leave_modal_title">
        <div class="m3-modal__body admin-workspace-leave-m3__body">
          <h2 id="ws_leave_modal_title" class="admin-workspace-leave-m3__title">You’ve started editing this mini-site. Are you sure you want to leave?</h2>
          <p class="muted admin-workspace-leave-m3__desc">
            Leave discards unsaved changes and returns to the saved preview. Cancel keeps you in edit mode.
          </p>
        </div>
        <div class="m3-modal__footer">
          <%- include('../partials/components/button', { variant: 'default', type: 'button', label: 'Cancel' }) %>
          <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Leave' }) %>
        </div>
      </div>
    </div>

    <div
      id="ws_publish_overlay"
      class="m3-modal-overlay admin-workspace-busy-m3"
      data-ws-overlay
      hidden
      aria-hidden="true"
    >
      <div class="m3-modal-overlay__backdrop"></div>
      <div class="m3-modal m3-modal--workspace-busy" role="alertdialog" aria-live="polite" aria-busy="true">
        <div class="m3-modal__body m3-modal__body--workspace-busy">
          <div class="admin-workspace__hourglass" aria-hidden="true">
            <span class="admin-workspace__hourglass-inner">⏳</span>
          </div>
          <div class="admin-workspace__overlay-text">Publishing mini-site…</div>
        </div>
      </div>
    </div>

    <% 
      var wsCompany = {
        id: company.id,
        name: company.name,
        subdomain: company.subdomain,
        category_id: company.category_id,
        headline: company.headline,
        about: company.about,
        services: company.services,
        phone: company.phone,
        email: company.email,
        location: company.location,
        years_experience: company.years_experience,
        service_areas: company.service_areas,
        hours_text: company.hours_text,
        featured_cta_label: company.featured_cta_label,
        featured_cta_phone: company.featured_cta_phone,
        logo_url: company.logo_url,
      };
      var __wsBoot = {
        companyId: company.id,
        company: wsCompany,
        galleryAdminText: typeof galleryAdminText !== 'undefined' ? galleryAdminText : '',
        paths: {
          previewFrame: previewFramePath,
          previewDraft: '/admin/companies/' + company.id + '/preview-draft',
          publish: '/admin/companies/' + company.id + '/publish',
        },
        adminTenantSlug: typeof adminTenantSlug !== 'undefined' ? adminTenantSlug : '',
      };
    %>
    <script>
      window.__WORKSPACE__ = <%- JSON.stringify(__wsBoot).replace(/</g, '\\u003c') %>;
    </script>
    <script src="<%= asset('admin-company-workspace') %>"></script>
  </body>
</html>
