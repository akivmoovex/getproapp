<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Settings | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app admin-settings-hub-page<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Settings', activeNav: 'settings' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <header class="admin-settings-hub__hero">
          <h1 class="admin-settings-hub__title">Settings</h1>
          <p class="admin-settings-hub__lead muted">
            Choose a tool below. It opens in a full-width panel; use <strong>×</strong> in the top-right, click the dimmed backdrop, or press <kbd class="admin-settings-hub__kbd">Esc</kbd> to return here.
          </p>
        </header>

        <div class="admin-settings-hub__grid">
          <% if (typeof canEditDirectory !== 'undefined' && canEditDirectory) { %>
          <button type="button" class="admin-settings-hub__card" data-settings-embed-url="/admin/categories?embed=1">
            <span class="admin-settings-hub__card-icon" aria-hidden="true">📋</span>
            <span class="admin-settings-hub__card-title">Professions</span>
            <span class="admin-settings-hub__card-desc muted">Categories &amp; professions for the directory</span>
          </button>
          <button type="button" class="admin-settings-hub__card" data-settings-embed-url="/admin/companies?embed=1">
            <span class="admin-settings-hub__card-icon" aria-hidden="true">🏢</span>
            <span class="admin-settings-hub__card-title">Companies</span>
            <span class="admin-settings-hub__card-desc muted">Listings and mini-sites</span>
          </button>
          <button type="button" class="admin-settings-hub__card" data-settings-embed-url="/admin/cities?embed=1">
            <span class="admin-settings-hub__card-icon" aria-hidden="true">📍</span>
            <span class="admin-settings-hub__card-title">Cities</span>
            <span class="admin-settings-hub__card-desc muted">City filters for the region</span>
          </button>
          <% } %>

          <button type="button" class="admin-settings-hub__card" data-settings-embed-url="/admin/leads?embed=1">
            <span class="admin-settings-hub__card-icon" aria-hidden="true">✉️</span>
            <span class="admin-settings-hub__card-title">Leads</span>
            <span class="admin-settings-hub__card-desc muted">Inquiries and partner signups</span>
          </button>

          <% if (typeof canManageUsers !== 'undefined' && canManageUsers) { %>
          <button type="button" class="admin-settings-hub__card" data-settings-embed-url="/admin/users?embed=1">
            <span class="admin-settings-hub__card-icon" aria-hidden="true">👤</span>
            <span class="admin-settings-hub__card-title">Users</span>
            <span class="admin-settings-hub__card-desc muted">Admin users for this region</span>
          </button>
          <% } %>

          <% if (typeof canAccessTenantSettings !== 'undefined' && canAccessTenantSettings) { %>
          <button
            type="button"
            class="admin-settings-hub__card admin-settings-hub__card--accent"
            data-settings-embed-url="<%= isSuper ? '/admin/settings/tenants?embed=1' : ('/admin/settings/tenant/' + tenantIdForSettings + '?embed=1') %>"
          >
            <span class="admin-settings-hub__card-icon" aria-hidden="true">⚙️</span>
            <span class="admin-settings-hub__card-title">Global settings</span>
            <span class="admin-settings-hub__card-desc muted">Phones, email, WhatsApp for this region</span>
          </button>
          <% } %>
        </div>
      </div>
    </main>

    <div id="admin_settings_modal" class="admin-settings-modal" aria-hidden="true" hidden>
      <div class="admin-settings-modal__backdrop" data-settings-modal-close tabindex="-1"></div>
      <!-- Header row keeps the close control out of the iframe document (no overlap with embedded toolbars). -->
      <div class="admin-settings-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="admin_settings_modal_title">
        <header class="admin-settings-modal__header">
          <h2 id="admin_settings_modal_title" class="admin-settings-modal__headline">Admin tool</h2>
          <button type="button" class="admin-settings-modal__close" data-settings-modal-close aria-label="Close dialog">
            ×
          </button>
        </header>
        <iframe id="admin_settings_iframe" class="admin-settings-modal__iframe" title="Embedded admin screen"></iframe>
      </div>
    </div>

    <script src="/admin-settings-hub.js?v=<%= stylesVersion %>"></script>
  </body>
</html>
