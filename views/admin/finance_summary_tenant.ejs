<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Finance · <%= tenant.name %> | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Finance summary', activeNav: 'finance_summary' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <header class="admin-dashboard__header">
          <div>
            <h1 class="admin-dashboard__title"><%= tenant.name %></h1>
            <p class="admin-dashboard__subtitle muted">Tenant finance drill-down · <%= tenant.slug %> · read-only</p>
          </div>
        </header>

        <% var _embedQ = (typeof embed !== 'undefined' && embed) ? '&embed=1' : ''; %>
        <% var _prTenant = 'tenant_id=' + tenantId + _embedQ; %>

        <p>
          <a href="/admin/finance/summary<% if (typeof embed !== 'undefined' && embed) { %>?embed=1<% } %>">← Cross-tenant finance summary</a>
          · <a href="/admin/finance/cfo/tenant/<%= tenantId %><% if (typeof embed !== 'undefined' && embed) { %>?embed=1<% } %>">CFO period drill-down</a>
        </p>

        <% var ps = typeof payoutSummary !== 'undefined' && payoutSummary ? payoutSummary : null; %>
        <% var sc = ps && ps.statusCounts ? ps.statusCounts : {}; %>

        <section class="admin-dashboard__grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(10rem,1fr));gap:0.75rem;margin-bottom:1.25rem;">
          <div class="card" style="padding:0.85rem;">
            <p class="muted" style="margin:0;font-size:0.8rem;">Pay runs D / L / A / P / V</p>
            <p style="margin:0.25rem 0 0 0;font-weight:700;"><%= sc.draft != null ? sc.draft : 0 %> / <%= sc.locked != null ? sc.locked : 0 %> / <%= sc.approved != null ? sc.approved : 0 %> / <%= sc.paid != null ? sc.paid : 0 %> / <%= sc.void != null ? sc.void : 0 %></p>
          </div>
          <div class="card" style="padding:0.85rem;">
            <p class="muted" style="margin:0;font-size:0.8rem;">Frozen payable (A+P)</p>
            <p class="admin-finance-num" style="margin:0.25rem 0 0 0;font-size:1.25rem;font-weight:700;"><%= ps ? Number(ps.frozenPayableApprovedPaid || 0).toFixed(2) : '—' %></p>
          </div>
          <div class="card" style="padding:0.85rem;">
            <p class="muted" style="margin:0;font-size:0.8rem;">Net paid (full ledger)</p>
            <p class="admin-finance-num" style="margin:0.25rem 0 0 0;font-size:1.25rem;font-weight:700;"><%= ps ? Number(ps.totalNetPaidLedger || 0).toFixed(2) : '—' %></p>
          </div>
          <div class="card" style="padding:0.85rem;">
            <p class="muted" style="margin:0;font-size:0.8rem;">Remaining balance</p>
            <% var _out = ps ? Number(ps.outstandingAmount || 0) : 0; var _outCls = 'admin-finance-num'; if (ps && _out < 0) { _outCls += ' admin-finance-num--warn'; } else if (ps && _out > 0) { _outCls += ' admin-finance-num--outstanding'; } %>
            <p class="<%= _outCls %>" style="margin:0.25rem 0 0 0;font-size:1.25rem;font-weight:700;"><%= ps ? _out.toFixed(2) : '—' %></p>
            <p class="muted" style="margin:0.35rem 0 0 0;font-size:0.75rem;">Frozen (A+P) − full ledger</p>
          </div>
          <div class="card" style="padding:0.85rem;">
            <p class="muted" style="margin:0;font-size:0.8rem;">Ledger on A+P runs</p>
            <p class="admin-finance-num" style="margin:0.25rem 0 0 0;font-size:1.1rem;font-weight:700;"><%= ps ? Number(ps.ledgerPaidOnApprovedPaidRuns || 0).toFixed(2) : '—' %></p>
          </div>
        </section>

        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Quick links</h2>
          <p style="display:flex;flex-wrap:wrap;gap:0.5rem;">
            <a class="c-button c-button--outline" style="text-decoration:none;" href="/admin/field-agent-pay-runs?<%= _prTenant %>">Pay runs (tenant)</a>
            <a class="c-button c-button--outline" style="text-decoration:none;" href="/admin/field-agent-pay-runs/finance-dashboard?<%= _prTenant %>">Payout review</a>
          </p>
        </section>

        <% (payRunSlices || []).forEach(function (slice) { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush"><%= slice.title %></h2>
          <p class="muted" style="margin-bottom:0.75rem;font-size:0.9rem;"><%= slice.description %></p>
          <div class="admin-table-wrap" style="overflow-x:auto;">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Period</th>
                  <th>Status</th>
                  <th style="text-align:right;">Frozen payable</th>
                  <th style="text-align:right;">Net paid</th>
                  <th style="text-align:right;">Balance</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% if (!(slice.rows || []).length) { %>
                <tr><td colspan="7"><p class="admin-finance-empty" style="margin:0;">No runs in this list.</p></td></tr>
                <% } %>
                <% (slice.rows || []).forEach(function (r) { %>
                <tr>
                  <td><%= r.pay_run_id %></td>
                  <td style="white-space:nowrap;"><%= r.period_start ? new Date(r.period_start).toISOString().slice(0, 10) : '—' %> — <%= r.period_end ? new Date(r.period_end).toISOString().slice(0, 10) : '—' %></td>
                  <td><%- include('../partials/admin_finance_status_badge', { status: r.run_status }) %></td>
                  <td class="admin-finance-num"><%= Number(r.run_payable_total || 0).toFixed(2) %></td>
                  <td class="admin-finance-num"><%= Number(r.total_paid_amount || 0).toFixed(2) %></td>
                  <% var _br = Number(r.balance_remaining || 0); var _brCls = 'admin-finance-num'; if (_br < 0) { _brCls += ' admin-finance-num--warn'; } else if (_br > 0) { _brCls += ' admin-finance-num--outstanding'; } %>
                  <td class="<%= _brCls %>"><%= _br.toFixed(2) %></td>
                  <td style="white-space:nowrap;">
                    <a href="/admin/field-agent-pay-runs/<%= r.pay_run_id %>/finance-detail?<%= _prTenant %>">Finance detail</a>
                    · <a href="/admin/field-agent-pay-runs/<%= r.pay_run_id %>?<%= _prTenant %>">Workflow</a>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>
        <% }); %>
      </div>
    </main>
  </body>
</html>
