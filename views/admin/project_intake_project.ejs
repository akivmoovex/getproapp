<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>New project details | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
    <style>
      .intake-carousel { display: flex; gap: 0.5rem; overflow-x: auto; padding: 0.5rem 0; max-width: 100%; }
      .intake-carousel img { height: 120px; width: auto; border-radius: 4px; object-fit: cover; flex-shrink: 0; }
    </style>
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: navTitle || 'New project', activeNav: activeNav || 'project_intake' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <%- include('../partials/admin_intake_otp_banner') %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flash" role="alert"><%= error %></div>
        <% } %>
        <% if (typeof notice !== 'undefined' && notice) { %>
          <div class="flash flash--info" role="status"><%= notice %></div>
        <% } %>
        <% if (typeof otp_notice !== 'undefined' && otp_notice) { %>
          <% var _otpFlashClass = typeof otp_notice_ok !== 'undefined' && otp_notice_ok === true ? 'flash flash--success' : (typeof otp_notice_ok !== 'undefined' && otp_notice_ok === false ? 'flash' : 'flash flash--info'); %>
          <% var _otpRole = typeof otp_notice_ok !== 'undefined' && otp_notice_ok === false ? 'alert' : 'status'; %>
          <div class="<%= _otpFlashClass %>" role="<%= _otpRole %>"><%= otp_notice %></div>
        <% } %>

        <% const canMutate = typeof adminNav !== 'undefined' && adminNav.canMutateProjectIntake; %>

        <div class="card admin-form-card">
          <h1 class="admin-form-card__title">Client</h1>
          <p class="muted" style="margin-bottom:0.35rem;">Client code</p>
          <div class="admin-intake-code" aria-label="Client code"><%= client.client_code %></div>
          <p style="margin-top:0.75rem;"><strong><%= client.full_name %></strong></p>
          <p class="muted">External ref: <%= client.external_client_reference %> · Phone: <%= client.phone %></p>
          <% if (client.phone_verified_at) { %>
            <p class="flash flash--info" role="status">Phone verified at <%= client.phone_verified_at %>.</p>
          <% } else { %>
            <p class="muted">Phone not verified.</p>
          <% } %>
        </div>

        <% if (canMutate && !client.phone_verified_at) { %>
        <div class="card admin-form-card" style="margin-top:1rem;">
          <h2 class="admin-form-card__title">SMS OTP (optional)</h2>
          <p class="input-field__help muted" style="margin-top:0;">Uses the same SMS rules as the banner at the top of this page.</p>
          <form method="post" action="/admin/project-intake/otp/send" class="form" style="margin-bottom:1rem;">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <input type="hidden" name="client_id" value="<%= client.id %>" />
            <%- include('../partials/components/button', { variant: 'default', type: 'submit', label: 'Send OTP' }) %>
          </form>
          <form method="post" action="/admin/project-intake/otp/verify" class="form">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <input type="hidden" name="client_id" value="<%= client.id %>" />
            <div class="input-field" style="max-width:12rem;">
              <label class="input-field__label" for="otp_code">6-digit code</label>
              <input id="otp_code" name="otp_code" class="input-field__control" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" />
            </div>
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Verify' }) %>
          </form>
        </div>
        <% } %>

        <div class="card admin-form-card" style="margin-top:1rem;">
          <h2 class="admin-form-card__title">Project</h2>
          <p class="muted intake-lifecycle-hint" style="margin:0 0 1rem; max-width:40rem;">
            Saving creates a <strong>draft</strong>, then sets the project to <strong>needs review</strong> or <strong>ready to publish</strong> based on completeness.
            Nothing is exposed to assigned companies until you <strong>Publish</strong> on the next screen (or project detail).
          </p>
          <% if (!canMutate) { %>
            <p class="flash" role="status">Read-only role: you cannot submit projects.</p>
          <% } else { %>
          <form method="post" action="/admin/project-intake/projects" class="form" enctype="multipart/form-data" id="intake-project-form">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <input type="hidden" name="client_id" value="<%= client.id %>" />
            <h3 class="input-field__label">Client address (editable)</h3>
            <div class="input-field">
              <input name="client_address_street" class="input-field__control" placeholder="Street name" value="<%= client.address_street %>" />
            </div>
            <div class="input-field">
              <input name="client_address_house_number" class="input-field__control" placeholder="House number" value="<%= client.address_house_number %>" />
            </div>
            <div class="input-field">
              <input name="client_address_apartment_number" class="input-field__control" placeholder="Apartment number" value="<%= client.address_apartment_number %>" />
            </div>
            <div class="input-field">
              <label class="input-field__label" for="intake_category_id">Profession / category</label>
              <select id="intake_category_id" name="intake_category_id" class="input-field__control" required>
                <option value="">Select profession</option>
                <% (typeof intakeCategories !== 'undefined' ? intakeCategories : []).forEach(function (cat) { %>
                  <option value="<%= cat.id %>"><%= cat.name %></option>
                <% }); %>
              </select>
              <p class="input-field__help muted">Required for publishing; used for lead routing settings per category.</p>
            </div>
            <h3 class="input-field__label" style="margin-top:1rem;">Project location</h3>
            <div class="input-field">
              <label class="input-field__label" for="city">City</label>
              <select id="city" name="city" class="input-field__control" required>
                <option value="">Select city</option>
                <% cities.forEach(function (c) { %>
                  <option value="<%= c.name %>"><%= c.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="input-field">
              <label class="input-field__label" for="neighborhood">Neighborhood</label>
              <input id="neighborhood" name="neighborhood" class="input-field__control" maxlength="120" />
            </div>
            <div class="input-field">
              <label class="input-field__label" for="street_name">Street name</label>
              <input id="street_name" name="street_name" class="input-field__control" maxlength="200" />
            </div>
            <div class="input-field">
              <label class="input-field__label" for="house_number">House number</label>
              <input id="house_number" name="house_number" class="input-field__control" maxlength="40" />
            </div>
            <div class="input-field">
              <label class="input-field__label" for="apartment_number">Apartment number</label>
              <input id="apartment_number" name="apartment_number" class="input-field__control" maxlength="40" />
            </div>
            <div class="input-field">
              <label class="input-field__label" for="estimated_budget">Estimated budget (<%= budget.displayPrefix %>)</label>
              <input id="estimated_budget" name="estimated_budget" class="input-field__control" inputmode="decimal" />
              <p class="input-field__help muted"><%= budget.label %> · stored currency code <%= budget.code %></p>
            </div>
            <div class="input-field">
              <label class="input-field__label" for="images">Pictures</label>
              <input id="images" name="images" type="file" class="input-field__control" accept="image/jpeg,image/png,image/webp,image/gif" multiple />
              <p class="input-field__help muted">Up to 5 images per project. JPEG, PNG, WebP, or GIF; 5 MB max each. Images are compressed automatically after upload.</p>
              <div id="intake-preview" class="intake-carousel" aria-live="polite"></div>
            </div>
            <div class="form-step__actions admin-gate-actions">
              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Save project (not published)' }) %>
              <%- include('../partials/components/button', { variant: 'text', href: '/admin/project-intake' + (typeof embed !== 'undefined' && embed ? '?embed=1' : ''), label: 'Cancel' }) %>
            </div>
          </form>
          <script>
            (function () {
              var input = document.getElementById("images");
              var box = document.getElementById("intake-preview");
              if (!input || !box) return;
              input.addEventListener("change", function () {
                box.innerHTML = "";
                var files = Array.prototype.slice.call(input.files || [], 0, 5);
                files.forEach(function (f) {
                  if (!f.type || f.type.indexOf("image/") !== 0) return;
                  var url = URL.createObjectURL(f);
                  var img = document.createElement("img");
                  img.src = url;
                  img.alt = "";
                  box.appendChild(img);
                });
              });
            })();
          </script>
          <% } %>
        </div>
      </div>
    </main>
  </body>
</html>
