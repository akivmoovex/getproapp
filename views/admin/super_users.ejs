<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>All admin users | GetPro Super</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'All tenants — users', activeNav: 'super_users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <div class="admin-super-users__topbar">
        <% if (!editMode) { %>
        <a class="btn btn-primary" href="/admin/super/users?edit=1<%= typeof filterSuffix !== 'undefined' ? filterSuffix : '' %>">Edit</a>
        <% } else { %>
        <a class="btn" href="/admin/super/users<%= typeof filterSuffix !== 'undefined' && filterSuffix ? '?' + filterSuffix.slice(1) : '' %>">Done</a>
        <% } %>
      </div>
      <p class="admin-intro" style="margin-bottom:18px;">
        Passwords are stored as <strong>bcrypt hashes</strong> only — they cannot be displayed.<% if (editMode) { %> Use <strong>Edit</strong> on a user to set a new password.<% } %>
        <% if (seedDemoNote) { %>
          Seed accounts from <code>SEED_BUILTIN_USERS</code>: <code>tenantmanager</code> / <code>superadmin</code> (password <code>1234</code> if seeded).
          Demo region also has migration-seeded users <code>demo_manager</code>, <code>demo_editor</code>, <code>demo_agent</code> (password <code>demo1234</code>) on the demo tenant only.
        <% } %>
      </p>

      <h1 class="section-title" style="margin-top:0;">All regions — users</h1>
      <% var uf = typeof userFilters !== 'undefined' ? userFilters : {}; %>
      <form method="get" action="/admin/super/users" class="admin-filter-form">
        <% if (editMode) { %><input type="hidden" name="edit" value="1" /><% } %>
        <div class="admin-filter-form__grid">
          <div>
            <label class="admin-filter-form__label" for="u_username">Username</label>
            <input id="u_username" name="u_username" type="search" value="<%= uf.u_username || '' %>" placeholder="Filter…" autocomplete="off" />
          </div>
          <div>
            <label class="admin-filter-form__label" for="u_tenant">Tenant</label>
            <input id="u_tenant" name="u_tenant" type="search" value="<%= uf.u_tenant || '' %>" placeholder="Filter…" autocomplete="off" />
          </div>
          <div>
            <label class="admin-filter-form__label" for="u_role">Role</label>
            <input id="u_role" name="u_role" type="search" value="<%= uf.u_role || '' %>" placeholder="Filter…" autocomplete="off" />
          </div>
          <div>
            <label class="admin-filter-form__label" for="u_status">Status</label>
            <select id="u_status" name="u_status">
              <option value="" <%= !uf.u_status ? 'selected' : '' %>>All</option>
              <option value="enabled" <%= uf.u_status === 'enabled' ? 'selected' : '' %>>Enabled</option>
              <option value="disabled" <%= uf.u_status === 'disabled' ? 'selected' : '' %>>Disabled</option>
            </select>
          </div>
        </div>
        <div class="admin-filter-form__actions">
          <button class="btn btn-primary" type="submit">Apply filters</button>
          <a class="btn" href="/admin/super/users<%= editMode ? '?edit=1' : '' %>">Clear</a>
        </div>
      </form>

      <% if (editMode) { %>
      <p class="admin-intro">Create, edit, delete, enable/disable, or change passwords for any admin user.</p>
      <div class="admin-toolbar">
        <a class="btn btn-primary" href="/admin/super/users/new">New user</a>
      </div>
      <% } else { %>
      <p class="admin-intro">View-only list. Choose <strong>Edit</strong> above to add or change users.</p>
      <% } %>
      <div class="card">
        <div class="table-wrap">
        <table class="table<%= editMode ? '' : ' table--readonly' %>">
          <thead>
            <tr>
              <th>Username</th>
              <th>Tenant</th>
              <th>Role</th>
              <th>Password</th>
              <th>Status</th>
              <% if (editMode) { %><th>Actions</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% if (!allUsers || allUsers.length === 0) { %>
              <tr><td colspan="<%= editMode ? 6 : 5 %>" class="muted">No admin users match these filters.</td></tr>
            <% } %>
            <% (allUsers || []).forEach(function(u) { %>
              <tr>
                <td style="font-weight:700;"><%= u.username %></td>
                <td><%= u.tenant_id == null ? '—' : (u.tenant_name || u.tenant_slug || '#' + u.tenant_id) %></td>
                <td class="muted"><%= u.role %></td>
                <td class="muted" style="font-size:12px;">Hashed (not shown)</td>
                <td><%= u.enabled === 0 ? 'Disabled' : 'Enabled' %></td>
                <% if (editMode) { %><td><a class="btn" href="/admin/super/users/<%= u.id %>/edit">Edit</a></td><% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      </div>
    </main>
  </body>
</html>
