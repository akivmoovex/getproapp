<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Draft pay-run snapshots | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Pay runs', activeNav: 'field_agent_pay_runs' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <header class="admin-dashboard__header">
          <div>
            <h1 class="admin-dashboard__title">Draft pay-run snapshots</h1>
            <p class="admin-dashboard__subtitle muted">
              Frozen draft values for admin review. Not final approval or payment. Field-agent dashboard rolling estimates stay separate.
            </p>
          </div>
        </header>

        <% if (typeof isSuper !== 'undefined' && isSuper && tenants && tenants.length) { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Region</h2>
          <form method="get" action="/admin/field-agent-pay-runs" class="admin-filter-form">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <div class="input-field">
              <label class="input-field__label" for="pr_tenant">Tenant</label>
              <select id="pr_tenant" name="tenant_id" class="input-field__control" onchange="this.form.submit()">
                <% tenants.forEach(function (t) { %>
                <option value="<%= t.id %>" <%= Number(tenantId) === Number(t.id) ? 'selected' : '' %>><%= t.name %> (<%= t.slug %>)</option>
                <% }); %>
              </select>
            </div>
          </form>
        </section>
        <% } %>

        <% var _newQs = []; if (typeof embed !== 'undefined' && embed) _newQs.push('embed=1'); if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') _newQs.push('tenant_id=' + tenantId); %>
        <% var _listQs = _newQs.length ? _newQs.join('&') : ''; %>
        <p style="margin-bottom: 1rem;">
          <a href="/admin/field-agent-pay-runs/new<%= _listQs.length ? '?' + _listQs : '' %>">Create draft snapshot (preview period)</a>
          <span class="muted"> · </span>
          <a href="/admin/field-agent-pay-runs/finance-dashboard<%= _listQs.length ? '?' + _listQs : '' %>">Payout review</a>
          <span class="muted">(read-only finance)</span>
        </p>

        <section class="card">
          <h2 class="section-title section-title--flush">Draft runs (this region)</h2>
          <% if (!runs || !runs.length) { %>
            <p class="muted">No draft pay runs yet.</p>
          <% } else { %>
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Period start</th>
                    <th>Period end</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% runs.forEach(function (r) { %>
                  <tr>
                    <td><%= r.id %></td>
                    <td><%= r.period_start ? new Date(r.period_start).toISOString().slice(0, 10) : '—' %></td>
                    <td><%= r.period_end ? new Date(r.period_end).toISOString().slice(0, 10) : '—' %></td>
                    <td><% if (r.status === 'approved') { %><strong>Approved</strong><% } else if (r.status === 'paid') { %><strong>Paid</strong><% } else { %><%= r.status %><% } %></td>
                    <td class="muted"><%= r.created_at ? new Date(r.created_at).toLocaleString() : '—' %></td>
                    <td style="white-space:nowrap;">
                      <a href="/admin/field-agent-pay-runs/<%= r.id %><%= _listQs.length ? '?' + _listQs : '' %>">Workflow</a>
                      · <a href="/admin/field-agent-pay-runs/<%= r.id %>/finance-detail<%= _listQs.length ? '?' + _listQs : '' %>">Finance detail</a>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </section>
      </div>
    </main>
  </body>
</html>
