<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= company ? 'Edit' : 'New' %> Company | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: company ? 'Edit company' : 'New company', activeNav: 'companies' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <div class="admin-toolbar">
        <a class="btn" href="/admin/companies?edit=1<%= typeof embed !== 'undefined' && embed ? '&embed=1' : '' %>">← All companies</a>
      </div>

      <div class="card admin-form-card admin-form-card--wide">
        <% if (company && typeof miniSiteUrl !== 'undefined' && miniSiteUrl && miniSiteUrl !== '#') { %>
        <div class="admin-mini-site-urls">
          <div class="admin-mini-site-urls__title">Public URLs</div>
          <div class="muted admin-mini-site-urls__line">
            <strong>Mini-site</strong> (what customers see on this page):
            <a href="<%= miniSiteUrl %>" target="_blank" rel="noopener noreferrer"><%= typeof miniSiteLabel !== 'undefined' && miniSiteLabel ? miniSiteLabel : miniSiteUrl %></a>
          </div>
          <% if (typeof directoryProfileUrl !== 'undefined' && directoryProfileUrl && directoryProfileUrl !== '/company') { %>
          <div class="muted admin-mini-site-urls__line u-mt-tight">
            <strong>Directory profile</strong> (same company, directory layout):
            <a href="<%= directoryProfileUrl %>" target="_blank" rel="noopener noreferrer"><%= directoryProfileUrl.replace(/^https?:\/\//, '') %></a>
          </div>
          <% } %>
        </div>
        <% } else if (typeof miniSiteExampleLabel !== 'undefined' && miniSiteExampleLabel) { %>
        <div class="muted admin-callout-muted">
          After you save, the mini-site will live at <span class="kbd"><%= miniSiteExampleLabel %></span> (replace <span class="kbd">your-company-slug</span> with the <strong>Subdomain</strong> you choose below).
        </div>
        <% } %>
        <form
          method="post"
          action="<%= company ? '/admin/companies/' + company.id : '/admin/companies' %>"
          class="form"
        >
          <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
          <div>
            <label for="logo_url">Logo image URL</label>
            <input
              id="logo_url"
              name="logo_url"
              type="url"
              inputmode="url"
              placeholder="https://…"
              value="<%= company && company.logo_url ? company.logo_url : '' %>"
            />
            <div class="muted admin-field-hint">
              Shown in the company header next to the name. Use a square or wide logo over HTTPS.
            </div>
          </div>

          <div class="hero-grid hero-grid--2col">
            <div>
              <label for="name">Company Name</label>
              <input id="name" name="name" value="<%= company ? company.name : '' %>" required />
            </div>
            <div>
              <label for="subdomain">Subdomain</label>
              <input id="subdomain" name="subdomain" value="<%= company ? company.subdomain : '' %>" required />
              <div class="muted admin-field-hint">
                URL path on this region’s site, e.g. <span class="kbd"><%= typeof adminTenantSlug !== 'undefined' && adminTenantSlug ? adminTenantSlug + '.' : '' %><%= baseDomain || 'getproapp.org' %>/mybiz</span> — use <span class="kbd">mybiz</span> as the value here (letters, numbers, hyphens).
              </div>
            </div>
          </div>

          <div>
            <label for="category_id">Category</label>
            <select id="category_id" name="category_id">
              <option value="">Uncategorized</option>
              <% categories.forEach(function(cat) { %>
                <option value="<%= cat.id %>" <%= company && company.category_id === cat.id ? 'selected' : '' %>><%= cat.name %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="headline">Headline</label>
            <input id="headline" name="headline" value="<%= company ? company.headline : '' %>" />
          </div>

          <div>
            <label for="about">About</label>
            <textarea id="about" name="about"><%= company ? company.about : '' %></textarea>
          </div>

          <div>
            <label for="services">Services (one per line)</label>
            <textarea id="services" name="services"><%= company ? company.services : '' %></textarea>
          </div>

          <% if (typeof adminTenantSlug !== 'undefined' && adminTenantSlug === 'zm') { %>
          <p class="muted admin-zm-phone-note">
            Zambian numbers: <strong>0</strong> followed by <strong>9 digits</strong> (10 digits total, e.g. 0977123456).
          </p>
          <% } %>
          <div class="hero-grid hero-grid--2col">
            <div>
              <label for="phone">Phone</label>
              <input id="phone" name="phone" value="<%= company ? company.phone : '' %>" />
            </div>
            <div>
              <label for="email">Email</label>
              <input id="email" name="email" type="text" inputmode="email" autocomplete="email" value="<%= company ? company.email : '' %>" />
            </div>
          </div>

          <div>
            <label for="location">Location</label>
            <input id="location" name="location" value="<%= company ? company.location : '' %>" />
          </div>

          <div>
            <label for="years_experience">Years in business</label>
            <input
              id="years_experience"
              name="years_experience"
              type="number"
              min="0"
              max="999"
              placeholder="e.g. 8"
              value="<%= company && company.years_experience != null && company.years_experience !== '' ? company.years_experience : '' %>"
            />
          </div>

          <div>
            <label for="service_areas">Service areas (regions &amp; cities)</label>
            <textarea id="service_areas" name="service_areas" rows="4" placeholder="One area per line"><%= company ? company.service_areas : '' %></textarea>
          </div>

          <div>
            <label for="hours_text">Hours / availability</label>
            <textarea id="hours_text" name="hours_text" rows="4" placeholder="e.g. Mon–Fri 08:00–17:00"><%= company ? company.hours_text : '' %></textarea>
          </div>

          <div>
            <label for="gallery_text">Recent work — image URLs</label>
            <textarea id="gallery_text" name="gallery_text" rows="7" placeholder="https://example.com/job1.jpg|Kitchen rewire&#10;https://example.com/job2.jpg"><%= typeof galleryAdminText !== 'undefined' ? galleryAdminText : '' %></textarea>
            <div class="muted admin-field-hint">
              One URL per line. Optional caption after <span class="kbd">|</span>. Use HTTPS links to images you are allowed to display.
            </div>
          </div>

          <div class="hero-grid hero-grid--2col">
            <div>
              <label for="featured_cta_label">CTA Label</label>
              <input id="featured_cta_label" name="featured_cta_label" value="<%= company ? company.featured_cta_label : 'Call us' %>" />
            </div>
            <div>
              <label for="featured_cta_phone">CTA Phone</label>
              <input id="featured_cta_phone" name="featured_cta_phone" value="<%= company ? company.featured_cta_phone : '' %>" />
            </div>
          </div>

          <div class="admin-gate-actions">
            <button class="btn btn-primary" type="submit">Save</button>
          </div>
        </form>
      </div>
      </div>
    </main>
  </body>
</html>

