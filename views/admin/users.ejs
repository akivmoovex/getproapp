<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Users | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Tenant users', activeNav: 'users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <h1 class="section-title" style="margin-top:0;">Admin users (this region)</h1>
      <div class="admin-toolbar">
        <a class="btn btn-primary" href="/admin/users/new">New user</a>
      </div>
      <div class="card">
        <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Role</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
              <tr>
                <td style="font-weight:700;"><%= u.username %></td>
                <td class="muted"><%= u.role %></td>
                <td><%= u.enabled === 0 ? 'Disabled' : 'Enabled' %></td>
                <td class="muted" style="font-size:12px;"><%= u.created_at %></td>
                <td><a class="btn" href="/admin/users/<%= u.id %>/edit">Edit</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      </div>
    </main>
  </body>
</html>
