<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Users | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Tenant users', activeNav: 'users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% var _embed = typeof embed !== 'undefined' && embed; %>
      <h1 class="section-title section-title--flush">Admin users (this region)</h1>
      <div class="admin-toolbar">
        <%- include('../partials/components/button', { variant: 'primary', href: '/admin/users/new' + (_embed ? '?embed=1' : ''), label: 'New user' }) %>
      </div>
      <div class="card">
        <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Role</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
              <tr>
                <td class="table__strong"><%= u.username %></td>
                <td class="muted"><%= u.role %></td>
                <td><%= u.enabled === 0 ? 'Disabled' : 'Enabled' %></td>
                <td class="muted"><%- include('../partials/event_time', { at: u.created_at }) %></td>
                <td><%- include('../partials/components/button', { variant: 'default', href: '/admin/users/' + u.id + '/edit' + (_embed ? '?embed=1' : ''), label: 'Edit' }) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      </div>
    </main>
  </body>
</html>
