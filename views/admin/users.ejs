<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Users | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=20260320k" />
  </head>
  <body>
    <div class="container" style="padding: 22px 0;">
      <%- include('../partials/admin_nav', { navTitle: 'Tenant users', activeNav: 'users' }) %>

      <div class="section-title" style="margin-top:22px;">Admin users (this tenant)</div>
      <div class="nav-links" style="margin-bottom:14px;">
        <a class="btn btn-primary" href="/admin/users/new">New user</a>
      </div>
      <div class="card">
        <table class="table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Role</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
              <tr>
                <td style="font-weight:700;"><%= u.username %></td>
                <td class="muted"><%= u.role %></td>
                <td class="muted" style="font-size:12px;"><%= u.created_at %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>
