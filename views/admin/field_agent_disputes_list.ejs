<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Statement disputes | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Statement disputes', activeNav: 'field_agent_disputes' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <header class="admin-dashboard__header">
          <div>
            <h1 class="admin-dashboard__title">Statement disputes</h1>
            <p class="admin-dashboard__subtitle muted">Review field-agent disputes. Statement amounts stay frozen until a separate adjustment process exists.</p>
          </div>
        </header>

        <% if (typeof isSuper !== 'undefined' && isSuper && tenants && tenants.length) { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Region</h2>
          <form method="get" action="/admin/field-agent-disputes" class="admin-filter-form">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <div class="input-field">
              <label class="input-field__label" for="fd_tenant">Tenant</label>
              <select id="fd_tenant" name="tenant_id" class="input-field__control" onchange="this.form.submit()">
                <% tenants.forEach(function (t) { %>
                <option value="<%= t.id %>" <%= Number(tenantId) === Number(t.id) ? 'selected' : '' %>><%= t.name %> (<%= t.slug %>)</option>
                <% }); %>
              </select>
            </div>
          </form>
        </section>
        <% } %>

        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Filter</h2>
          <form method="get" action="/admin/field-agent-disputes" class="admin-filter-form">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <% if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') { %>
            <input type="hidden" name="tenant_id" value="<%= tenantId %>" />
            <% } %>
            <div class="input-field">
              <label class="input-field__label" for="fd_status">Status</label>
              <select id="fd_status" name="status" class="input-field__control" onchange="this.form.submit()">
                <option value="">All</option>
                <option value="open" <%= filterStatus === 'open' ? 'selected' : '' %>>Open</option>
                <option value="under_review" <%= filterStatus === 'under_review' ? 'selected' : '' %>>Under review</option>
                <option value="resolved" <%= filterStatus === 'resolved' ? 'selected' : '' %>>Resolved</option>
                <option value="rejected" <%= filterStatus === 'rejected' ? 'selected' : '' %>>Rejected</option>
              </select>
            </div>
          </form>
        </section>

        <section class="card">
          <% if (!disputes || !disputes.length) { %>
            <p class="muted">No disputes match this filter.</p>
          <% } else { %>
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Period</th>
                    <th>Agent</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% disputes.forEach(function (d) { %>
                  <tr>
                    <td><%= d.id %></td>
                    <td><%= d.period_start ? new Date(d.period_start).toISOString().slice(0, 10) : '—' %> — <%= d.period_end ? new Date(d.period_end).toISOString().slice(0, 10) : '—' %></td>
                    <td><%= d.field_agent_label_snapshot || '—' %></td>
                    <td><%= d.status %></td>
                    <td class="muted"><%= d.created_at ? new Date(d.created_at).toLocaleString() : '—' %></td>
                    <td>
                      <% var _dq = []; if (typeof embed !== 'undefined' && embed) _dq.push('embed=1'); if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') _dq.push('tenant_id=' + tenantId); %>
                      <a href="/admin/field-agent-disputes/<%= d.id %><%= _dq.length ? '?' + _dq.join('&') : '' %>">View</a>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </section>
      </div>
    </main>
  </body>
</html>
