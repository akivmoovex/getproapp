<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Region settings | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app">
    <%- include('../partials/admin_nav', { navTitle: 'Region settings', activeNav: 'settings' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <div class="admin-toolbar" style="margin-bottom: 8px">
          <a class="btn" href="/admin/settings">← Settings hub</a>
        </div>
        <h1 class="section-title" style="margin-top: 0">Region settings</h1>
        <p class="admin-intro" style="margin-bottom: 20px">
          Choose a region to edit call-center phone, support line, WhatsApp, and email. These apply to directory footers and company mini-sites.
        </p>
        <div class="card">
          <div class="table-wrap">
            <table class="table admin-settings-tenant-table">
              <thead>
                <tr>
                  <th scope="col">Region</th>
                  <th scope="col">Short</th>
                  <th scope="col">Stage</th>
                  <th scope="col">Listing phone</th>
                  <th scope="col" class="admin-settings-tenant-table__actions"> </th>
                </tr>
              </thead>
              <tbody>
                <% if (!tenants || tenants.length === 0) { %>
                <tr>
                  <td colspan="5" class="muted">No regions found.</td>
                </tr>
                <% } %>
                <% (tenants || []).forEach(function (t) { %>
                <tr class="admin-settings-tenant-table__row">
                  <td>
                    <a class="admin-settings-tenant-table__name" href="/admin/settings/tenant/<%= t.id %>"><%= t.name %></a>
                  </td>
                  <td class="muted"><span class="kbd"><%= t.slug %></span></td>
                  <td><%= t.stage %></td>
                  <td class="muted" style="font-size: 13px"><%= t.callcenter_phone ? t.callcenter_phone : '—' %></td>
                  <td class="admin-settings-tenant-table__actions">
                    <a class="btn btn-primary" href="/admin/settings/tenant/<%= t.id %>">Edit</a>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
