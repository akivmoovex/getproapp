<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= category ? 'Edit' : 'New' %> profession | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: category ? 'Edit profession' : 'New profession', activeNav: 'categories' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <div class="admin-toolbar">
        <a class="btn" href="/admin/categories?edit=1<%= typeof embed !== 'undefined' && embed ? '&embed=1' : '' %>">← All professions</a>
      </div>

      <div class="card admin-form-card">
        <form
          method="post"
          action="<%= category ? '/admin/categories/' + category.id : '/admin/categories' %>"
          class="form"
        >
          <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
          <div>
            <label for="name">Category name</label>
            <input id="name" name="name" value="<%= category ? category.name : '' %>" required />
          </div>
          <div>
            <label for="slug">Category slug</label>
            <input id="slug" name="slug" value="<%= category ? category.slug : '' %>" required />
            <div class="admin-field-hint">
              Example: `accounting`, `lawyers`, `electricians`.
            </div>
          </div>

          <div class="admin-gate-actions">
            <button class="btn btn-primary" type="submit">Save</button>
          </div>
        </form>
      </div>
      </div>
    </main>
  </body>
</html>

