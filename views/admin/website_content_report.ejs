                <label class="input-field__label" for="published">Published</label>
                <select id="published" name="published" class="input-field__control">
                  <% var _pub = (filters && filters.published) ? filters.published : 'all'; %>
                  <option value="all" <%= _pub === 'all' ? 'selected' : '' %>>All</option>
                  <option value="yes" <%= _pub === 'yes' ? 'selected' : '' %>>Yes</option>
                  <option value="no" <%= _pub === 'no' ? 'selected' : '' %>>No</option>
                </select>
              </div>
              <div class="input-field">
                <label class="input-field__label" for="city">City</label>
                <input id="city" name="city" class="input-field__control" value="<%= (filters && filters.city) ? filters.city : '' %>" maxlength="120" placeholder="Optional" />
              </div>
              <div class="input-field">
                <label class="input-field__label" for="report_category">Category</label>
                <select id="report_category" name="category" class="input-field__control">
                  <% var _rcat = (filters && filters.category) ? filters.category : ''; %>
                  <option value="" <%= !_rcat ? 'selected' : '' %>>All categories</option>
                  <% (typeof websiteReportCategoryOptions !== 'undefined' ? websiteReportCategoryOptions : []).forEach(function(c) { %>
                    <option value="<%= c %>" <%= _rcat === c ? 'selected' : '' %>><%= c %></option>
                  <% }); %>
                </select>
              </div>
              <div class="input-field">
                <label class="input-field__label" for="quality_tier">Quality tier</label>
                <select id="quality_tier" name="quality_tier" class="input-field__control">
                  <% var _qt = (filters && filters.qualityTier) ? filters.qualityTier : 'all'; %>
                  <option value="all" <%= _qt === 'all' ? 'selected' : '' %>>All</option>
                  <option value="high" <%= _qt === 'high' ? 'selected' : '' %>>High</option>
                  <option value="medium" <%= _qt === 'medium' ? 'selected' : '' %>>Medium</option>
                  <option value="low" <%= _qt === 'low' ? 'selected' : '' %>>Low</option>
                </select>
              </div>
              <div class="input-field">
                <label class="input-field__label" for="quality_min">Min quality score</label>
                <input id="quality_min" name="quality_min" class="input-field__control" type="number" min="0" max="100" value="<%= (filters && filters.qualityMin != null) ? filters.qualityMin : '' %>" />
              </div>
              <div class="input-field">
                <label class="input-field__label" for="has_verified_specialities">Has verified specialities</label>
                <select id="has_verified_specialities" name="has_verified_specialities" class="input-field__control">
                  <% var _hvs = (filters && filters.hasVerifiedSpecialities) ? filters.hasVerifiedSpecialities : 'all'; %>
                  <option value="all" <%= _hvs === 'all' ? 'selected' : '' %>>All</option>
                  <option value="yes" <%= _hvs === 'yes' ? 'selected' : '' %>>Yes</option>
                  <option value="no" <%= _hvs === 'no' ? 'selected' : '' %>>No</option>
                </select>
              </div>
              <div class="input-field">
                <label class="input-field__label" for="has_hours">Has hours</label>
                <select id="has_hours" name="has_hours" class="input-field__control">
                  <% var _hh = (filters && filters.hasHours) ? filters.hasHours : 'all'; %>
                  <option value="all" <%= _hh === 'all' ? 'selected' : '' %>>All</option>
                  <option value="yes" <%= _hh === 'yes' ? 'selected' : '' %>>Yes</option>
                  <option value="no" <%= _hh === 'no' ? 'selected' : '' %>>No</option>
                </select>
              </div>
              <div class="input-field">
                <label class="input-field__label" for="has_established_year">Established year present</label>
                <select id="has_established_year" name="has_established_year" class="input-field__control">
                  <% var _hey = (filters && filters.hasEstablishedYear) ? filters.hasEstablishedYear : 'all'; %>
                  <option value="all" <%= _hey === 'all' ? 'selected' : '' %>>All</option>
                  <option value="yes" <%= _hey === 'yes' ? 'selected' : '' %>>Yes</option>
                  <option value="no" <%= _hey === 'no' ? 'selected' : '' %>>No</option>
                </select>
              </div>
            </div>
            <div class="form-step__actions admin-gate-actions" style="flex-wrap:wrap;gap:0.5rem;">
              <%- include('../partials/components/button', { variant: 'default', type: 'submit', label: 'Apply filters' }) %>
              <a class="btn btn--secondary" href="/admin/crm/websites/report">Reset</a>
              <a class="btn btn--secondary" href="<%= csvHref %>">Export CSV (default columns)</a>
              <% if (typeof csvHrefModeration !== 'undefined' && csvHrefModeration) { %>
              <a class="btn btn--secondary" href="<%= csvHrefModeration %>">CSV · Moderation</a>
              <a class="btn btn--secondary" href="<%= csvHrefQuality %>">CSV · Quality</a>
              <a class="btn btn--secondary" href="<%= csvHrefPublishReadiness %>">CSV · Publish readiness</a>
              <% } %>
            </div>
          </div>
        </form>

        <% var _rows = Array.isArray(rows) ? rows : []; %>
        <% var _show = (typeof reportHtmlColumnShow !== 'undefined' && reportHtmlColumnShow) ? reportHtmlColumnShow : {}; %>
        <% function _hcol(k) { return _show[k] !== false; } %>
        <% var _colspan = typeof reportHtmlColspan !== 'undefined' ? reportHtmlColspan : 17; %>
        <div class="card admin-table-card">
          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <% if (_hcol('submission')) { %><th>Submission</th><% } %>
                  <% if (_hcol('tenant')) { %><th>Tenant</th><% } %>
                  <% if (_hcol('field_agent')) { %><th>Field agent</th><% } %>
                  <% if (_hcol('review')) { %><th>Review</th><% } %>
                  <% if (_hcol('published')) { %><th>Published</th><% } %>
                  <% if (_hcol('quality')) { %><th>Quality</th><% } %>
                  <% if (_hcol('established')) { %><th>Established</th><% } %>
                  <% if (_hcol('est_set')) { %><th>Est. set</th><% } %>
                  <% if (_hcol('specs')) { %><th>Specs</th><% } %>
                  <% if (_hcol('verified')) { %><th>Verified</th><% } %>
                  <% if (_hcol('hours')) { %><th>Hours</th><% } %>
                  <% if (_hcol('has_hours')) { %><th>Has hours</th><% } %>
                  <% if (_hcol('updated')) { %><th>Updated</th><% } %>
                  <% if (_hcol('submitted')) { %><th>Submitted</th><% } %>
                  <% if (_hcol('published_at')) { %><th>Published at</th><% } %>
                  <% if (_hcol('missing_summary')) { %><th>Missing data</th><% } %>
                  <% if (_hcol('actions')) { %><th>Actions</th><% } %>
                </tr>
              </thead>
              <tbody>
                <% if (!_rows.length) { %>
                  <tr><td colspan="<%= _colspan %>" class="muted">No records for these filters.</td></tr>
                <% } %>
                <% _rows.forEach(function (r) { %>
                  <% var _reviewUrl = '/admin/field-agent/submissions/' + r.submission_id + '/website-listing-review'; %>
                  <% var _queueHref = (r.website_report_queue_href != null && r.website_report_queue_href !== '') ? r.website_report_queue_href : '/admin/crm?queue=websites'; %>
                  <% var _hl = (typeof websiteReportHighlightSubmissionId !== 'undefined' && websiteReportHighlightSubmissionId != null && Number(r.submission_id) === Number(websiteReportHighlightSubmissionId)); %>
                  <tr<% if (_hl) { %> class="website-report-row--highlight"<% } %>>
                    <% if (_hcol('submission')) { %>
                    <td>
                      <a href="<%= _reviewUrl %>">#<%= r.submission_id %></a>
                      <div><%= r.lead_name || 'Unknown lead' %></div>
                      <% if (r.city) { %><div class="muted"><%= r.city %></div><% } %>
                    </td>
                    <% } %>
                    <% if (_hcol('tenant')) { %><td><%= r.tenant_label || '' %></td><% } %>
                    <% if (_hcol('field_agent')) { %><td><%= r.field_agent_label || '' %></td><% } %>
                    <% if (_hcol('review')) { %><td><%= r.review_status %></td><% } %>
                    <% if (_hcol('published')) { %><td><%= r.published %></td><% } %>
                    <% if (_hcol('quality')) { %><td><%= r.quality_score %> (<%= r.quality_tier %>)</td><% } %>
                    <% if (_hcol('established')) { %><td><%= r.established_year != null ? r.established_year : '' %></td><% } %>
                    <% if (_hcol('est_set')) { %><td><%= r.established_year != null ? 'yes' : 'no' %></td><% } %>
                    <% if (_hcol('specs')) { %><td><%= r.specialities_count %></td><% } %>
                    <% if (_hcol('verified')) { %><td><%= r.verified_specialities_count %></td><% } %>
                    <% if (_hcol('hours')) { %><td><%= r.hours_completeness %></td><% } %>
                    <% if (_hcol('has_hours')) { %><td><%= Number(r.hours_days_count || 0) > 0 ? 'yes' : 'no' %></td><% } %>
                    <% if (_hcol('updated')) { %><td><%= r.submission_updated_at ? new Date(r.submission_updated_at).toISOString() : '' %></td><% } %>
                    <% if (_hcol('submitted')) { %><td><%= r.website_listing_review_requested_at ? new Date(r.website_listing_review_requested_at).toISOString() : '' %></td><% } %>
                    <% if (_hcol('published_at')) { %><td><%= r.company_created_at ? new Date(r.company_created_at).toISOString() : '' %></td><% } %>
                    <% if (_hcol('missing_summary')) { %>
                    <td class="muted" style="font-size:0.92em;max-width:14rem;line-height:1.25;">
                      <% if (r.website_report_missing_count > 0) { %>
                      <div><%= r.website_report_missing_count %> gap<%= r.website_report_missing_count === 1 ? '' : 's' %></div>
                      <% if (r.website_report_missing_preview_labels) { %>
                      <div style="margin-top:0.2rem;"><%= r.website_report_missing_preview_labels %><% if (r.website_report_missing_more_count > 0) { %> <span class="muted">(+<%= r.website_report_missing_more_count %> more)</span><% } %></div>
                      <% } %>
                      <% } else { %>
                      —
                      <% } %>
                    </td>
                    <% } %>
                    <% if (_hcol('actions')) { %>
                    <td>
                      <a href="<%= _reviewUrl %>">Open review</a>
                      <span class="muted"> · </span>
                      <a href="<%= String(_queueHref).replace(/&/g, '&amp;') %>">View in queue</a>
                      <% if (r.website_report_missing_slices && r.website_report_missing_slices.length) { %>
                      <div class="muted" style="margin-top:0.35rem;font-size:0.9em;">
                        Missing:
                        <% r.website_report_missing_slices.forEach(function(slice, idx) { %>
                          <% if (idx) { %><span class="muted"> · </span><% } %>
                          <a href="<%= String(slice.href).replace(/&/g, '&amp;') %>"><%= slice.label %></a>
                        <% }); %>
                      </div>
                      <% } %>
                    </td>
                    <% } %>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
