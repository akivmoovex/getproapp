<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Website content report | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
    <style>
      .website-report-row--highlight {
        outline: 2px solid var(--accent, #2563eb);
        outline-offset: -2px;
        background: rgba(37, 99, 235, 0.07);
      }
    </style>
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Website content report', activeNav: 'crm' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <h1 class="section-title">Website content report</h1>
        <p class="admin-intro muted">Operational table for website-content quality and publish state. CSV exports use the same row filters; optional column sets only change which columns are included. HTML column views (<code>view_set</code>) affect the on-screen table only, not CSV.</p>

        <% var _htmlVs = (typeof reportHtmlViewSet !== 'undefined' && reportHtmlViewSet && reportHtmlViewSet !== 'default') ? ('&view_set=' + encodeURIComponent(reportHtmlViewSet)) : ''; %>
        <% var _f = (typeof filters !== 'undefined' && filters) ? filters : {}; %>
        <% var _catPreserve = (_f.category && String(_f.category).trim()) ? ('&category=' + encodeURIComponent(String(_f.category).trim())) : ''; %>
        <% var _cityPreserve = (_f.city && String(_f.city).trim()) ? ('&city=' + encodeURIComponent(String(_f.city).trim())) : ''; %>

        <div class="card admin-form-card" style="padding:0.75rem;margin:0 0 0.75rem;">
          <p class="muted" style="margin:0 0 0.5rem;">Report presets</p>
          <p style="display:flex;gap:0.45rem;flex-wrap:wrap;margin:0;">
            <a class="btn btn--secondary" href="/admin/crm/websites/report?review_status=changes_requested&quality_tier=low<%= _htmlVs %><%= _catPreserve %>">Needs attention</a>
            <a class="btn btn--secondary" href="/admin/crm/websites/report?review_status=changes_requested<%= _htmlVs %><%= _catPreserve %>">Changes requested</a>
            <a class="btn btn--secondary" href="/admin/crm/websites/report?published=yes&quality_tier=high&has_hours=yes&has_verified_specialities=yes<%= _htmlVs %><%= _catPreserve %>">Published and complete</a>
            <a class="btn btn--secondary" href="/admin/crm/websites/report?has_hours=no<%= _htmlVs %><%= _catPreserve %>">Missing hours</a>
            <a class="btn btn--secondary" href="/admin/crm/websites/report?has_established_year=no<%= _htmlVs %><%= _catPreserve %>">No established year</a>
            <a class="btn btn--secondary" href="/admin/crm/websites/report?quality_tier=high<%= _htmlVs %><%= _catPreserve %>">High quality</a>
          </p>
        </div>

        <% if (typeof htmlViewHrefDefault !== 'undefined' && htmlViewHrefDefault) { %>
        <div class="card admin-form-card" style="padding:0.75rem;margin:0 0 0.75rem;">
          <p class="muted" style="margin:0 0 0.5rem;">Table column view (HTML only)</p>
          <p style="display:flex;gap:0.45rem;flex-wrap:wrap;margin:0;">
            <a class="btn <%= (typeof reportHtmlViewSet !== 'undefined' && reportHtmlViewSet === 'default') ? '' : 'btn--secondary' %>" href="<%= htmlViewHrefDefault %>">Default columns</a>
            <a class="btn <%= (typeof reportHtmlViewSet !== 'undefined' && reportHtmlViewSet === 'moderation') ? '' : 'btn--secondary' %>" href="<%= htmlViewHrefModeration %>">Moderation</a>
            <a class="btn <%= (typeof reportHtmlViewSet !== 'undefined' && reportHtmlViewSet === 'quality') ? '' : 'btn--secondary' %>" href="<%= htmlViewHrefQuality %>">Quality</a>
            <a class="btn <%= (typeof reportHtmlViewSet !== 'undefined' && reportHtmlViewSet === 'publish_readiness') ? '' : 'btn--secondary' %>" href="<%= htmlViewHrefPublishReadiness %>">Publish readiness</a>
          </p>
        </div>
        <% } %>

        <% if (typeof websiteReportShareUrl !== 'undefined' && websiteReportShareUrl) { %>
        <div class="card admin-form-card website-share-card website-share-card--copy-wrap website-share-card--focus-a11y website-share-card--group-focus-a11y" style="padding:0.75rem;margin:0 0 0.75rem;max-width:100%;min-width:0;box-sizing:border-box;display:flex;flex-direction:column;gap:0;">
          <div id="website-report-share-copy-live" class="visually-hidden" role="status" aria-live="polite" aria-atomic="true"></div>
          <div style="display:flex;flex-direction:column;gap:0.35rem;">
            <p class="muted" style="margin:0;"><strong>Permalink</strong> — URL for this report (filters + column view).</p>
            <% if (typeof websiteReportShareLabel !== 'undefined' && websiteReportShareLabel) { %>
            <p class="muted" style="margin:0;font-size:0.95em;"><strong>Summary:</strong> <%= websiteReportShareLabel %></p>
            <% } %>
            <p class="muted" style="margin:0;font-size:0.88em;line-height:1.35;">HTML filters and column view only. CSV <code>export_set</code> not included. Not stored — bookmark or copy the URL.</p>
          </div>
          <div class="website-share-a11y-group website-share-a11y-group--permalink" style="padding-top:0.55rem;margin-top:0.35rem;border-top:1px solid var(--line,#e6e8ee);display:flex;flex-direction:column;gap:0.4rem;width:100%;min-width:0;box-sizing:border-box;" role="group" aria-label="Permalink: report URL, copy, and open in new tab">
            <div class="website-share-copy-row" style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:stretch;width:100%;max-width:100%;min-width:0;box-sizing:border-box;">
              <input
                type="text"
                readonly
                class="input-field__control"
                style="flex:1 1 12rem;min-width:0;max-width:100%;cursor:text;box-sizing:border-box;"
                id="website-report-share-url"
                value="<%= websiteReportShareUrl %>"
                onclick="this.select();"
                aria-label="Shareable report URL"
              />
              <button type="button" class="btn btn--primary website-share-copy-btn--primary" id="website-report-share-copy" style="white-space:nowrap;flex-shrink:0;">Copy URL</button>
            </div>
            <% if (typeof websiteReportSharePath !== 'undefined' && websiteReportSharePath) { %>
            <p class="muted" style="margin:0;font-size:0.88em;line-height:1.35;"><a href="<%= String(websiteReportSharePath).replace(/&/g, '&amp;') %>" target="_blank" rel="noopener noreferrer">Open current state in new tab</a></p>
            <% } %>
          </div>
          <% if (typeof websiteReportShareSnippet !== 'undefined' && websiteReportShareSnippet) { %>
          <div class="website-share-a11y-group website-share-a11y-group--snippet" style="padding-top:0.55rem;margin-top:0.35rem;border-top:1px solid var(--line,#e6e8ee);display:flex;flex-direction:column;gap:0.45rem;width:100%;min-width:0;box-sizing:border-box;" role="group" aria-label="Message snippet: text field and copy">
            <p class="muted" style="margin:0;font-size:0.88em;"><strong>Snippet</strong> — summary and URL (plain text).</p>
            <div class="website-share-copy-row" style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:flex-start;width:100%;max-width:100%;min-width:0;box-sizing:border-box;">
              <textarea
                readonly
                class="input-field__control"
                style="flex:1 1 12rem;min-width:0;max-width:100%;min-height:3.25rem;resize:vertical;cursor:text;font-family:inherit;box-sizing:border-box;"
                id="website-report-share-snippet"
                onclick="this.select();"
                aria-label="Shareable report message snippet"
              ><%= websiteReportShareSnippet %></textarea>
              <button type="button" class="btn btn--primary website-share-copy-btn--primary" id="website-report-share-snippet-copy" style="white-space:nowrap;align-self:flex-start;flex-shrink:0;">Copy snippet</button>
            </div>
          </div>
          <% } %>
          <div class="website-share-a11y-group website-share-a11y-group--operational" style="padding-top:0.55rem;margin-top:0.35rem;border-top:1px solid var(--line,#e6e8ee);display:flex;flex-direction:column;gap:0.35rem;width:100%;min-width:0;box-sizing:border-box;" role="group" aria-label="Operational report views: preset links">
            <p class="muted" id="website-report-share-operational-hint" style="margin:0;font-size:0.88em;line-height:1.35;"><strong>Operational share states</strong> — preset filtered views (not saved). Keeps <code>view_set</code>, category, and city when set.</p>
            <p id="website-report-share-operational-states" style="display:flex;gap:0.4rem;flex-wrap:wrap;margin:0;">
              <a class="btn btn--secondary" href="/admin/crm/websites/report?review_status=changes_requested&quality_tier=low<%= _htmlVs %><%= _catPreserve %><%= _cityPreserve %>">Needs attention report</a>
              <a class="btn btn--secondary" href="/admin/crm/websites/report?quality_tier=high<%= _htmlVs %><%= _catPreserve %><%= _cityPreserve %>">High quality report</a>
              <a class="btn btn--secondary" href="/admin/crm/websites/report?has_hours=no<%= _htmlVs %><%= _catPreserve %><%= _cityPreserve %>">Missing hours report</a>
              <a class="btn btn--secondary" href="/admin/crm/websites/report?has_established_year=no<%= _htmlVs %><%= _catPreserve %><%= _cityPreserve %>">No established year report</a>
            </p>
          </div>
          <% var _rpBestMd = typeof websiteReportShareSnippetMarkdown !== 'undefined' && websiteReportShareSnippetMarkdown; %>
          <% var _rpBestChat = typeof websiteReportShareChatSnippet !== 'undefined' && websiteReportShareChatSnippet; %>
          <% var _rpBestEmail = typeof websiteReportShareBundleEmailReady !== 'undefined' && websiteReportShareBundleEmailReady; %>
          <% if (_rpBestMd || _rpBestChat || _rpBestEmail) { %>
          <% var _rpBestShareLbl = (typeof websiteReportShareLabel !== 'undefined' && websiteReportShareLabel) ? String(websiteReportShareLabel).trim() : ''; %>
          <div class="website-share-best-format-shortcuts website-share-a11y-group website-share-a11y-group--best-for" style="padding-top:0.45rem;margin-top:0.25rem;border-top:1px solid var(--line,#e6e8ee);width:100%;min-width:0;box-sizing:border-box;" role="group" aria-label="Best-for copy: Slack, email, and docs shortcuts">
            <p class="muted" id="website-report-share-best-format-hint" style="margin:0 0 0.35rem;font-size:0.82em;line-height:1.35;"><strong>Best for</strong> — same copy as Advanced, one click (Slack / email / docs).</p>
            <p class="muted website-share-best-for-copy-best-legend" id="website-report-share-copy-best-legend" style="margin:0 0 0.38rem;font-size:0.78em;line-height:1.4;"><strong>Copy best</strong> — Slack uses chat bundle; Email uses plain bundle; Docs uses markdown bundle.</p>
            <p id="website-report-share-best-format-actions" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin:0;align-items:flex-start;min-width:0;width:100%;box-sizing:border-box;">
              <% if (_rpBestChat) { %>
              <div class="website-share-best-for-row website-share-best-for-row--slack website-share-a11y-group website-share-a11y-group--best-for-slack" style="display:flex;flex-direction:column;gap:0.24rem;align-items:stretch;max-width:100%;min-width:0;box-sizing:border-box;border:1px solid var(--line,#e6e8ee);border-radius:8px;padding:0.4rem 0.5rem;background:rgba(255,255,255,0.5);" role="group" aria-label="Best-for: Slack — copy and related deep-link fields">
                <div class="website-share-best-for-row__primary" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.45rem;min-width:0;width:100%;box-sizing:border-box;">
                  <strong class="muted" style="font-size:0.76em;font-weight:700;letter-spacing:0.02em;margin:0;">Slack</strong>
                  <button type="button" class="btn btn--primary website-share-copy-btn--primary" id="website-report-share-best-slack-copy" style="font-size:0.83em;padding:0.26em 0.5em;line-height:1.2;white-space:nowrap;" aria-label="Copy best format for Slack (chat snippet)">Copy for Slack</button>
                  <% if (typeof websiteReportShareDeepLinks !== 'undefined' && websiteReportShareDeepLinks && websiteReportShareDeepLinks.chat) { %>
                  <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" id="website-report-share-best-slack-copy-best" style="font-size:0.8em;padding:0.24em 0.48em;line-height:1.2;white-space:nowrap;" aria-label="Copy richest Best-for preset for Slack (chat deep-link bundle)">Copy best</button>
                  <span class="muted website-share-best-for-copy-best-hint" style="font-size:0.74em;line-height:1.25;white-space:nowrap;">uses chat bundle</span>
                  <% } %>
                </div>
              <% if (typeof websiteReportShareDeepLinks !== 'undefined' && websiteReportShareDeepLinks && websiteReportShareDeepLinks.chat) { %>
                <div class="website-share-best-for-row__links" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.35rem;">
              <a id="website-report-share-best-slack-open-source" class="muted" href="<%= websiteReportShareDeepLinks.chat %>" style="font-size:0.82em;line-height:1.2;white-space:nowrap;">Open source</a>
              <input type="text" readonly tabindex="-1" aria-hidden="true" class="input-field__control" style="position:absolute;left:-10000px;width:1px;height:1px;overflow:hidden;opacity:0;" id="website-report-share-best-slack-open-url" value="<%= websiteReportShareDeepLinks.chat %>" />
              <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.82em;padding:0.22em 0.45em;line-height:1.2;white-space:nowrap;" id="website-report-share-best-slack-open-copy" aria-label="Copy Slack advanced-source deep link URL">Copy link</button>
                </div>
                <div class="website-share-best-for-row__bundles" style="display:flex;flex-direction:column;gap:0.2rem;width:100%;min-width:0;">
              <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                <textarea
                  readonly
                  class="input-field__control"
                  style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:2.15rem;max-height:4.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                  id="website-report-share-best-slack-open-bundle"
                  onclick="this.select();"
                  aria-label="Best-for deep-link bundle for Slack (label, target, URL)"
                ><%= _rpBestShareLbl %><% if (_rpBestShareLbl) { %>

<% } %>Best for: Slack
<%= websiteReportShareDeepLinks.chat %></textarea>
                <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-report-share-best-slack-open-bundle-copy" aria-label="Copy best-for deep-link bundle for Slack">Copy bundle</button>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                <textarea
                  readonly
                  class="input-field__control"
                  style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:1.85rem;max-height:3.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                  id="website-report-share-best-slack-open-bundle-md"
                  onclick="this.select();"
                  aria-label="Best-for deep-link bundle for Slack, markdown one-liner"
                ><% if (_rpBestShareLbl) { %>[<%= _rpBestShareLbl %> · Best for: Slack](<%= websiteReportShareDeepLinks.chat %>)<% } else { %>[Best for: Slack](<%= websiteReportShareDeepLinks.chat %>)<% } %></textarea>
                <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-report-share-best-slack-open-bundle-md-copy" aria-label="Copy best-for deep-link bundle for Slack (markdown)">MD</button>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                <textarea
                  readonly
                  class="input-field__control"
                  style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:1.85rem;max-height:3.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                  id="website-report-share-best-slack-open-bundle-chat"
                  onclick="this.select();"
                  aria-label="Best-for deep-link bundle for Slack, chat one-liner"
                ><% if (_rpBestShareLbl) { %><<%= websiteReportShareDeepLinks.chat %>|<%= _rpBestShareLbl %> · Best for: Slack><% } else { %><<%= websiteReportShareDeepLinks.chat %>|Best for: Slack><% } %></textarea>
                <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-report-share-best-slack-open-bundle-chat-copy" aria-label="Copy best-for deep-link bundle for Slack (chat)">Chat</button>
              </div>
                </div>
              <% } %>
              </div>
              <% } %>
              <% if (_rpBestEmail) { %>
              <div class="website-share-best-for-row website-share-best-for-row--email website-share-a11y-group website-share-a11y-group--best-for-email" style="display:flex;flex-direction:column;gap:0.24rem;align-items:stretch;max-width:100%;min-width:0;box-sizing:border-box;border:1px solid var(--line,#e6e8ee);border-radius:8px;padding:0.4rem 0.5rem;background:rgba(255,255,255,0.5);" role="group" aria-label="Best-for: Email — copy and related deep-link fields">
                <div class="website-share-best-for-row__primary" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.45rem;min-width:0;width:100%;box-sizing:border-box;">
                  <strong class="muted" style="font-size:0.76em;font-weight:700;letter-spacing:0.02em;margin:0;">Email</strong>
                  <button type="button" class="btn btn--primary website-share-copy-btn--primary" id="website-report-share-best-email-copy" style="font-size:0.83em;padding:0.26em 0.5em;line-height:1.2;white-space:nowrap;" aria-label="Copy best format for email (email-ready bundle)">Copy for Email</button>
                  <% if (typeof websiteReportShareDeepLinks !== 'undefined' && websiteReportShareDeepLinks && websiteReportShareDeepLinks.bundles) { %>
                  <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" id="website-report-share-best-email-copy-best" style="font-size:0.8em;padding:0.24em 0.48em;line-height:1.2;white-space:nowrap;" aria-label="Copy richest Best-for preset for Email (plain deep-link bundle)">Copy best</button>
                  <span class="muted website-share-best-for-copy-best-hint" style="font-size:0.74em;line-height:1.25;white-space:nowrap;">uses plain bundle</span>
                  <% } %>
                </div>
              <% if (typeof websiteReportShareDeepLinks !== 'undefined' && websiteReportShareDeepLinks && websiteReportShareDeepLinks.bundles) { %>
                <div class="website-share-best-for-row__links" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.35rem;">
              <a id="website-report-share-best-email-open-source" class="muted" href="<%= websiteReportShareDeepLinks.bundles %>" style="font-size:0.82em;line-height:1.2;white-space:nowrap;">Open source</a>
              <input type="text" readonly tabindex="-1" aria-hidden="true" class="input-field__control" style="position:absolute;left:-10000px;width:1px;height:1px;overflow:hidden;opacity:0;" id="website-report-share-best-email-open-url" value="<%= websiteReportShareDeepLinks.bundles %>" />
              <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.82em;padding:0.22em 0.45em;line-height:1.2;white-space:nowrap;" id="website-report-share-best-email-open-copy" aria-label="Copy email bundles advanced-source deep link URL">Copy link</button>
                </div>
                <div class="website-share-best-for-row__bundles" style="display:flex;flex-direction:column;gap:0.2rem;width:100%;min-width:0;">
              <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                <textarea
                  readonly
                  class="input-field__control"
                  style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:2.15rem;max-height:4.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                  id="website-report-share-best-email-open-bundle"
                  onclick="this.select();"
                  aria-label="Best-for deep-link bundle for Email (label, target, URL)"
                ><%= _rpBestShareLbl %><% if (_rpBestShareLbl) { %>

<% } %>Best for: Email
<%= websiteReportShareDeepLinks.bundles %></textarea>
                <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-report-share-best-email-open-bundle-copy" aria-label="Copy best-for deep-link bundle for Email">Copy bundle</button>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                <textarea
                  readonly
                  class="input-field__control"
                  style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:1.85rem;max-height:3.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                  id="website-report-share-best-email-open-bundle-md"
                  onclick="this.select();"
                  aria-label="Best-for deep-link bundle for Email, markdown one-liner"
                ><% if (_rpBestShareLbl) { %>[<%= _rpBestShareLbl %> · Best for: Email](<%= websiteReportShareDeepLinks.bundles %>)<% } else { %>[Best for: Email](<%= websiteReportShareDeepLinks.bundles %>)<% } %></textarea>
                <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-report-share-best-email-open-bundle-md-copy" aria-label="Copy best-for deep-link bundle for Email (markdown)">MD</button>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                <textarea
                  readonly
                  class="input-field__control"
                  style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:1.85rem;max-height:3.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                  id="website-report-share-best-email-open-bundle-chat"
                  onclick="this.select();"
                  aria-label="Best-for deep-link bundle for Email, chat one-liner"
                ><% if (_rpBestShareLbl) { %><<%= websiteReportShareDeepLinks.bundles %>|<%= _rpBestShareLbl %> · Best for: Email><% } else { %><<%= websiteReportShareDeepLinks.bundles %>|Best for: Email><% } %></textarea>
                <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-report-share-best-email-open-bundle-chat-copy" aria-label="Copy best-for deep-link bundle for Email (chat)">Chat</button>
              </div>
                </div>
              <% } %>
