        <script>
          (function () {
            var WEBSITE_SHARE_COPY_OK_MS = 2000;
            var WEBSITE_SHARE_COPY_FAIL_MS = 2500;
            var copyLiveEl = document.getElementById("website-report-share-copy-live");
            function clearCopyLiveForNewAttempt() {
              if (!copyLiveEl) return;
              if (copyLiveEl._copyLiveRearmTimer) {
                clearTimeout(copyLiveEl._copyLiveRearmTimer);
                copyLiveEl._copyLiveRearmTimer = null;
              }
              copyLiveEl.textContent = "";
            }
            function setCopyLiveAnnounce(msg) {
              if (!copyLiveEl) return;
              if (copyLiveEl._copyLiveRearmTimer) {
                clearTimeout(copyLiveEl._copyLiveRearmTimer);
                copyLiveEl._copyLiveRearmTimer = null;
              }
              copyLiveEl.textContent = "";
              copyLiveEl._copyLiveRearmTimer = setTimeout(function () {
                if (copyLiveEl) copyLiveEl.textContent = msg;
                copyLiveEl._copyLiveRearmTimer = null;
              }, 0);
            }
            function resetAllCopyButtonStatesInShareCard(fromBtn) {
              var card = fromBtn && fromBtn.closest && fromBtn.closest(".website-share-card");
              if (!card) return;
              var nodes = card.querySelectorAll("button");
              for (var i = 0; i < nodes.length; i++) {
                var b = nodes[i];
                if (b._websiteShareCopyTimer) {
                  clearTimeout(b._websiteShareCopyTimer);
                  b._websiteShareCopyTimer = null;
                }
                var saved = b.getAttribute("data-website-share-copy-label");
                if (saved) {
                  b.textContent = saved;
                }
                b.removeAttribute("aria-busy");
                b.classList.remove("website-share-copy-btn--busy", "website-share-copy-btn--copied-state", "website-share-copy-btn--failed-state");
              }
            }
            function applyCopyButtonFeedback(btn, mode, orig) {
              if (!btn) return;
              if (btn._websiteShareCopyTimer) {
                clearTimeout(btn._websiteShareCopyTimer);
                btn._websiteShareCopyTimer = null;
              }
              btn.removeAttribute("aria-busy");
              btn.classList.remove("website-share-copy-btn--busy", "website-share-copy-btn--copied-state", "website-share-copy-btn--failed-state");
              if (mode === "ok") {
                setCopyLiveAnnounce("Copied");
                btn.textContent = "Copied";
                btn.classList.add("website-share-copy-btn--copied-state");
                btn._websiteShareCopyTimer = setTimeout(function () {
                  if (!btn) return;
                  if (btn.isConnected === false) {
                    btn._websiteShareCopyTimer = null;
                    return;
                  }
                  btn.textContent = orig;
                  btn.classList.remove("website-share-copy-btn--copied-state");
                  btn._websiteShareCopyTimer = null;
                }, WEBSITE_SHARE_COPY_OK_MS);
              } else {
                setCopyLiveAnnounce("Select and copy");
                btn.textContent = "Select and copy";
                btn.classList.add("website-share-copy-btn--failed-state");
                btn._websiteShareCopyTimer = setTimeout(function () {
                  if (!btn) return;
                  if (btn.isConnected === false) {
                    btn._websiteShareCopyTimer = null;
                    return;
                  }
                  btn.textContent = orig;
                  btn.classList.remove("website-share-copy-btn--failed-state");
                  btn._websiteShareCopyTimer = null;
                }, WEBSITE_SHARE_COPY_FAIL_MS);
              }
            }
            function wireCopy(btnId, fieldId) {
              var btn = document.getElementById(btnId);
              var field = document.getElementById(fieldId);
              if (!btn || !field) return;
              btn.addEventListener("click", function () {
                resetAllCopyButtonStatesInShareCard(btn);
                clearCopyLiveForNewAttempt();
                if (!btn.getAttribute("data-website-share-copy-label")) {
                  btn.setAttribute("data-website-share-copy-label", String(btn.textContent).replace(/\s+/g, " ").trim());
                }
                var orig = btn.getAttribute("data-website-share-copy-label");
                field.focus();
                if (field.select) field.select();
                try {
                  if (field.setSelectionRange) field.setSelectionRange(0, (field.value != null ? String(field.value) : "").length);
                } catch (e) {}
                btn.setAttribute("aria-busy", "true");
                btn.classList.add("website-share-copy-btn--busy");
                var val = field.value != null ? String(field.value) : "";
                var writeText = navigator.clipboard && navigator.clipboard.writeText;
                if (typeof writeText !== "function") {
                  applyCopyButtonFeedback(btn, "fail", orig);
                  return;
                }
                var p;
                try {
                  p = writeText.call(navigator.clipboard, val);
                } catch (e) {
                  applyCopyButtonFeedback(btn, "fail", orig);
                  return;
                }
                if (p && typeof p.then === "function") {
                  p.then(function () {
                    if (!btn || btn.isConnected === false) return;
                    applyCopyButtonFeedback(btn, "ok", orig);
                  }).catch(function () {
                    if (!btn || btn.isConnected === false) return;
                    applyCopyButtonFeedback(btn, "fail", orig);
                  });
                } else {
                  applyCopyButtonFeedback(btn, "fail", orig);
                }
              });
            }
            wireCopy("website-report-share-copy", "website-report-share-url");
            wireCopy("website-report-share-snippet-copy", "website-report-share-snippet");
            wireCopy("website-report-share-snippet-md-copy", "website-report-share-snippet-md");
            wireCopy("website-report-share-chat-copy", "website-report-share-chat-snippet");
            wireCopy("website-report-share-named-copy", "website-report-share-named");
            wireCopy("website-report-share-email-subject-copy", "website-report-share-email-subject");
            wireCopy("website-report-share-email-body-copy", "website-report-share-email-body");
            wireCopy("website-report-share-bundle-all-copy", "website-report-share-bundle-all");
            wireCopy("website-report-share-bundle-quick-copy", "website-report-share-bundle-quick");
            wireCopy("website-report-share-bundle-email-copy", "website-report-share-bundle-email");
            wireCopy("website-report-share-bundle-chat-copy", "website-report-share-bundle-chat");
            wireCopy("website-report-share-best-slack-copy", "website-report-share-chat-snippet");
            wireCopy("website-report-share-best-slack-copy-best", "website-report-share-best-slack-open-bundle-chat");
            wireCopy("website-report-share-best-email-copy", "website-report-share-bundle-email");
            wireCopy("website-report-share-best-email-copy-best", "website-report-share-best-email-open-bundle");
            wireCopy("website-report-share-best-docs-copy", "website-report-share-snippet-md");
            wireCopy("website-report-share-best-docs-copy-best", "website-report-share-best-docs-open-bundle-md");
            wireCopy("website-report-share-best-slack-open-copy", "website-report-share-best-slack-open-url");
            wireCopy("website-report-share-best-email-open-copy", "website-report-share-best-email-open-url");
            wireCopy("website-report-share-best-docs-open-copy", "website-report-share-best-docs-open-url");
            wireCopy("website-report-share-best-slack-open-bundle-copy", "website-report-share-best-slack-open-bundle");
            wireCopy("website-report-share-best-slack-open-bundle-md-copy", "website-report-share-best-slack-open-bundle-md");
            wireCopy("website-report-share-best-slack-open-bundle-chat-copy", "website-report-share-best-slack-open-bundle-chat");
            wireCopy("website-report-share-best-email-open-bundle-copy", "website-report-share-best-email-open-bundle");
            wireCopy("website-report-share-best-email-open-bundle-md-copy", "website-report-share-best-email-open-bundle-md");
            wireCopy("website-report-share-best-email-open-bundle-chat-copy", "website-report-share-best-email-open-bundle-chat");
            wireCopy("website-report-share-best-docs-open-bundle-copy", "website-report-share-best-docs-open-bundle");
            wireCopy("website-report-share-best-docs-open-bundle-md-copy", "website-report-share-best-docs-open-bundle-md");
            wireCopy("website-report-share-best-docs-open-bundle-chat-copy", "website-report-share-best-docs-open-bundle-chat");
            wireCopy("website-report-share-direct-markdown-copy", "website-report-share-direct-markdown-url");
            wireCopy("website-report-share-direct-chat-copy", "website-report-share-direct-chat-url");
            wireCopy("website-report-share-direct-named-copy", "website-report-share-direct-named-url");
            wireCopy("website-report-share-direct-email-copy", "website-report-share-direct-email-url");
            wireCopy("website-report-share-direct-bundles-copy", "website-report-share-direct-bundles-url");
            wireCopy("website-report-share-direct-markdown-bundle-copy", "website-report-share-direct-markdown-bundle");
            wireCopy("website-report-share-direct-chat-bundle-copy", "website-report-share-direct-chat-bundle");
            wireCopy("website-report-share-direct-named-bundle-copy", "website-report-share-direct-named-bundle");
            wireCopy("website-report-share-direct-email-bundle-copy", "website-report-share-direct-email-bundle");
            wireCopy("website-report-share-direct-bundles-bundle-copy", "website-report-share-direct-bundles-bundle");
            wireCopy("website-report-share-advanced-target-preset-markdown-snippet-copy", "website-report-share-advanced-target-preset-markdown-snippet");
            wireCopy("website-report-share-advanced-target-preset-chat-snippet-copy", "website-report-share-advanced-target-preset-chat-snippet");
            wireCopy("website-report-share-advanced-target-preset-named-snippet-copy", "website-report-share-advanced-target-preset-named-snippet");
            wireCopy("website-report-share-advanced-target-preset-email-snippet-copy", "website-report-share-advanced-target-preset-email-snippet");
            wireCopy("website-report-share-advanced-target-preset-bundles-snippet-copy", "website-report-share-advanced-target-preset-bundles-snippet");
            wireCopy("website-report-share-advanced-target-preset-markdown-snippet-md-copy", "website-report-share-advanced-target-preset-markdown-snippet-md");
            wireCopy("website-report-share-advanced-target-preset-markdown-snippet-chat-copy", "website-report-share-advanced-target-preset-markdown-snippet-chat");
            wireCopy("website-report-share-advanced-target-preset-chat-snippet-md-copy", "website-report-share-advanced-target-preset-chat-snippet-md");
            wireCopy("website-report-share-advanced-target-preset-chat-snippet-chat-copy", "website-report-share-advanced-target-preset-chat-snippet-chat");
            wireCopy("website-report-share-advanced-target-preset-named-snippet-md-copy", "website-report-share-advanced-target-preset-named-snippet-md");
            wireCopy("website-report-share-advanced-target-preset-named-snippet-chat-copy", "website-report-share-advanced-target-preset-named-snippet-chat");
            wireCopy("website-report-share-advanced-target-preset-email-snippet-md-copy", "website-report-share-advanced-target-preset-email-snippet-md");
            wireCopy("website-report-share-advanced-target-preset-email-snippet-chat-copy", "website-report-share-advanced-target-preset-email-snippet-chat");
