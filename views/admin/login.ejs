<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <%- include('../partials/theme_boot') %>
    <title>Admin Login | <%= _bn %></title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-gate-page">
    <div class="container admin-gate-wrap">
      <div class="card admin-gate-card">
        <a href="/login" class="admin-gate-brand">
          <div class="logo" aria-hidden="true"></div>
          <div>
            <div class="admin-gate-brand__title"><%= _bn %> Admin</div>
            <div class="admin-gate-brand__subtitle">Sign in to manage categories, listings, and leads.</div>
          </div>
        </a>
        <%- include('../partials/admin_gate_form', { formAction: '/admin/login', error: error, cancelHref: typeof cancelHref !== 'undefined' ? cancelHref : '/' }) %>
      </div>
    </div>
    <%- include('../partials/theme_prefs') %>
  </body>
</html>
