<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Leads | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Lead reports', activeNav: 'leads' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <h1 class="section-title section-title--flush">Potential partners — “Call me”</h1>
      <p class="admin-intro">Join exit modal — <strong>this region only</strong>.</p>
      <div class="card card--mb-xl">
        <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Label</th>
              <th>Name</th>
              <th>Phone</th>
              <th>Context</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <% if (!partnerCallbacks || partnerCallbacks.length === 0) { %>
              <tr><td colspan="5" class="muted">No callback requests yet.</td></tr>
            <% } %>
            <% (partnerCallbacks || []).forEach(function(c) { %>
              <tr>
                <td><%= c.interest_label || 'Potential Partner' %></td>
                <td><%= c.name %></td>
                <td><%= c.phone %></td>
                <td class="muted"><%= c.context %></td>
                <td class="muted"><%- include('../partials/event_time', { at: c.created_at }) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>

      <h2 class="section-title">Join sign-ups (full wizard)</h2>
      <p class="admin-intro">Completed partner applications from the Join page for this region.</p>
      <div class="card card--mb-xl">
        <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Profession</th>
              <th>City</th>
              <th>Name</th>
              <th>Phone</th>
              <th>VAT / PACRA</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <% if (!partnerSignups || partnerSignups.length === 0) { %>
              <tr><td colspan="6" class="muted">No join sign-ups yet.</td></tr>
            <% } %>
            <% (partnerSignups || []).forEach(function(s) { %>
              <tr>
                <td><%= s.profession %></td>
                <td><%= s.city %></td>
                <td><%= s.name %></td>
                <td><%= s.phone %></td>
                <td class="muted"><%= s.vat_or_pacra %></td>
                <td class="muted"><%- include('../partials/event_time', { at: s.created_at }) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>

      <% if (!embed) { %>
      <h2 class="section-title">Company lead requests</h2>
      <p class="admin-intro">Messages from company profile pages.</p>

      <div class="card card--mb-md">
        <form method="get" action="/admin/leads" class="flex-row-end">
          <div class="flex-1-min">
            <label for="company_id">Filter by company</label>
            <select id="company_id" name="company_id">
              <option value="">All companies</option>
              <% companies.forEach(function(c) { %>
                <option value="<%= c.id %>" <%= selectedCompanyId && Number(selectedCompanyId) === c.id ? 'selected' : '' %>>
                  <%= c.name %> (@<%= c.subdomain %>)
                </option>
              <% }) %>
            </select>
          </div>
          <button class="btn btn-primary" type="submit">Apply</button>
        </form>
      </div>

      <div class="card">
        <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Company</th>
              <th>Name</th>
              <th>Phone</th>
              <th>Email</th>
              <th>Message</th>
              <th>Status</th>
              <th>Time</th>
              <% if (typeof adminNav !== 'undefined' && adminNav.canEditDirectory) { %><th>Actions</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% if (!leads || leads.length === 0) { %>
              <tr><td colspan="<%= typeof adminNav !== 'undefined' && adminNav.canEditDirectory ? 8 : 7 %>" class="muted">No company leads yet.</td></tr>
            <% } %>
            <% (leads || []).forEach(function(l) { %>
              <tr>
                <td>
                  <div class="u-text-strong"><%= l.company_name %></div>
                  <div class="muted">@<%= l.company_subdomain %></div>
                </td>
                <td><%= l.name %></td>
                <td><%= l.phone %></td>
                <td><%= l.email %></td>
                <td><%= l.message %></td>
                <td><%= typeof leadStatusLabel === 'function' ? leadStatusLabel(l.status) : l.status %></td>
                <td class="muted"><%- include('../partials/event_time', { at: l.created_at }) %></td>
                <% if (typeof adminNav !== 'undefined' && adminNav.canEditDirectory) { %>
                  <td><a class="btn" href="/admin/leads/<%= l.id %>/edit">Edit</a></td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      <% } %>

      </div>
    </main>
  </body>
</html>
