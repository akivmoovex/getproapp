<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>New user | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'New tenant user', activeNav: 'users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% if (error) { %>
        <div class="flash" role="alert"><%= error %></div>
      <% } %>

      <div class="card admin-form-card">
        <form method="post" action="/admin/users" class="form">
          <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
          <div class="form-step form-step--admin">
            <div class="form-step__body">
              <div class="input-field">
                <label for="username" class="input-field__label">Username</label>
                <input id="username" name="username" class="input-field__control" autocomplete="username" required />
              </div>
              <div class="input-field">
                <label for="password" class="input-field__label">Password</label>
                <input id="password" name="password" class="input-field__control" type="password" autocomplete="new-password" required minlength="8" />
                <p class="input-field__help">At least 8 characters.</p>
              </div>
              <div class="input-field">
                <label for="role" class="input-field__label">Role</label>
                <select id="role" name="role" class="input-field__control">
                  <option value="tenant_manager">tenant_manager — create users, edit directory</option>
                  <option value="tenant_editor" selected>tenant_editor — edit directory data</option>
                  <option value="tenant_agent">tenant_agent — CRM tasks (claim &amp; update)</option>
                  <option value="tenant_viewer">tenant_viewer — reports only (dashboard + leads)</option>
                </select>
              </div>
              <p class="input-field__help muted admin-zm-phone-note">
                New users belong to tenant <strong>#<%= tenantId %></strong>. Super admin accounts are not created here.
              </p>
            </div>
            <div class="form-step__actions admin-gate-actions">
              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Create user' }) %>
              <%- include('../partials/components/button', { variant: 'text', href: '/admin/users', label: 'Cancel' }) %>
            </div>
          </div>
        </form>
      </div>
      </div>
    </main>
  </body>
</html>
