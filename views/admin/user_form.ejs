<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>New user | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'New tenant user', activeNav: 'users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% if (error) { %>
        <div class="flash" role="alert"><%= error %></div>
      <% } %>

      <div class="card admin-form-card">
        <form method="post" action="/admin/users" class="form">
          <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
          <div>
            <label for="username">Username</label>
            <input id="username" name="username" autocomplete="username" required />
          </div>
          <div>
            <label for="password">Password</label>
            <input id="password" name="password" type="password" autocomplete="new-password" required minlength="8" />
            <div class="admin-field-hint">At least 8 characters.</div>
          </div>
          <div>
            <label for="role">Role</label>
            <select id="role" name="role">
              <option value="tenant_manager">tenant_manager — create users, edit directory</option>
              <option value="tenant_editor" selected>tenant_editor — edit directory data</option>
              <option value="tenant_agent">tenant_agent — CRM tasks (claim &amp; update)</option>
              <option value="tenant_viewer">tenant_viewer — reports only (dashboard + leads)</option>
            </select>
          </div>
          <div class="muted admin-zm-phone-note">
            New users belong to tenant <strong>#<%= tenantId %></strong>. Super admin accounts are not created here.
          </div>
          <div class="admin-gate-actions">
            <button class="btn btn--primary" type="submit">Create user</button>
            <a class="btn" href="/admin/users">Cancel</a>
          </div>
        </form>
      </div>
      </div>
    </main>
  </body>
</html>
