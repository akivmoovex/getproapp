<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Project saved | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
    <style>
      .intake-success-carousel { display: flex; gap: 0.5rem; overflow-x: auto; padding: 0.75rem 0; }
      .intake-success-carousel a { flex-shrink: 0; }
      .intake-success-carousel img { height: 160px; width: auto; border-radius: 4px; object-fit: cover; display: block; }
    </style>
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: navTitle || 'Project saved', activeNav: activeNav || 'project_intake' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <div class="card admin-form-card">
          <h1 class="admin-form-card__title">Project recorded</h1>
          <p class="muted" style="margin-bottom:0.35rem;">Project code</p>
          <div class="admin-intake-code" aria-label="Project code"><%= project.project_code %></div>
          <p class="muted" style="margin-top:0.75rem;margin-bottom:0.35rem;">Client code</p>
          <div class="admin-intake-code" aria-label="Client code"><%= project.client_code %></div>
          <p style="margin-top:0.75rem;"><strong><%= project.client_name %></strong></p>
          <p class="muted">External ref: <%= project.external_client_reference %> · Phone: <%= project.client_phone %> (snapshot from save)</p>
          <p><span class="muted">Project status:</span> <strong><%= typeof projectStatusLabel !== 'undefined' ? projectStatusLabel : project.status %></strong><% if (typeof projectStatusLabel !== 'undefined' && projectStatusLabel !== project.status) { %> <span class="muted">(<%= project.status %>)</span><% } %></p>
          <p>City: <strong><%= project.city %></strong> · Budget: <% if (project.estimated_budget_value != null) { %><%= budget.displayPrefix %> <%= project.estimated_budget_value %><% } else { %>—<% } %></p>
        </div>

        <% var _pv = typeof publishValidation !== 'undefined' && publishValidation ? publishValidation : { ok: true, errors: [], warnings: [] }; %>
        <% var _canPub = typeof showPublishOnSuccess !== 'undefined' && showPublishOnSuccess && typeof adminNav !== 'undefined' && adminNav.canMutateProjectIntake; %>
        <div class="card admin-form-card" style="margin-top:1rem;">
          <h2 class="admin-form-card__title">Publishing checklist</h2>
          <p class="muted" style="margin-top:0;">Assigned companies only see this lead in the company portal after you <strong>publish</strong>. Stage 1 does not auto-allocate providers.</p>
          <% if (_pv.errors && _pv.errors.length) { %>
            <ul class="intake-publish-warnings" role="list">
              <% _pv.errors.forEach(function (e) { %>
                <li class="flash" role="alert" style="margin-bottom:0.35rem;"><%= e.message %></li>
              <% }); %>
            </ul>
          <% } else { %>
            <p class="flash flash--success" role="status">All required fields for publishing are satisfied.</p>
          <% } %>
          <% if (_canPub) { %>
            <form method="post" action="/admin/project-intake/projects/<%= project.id %>/publish" class="form" style="margin-top:1rem;">
              <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Publish project', disabled: !_pv.ok, extraAttrs: !_pv.ok ? 'aria-disabled="true"' : '' }) %>
              <% if (!_pv.ok) { %>
                <p class="muted" style="margin-top:0.5rem;">Fix the issues using <strong>Quick edit</strong> on <a href="/admin/projects/<%= project.id %>">project detail</a>, or adjust intake rules in <code>intake_allocation_settings</code>.</p>
              <% } %>
            </form>
          <% } else if (typeof adminNav !== 'undefined' && !adminNav.canMutateProjectIntake) { %>
            <p class="muted">Read-only: publishing is disabled for your role.</p>
          <% } %>
        </div>

        <% if (images && images.length) { %>
        <div class="card admin-form-card" style="margin-top:1rem;">
          <h2 class="admin-form-card__title">Photos</h2>
          <div class="intake-success-carousel">
            <% images.forEach(function (im) { %>
              <a href="/admin/project-intake/files/<%= im.id %><%= typeof embed !== 'undefined' && embed ? '?embed=1' : '' %>" target="_blank" rel="noopener">
                <img src="/admin/project-intake/files/<%= im.id %><%= typeof embed !== 'undefined' && embed ? '?embed=1' : '' %>" alt="" loading="lazy" />
              </a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <p style="margin-top:1rem;">
          <%- include('../partials/components/button', { variant: 'default', href: '/admin/projects/' + project.id, label: 'Open project detail' }) %>
          <%- include('../partials/components/button', { variant: 'primary', href: '/admin/project-intake' + (typeof embed !== 'undefined' && embed ? '?embed=1' : ''), label: 'Another project' }) %>
        </p>
      </div>
    </main>
  </body>
</html>
