<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Project saved | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
    <style>
      .intake-success-carousel { display: flex; gap: 0.5rem; overflow-x: auto; padding: 0.75rem 0; }
      .intake-success-carousel a { flex-shrink: 0; }
      .intake-success-carousel img { height: 160px; width: auto; border-radius: 4px; object-fit: cover; display: block; }
    </style>
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: navTitle || 'Project saved', activeNav: activeNav || 'project_intake' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <div class="card admin-form-card">
          <h1 class="admin-form-card__title">Project recorded</h1>
          <p class="muted" style="margin-bottom:0.35rem;">Project code</p>
          <div class="admin-intake-code" aria-label="Project code"><%= project.project_code %></div>
          <p class="muted" style="margin-top:0.75rem;margin-bottom:0.35rem;">Client code</p>
          <div class="admin-intake-code" aria-label="Client code"><%= project.client_code %></div>
          <p style="margin-top:0.75rem;"><strong><%= project.client_name %></strong></p>
          <p class="muted">External ref: <%= project.external_client_reference %> · Phone: <%= project.client_phone %> (snapshot from save)</p>
          <p><span class="muted">Project status:</span> <strong><%= typeof projectStatusLabel !== 'undefined' ? projectStatusLabel : project.status %></strong><% if (typeof projectStatusLabel !== 'undefined' && projectStatusLabel !== project.status) { %> <span class="muted">(<%= project.status %>)</span><% } %></p>
          <p>City: <strong><%= project.city %></strong> · Budget: <% if (project.estimated_budget_value != null) { %><%= budget.displayPrefix %> <%= project.estimated_budget_value %><% } else { %>—<% } %></p>
        </div>

        <% if (images && images.length) { %>
        <div class="card admin-form-card" style="margin-top:1rem;">
          <h2 class="admin-form-card__title">Photos</h2>
          <div class="intake-success-carousel">
            <% images.forEach(function (im) { %>
              <a href="/admin/project-intake/files/<%= im.id %><%= typeof embed !== 'undefined' && embed ? '?embed=1' : '' %>" target="_blank" rel="noopener">
                <img src="/admin/project-intake/files/<%= im.id %><%= typeof embed !== 'undefined' && embed ? '?embed=1' : '' %>" alt="" loading="lazy" />
              </a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <p style="margin-top:1rem;">
          <a class="btn btn--primary" href="/admin/project-intake<%= typeof embed !== 'undefined' && embed ? '?embed=1' : '' %>">Another project</a>
        </p>
      </div>
    </main>
  </body>
</html>
