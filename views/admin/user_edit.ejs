<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Edit user | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Edit tenant user', activeNav: 'users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% if (error) { %>
        <div class="flash" role="alert"><%= error %></div>
      <% } %>
      <% if (typeof saved !== 'undefined' && saved) { %>
        <div class="flash flash--success" role="status" aria-live="polite">Changes saved.</div>
      <% } %>

      <div class="card admin-form-card">
        <div class="admin-form-shell is-read-mode" data-admin-form-edit>
          <div class="admin-form-shell__toolbar admin-form-shell__toolbar--split">
            <%- include('../partials/components/button', { variant: 'text', href: '/admin/users' + (typeof embed !== 'undefined' && embed ? '?embed=1' : ''), label: '← Users', className: 'admin-form-shell__back' }) %>
            <p class="admin-form-shell__unsaved" hidden>Unsaved changes</p>
            <div class="admin-form-shell__toolbar-end">
              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Done', hidden: true, className: 'admin-form-shell__btn--done' }) %>
              <%- include('../partials/components/button', { variant: 'text', type: 'button', label: 'Cancel', hidden: true, className: 'admin-form-shell__btn--cancel' }) %>
              <%- include('../partials/components/button', { variant: 'default', type: 'button', label: 'Edit', className: 'admin-form-shell__btn--edit' }) %>
            </div>
          </div>
          <form method="post" action="/admin/users/<%= user.id %>" class="form">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <div class="form-step form-step--admin">
              <div class="form-step__body">
                <div class="input-field">
                  <label for="username" class="input-field__label">Username</label>
                  <input id="username" name="username" class="input-field__control" value="<%= user.username %>" autocomplete="username" required />
                </div>
                <div class="input-field">
                  <label for="password" class="input-field__label">New password (optional)</label>
                  <input id="password" name="password" class="input-field__control" type="password" autocomplete="new-password" minlength="8" />
                  <p class="input-field__help">Leave blank to keep the current password. Minimum 8 characters if set.</p>
                </div>
                <div class="input-field">
                  <label for="role" class="input-field__label">Role</label>
                  <select id="role" name="role" class="input-field__control">
                    <option value="tenant_manager" <%= user.role === 'tenant_manager' ? 'selected' : '' %>>tenant_manager</option>
                    <option value="csr" <%= user.role === 'csr' ? 'selected' : '' %>>csr</option>
                    <option value="tenant_editor" <%= user.role === 'tenant_editor' ? 'selected' : '' %>>tenant_editor</option>
                    <option value="tenant_agent" <%= user.role === 'tenant_agent' ? 'selected' : '' %>>tenant_agent</option>
                    <option value="tenant_viewer" <%= user.role === 'tenant_viewer' ? 'selected' : '' %>>tenant_viewer</option>
                    <option value="finance_viewer" <%= user.role === 'finance_viewer' ? 'selected' : '' %>>finance_viewer</option>
                    <option value="finance_operator" <%= user.role === 'finance_operator' ? 'selected' : '' %>>finance_operator</option>
                    <option value="finance_manager" <%= user.role === 'finance_manager' ? 'selected' : '' %>>finance_manager</option>
                  </select>
                </div>
                <div class="input-field">
                  <label class="form-check">
                    <input type="checkbox" name="enabled" value="1" <%= user.enabled !== 0 ? 'checked' : '' %> />
                    Account enabled (can sign in)
                  </label>
                </div>
              </div>
            </div>
          </form>
        </div>

        <% if (typeof currentUserId !== 'undefined' && user.id !== currentUserId) { %>
        <form method="post" action="/admin/users/<%= user.id %>/delete" class="form--delete" onsubmit="return confirm('Delete this user permanently?');">
          <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
          <%- include('../partials/components/button', { variant: 'danger-outline', type: 'submit', label: 'Delete user' }) %>
        </form>
        <% } %>
      </div>
      </div>
    </main>
    <script src="<%= asset('admin-form-edit-mode') %>"></script>
  </body>
</html>
