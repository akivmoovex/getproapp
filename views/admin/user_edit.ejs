<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Edit user | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Edit tenant user', activeNav: 'users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% if (error) { %>
        <div class="flash" role="alert"><%= error %></div>
      <% } %>

      <div class="card admin-form-card">
        <form method="post" action="/admin/users/<%= user.id %>" class="form">
          <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
          <div>
            <label for="username">Username</label>
            <input id="username" name="username" value="<%= user.username %>" autocomplete="username" required />
          </div>
          <div>
            <label for="password">New password (optional)</label>
            <input id="password" name="password" type="password" autocomplete="new-password" minlength="8" />
            <div class="admin-field-hint">Leave blank to keep the current password. Minimum 8 characters if set.</div>
          </div>
          <div>
            <label for="role">Role</label>
            <select id="role" name="role">
              <option value="tenant_manager" <%= user.role === 'tenant_manager' ? 'selected' : '' %>>tenant_manager</option>
              <option value="tenant_editor" <%= user.role === 'tenant_editor' ? 'selected' : '' %>>tenant_editor</option>
              <option value="tenant_agent" <%= user.role === 'tenant_agent' ? 'selected' : '' %>>tenant_agent</option>
              <option value="tenant_viewer" <%= user.role === 'tenant_viewer' ? 'selected' : '' %>>tenant_viewer</option>
            </select>
          </div>
          <div>
            <label class="form-check">
              <input type="checkbox" name="enabled" value="1" <%= user.enabled !== 0 ? 'checked' : '' %> />
              Account enabled (can sign in)
            </label>
          </div>
          <div class="admin-gate-actions">
            <button class="btn btn-primary" type="submit">Save changes</button>
            <a class="btn" href="/admin/users<%= typeof embed !== 'undefined' && embed ? '?embed=1' : '' %>">Cancel</a>
          </div>
        </form>

        <% if (typeof currentUserId !== 'undefined' && user.id !== currentUserId) { %>
        <form method="post" action="/admin/users/<%= user.id %>/delete" class="form--delete" onsubmit="return confirm('Delete this user permanently?');">
          <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
          <button class="btn btn--danger-outline" type="submit">Delete user</button>
        </form>
        <% } %>
      </div>
      </div>
    </main>
  </body>
</html>
