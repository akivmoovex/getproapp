<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Dashboard | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app">
    <%- include('../partials/admin_nav', { navTitle: 'Dashboard & overview', activeNav: 'dashboard' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <h1 class="section-title" style="margin-top:0;">Overview</h1>
      <div class="grid-3 admin-stat-grid">
        <div class="card admin-stat-card">
          <div class="muted">Professions</div>
          <div class="admin-stat-card__value"><%= categoriesCount %></div>
        </div>
        <div class="card admin-stat-card">
          <div class="muted">Companies</div>
          <div class="admin-stat-card__value"><%= companiesCount %></div>
        </div>
        <div class="card admin-stat-card">
          <div class="muted">Leads</div>
          <div class="admin-stat-card__value"><%= leadsCount %></div>
        </div>
      </div>

      <h2 class="section-title">Latest leads</h2>
      <div class="card">
        <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Company</th>
              <th>Name</th>
              <th>Phone</th>
              <th>Message</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <% latestLeads.forEach(function(l) { %>
              <tr>
                <td>
                  <div style="font-weight:800;"><%= l.company_name %></div>
                  <div class="muted" style="font-size:12px;">@<%= l.company_subdomain %></div>
                </td>
                <td><%= l.name %></td>
                <td><%= l.phone %></td>
                <td><%= l.message %></td>
                <td class="muted" style="font-size:12px;"><%= l.created_at %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      </div>
    </main>
  </body>
</html>

