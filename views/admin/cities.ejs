<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Cities | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Cities (join & search)', activeNav: 'cities' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% var _fs = typeof filterSuffix !== 'undefined' ? filterSuffix : ''; %>
      <% var _embed = typeof embed !== 'undefined' && embed; %>
      <div class="admin-super-users__topbar">
        <% if (!editMode) { %>
        <%- include('../partials/components/button', { variant: 'primary', href: '/admin/cities?edit=1' + _fs + (_embed ? '&embed=1' : ''), label: 'Edit' }) %>
        <% } else { %>
        <%- include('../partials/components/button', { variant: 'default', href: '/admin/cities' + (_fs ? '?' + _fs.slice(1) + (_embed ? '&embed=1' : '') : (_embed ? '?embed=1' : '')), label: 'Done' }) %>
        <% } %>
      </div>

      <h1 class="section-title section-title--flush">Cities</h1>
      <p class="admin-intro">
        Controls which cities appear in the Join flow and home/directory autocomplete for this region. <strong>Enabled</strong> allows normal sign-up; <strong>Big city</strong> is used for rotating placeholder hints on Join step 2. Disabled cities still appear in the list — applicants see a waitlist message.
      </p>

      <% var f = typeof filters !== 'undefined' ? filters : {}; %>
      <form method="get" action="/admin/cities" class="admin-filter-form">
        <% if (editMode) { %><input type="hidden" name="edit" value="1" /><% } %>
        <% if (_embed) { %><input type="hidden" name="embed" value="1" /><% } %>
        <div class="admin-filter-form__grid">
          <div>
            <label class="admin-filter-form__label" for="q_name">City</label>
            <input id="q_name" name="q_name" type="search" value="<%= f.q_name || '' %>" placeholder="Filter…" autocomplete="off" />
          </div>
          <div>
            <label class="admin-filter-form__label" for="q_enabled">Enabled</label>
            <select id="q_enabled" name="q_enabled">
              <option value="" <%= !f.q_enabled ? 'selected' : '' %>>All</option>
              <option value="yes" <%= f.q_enabled === 'yes' ? 'selected' : '' %>>Yes</option>
              <option value="no" <%= f.q_enabled === 'no' ? 'selected' : '' %>>No</option>
            </select>
          </div>
          <div>
            <label class="admin-filter-form__label" for="q_big">Big city</label>
            <select id="q_big" name="q_big">
              <option value="" <%= !f.q_big ? 'selected' : '' %>>All</option>
              <option value="yes" <%= f.q_big === 'yes' ? 'selected' : '' %>>Yes</option>
              <option value="no" <%= f.q_big === 'no' ? 'selected' : '' %>>No</option>
            </select>
          </div>
        </div>
        <div class="admin-filter-form__actions">
          <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Apply filters' }) %>
          <%- include('../partials/components/button', { variant: 'default', href: '/admin/cities' + (editMode ? '?edit=1' : '') + (editMode && _embed ? '&embed=1' : (!editMode && _embed ? '?embed=1' : '')), label: 'Clear' }) %>
        </div>
      </form>

      <% if (editMode) { %>
      <div class="card admin-form-card admin-form-card--wide card--mb-lg">
        <h2 class="section-title section-title--form-card">Add city</h2>
        <form method="post" action="/admin/cities" class="form admin-inline-form">
          <% if (_embed) { %><input type="hidden" name="embed" value="1" /><% } %>
          <div>
            <label for="new_city_name">Name</label>
            <input id="new_city_name" class="input-min-200" name="name" required placeholder="e.g. Lusaka" />
          </div>
          <div class="form-check">
            <input id="new_city_enabled" type="checkbox" name="enabled" value="1" checked />
            <label for="new_city_enabled">Enabled</label>
          </div>
          <div class="form-check">
            <input id="new_city_big" type="checkbox" name="big_city" value="1" />
            <label for="new_city_big">Big city</label>
          </div>
          <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Add' }) %>
        </form>
      </div>
      <% } else { %>
      <p class="admin-intro">View-only list. Choose <strong>Edit</strong> to add or change cities.</p>
      <% } %>

      <div class="card">
        <div class="table-wrap">
        <table class="table<%= editMode ? '' : ' table--readonly' %>">
          <thead>
            <tr>
              <th>City</th>
              <th>Enabled</th>
              <th>Big city</th>
              <% if (editMode) { %><th>Actions</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% if (!cities || cities.length === 0) { %>
              <tr><td colspan="<%= editMode ? 4 : 3 %>" class="muted">No cities match these filters.</td></tr>
            <% } %>
            <% (cities || []).forEach(function(c) { %>
              <tr>
                <% if (!editMode) { %>
                <td><%= c.name %></td>
                <td><%= c.enabled ? 'Yes' : 'No' %></td>
                <td><%= c.big_city ? 'Yes' : 'No' %></td>
                <% } else { %>
                <td>
                  <label class="visually-hidden" for="city-name-<%= c.id %>">City name</label>
                  <input id="city-name-<%= c.id %>" class="input-min-160" name="name" form="city-up-<%= c.id %>" value="<%= c.name %>" required />
                </td>
                <td>
                  <div class="form-check form-check--tight">
                    <input id="city-en-<%= c.id %>" type="checkbox" name="enabled" form="city-up-<%= c.id %>" value="1" <%= c.enabled ? 'checked' : '' %> />
                    <label for="city-en-<%= c.id %>">Yes</label>
                  </div>
                </td>
                <td>
                  <div class="form-check form-check--tight">
                    <input id="city-big-<%= c.id %>" type="checkbox" name="big_city" form="city-up-<%= c.id %>" value="1" <%= c.big_city ? 'checked' : '' %> />
                    <label for="city-big-<%= c.id %>">Yes</label>
                  </div>
                </td>
                <td>
                  <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Save', form: 'city-up-' + c.id }) %>
                  <form method="post" action="/admin/cities/<%= c.id %>/delete" class="form-inline-delete" onsubmit="return confirm('Remove this city from the list?');">
                    <% if (_embed) { %><input type="hidden" name="embed" value="1" /><% } %>
                    <%- include('../partials/components/button', { variant: 'default', type: 'submit', label: 'Delete' }) %>
                  </form>
                  <form id="city-up-<%= c.id %>" method="post" action="/admin/cities/<%= c.id %>" hidden aria-hidden="true">
                    <% if (_embed) { %><input type="hidden" name="embed" value="1" /><% } %>
                  </form>
                </td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      </div>
    </main>
  </body>
</html>
