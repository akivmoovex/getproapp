<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>New project | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: navTitle || 'New project', activeNav: activeNav || 'project_intake' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <%- include('../partials/admin_intake_otp_banner') %>
        <% if (typeof notice !== 'undefined' && notice) { %>
          <div class="flash flash--info" role="status"><%= notice %></div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flash" role="alert"><%= error %></div>
        <% } %>

        <div class="card admin-form-card">
          <h1 class="admin-form-card__title">Find existing client</h1>
          <p class="muted">Search by phone or NRZ for this region only. All lookups are scoped to your current admin tenant.</p>
          <form method="post" action="/admin/project-intake/search" class="form">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <div class="input-field">
              <label class="input-field__label" for="phone">Phone</label>
              <input id="phone" name="phone" class="input-field__control" value="<%= phone || '' %>" autocomplete="tel" />
            </div>
            <div class="input-field">
              <label class="input-field__label" for="nrz">NRZ number</label>
              <input id="nrz" name="nrz" class="input-field__control" value="<%= nrz || '' %>" />
            </div>
            <div class="form-step__actions admin-gate-actions">
              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Search' }) %>
            </div>
          </form>
        </div>

        <% if (searched) { %>
          <div class="card admin-form-card" style="margin-top: 1rem;">
            <% if (foundClient) { %>
              <h2 class="admin-form-card__title">Client found</h2>
              <p class="muted" style="margin-bottom:0.35rem;">Client code</p>
              <div class="admin-intake-code" aria-label="Client code"><%= foundClient.client_code %></div>
              <p><strong><%= foundClient.full_name %></strong></p>
              <p class="muted">External ref: <%= foundClient.external_client_reference %> · Phone: <%= foundClient.phone %></p>
              <%- include('../partials/components/button', { variant: 'primary', href: '/admin/project-intake/project/new?clientId=' + foundClient.id + (typeof embed !== 'undefined' && embed ? '&embed=1' : ''), label: 'Continue to new project' }) %>
            <% } else { %>
              <h2 class="admin-form-card__title">No client found</h2>
              <p>Create a new client record, then you will open the project form.</p>
              <%- include('../partials/components/button', { variant: 'primary', href: '/admin/project-intake/clients/new?phone=' + encodeURIComponent(phone || '') + '&nrz=' + encodeURIComponent(nrz || '') + (typeof embed !== 'undefined' && embed ? '&embed=1' : ''), label: 'Create new client' }) %>
            <% } %>
          </div>
        <% } %>
      </div>
    </main>
  </body>
</html>
