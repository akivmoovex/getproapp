<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Dispute #<%= dispute.id %> | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
    <style>
      .fa-statement-doc__title { font-size: 1.125rem; margin: 0 0 0.75rem; }
      .fa-statement-doc__meta { margin: 0.35rem 0; }
      .fa-statement-doc__muted { margin: 0.25rem 0; color: #555; font-size: 0.875rem; }
      .fa-statement-doc__disclaimer { margin: 1rem 0; padding: 0.75rem; background: #f5f5f5; border-radius: 4px; font-size: 0.9rem; }
      .fa-statement-doc__h2 { font-size: 1rem; margin: 1rem 0 0.5rem; }
      .fa-statement-doc__dl { margin: 0; }
      .fa-statement-doc__row { display: flex; justify-content: space-between; gap: 1rem; padding: 0.35rem 0; border-bottom: 1px solid #eee; flex-wrap: wrap; }
      .fa-statement-doc__row dt { margin: 0; font-weight: 500; color: #444; }
      .fa-statement-doc__row dd { margin: 0; font-weight: 600; text-align: right; }
      .fa-statement-doc__row--total { border-bottom: none; margin-top: 0.25rem; padding-top: 0.5rem; border-top: 2px solid #ccc; }
    </style>
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Dispute detail', activeNav: 'field_agent_disputes' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <% var _backQs = []; if (typeof embed !== 'undefined' && embed) _backQs.push('embed=1'); if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') _backQs.push('tenant_id=' + tenantId); %>
        <p><a href="/admin/field-agent-disputes<%= _backQs.length ? '?' + _backQs.join('&') : '' %>">← Back to disputes</a></p>

        <header class="admin-dashboard__header">
          <h1 class="admin-dashboard__title">Dispute #<%= dispute.id %></h1>
          <p class="admin-dashboard__subtitle muted">Status: <strong><%= dispute.status %></strong></p>
        </header>

        <% if (typeof flashResolvedWithAdjustment !== 'undefined' && flashResolvedWithAdjustment) { %>
          <p class="admin-gate-success" role="status">Dispute resolved with adjustment. Original statement snapshot was not modified.</p>
        <% } %>

        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Field agent submission</h2>
          <p><strong>Reason:</strong> <%= dispute.dispute_reason %></p>
          <% if (dispute.dispute_notes) { %><p><strong>Notes:</strong> <%= dispute.dispute_notes %></p><% } %>
          <p class="muted">Submitted <%= dispute.created_at ? new Date(dispute.created_at).toLocaleString() : '—' %></p>
          <% if (dispute.resolved_at) { %>
            <p class="muted">Resolved <%= new Date(dispute.resolved_at).toLocaleString() %></p>
          <% } %>
          <% if (dispute.admin_notes) { %><p><strong>Admin notes:</strong> <%= dispute.admin_notes %></p><% } %>
        </section>

        <% if (typeof detail !== 'undefined' && detail) { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Frozen statement snapshot (read-only)</h2>
          <p class="muted">Adjustments do not modify original statements. They are recorded separately for audit and future payout handling.</p>
          <p class="muted">Same values shown to the field agent. No edits from this screen.</p>
          <%- include('../partials/field_agent_monthly_statement_body', {
            detail,
            tenantRegionLabel: typeof tenantRegionLabel !== 'undefined' ? tenantRegionLabel : '',
            showTenantLine: true,
            omitDocumentTitle: true,
          }) %>
        </section>
        <% } %>

        <% if (dispute.status === 'open') { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Mark as under review</h2>
          <form method="post" action="/admin/field-agent-disputes/<%= dispute.id %>/status">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <% if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') { %><input type="hidden" name="tenant_id" value="<%= tenantId %>" /><% } %>
            <input type="hidden" name="status" value="under_review" />
            <div class="input-field">
              <label class="input-field__label" for="admin_notes_ur">Admin notes (optional)</label>
              <textarea id="admin_notes_ur" name="admin_notes" class="input-field__control" rows="2" maxlength="8000"></textarea>
            </div>
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Mark as under review' }) %>
          </form>
        </section>
        <% } %>

        <% if (dispute.status === 'under_review') { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Resolve with adjustment</h2>
          <p class="muted">Creates a ledger adjustment linked to this line and marks the dispute resolved. Does not edit the frozen snapshot.</p>
          <form method="post" action="/admin/field-agent-disputes/<%= dispute.id %>/resolve-with-adjustment" style="margin-bottom:1.5rem;">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <% if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') { %><input type="hidden" name="tenant_id" value="<%= tenantId %>" /><% } %>
            <div class="input-field" style="margin-bottom:0.75rem;">
              <label class="input-field__label" for="rwa_amount">Amount (+ or −)</label>
              <input class="input-field__control" id="rwa_amount" name="adjustment_amount" type="text" required placeholder="-10.00" />
            </div>
            <div class="input-field" style="margin-bottom:0.75rem;">
              <label class="input-field__label" for="rwa_reason">Reason (required)</label>
              <input class="input-field__control" id="rwa_reason" name="reason" type="text" required maxlength="4000" />
            </div>
            <div class="input-field" style="margin-bottom:0.75rem;">
              <label class="input-field__label" for="rwa_type">Type</label>
              <select class="input-field__control" id="rwa_type" name="adjustment_type">
                <option value="manual">Manual</option>
                <option value="sp">SP</option>
                <option value="ec">EC</option>
                <option value="recruitment">Recruitment</option>
              </select>
            </div>
            <div class="input-field" style="margin-bottom:0.75rem;">
              <label class="input-field__label" for="rwa_notes">Admin notes (optional)</label>
              <textarea class="input-field__control" id="rwa_notes" name="admin_notes" rows="2" maxlength="8000"></textarea>
            </div>
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Resolve with adjustment' }) %>
          </form>
        </section>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Resolve or reject</h2>
          <p class="muted">Closing a dispute without an adjustment does not change stored statement amounts.</p>
          <form method="post" action="/admin/field-agent-disputes/<%= dispute.id %>/status" style="margin-bottom:1rem;">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <% if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') { %><input type="hidden" name="tenant_id" value="<%= tenantId %>" /><% } %>
            <input type="hidden" name="status" value="resolved" />
            <div class="input-field">
              <label class="input-field__label" for="admin_notes_res">Admin notes (optional)</label>
              <textarea id="admin_notes_res" name="admin_notes" class="input-field__control" rows="2" maxlength="8000"></textarea>
            </div>
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Resolve dispute' }) %>
          </form>
          <form method="post" action="/admin/field-agent-disputes/<%= dispute.id %>/status">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <% if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') { %><input type="hidden" name="tenant_id" value="<%= tenantId %>" /><% } %>
            <input type="hidden" name="status" value="rejected" />
            <div class="input-field">
              <label class="input-field__label" for="admin_notes_rej">Admin notes (optional)</label>
              <textarea id="admin_notes_rej" name="admin_notes" class="input-field__control" rows="2" maxlength="8000"></textarea>
            </div>
            <%- include('../partials/components/button', { variant: 'outline', type: 'submit', label: 'Reject dispute' }) %>
          </form>
        </section>
        <% } %>
      </div>
    </main>
  </body>
</html>
