<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Companies | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Companies', activeNav: 'companies' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% var _fs = typeof filterSuffix !== 'undefined' ? filterSuffix : ''; %>
      <% var _embed = typeof embed !== 'undefined' && embed; %>
      <% if (typeof saved !== 'undefined' && saved) { %>
      <div class="flash flash--success" role="status" aria-live="polite">Changes saved.</div>
      <% } %>
      <div class="admin-super-users__topbar">
        <% if (!editMode) { %>
        <%- include('../partials/components/button', { variant: 'primary', href: '/admin/companies?edit=1' + _fs + (_embed ? '&embed=1' : ''), label: 'Edit' }) %>
        <% } else { %>
        <%- include('../partials/components/button', { variant: 'default', href: '/admin/companies' + (_fs ? '?' + _fs.slice(1) + (_embed ? '&embed=1' : '') : (_embed ? '?embed=1' : '')), label: 'Done' }) %>
        <% } %>
      </div>

      <h1 class="section-title section-title--flush">Companies</h1>
      <% var f = typeof filters !== 'undefined' ? filters : {}; %>
      <form method="get" action="/admin/companies" class="admin-filter-form">
        <% if (editMode) { %><input type="hidden" name="edit" value="1" /><% } %>
        <% if (_embed) { %><input type="hidden" name="embed" value="1" /><% } %>
        <div class="admin-filter-form__grid">
          <div>
            <label class="admin-filter-form__label" for="q_name">Name</label>
            <input id="q_name" name="q_name" type="search" value="<%= f.q_name || '' %>" placeholder="Filter…" autocomplete="off" />
          </div>
          <div>
            <label class="admin-filter-form__label" for="q_subdomain">Subdomain</label>
            <input id="q_subdomain" name="q_subdomain" type="search" value="<%= f.q_subdomain || '' %>" placeholder="Filter…" autocomplete="off" />
          </div>
          <div>
            <label class="admin-filter-form__label" for="q_category">Category</label>
            <input id="q_category" name="q_category" type="search" value="<%= f.q_category || '' %>" placeholder="Filter…" autocomplete="off" />
          </div>
          <div>
            <label class="admin-filter-form__label" for="q_updated">Updated</label>
            <input id="q_updated" name="q_updated" type="search" value="<%= f.q_updated || '' %>" placeholder="Filter…" autocomplete="off" />
          </div>
        </div>
        <div class="admin-filter-form__actions">
          <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Apply filters' }) %>
          <%- include('../partials/components/button', { variant: 'default', href: '/admin/companies' + (editMode ? '?edit=1' : '') + (editMode && _embed ? '&embed=1' : (!editMode && _embed ? '?embed=1' : '')), label: 'Clear' }) %>
        </div>
      </form>

      <% if (editMode) { %>
      <div class="admin-toolbar">
        <%- include('../partials/components/button', { variant: 'primary', href: '/admin/companies/new' + (_embed ? '?embed=1' : ''), label: 'New company' }) %>
      </div>
      <% } else { %>
      <p class="admin-intro">View-only list. Choose <strong>Edit</strong> to add or change companies.</p>
      <% } %>

      <div class="card">
        <div class="table-wrap">
        <table class="table<%= editMode ? '' : ' table--readonly' %>">
          <thead>
            <tr>
              <th>Name</th>
              <th>Mini-site</th>
              <th>Category</th>
              <th>Directory profile</th>
              <th>Directory featured</th>
              <th>Premium</th>
              <% if (typeof portalCreditUiActive !== 'undefined' && portalCreditUiActive) { %>
              <th>Portal credit</th>
              <% } %>
              <th>Updated</th>
              <% if (editMode) { %><th>Actions</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% var _pcCol = typeof portalCreditUiActive !== 'undefined' && portalCreditUiActive ? 1 : 0; %>
            <% var _emptyCols = (editMode ? 8 : 7) + _pcCol; %>
            <% if (!companies || companies.length === 0) { %>
              <tr>
                <td colspan="<%= _emptyCols %>" class="admin-table-empty-cell">
                  <%- include('../partials/components/empty_state', {
                    hint: 'No companies match these filters.',
                    compact: true,
                    extraClass: 'state-block--admin-inline'
                  }) %>
                </td>
              </tr>
            <% } %>
            <% (companies || []).forEach(function(c) { %>
              <tr>
                <td class="table__strong-800">
                  <% if (c.miniSitePublicUrl) { %>
                    <a href="<%= c.miniSitePublicUrl %>" target="_blank" rel="noopener noreferrer"><%= c.name %></a>
                  <% } else { %>
                    <%= c.name %>
                  <% } %>
                </td>
                <td class="muted muted--caption">
                  <% if (baseDomain && typeof adminTenantSlug !== 'undefined' && adminTenantSlug) { %>
                    <span class="kbd"><%= adminTenantSlug %>.<%= baseDomain %>/<%= c.subdomain %></span>
                    <% if (c.miniSitePublicUrl) { %>
                      · <a href="<%= c.miniSitePublicUrl %>" target="_blank" rel="noopener noreferrer">Open</a>
                    <% } %>
                  <% } else { %>
                    @<%= c.subdomain %>
                  <% } %>
                </td>
                <td><%= c.category_name || '—' %></td>
                <td>
                  <% if (baseDomain && typeof adminTenantSlug !== 'undefined' && adminTenantSlug) { %>
                    <a href="https://<%= adminTenantSlug %>.<%= baseDomain %>/company/<%= c.id %>" target="_blank" rel="noopener noreferrer">Open</a>
                  <% } else { %>
                    <span class="muted" title="Set BASE_DOMAIN">—</span>
                  <% } %>
                </td>
                <td><% if (editMode && typeof canManageFeaturedPremium !== 'undefined' && canManageFeaturedPremium) { %>
                  <form id="dirflags-<%= c.id %>" method="post" action="/admin/companies/<%= c.id %>/directory-flags<%= _embed ? '?embed=1' : '' %>" class="admin-companies-flags-form">
                    <% if (_embed) { %><input type="hidden" name="embed" value="1" /><% } %>
                    <% if (typeof filterQueryForSave !== 'undefined' && filterQueryForSave) { %>
                    <input type="hidden" name="return_query" value="<%= filterQueryForSave.replace(/"/g, '&quot;') %>" />
                    <% } %>
                  </form>
                  <label class="admin-companies-flag-label"><input type="checkbox" name="directory_featured" value="1" form="dirflags-<%= c.id %>" <%= c.directory_featured ? 'checked' : '' %> title="Show in homepage/footer featured directory search" /> List</label>
                <% } else { %>
                  <span class="muted"><%= c.directory_featured ? 'Yes' : 'No' %></span>
                <% } %></td>
                <td><% if (editMode && typeof canManageFeaturedPremium !== 'undefined' && canManageFeaturedPremium) { %>
                  <label class="admin-companies-flag-label"><input type="checkbox" name="is_premium" value="1" form="dirflags-<%= c.id %>" <%= c.is_premium ? 'checked' : '' %> title="Premium provider (directory)" /> Yes</label>
                  <button type="submit" class="btn btn--sm" form="dirflags-<%= c.id %>">Save</button>
                <% } else { %>
                  <span class="muted"><%= c.is_premium ? 'Yes' : 'No' %></span>
                <% } %></td>
                <% if (typeof portalCreditUiActive !== 'undefined' && portalCreditUiActive) { %>
                <td>
                  <% if (c.portal_credit_blocked) { %>
                  <span class="admin-credit-blocked-badge">Blocked</span>
                  <% } %>
                  <span class="muted admin-companies-credit-balance"><%= c.portal_lead_credits_balance != null ? c.portal_lead_credits_balance : '0' %> ZMW</span>
                </td>
                <% } %>
                <td class="muted"><%- include('../partials/event_time', { at: c.updated_at }) %></td>
                <% if (editMode) { %><td><%- include('../partials/components/button', { variant: 'default', href: '/admin/companies/' + c.id + '/workspace' + (_embed ? '?embed=1' : ''), label: 'Edit' }) %></td><% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      </div>
    </main>
  </body>
</html>
