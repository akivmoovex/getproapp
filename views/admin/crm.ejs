<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>CRM | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app admin-crm-page<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'CRM tasks', activeNav: 'crm' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <h1 class="section-title admin-crm-page__title">CRM — board</h1>
        <p class="admin-intro muted">
          Drag tasks between columns to update status. Click a card to open details. New tasks can include an assignee; unassigned tasks stay in <strong>New</strong>.
        </p>

        <div class="admin-crm-top">
          <% if (canMutateCrm) { %>
          <div class="card admin-form-card admin-crm-panel admin-crm-create">
            <h2 class="admin-crm-section__title">New task</h2>
            <p class="muted admin-crm-section__lead">Assignee defaults to you; choose <strong>Unassigned</strong> to leave the task in the New column.</p>
            <form method="post" action="/admin/crm/tasks" class="form">
              <div>
                <label for="crm_title">Title</label>
                <input id="crm_title" name="title" required maxlength="200" placeholder="Short summary" />
              </div>
              <div>
                <label for="crm_desc">Description</label>
                <textarea id="crm_desc" name="description" rows="4" placeholder="Details…"></textarea>
              </div>
              <div>
                <label for="crm_owner">Assignee</label>
                <select id="crm_owner" name="owner_id">
                  <option value="">Unassigned (stays in New)</option>
                  <% (crmTenantUsers || []).forEach(function(u) { %>
                    <option value="<%= u.id %>" <%= Number(u.id) === Number(currentUserId) ? 'selected' : '' %>><%= u.username %></option>
                  <% }); %>
                </select>
              </div>
              <div>
                <label for="crm_attachment">Attachment link (optional)</label>
                <input id="crm_attachment" name="attachment_url" type="url" maxlength="2000" placeholder="https://…" />
                <div class="admin-field-hint">Link to a file or document (https only).</div>
              </div>
              <div class="admin-gate-actions">
                <button class="btn btn-primary" type="submit">Create task</button>
              </div>
            </form>
          </div>
          <% } %>

          <aside class="card admin-crm-unassigned" aria-labelledby="crm-unassigned-title">
            <h2 id="crm-unassigned-title" class="admin-crm-section__title">Unassigned (New)</h2>
            <p class="muted admin-crm-section__lead">Pool tasks with no assignee. Also listed in the <strong>New</strong> column below — claim from the card or open details.</p>
            <% var _u = typeof unassignedTasks !== 'undefined' && unassignedTasks ? unassignedTasks : []; %>
            <% if (!_u.length) { %>
              <p class="muted admin-crm-unassigned__empty">No unassigned tasks.</p>
            <% } else { %>
              <ul class="admin-crm-unassigned__list">
                <% _u.forEach(function(t) { %>
                  <li class="admin-crm-unassigned__item">
                    <button type="button" class="admin-crm-unassigned__link" data-crm-open-task="<%= t.id %>">
                      <span class="admin-crm-unassigned__item-title"><%= t.title %></span>
                      <% if (t.description) { %>
                        <span class="admin-crm-unassigned__item-snippet muted"><%= String(t.description).length > 120 ? String(t.description).slice(0, 120) + '…' : t.description %></span>
                      <% } %>
                    </button>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </aside>
        </div>

        <div class="admin-crm-kanban" aria-label="Task board by status">
          <% (CRM_TASK_STATUSES || []).forEach(function(st) { %>
            <% var colTasks = (tasksByStatus && tasksByStatus[st]) ? tasksByStatus[st] : []; %>
            <section class="admin-crm-kanban__col" data-crm-status="<%= st %>">
              <header class="admin-crm-kanban__col-head">
                <button type="button" class="admin-crm-kanban__col-toggle" aria-expanded="true" aria-controls="crm-col-<%= st %>" title="Collapse or expand column">
                  <span class="admin-crm-kanban__col-toggle-icon" aria-hidden="true"></span>
                </button>
                <h2 class="admin-crm-kanban__col-title"><%= typeof crmTaskStatusLabel === 'function' ? crmTaskStatusLabel(st) : st %></h2>
                <span class="admin-crm-kanban__col-count" aria-hidden="true"><%= colTasks.length %></span>
              </header>
              <div
                class="admin-crm-kanban__dropzone"
                id="crm-col-<%= st %>"
                data-crm-dropzone="<%= st %>"
                role="list"
              >
                <% colTasks.forEach(function(t) { %>
                  <article
                    class="admin-crm-card <%= t.canDrag ? 'admin-crm-card--draggable' : '' %>"
                    role="listitem"
                    data-task-id="<%= t.id %>"
                    data-crm-status="<%= st %>"
                    <% if (t.canDrag) { %>draggable="true"<% } else { %>draggable="false"<% } %>
                  >
                    <div class="admin-crm-card__body" data-crm-open-task="<%= t.id %>" role="button" tabindex="0">
                      <h3 class="admin-crm-card__title-text"><%= t.title %></h3>
                      <% if (t.owner_username) { %>
                        <p class="admin-crm-card__meta muted"><%= t.owner_username %></p>
                      <% } else { %>
                        <p class="admin-crm-card__meta muted">Unassigned</p>
                      <% } %>
                      <% if (t.description) { %>
                        <p class="admin-crm-card__snippet muted"><%= String(t.description).length > 100 ? String(t.description).slice(0, 100) + '…' : t.description %></p>
                      <% } %>
                      <% if (t.attachment_url && String(t.attachment_url).trim()) { %>
                        <p class="admin-crm-card__attach muted">📎 Link attached</p>
                      <% } %>
                    </div>
                  </article>
                <% }); %>
                <% if (!colTasks.length) { %>
                  <p class="admin-crm-kanban__empty muted">No tasks</p>
                <% } %>
              </div>
            </section>
          <% }); %>
        </div>
      </div>
    </main>

    <div id="crm_task_overlay" class="m3-modal-overlay admin-crm-overlay" aria-hidden="true" hidden>
      <div class="m3-modal-overlay__backdrop" data-crm-close-overlay tabindex="-1"></div>
      <div class="m3-modal m3-modal--crm-task" role="dialog" aria-modal="true" aria-label="Task details">
        <header class="m3-modal__header m3-modal__header--end">
          <button type="button" class="m3-modal__close" data-crm-close-overlay aria-label="Close task details">×</button>
        </header>
        <div class="m3-modal__body" id="crm_task_overlay_body"></div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>

    <script>
      window.__CRM_KANBAN__ = {
        statuses: <%- JSON.stringify(CRM_TASK_STATUSES || []) %>,
      };
    </script>
    <script src="/admin-crm-kanban.js?v=<%= stylesVersion %>"></script>
  </body>
</html>
