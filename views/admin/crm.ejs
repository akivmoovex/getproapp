<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>CRM | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app admin-crm-page<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'CRM tasks', activeNav: 'crm' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <h1 class="section-title admin-crm-page__title">CRM — board</h1>
        <% var _webOnly = typeof crmWebsitesOnly !== 'undefined' && crmWebsitesOnly; %>
        <% var _canWebQ = typeof canAccessWebsiteQueue !== 'undefined' && canAccessWebsiteQueue; %>
        <% if (_canWebQ) { %>
        <p style="display:flex;gap:0.5rem;flex-wrap:wrap;margin:0 0 0.75rem;">
          <a class="btn <%= _webOnly ? 'btn--secondary' : '' %>" href="/admin/crm">All CRM</a>
          <a class="btn <%= _webOnly ? '' : 'btn--secondary' %>" href="/admin/crm?queue=websites">Websites</a>
          <a class="btn btn--secondary" href="<%= typeof crmWebsiteReportUrl !== 'undefined' && crmWebsiteReportUrl ? crmWebsiteReportUrl : '/admin/crm/websites/report' %>">Websites report</a>
        </p>
        <% } %>
        <% var _wqc = (typeof websiteQualityControls !== 'undefined' && websiteQualityControls) ? websiteQualityControls : {}; %>
        <% var _rrQ = (typeof websiteQueueReportReturnHref !== 'undefined' && websiteQueueReportReturnHref) ? ('&report_return=' + encodeURIComponent(websiteQueueReportReturnHref)) : ''; %>
        <% var _opCity = (_wqc.city && String(_wqc.city).trim()) ? ('&city=' + encodeURIComponent(String(_wqc.city).trim())) : ''; %>
        <% var _opCat = (_wqc.category && String(_wqc.category).trim()) ? ('&category=' + encodeURIComponent(String(_wqc.category).trim())) : ''; %>
        <% var _opPreserve = _opCity + _opCat; %>
        <% if (_webOnly) { %>
          <div class="card admin-form-card" style="padding:0.75rem;margin:0 0 0.75rem;">
            <p class="muted" style="margin:0 0 0.5rem;">Queue presets</p>
            <p style="display:flex;gap:0.45rem;flex-wrap:wrap;margin:0;">
              <a class="btn btn--secondary" href="/admin/crm?queue=websites&quality_tier=low&quality_sort=asc<%= _rrQ %>">Low quality</a>
              <a class="btn btn--secondary" href="/admin/crm?queue=websites&quality_tier=high&quality_sort=desc<%= _rrQ %>">High quality</a>
              <a class="btn btn--secondary" href="/admin/crm?queue=websites&has_hours=no&quality_sort=asc<%= _rrQ %>">Missing hours</a>
              <a class="btn btn--secondary" href="/admin/crm?queue=websites&review_status=changes_requested&quality_sort=asc<%= _rrQ %>">Changes requested</a>
              <a class="btn btn--secondary" href="/admin/crm?queue=websites&review_status=submitted&quality_sort=asc<%= _rrQ %>">Ready to review</a>
            </p>
            <% if (typeof websiteQueueFilteredReportHref !== 'undefined' && websiteQueueFilteredReportHref) { %>
            <p class="muted" style="margin:0.5rem 0 0;"><a href="<%= websiteQueueFilteredReportHref %>">View in report</a> — uses review status, city, and quality tier when set; queue-only filters are omitted.</p>
            <% } %>
            <% if (typeof websiteQueueReportReturnHref !== 'undefined' && websiteQueueReportReturnHref) { %>
            <p class="muted" style="margin:0.5rem 0 0;"><a href="<%= String(websiteQueueReportReturnHref).replace(/&/g, '&amp;') %>">Back to report</a> — resume the filters and column view you left from.</p>
            <% } %>
            <% if (typeof websiteQueueShareUrl !== 'undefined' && websiteQueueShareUrl) { %>
            <div class="website-share-card website-share-card--copy-wrap website-share-card--focus-a11y website-share-card--group-focus-a11y" style="margin-top:0.65rem;padding-top:0.65rem;border-top:1px solid var(--line,#e6e8ee);max-width:100%;min-width:0;box-sizing:border-box;display:flex;flex-direction:column;gap:0;">
              <div id="website-queue-share-copy-live" class="visually-hidden" role="status" aria-live="polite" aria-atomic="true"></div>
              <div style="display:flex;flex-direction:column;gap:0.35rem;">
                <p class="muted" style="margin:0;"><strong>Permalink</strong> — URL for this queue (current filters).</p>
                <% if (typeof websiteQueueShareLabel !== 'undefined' && websiteQueueShareLabel) { %>
                <p class="muted" style="margin:0;font-size:0.95em;"><strong>Summary:</strong> <%= websiteQueueShareLabel %></p>
                <% } %>
                <p class="muted" style="margin:0;font-size:0.88em;line-height:1.35;">Current quality filters and <code>report_return</code> when set. Bulk notices omitted. Not stored — bookmark or copy the URL.</p>
              </div>
              <div class="website-share-a11y-group website-share-a11y-group--permalink" style="padding-top:0.55rem;margin-top:0.35rem;border-top:1px solid var(--line,#e6e8ee);display:flex;flex-direction:column;gap:0.4rem;width:100%;min-width:0;box-sizing:border-box;" role="group" aria-label="Permalink: queue URL, copy, and open in new tab">
                <div class="website-share-copy-row" style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:stretch;width:100%;max-width:100%;min-width:0;box-sizing:border-box;">
                  <input
                    type="text"
                    readonly
                    class="input-field__control"
                    style="flex:1 1 12rem;min-width:0;max-width:100%;cursor:text;box-sizing:border-box;"
                    id="website-queue-share-url"
                    value="<%= websiteQueueShareUrl %>"
                    onclick="this.select();"
                    aria-label="Shareable queue URL"
                  />
                  <button type="button" class="btn btn--primary website-share-copy-btn--primary" id="website-queue-share-copy" style="white-space:nowrap;flex-shrink:0;">Copy URL</button>
                </div>
                <% if (typeof websiteQueueSharePath !== 'undefined' && websiteQueueSharePath) { %>
                <p class="muted" style="margin:0;font-size:0.88em;line-height:1.35;"><a href="<%= String(websiteQueueSharePath).replace(/&/g, '&amp;') %>" target="_blank" rel="noopener noreferrer">Open current state in new tab</a></p>
                <% } %>
              </div>
              <% if (typeof websiteQueueShareSnippet !== 'undefined' && websiteQueueShareSnippet) { %>
              <div class="website-share-a11y-group website-share-a11y-group--snippet" style="padding-top:0.55rem;margin-top:0.35rem;border-top:1px solid var(--line,#e6e8ee);display:flex;flex-direction:column;gap:0.45rem;width:100%;min-width:0;box-sizing:border-box;" role="group" aria-label="Message snippet: text field and copy">
                <p class="muted" style="margin:0;font-size:0.88em;"><strong>Snippet</strong> — summary and URL (plain text).</p>
                <div class="website-share-copy-row" style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:flex-start;width:100%;max-width:100%;min-width:0;box-sizing:border-box;">
                  <textarea
                    readonly
                    class="input-field__control"
                    style="flex:1 1 12rem;min-width:0;max-width:100%;min-height:3.25rem;resize:vertical;cursor:text;font-family:inherit;box-sizing:border-box;"
                    id="website-queue-share-snippet"
                    onclick="this.select();"
                    aria-label="Shareable queue message snippet"
                  ><%= websiteQueueShareSnippet %></textarea>
                  <button type="button" class="btn btn--primary website-share-copy-btn--primary" id="website-queue-share-snippet-copy" style="white-space:nowrap;align-self:flex-start;flex-shrink:0;">Copy snippet</button>
                </div>
              </div>
              <% } %>
              <div class="website-share-a11y-group website-share-a11y-group--operational" style="padding-top:0.55rem;margin-top:0.35rem;border-top:1px solid var(--line,#e6e8ee);display:flex;flex-direction:column;gap:0.35rem;width:100%;min-width:0;box-sizing:border-box;" role="group" aria-label="Operational queue views: preset links">
                <p class="muted" id="website-queue-share-operational-hint" style="margin:0;font-size:0.88em;line-height:1.35;"><strong>Operational share states</strong> — preset filtered views (not saved). Keeps <code>report_return</code>, city, and category when set.</p>
                <p id="website-queue-share-operational-states" style="display:flex;gap:0.4rem;flex-wrap:wrap;margin:0;">
                  <a class="btn btn--secondary" href="/admin/crm?queue=websites&quality_tier=low&quality_sort=asc<%= _opPreserve %><%= _rrQ %>">Low quality queue</a>
                  <a class="btn btn--secondary" href="/admin/crm?queue=websites&has_hours=no&quality_sort=asc<%= _opPreserve %><%= _rrQ %>">Missing hours queue</a>
                  <a class="btn btn--secondary" href="/admin/crm?queue=websites&review_status=changes_requested&quality_sort=asc<%= _opPreserve %><%= _rrQ %>">Changes requested queue</a>
                  <a class="btn btn--secondary" href="/admin/crm?queue=websites&review_status=submitted&quality_sort=asc<%= _opPreserve %><%= _rrQ %>">Ready to review queue</a>
                </p>
              </div>
              <% var _qBestMd = typeof websiteQueueShareSnippetMarkdown !== 'undefined' && websiteQueueShareSnippetMarkdown; %>
              <% var _qBestChat = typeof websiteQueueShareChatSnippet !== 'undefined' && websiteQueueShareChatSnippet; %>
              <% var _qBestEmail = typeof websiteQueueShareBundleEmailReady !== 'undefined' && websiteQueueShareBundleEmailReady; %>
              <% if (_qBestMd || _qBestChat || _qBestEmail) { %>
              <% var _qBestShareLbl = (typeof websiteQueueShareLabel !== 'undefined' && websiteQueueShareLabel) ? String(websiteQueueShareLabel).trim() : ''; %>
              <div class="website-share-best-format-shortcuts website-share-a11y-group website-share-a11y-group--best-for" style="padding-top:0.45rem;margin-top:0.25rem;border-top:1px solid var(--line,#e6e8ee);width:100%;min-width:0;box-sizing:border-box;" role="group" aria-label="Best-for copy: Slack, email, and docs shortcuts">
                <p class="muted" id="website-queue-share-best-format-hint" style="margin:0 0 0.35rem;font-size:0.82em;line-height:1.35;"><strong>Best for</strong> — same copy as Advanced, one click (Slack / email / docs).</p>
                <p class="muted website-share-best-for-copy-best-legend" id="website-queue-share-copy-best-legend" style="margin:0 0 0.38rem;font-size:0.78em;line-height:1.4;"><strong>Copy best</strong> — Slack uses chat bundle; Email uses plain bundle; Docs uses markdown bundle.</p>
                <p id="website-queue-share-best-format-actions" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin:0;align-items:flex-start;min-width:0;width:100%;box-sizing:border-box;">
                  <% if (_qBestChat) { %>
                  <div class="website-share-best-for-row website-share-best-for-row--slack website-share-a11y-group website-share-a11y-group--best-for-slack" style="display:flex;flex-direction:column;gap:0.24rem;align-items:stretch;max-width:100%;min-width:0;box-sizing:border-box;border:1px solid var(--line,#e6e8ee);border-radius:8px;padding:0.4rem 0.5rem;background:rgba(255,255,255,0.5);" role="group" aria-label="Best-for: Slack — copy and related deep-link fields">
                    <div class="website-share-best-for-row__primary" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.45rem;min-width:0;width:100%;box-sizing:border-box;">
                      <strong class="muted" style="font-size:0.76em;font-weight:700;letter-spacing:0.02em;margin:0;">Slack</strong>
                      <button type="button" class="btn btn--primary website-share-copy-btn--primary" id="website-queue-share-best-slack-copy" style="font-size:0.83em;padding:0.26em 0.5em;line-height:1.2;white-space:nowrap;" aria-label="Copy best format for Slack (chat snippet)">Copy for Slack</button>
                      <% if (typeof websiteQueueShareDeepLinks !== 'undefined' && websiteQueueShareDeepLinks && websiteQueueShareDeepLinks.chat) { %>
                      <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" id="website-queue-share-best-slack-copy-best" style="font-size:0.8em;padding:0.24em 0.48em;line-height:1.2;white-space:nowrap;" aria-label="Copy richest Best-for preset for Slack (chat deep-link bundle)">Copy best</button>
                      <span class="muted website-share-best-for-copy-best-hint" style="font-size:0.74em;line-height:1.25;white-space:nowrap;">uses chat bundle</span>
                      <% } %>
                    </div>
                  <% if (typeof websiteQueueShareDeepLinks !== 'undefined' && websiteQueueShareDeepLinks && websiteQueueShareDeepLinks.chat) { %>
                    <div class="website-share-best-for-row__links" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.35rem;">
                  <a id="website-queue-share-best-slack-open-source" class="muted" href="<%= websiteQueueShareDeepLinks.chat %>" style="font-size:0.82em;line-height:1.2;white-space:nowrap;">Open source</a>
                  <input type="text" readonly tabindex="-1" aria-hidden="true" class="input-field__control" style="position:absolute;left:-10000px;width:1px;height:1px;overflow:hidden;opacity:0;" id="website-queue-share-best-slack-open-url" value="<%= websiteQueueShareDeepLinks.chat %>" />
                  <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.82em;padding:0.22em 0.45em;line-height:1.2;white-space:nowrap;" id="website-queue-share-best-slack-open-copy" aria-label="Copy Slack advanced-source deep link URL">Copy link</button>
                    </div>
                    <div class="website-share-best-for-row__bundles" style="display:flex;flex-direction:column;gap:0.2rem;width:100%;min-width:0;">
                  <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                    <textarea
                      readonly
                      class="input-field__control"
                      style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:2.15rem;max-height:4.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                      id="website-queue-share-best-slack-open-bundle"
                      onclick="this.select();"
                      aria-label="Best-for deep-link bundle for Slack (label, target, URL)"
                    ><%= _qBestShareLbl %><% if (_qBestShareLbl) { %>

<% } %>Best for: Slack
<%= websiteQueueShareDeepLinks.chat %></textarea>
                    <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-queue-share-best-slack-open-bundle-copy" aria-label="Copy best-for deep-link bundle for Slack">Copy bundle</button>
                  </div>
                  <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                    <textarea
                      readonly
                      class="input-field__control"
                      style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:1.85rem;max-height:3.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                      id="website-queue-share-best-slack-open-bundle-md"
                      onclick="this.select();"
                      aria-label="Best-for deep-link bundle for Slack, markdown one-liner"
                    ><% if (_qBestShareLbl) { %>[<%= _qBestShareLbl %> · Best for: Slack](<%= websiteQueueShareDeepLinks.chat %>)<% } else { %>[Best for: Slack](<%= websiteQueueShareDeepLinks.chat %>)<% } %></textarea>
                    <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-queue-share-best-slack-open-bundle-md-copy" aria-label="Copy best-for deep-link bundle for Slack (markdown)">MD</button>
                  </div>
                  <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                    <textarea
                      readonly
                      class="input-field__control"
                      style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:1.85rem;max-height:3.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                      id="website-queue-share-best-slack-open-bundle-chat"
                      onclick="this.select();"
                      aria-label="Best-for deep-link bundle for Slack, chat one-liner"
                    ><% if (_qBestShareLbl) { %><<%= websiteQueueShareDeepLinks.chat %>|<%= _qBestShareLbl %> · Best for: Slack><% } else { %><<%= websiteQueueShareDeepLinks.chat %>|Best for: Slack><% } %></textarea>
                    <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-queue-share-best-slack-open-bundle-chat-copy" aria-label="Copy best-for deep-link bundle for Slack (chat)">Chat</button>
                  </div>
                    </div>
                  <% } %>
                  </div>
                  <% } %>
                  <% if (_qBestEmail) { %>
                  <div class="website-share-best-for-row website-share-best-for-row--email website-share-a11y-group website-share-a11y-group--best-for-email" style="display:flex;flex-direction:column;gap:0.24rem;align-items:stretch;max-width:100%;min-width:0;box-sizing:border-box;border:1px solid var(--line,#e6e8ee);border-radius:8px;padding:0.4rem 0.5rem;background:rgba(255,255,255,0.5);" role="group" aria-label="Best-for: Email — copy and related deep-link fields">
                    <div class="website-share-best-for-row__primary" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.45rem;min-width:0;width:100%;box-sizing:border-box;">
                      <strong class="muted" style="font-size:0.76em;font-weight:700;letter-spacing:0.02em;margin:0;">Email</strong>
                      <button type="button" class="btn btn--primary website-share-copy-btn--primary" id="website-queue-share-best-email-copy" style="font-size:0.83em;padding:0.26em 0.5em;line-height:1.2;white-space:nowrap;" aria-label="Copy best format for email (email-ready bundle)">Copy for Email</button>
                      <% if (typeof websiteQueueShareDeepLinks !== 'undefined' && websiteQueueShareDeepLinks && websiteQueueShareDeepLinks.bundles) { %>
                      <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" id="website-queue-share-best-email-copy-best" style="font-size:0.8em;padding:0.24em 0.48em;line-height:1.2;white-space:nowrap;" aria-label="Copy richest Best-for preset for Email (plain deep-link bundle)">Copy best</button>
                      <span class="muted website-share-best-for-copy-best-hint" style="font-size:0.74em;line-height:1.25;white-space:nowrap;">uses plain bundle</span>
                      <% } %>
                    </div>
                  <% if (typeof websiteQueueShareDeepLinks !== 'undefined' && websiteQueueShareDeepLinks && websiteQueueShareDeepLinks.bundles) { %>
                    <div class="website-share-best-for-row__links" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.35rem;">
                  <a id="website-queue-share-best-email-open-source" class="muted" href="<%= websiteQueueShareDeepLinks.bundles %>" style="font-size:0.82em;line-height:1.2;white-space:nowrap;">Open source</a>
                  <input type="text" readonly tabindex="-1" aria-hidden="true" class="input-field__control" style="position:absolute;left:-10000px;width:1px;height:1px;overflow:hidden;opacity:0;" id="website-queue-share-best-email-open-url" value="<%= websiteQueueShareDeepLinks.bundles %>" />
                  <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.82em;padding:0.22em 0.45em;line-height:1.2;white-space:nowrap;" id="website-queue-share-best-email-open-copy" aria-label="Copy email bundles advanced-source deep link URL">Copy link</button>
                    </div>
                    <div class="website-share-best-for-row__bundles" style="display:flex;flex-direction:column;gap:0.2rem;width:100%;min-width:0;">
                  <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                    <textarea
                      readonly
                      class="input-field__control"
                      style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:2.15rem;max-height:4.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                      id="website-queue-share-best-email-open-bundle"
                      onclick="this.select();"
                      aria-label="Best-for deep-link bundle for Email (label, target, URL)"
                    ><%= _qBestShareLbl %><% if (_qBestShareLbl) { %>

<% } %>Best for: Email
<%= websiteQueueShareDeepLinks.bundles %></textarea>
                    <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-queue-share-best-email-open-bundle-copy" aria-label="Copy best-for deep-link bundle for Email">Copy bundle</button>
                  </div>
                  <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                    <textarea
                      readonly
                      class="input-field__control"
                      style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:1.85rem;max-height:3.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                      id="website-queue-share-best-email-open-bundle-md"
                      onclick="this.select();"
                      aria-label="Best-for deep-link bundle for Email, markdown one-liner"
                    ><% if (_qBestShareLbl) { %>[<%= _qBestShareLbl %> · Best for: Email](<%= websiteQueueShareDeepLinks.bundles %>)<% } else { %>[Best for: Email](<%= websiteQueueShareDeepLinks.bundles %>)<% } %></textarea>
                    <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-queue-share-best-email-open-bundle-md-copy" aria-label="Copy best-for deep-link bundle for Email (markdown)">MD</button>
                  </div>
                  <div style="display:flex;flex-wrap:wrap;gap:0.28rem;align-items:flex-start;max-width:100%;min-width:0;box-sizing:border-box;">
                    <textarea
                      readonly
                      class="input-field__control"
                      style="flex:1 1 8rem;min-width:0;max-width:min(16rem,100%);min-height:1.85rem;max-height:3.25rem;resize:vertical;cursor:text;font-size:0.76em;line-height:1.32;font-family:inherit;box-sizing:border-box;"
                      id="website-queue-share-best-email-open-bundle-chat"
                      onclick="this.select();"
                      aria-label="Best-for deep-link bundle for Email, chat one-liner"
                    ><% if (_qBestShareLbl) { %><<%= websiteQueueShareDeepLinks.bundles %>|<%= _qBestShareLbl %> · Best for: Email><% } else { %><<%= websiteQueueShareDeepLinks.bundles %>|Best for: Email><% } %></textarea>
                    <button type="button" class="btn btn--text btn--sm website-share-copy-btn--secondary website-share-copy-btn--secondary-compact" style="font-size:0.78em;padding:0.24em 0.42em;line-height:1.2;white-space:nowrap;align-self:flex-start;" id="website-queue-share-best-email-open-bundle-chat-copy" aria-label="Copy best-for deep-link bundle for Email (chat)">Chat</button>
                  </div>
                    </div>
                  <% } %>
                  </div>
