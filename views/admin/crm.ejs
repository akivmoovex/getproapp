                  <% var _qs = _wqc.qualitySort || 'none'; %>
                  <option value="none" <%= _qs === 'none' ? 'selected' : '' %>>Default</option>
                  <option value="desc" <%= _qs === 'desc' ? 'selected' : '' %>>High to low</option>
                  <option value="asc" <%= _qs === 'asc' ? 'selected' : '' %>>Low to high</option>
                </select>
              </div>
              <div class="input-field" style="min-width:180px;">
                <label class="input-field__label" for="crm-queue-city">City</label>
                <datalist id="crm-queue-city-options">
                  <% (typeof websiteQueueCityOptions !== 'undefined' ? websiteQueueCityOptions : []).forEach(function(c) { %>
                    <option value="<%= c %>"></option>
                  <% }); %>
                </datalist>
                <input id="crm-queue-city" name="city" class="input-field__control" value="<%= _wqc.city || '' %>" list="crm-queue-city-options" maxlength="120" placeholder="Any city" />
              </div>
              <div class="input-field" style="min-width:190px;">
                <label class="input-field__label" for="crm-queue-category">Category</label>
                <select id="crm-queue-category" name="category" class="input-field__control">
                  <% var _qc = _wqc.category || ''; %>
                  <option value="" <%= !_qc ? 'selected' : '' %>>All categories</option>
                  <% (typeof websiteQueueCategoryOptions !== 'undefined' ? websiteQueueCategoryOptions : []).forEach(function(c) { %>
                    <option value="<%= c %>" <%= _qc === c ? 'selected' : '' %>><%= c %></option>
                  <% }); %>
                </select>
              </div>
              <div class="input-field" style="min-width:220px;">
                <span class="input-field__label" id="crm-queue-missing-badges-label">Missing-data badges</span>
                <p class="input-field__help" style="margin:0 0 0.35rem;">Match any selected</p>
                <div class="input-field__control" style="height:auto;padding:0.35rem 0.5rem;max-height:9rem;overflow:auto;" role="group" aria-labelledby="crm-queue-missing-badges-label">
                  <% var _mbs = Array.isArray(_wqc.missingBadges) ? _wqc.missingBadges : []; %>
                  <% (typeof websiteQueueMissingBadgeOptions !== 'undefined' ? websiteQueueMissingBadgeOptions : []).forEach(function(opt) { %>
                    <label style="display:flex;gap:0.35rem;align-items:flex-start;margin:0.15rem 0;font-weight:normal;">
                      <input type="checkbox" name="missing_badge" value="<%= opt.key %>" <%= _mbs.indexOf(opt.key) !== -1 ? 'checked' : '' %> />
                      <span><%= opt.label %></span>
                    </label>
                  <% }); %>
                </div>
              </div>
              <div style="display:flex;gap:0.4rem;align-items:center;">
                <%- include('../partials/components/button', { variant: 'default', type: 'submit', label: 'Apply quality filters' }) %>
                <a class="btn btn--secondary" href="/admin/crm?queue=websites">Reset</a>
              </div>
            </div>
          </form>
        <% } %>
        <% var _bulkNotice = typeof websiteBulkNotice !== 'undefined' ? String(websiteBulkNotice || '') : ''; %>
        <% var _bulkError = typeof websiteBulkError !== 'undefined' ? String(websiteBulkError || '') : ''; %>
        <% if (_webOnly && _bulkNotice) { %>
          <p class="card" style="padding:0.6rem 0.8rem;border-color:#d9f2e3;background:#f3fcf7;margin:0 0 0.75rem;"><%= _bulkNotice %></p>
        <% } %>
        <% if (_webOnly && _bulkError) { %>
          <p class="card" style="padding:0.6rem 0.8rem;border-color:#f6d4d4;background:#fff6f6;margin:0 0 0.75rem;"><%= _bulkError %></p>
        <% } %>
        <% if (_webOnly && canMutateCrm) { %>
          <form id="crm-websites-bulk-form" method="post" action="/admin/crm/websites/bulk-review" class="card admin-form-card" style="padding:0.75rem;margin:0 0 0.75rem;">
            <input type="hidden" name="return_query" value="<%= typeof websiteQueueReturnQuery !== 'undefined' ? websiteQueueReturnQuery : '?queue=websites' %>" />
            <div style="display:flex;gap:0.5rem;align-items:flex-end;flex-wrap:wrap;">
              <div class="input-field" style="min-width:180px;">
                <label class="input-field__label" for="crm-bulk-action">Bulk action</label>
                <select id="crm-bulk-action" name="bulk_action" class="input-field__control">
                  <option value="changes_requested">Mark as changes requested</option>
                  <option value="publish_ready">Publish selected (safe skips)</option>
                </select>
              </div>
              <div class="input-field" style="flex:1;min-width:260px;">
                <label class="input-field__label" for="crm-bulk-comment">Shared comment (required for changes requested)</label>
                <input id="crm-bulk-comment" name="bulk_comment" class="input-field__control" maxlength="4000" placeholder="Comment sent to selected website submissions" />
              </div>
              <div style="display:flex;gap:0.4rem;align-items:center;">
                <button type="button" class="btn btn--secondary" id="crm-web-bulk-select-all">Select all on page</button>
                <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Apply to selected' }) %>
              </div>
            </div>
          </form>
        <% } %>
        <% var _csrBoard = typeof crmCsrScopedBoard !== 'undefined' && crmCsrScopedBoard; %>
        <p class="admin-intro muted">
          <% if (_csrBoard) { %>
            Showing <strong>your assigned</strong> tasks and any <strong>unassigned</strong> items you can claim. Inbound leads are assigned to CSRs in round-robin (FIFO rotation). Oldest tasks appear first within each column.
          <% } else { %>
            Drag tasks between columns to update status. Click a card to open details. New tasks can include an assignee; unassigned tasks stay in <strong>New</strong>. Tenant admins see the full pipeline for this region.
          <% } %>
        </p>

        <div class="admin-crm-top">
          <% if (canMutateCrm) { %>
          <div class="card admin-form-card admin-crm-panel admin-crm-create">
            <h2 class="admin-crm-section__title">New task</h2>
            <p class="muted admin-crm-section__lead">Assignee defaults to you; choose <strong>Unassigned</strong> to leave the task in the New column.</p>
            <form method="post" action="/admin/crm/tasks" class="form">
              <div class="form-step form-step--admin">
                <div class="form-step__body">
                  <div class="input-field">
                    <label for="crm_title" class="input-field__label">Title</label>
                    <input id="crm_title" name="title" class="input-field__control" required maxlength="200" placeholder="Short summary" />
                  </div>
                  <div class="input-field">
                    <label for="crm_desc" class="input-field__label">Description</label>
                    <textarea id="crm_desc" name="description" class="input-field__control" rows="4" placeholder="Details…"></textarea>
                  </div>
                  <div class="input-field">
                    <label for="crm_owner" class="input-field__label">Assignee</label>
                    <select id="crm_owner" name="owner_id" class="input-field__control">
                      <option value="">Unassigned (stays in New)</option>
                      <% (crmTenantUsers || []).forEach(function(u) { %>
                        <option value="<%= u.id %>" <%= Number(u.id) === Number(currentUserId) ? 'selected' : '' %>><%= u.username %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="input-field">
                    <label for="crm_attachment" class="input-field__label">Attachment link (optional)</label>
                    <input id="crm_attachment" name="attachment_url" class="input-field__control" type="url" maxlength="2000" placeholder="https://…" />
                    <p class="input-field__help">Link to a file or document (https only).</p>
                  </div>
                </div>
                <div class="form-step__actions admin-gate-actions">
                  <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Create task' }) %>
                </div>
              </div>
            </form>
          </div>
          <% } %>

          <aside class="card admin-crm-unassigned" aria-labelledby="crm-unassigned-title">
            <h2 id="crm-unassigned-title" class="admin-crm-section__title">Unassigned (New)</h2>
            <p class="muted admin-crm-section__lead">Pool tasks with no assignee. Also listed in the <strong>New</strong> column below — claim from the card or open details.</p>
            <% var _u = typeof unassignedTasks !== 'undefined' && unassignedTasks ? unassignedTasks : []; %>
            <% if (!_u.length) { %>
              <p class="muted admin-crm-unassigned__empty">No unassigned tasks.</p>
            <% } else { %>
              <ul class="admin-crm-unassigned__list">
                <% _u.forEach(function(t) { %>
                  <li class="admin-crm-unassigned__item">
                    <button type="button" class="admin-crm-unassigned__link" data-crm-open-task="<%= t.id %>">
                      <span class="admin-crm-unassigned__item-title"><%= t.title %></span>
                      <% if (t.description) { %>
                        <span class="admin-crm-unassigned__item-snippet muted"><%= String(t.description).length > 120 ? String(t.description).slice(0, 120) + '…' : t.description %></span>
                      <% } %>
                    </button>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </aside>
        </div>

        <div class="admin-crm-kanban" aria-label="Task board by status">
          <% (CRM_TASK_STATUSES || []).forEach(function(st) { %>
            <% var colTasks = (tasksByStatus && tasksByStatus[st]) ? tasksByStatus[st] : []; %>
            <section class="admin-crm-kanban__col" data-crm-status="<%= st %>">
              <header class="admin-crm-kanban__col-head">
                <button type="button" class="admin-crm-kanban__col-toggle" aria-expanded="true" aria-controls="crm-col-<%= st %>" title="Collapse or expand column">
                  <span class="admin-crm-kanban__col-toggle-icon" aria-hidden="true"></span>
                </button>
                <h2 class="admin-crm-kanban__col-title"><%= typeof crmTaskStatusLabel === 'function' ? crmTaskStatusLabel(st) : st %></h2>
                <span class="admin-crm-kanban__col-count" aria-hidden="true"><%= colTasks.length %></span>
              </header>
              <div
                class="admin-crm-kanban__dropzone"
                id="crm-col-<%= st %>"
                data-crm-dropzone="<%= st %>"
                role="list"
              >
                <% colTasks.forEach(function(t) { %>
                  <article
                    class="admin-crm-card <%= t.canDrag ? 'admin-crm-card--draggable' : '' %>"
                    role="listitem"
                    data-task-id="<%= t.id %>"
                    data-crm-status="<%= st %>"
                    <% if (t.canDrag) { %>draggable="true"<% } else { %>draggable="false"<% } %>
                  >
                    <% if (_webOnly && canMutateCrm) { %>
                      <label style="display:flex;align-items:center;gap:0.35rem;padding:0.4rem 0.5rem;border-bottom:1px solid var(--line,#e6e8ee);">
                        <input type="checkbox" name="crm_task_ids" value="<%= t.id %>" class="crm-web-bulk-checkbox" form="crm-websites-bulk-form" onclick="event.stopPropagation();" />
                        <span class="muted">Select</span>
                      </label>
                    <% } %>
                    <div class="admin-crm-card__body" data-crm-open-task="<%= t.id %>" role="button" tabindex="0">
                      <h3 class="admin-crm-card__title-text"><%= t.title %></h3>
                      <% if (t.owner_username) { %>
                        <p class="admin-crm-card__meta muted"><%= t.owner_username %></p>
                      <% } else { %>
                        <p class="admin-crm-card__meta muted">Unassigned</p>
                      <% } %>
                      <% if (t.description) { %>
                        <p class="admin-crm-card__snippet muted"><%= String(t.description).length > 100 ? String(t.description).slice(0, 100) + '…' : t.description %></p>
                      <% } %>
                      <% if (_webOnly && typeof t.website_quality_score !== 'undefined' && t.website_quality_score !== null) { %>
                        <p class="admin-crm-card__meta muted">
                          Quality: <strong><%= t.website_quality_score %>/100</strong>
                          (<%= String(t.website_quality_tier || '') %>)
                        </p>
                      <% } %>
                      <% if (_webOnly && t.website_missing_badges && t.website_missing_badges.length) { %>
                        <p class="admin-crm-card__meta muted" style="display:flex;gap:0.35rem;flex-wrap:wrap;">
                          <% var _badgeCap = 4; var _badgeList = t.website_missing_badges.slice(0, _badgeCap); %>
                          <% _badgeList.forEach(function(b) { %>
                            <span class="pro-directory-toolbar__chip"><%= b %></span>
                          <% }); %>
                          <% if (t.website_missing_badges.length > _badgeCap) { %>
                            <span class="pro-directory-toolbar__chip">+<%= t.website_missing_badges.length - _badgeCap %> more</span>
                          <% } %>
                        </p>
                      <% } %>
                      <% if (t.attachment_url && String(t.attachment_url).trim()) { %>
                        <p class="admin-crm-card__attach muted">📎 Link attached</p>
                      <% } %>
                    </div>
                    <% if (_webOnly && typeof t.website_queue_report_href === 'string' && t.website_queue_report_href) { %>
                      <p class="admin-crm-card__meta muted" style="padding:0 0.5rem 0.5rem;">
                        <a href="<%= String(t.website_queue_report_href).replace(/&/g, '&amp;') %>">View in report</a>
                      </p>
                    <% } %>
                  </article>
                <% }); %>
                <% if (!colTasks.length) { %>
                  <p class="admin-crm-kanban__empty muted">No tasks</p>
                <% } %>
              </div>
            </section>
          <% }); %>
        </div>
        <% if (_webOnly && canMutateCrm) { %>
          <script>
            (function () {
              const sourceForm = document.getElementById('crm-websites-bulk-form');
              const btnSelectAll = document.getElementById('crm-web-bulk-select-all');
              const actionSel = document.getElementById('crm-bulk-action');
              const commentInput = document.getElementById('crm-bulk-comment');
              if (!sourceForm) return;
              sourceForm.addEventListener('submit', function (ev) {
                if (!actionSel || !commentInput) return;
                if (String(actionSel.value || '') === 'changes_requested' && !String(commentInput.value || '').trim()) {
                  ev.preventDefault();
                  alert('Comment is required for bulk changes requested.');
                }
              });
              if (btnSelectAll) {
                btnSelectAll.addEventListener('click', function () {
                  const boxes = document.querySelectorAll('.crm-web-bulk-checkbox');
                  boxes.forEach(function (cb) { cb.checked = true; });
                });
              }
            })();
          </script>
        <% } %>
      </div>
    </main>

    <div id="crm_task_overlay" class="m3-modal-overlay admin-crm-overlay" aria-hidden="true" hidden>
      <div class="m3-modal-overlay__backdrop" data-crm-close-overlay tabindex="-1"></div>
      <div class="m3-modal m3-modal--crm-task" role="dialog" aria-modal="true" aria-label="Task details">
        <header class="m3-modal__header m3-modal__header--end">
          <button type="button" class="m3-modal__close" data-crm-close-overlay aria-label="Close task details">×</button>
        </header>
        <div class="m3-modal__body" id="crm_task_overlay_body"></div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>

    <script>
      window.__CRM_KANBAN__ = {
        statuses: <%- JSON.stringify(CRM_TASK_STATUSES || []) %>,
      };
    </script>
    <script src="<%= asset('admin-crm-kanban') %>"></script>
  </body>
</html>
