<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Field agent analytics | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Field agent analytics', activeNav: 'field_agent_analytics' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <header class="admin-dashboard__header">
          <div>
            <h1 class="admin-dashboard__title">Field agent analytics</h1>
            <p class="admin-dashboard__subtitle muted">
              Aggregates from <strong>provider submissions</strong> and <strong>callback leads</strong> (same tenant as your admin scope). Not sourced from CRM tasks.
            </p>
          </div>
        </header>

        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Filters</h2>
          <form method="get" action="/admin/field-agent-analytics" class="admin-filter-form admin-filter-form__grid">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <div class="input-field">
              <label class="input-field__label" for="faa_from">From (submission / lead created)</label>
              <input id="faa_from" name="from" type="date" class="input-field__control" value="<%= filters.from %>" />
            </div>
            <div class="input-field">
              <label class="input-field__label" for="faa_to">To</label>
              <input id="faa_to" name="to" type="date" class="input-field__control" value="<%= filters.to %>" />
            </div>
            <div class="input-field">
              <label class="input-field__label" for="faa_agent">Field agent</label>
              <select id="faa_agent" name="agent" class="input-field__control">
                <option value="">All agents</option>
                <% (agents || []).forEach(function (a) { %>
                <option value="<%= a.id %>" <%= Number(filters.agent) === Number(a.id) ? 'selected' : '' %>><%= a.username %><% if (a.display_name) { %> — <%= a.display_name %><% } %></option>
                <% }); %>
              </select>
            </div>
            <div class="input-field">
              <label class="input-field__label" for="faa_days">Trend window (days)</label>
              <input id="faa_days" name="days" type="number" min="7" max="90" class="input-field__control" value="<%= filters.days %>" />
            </div>
            <div class="input-field input-field--actions">
              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Apply' }) %>
            </div>
          </form>
          <p class="muted" style="margin-top: 0.75rem; font-size: 0.9rem;">
            Date range applies to <strong>created_at</strong> on submissions and callback leads. Commission totals are for submissions in that window (approved rows only for sum/average).
          </p>
          <p class="muted" style="margin-top: 0.5rem; font-size: 0.9rem;">
            The <strong>summary</strong> KPIs use both the date range and the field agent filter. The <strong>per field agent</strong> table uses the date range only (all agents in this tenant).
          </p>
        </section>

        <% var s = typeof summary !== 'undefined' ? summary : {}; %>
        <section class="admin-dashboard__kpis" aria-label="Summary metrics">
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Total submissions</span>
              <span class="admin-dashboard-kpi__value"><%= s.total != null ? s.total : 0 %></span>
            </div>
          </article>
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Pending</span>
              <span class="admin-dashboard-kpi__value"><%= s.pending != null ? s.pending : 0 %></span>
            </div>
          </article>
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Approved</span>
              <span class="admin-dashboard-kpi__value"><%= s.approved != null ? s.approved : 0 %></span>
            </div>
          </article>
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Rejected</span>
              <span class="admin-dashboard-kpi__value"><%= s.rejected != null ? s.rejected : 0 %></span>
            </div>
          </article>
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Approval rate (decided)</span>
              <span class="admin-dashboard-kpi__value"><%= typeof s.approval_rate_decided === 'number' ? (s.approval_rate_decided * 100).toFixed(1) + '%' : '—' %></span>
            </div>
          </article>
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Share approved (of all)</span>
              <span class="admin-dashboard-kpi__value"><%= typeof s.approval_rate_total === 'number' ? (s.approval_rate_total * 100).toFixed(1) + '%' : '—' %></span>
            </div>
          </article>
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Total commission (approved)</span>
              <span class="admin-dashboard-kpi__value"><%= Number(s.total_commission || 0).toFixed(2) %></span>
            </div>
          </article>
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Avg commission (approved)</span>
              <span class="admin-dashboard-kpi__value"><%= Number(s.avg_commission || 0).toFixed(2) %></span>
            </div>
          </article>
          <article class="admin-dashboard-kpi">
            <div class="admin-dashboard-kpi__body">
              <span class="admin-dashboard-kpi__label">Callback leads</span>
              <span class="admin-dashboard-kpi__value"><%= s.callback_leads != null ? s.callback_leads : 0 %></span>
            </div>
          </article>
        </section>

        <h2 class="section-title">Per field agent</h2>
        <div class="card card--mb-xl">
          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <th>Username</th>
                  <th>Display name</th>
                  <th>Submissions</th>
                  <th>Pending</th>
                  <th>Approved</th>
                  <th>Rejected</th>
                  <th>Approval % (decided)</th>
                  <th>Total commission</th>
                  <th>Callbacks</th>
                </tr>
              </thead>
              <tbody>
                <% (breakdown || []).forEach(function (row) { %>
                <tr>
                  <td><%= row.username %></td>
                  <td><%= row.display_name || '—' %></td>
                  <td><%= row.total %></td>
                  <td><%= row.pending %></td>
                  <td><%= row.approved %></td>
                  <td><%= row.rejected %></td>
                  <td><%= typeof row.approval_rate_decided === 'number' ? (row.approval_rate_decided * 100).toFixed(1) + '%' : '—' %></td>
                  <td><%= Number(row.total_commission || 0).toFixed(2) %></td>
                  <td><%= row.callback_leads %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>

        <h2 class="section-title">Trends (last <%= filters.days %> days, UTC days)</h2>
        <p class="muted admin-intro">
          Rolling window ending <strong>now</strong> (not the From/To filters above). New submissions per day and new callback leads per day, bucketed by <strong>UTC</strong> calendar date. The field agent filter applies. Does not chart approval timing (no <code>approved_at</code> column).
        </p>
        <div class="admin-dashboard__charts" style="display: grid; gap: 1rem;">
          <div class="card">
            <h3 class="admin-dashboard-panel__title">Submissions / day</h3>
            <div class="table-wrap">
              <table class="table">
                <thead><tr><th>Day</th><th>Count</th></tr></thead>
                <tbody>
                  <% if (!submissionsByDay || submissionsByDay.length === 0) { %>
                  <tr><td colspan="2" class="muted">No data in window.</td></tr>
                  <% } %>
                  <% (submissionsByDay || []).forEach(function (d) { %>
                  <tr><td><%= d.day %></td><td><%= d.count %></td></tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
          <div class="card">
            <h3 class="admin-dashboard-panel__title">Callback leads / day</h3>
            <div class="table-wrap">
              <table class="table">
                <thead><tr><th>Day</th><th>Count</th></tr></thead>
                <tbody>
                  <% if (!callbacksByDay || callbacksByDay.length === 0) { %>
                  <tr><td colspan="2" class="muted">No data in window.</td></tr>
                  <% } %>
                  <% (callbacksByDay || []).forEach(function (d) { %>
                  <tr><td><%= d.day %></td><td><%= d.count %></td></tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
