<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Super admin | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Regions & stages', activeNav: 'super' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% if (needTenant) { %>
        <div class="flash flash--info" role="status" aria-live="polite">Choose a tenant scope below before using directory tools or user management.</div>
      <% } %>

      <h1 class="section-title section-title--flush">All regions</h1>
      <p class="admin-intro">
        Create, edit, or remove regions. Set <strong>stage</strong> to <strong>Enabled</strong> for live traffic on the subdomain, or <strong>Disabled</strong> / <strong>PartnerCollection</strong> to hide from the picker and return 503 on that host (except <strong>global</strong>, apex-only).
      </p>
      <div class="admin-toolbar">
        <%- include('../partials/components/button', { variant: 'primary', href: '/admin/super/tenants/new', label: 'New region' }) %>
        <%- include('../partials/components/button', { variant: 'default', href: '/admin/super/users', label: 'All admin users' }) %>
      </div>
      <div class="card card--mb-xl">
        <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Short</th>
              <th>Stage</th>
              <th>Set stage</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% tenants.forEach(function(t) { %>
              <tr>
                <td><%= t.id %></td>
                <td><%= t.name %></td>
                <td class="muted"><%= t.slug %></td>
                <td><%= t.stage %></td>
                <td>
                  <form method="post" action="/admin/super/tenants/<%= t.id %>/stage" class="admin-inline-form">
                    <select name="stage" aria-label="Stage for <%= t.slug %>">
                      <option value="<%= stages.PARTNER_COLLECTION %>" <%= t.stage === stages.PARTNER_COLLECTION ? 'selected' : '' %>><%= stages.PARTNER_COLLECTION %></option>
                      <option value="<%= stages.ENABLED %>" <%= t.stage === stages.ENABLED ? 'selected' : '' %>><%= stages.ENABLED %></option>
                      <option value="<%= stages.DISABLED %>" <%= t.stage === stages.DISABLED ? 'selected' : '' %>><%= stages.DISABLED %></option>
                    </select>
                    <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Update' }) %>
                  </form>
                </td>
                <td>
                  <div class="flex-row-wrap--tight">
                    <%- include('../partials/components/button', { variant: 'default', href: '/admin/super/tenants/' + t.id + '/edit', label: 'Edit' }) %>
                    <% if (t.id !== 1 && t.slug !== 'global') { %>
                    <form method="post" action="/admin/super/tenants/<%= t.id %>/delete" onsubmit="return confirm('Delete region <%= t.name %> and all its directory data? This cannot be undone.');">
                      <%- include('../partials/components/button', { variant: 'default', type: 'submit', label: 'Delete' }) %>
                    </form>
                    <% } else { %>
                    <span class="muted muted--caption">—</span>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
        <p class="muted admin-muted-footnote">
          Use <strong>Set stage</strong> or <strong>Edit</strong> to enable or disable a region. Only <strong>Enabled</strong> tenants appear in the public region list (except <strong>global</strong>).
        </p>
      </div>

      <h2 class="section-title" id="act-as-region">Act as region</h2>
      <p class="admin-intro">Scope the directory and leads tools to one region. Sample listings and demo companies live under <strong>demo</strong>; production traffic is usually <strong>zm</strong> or another enabled region.</p>
      <div class="card card--max-640">
        <form method="post" action="/admin/super/scope" class="form">
          <input type="hidden" name="redirect" value="/admin/dashboard" />
          <div>
            <label for="tenant_id">Tenant scope</label>
            <select id="tenant_id" name="tenant_id">
              <option value="">— None (stay on Super only) —</option>
              <% tenants.forEach(function(t) { %>
                <option value="<%= t.id %>" <%= typeof selectedTenantId !== 'undefined' && selectedTenantId === t.id ? 'selected' : '' %>><%= t.name %> (<%= t.slug %>, <%= t.stage %>)</option>
              <% }) %>
            </select>
            <div class="muted admin-field-hint">
              While scoped, Categories, Companies, Leads, and Users apply to that tenant only.
            </div>
          </div>
          <div class="admin-gate-actions">
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Apply scope' }) %>
          </div>
        </form>
      </div>
      </div>
    </main>
  </body>
</html>
