<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>New admin user | Super</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'New user (any tenant)', activeNav: 'super_users' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <% if (error) { %>
        <div class="flash" role="alert"><%= error %></div>
      <% } %>

      <div class="card admin-form-card">
        <form method="post" action="/admin/super/users" class="form">
          <div>
            <label for="s_username">Username</label>
            <input id="s_username" name="username" autocomplete="username" required />
          </div>
          <div>
            <label for="s_password">Password</label>
            <input id="s_password" name="password" type="password" autocomplete="new-password" required minlength="8" />
            <div class="admin-field-hint">At least 8 characters.</div>
          </div>
          <div>
            <label for="s_role">Role</label>
            <select id="s_role" name="role">
              <% (roles || []).forEach(function(r) { %>
                <option value="<%= r %>" <%= r === 'tenant_editor' ? 'selected' : '' %>><%= r %></option>
              <% }) %>
            </select>
          </div>

          <div class="super-user-tenant-block">
            <div>
              <label for="tenant_name_display">Tenant name</label>
              <input
                id="tenant_name_display"
                class="super-user-tenant-readonly"
                type="text"
                readonly
                tabindex="-1"
                value="—"
                aria-describedby="tenant-new-hint"
              />
            </div>
            <div class="super-user-tenant-extra">
              <label for="s_tenant">Assign tenant</label>
              <select id="s_tenant" name="tenant_id">
                <option value="">— None (super admin only) —</option>
                <% (tenants || []).forEach(function(t) { %>
                  <option value="<%= t.id %>" data-tenant-name="<%= t.name %>" data-tenant-slug="<%= t.slug %>">
                    <%= t.name %> — <%= t.slug %> · <%= t.stage %>
                  </option>
                <% }) %>
              </select>
              <p id="tenant-new-hint" class="muted admin-field-hint">
                Choose <strong>None</strong> only for <code>super_admin</code>. For other roles, pick the tenant — the <strong>Tenant name</strong> field above updates to match.
              </p>
            </div>
          </div>

          <div class="admin-gate-actions">
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Create user' }) %>
            <%- include('../partials/components/button', { variant: 'default', href: '/admin/super/users?edit=1', label: 'Cancel' }) %>
          </div>
        </form>
      </div>
      </div>
    </main>
    <script>
      (function () {
        var sel = document.getElementById("s_tenant");
        var display = document.getElementById("tenant_name_display");
        if (!sel || !display) return;
        function sync() {
          var opt = sel.options[sel.selectedIndex];
          if (!opt || !sel.value) {
            display.value = "— (super admin — no tenant)";
            return;
          }
          var n = opt.getAttribute("data-tenant-name") || "";
          var s = opt.getAttribute("data-tenant-slug") || "";
          display.value = n ? n + " (" + s + ")" : opt.textContent;
        }
        sel.addEventListener("change", sync);
        sync();
      })();
    </script>
  </body>
</html>
