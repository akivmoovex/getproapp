<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Pay run #<%= run.id %> | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Pay run detail', activeNav: 'field_agent_pay_runs' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <header class="admin-dashboard__header">
          <div>
            <h1 class="admin-dashboard__title">
              Pay-run snapshot #<%= run.id %>
              <% if (run.status === 'draft') { %>
                <span class="muted" style="font-size:0.85rem;font-weight:600;">Draft</span>
              <% } else if (run.status === 'locked') { %>
                <span style="font-size:0.85rem;font-weight:600;">Locked — values frozen</span>
              <% } else if (run.status === 'approved') { %>
                <span style="font-size:0.85rem;font-weight:600;">Ready for payout processing</span>
              <% } else if (run.status === 'paid') { %>
                <span style="font-size:0.85rem;font-weight:600;">Marked as paid (record only)</span>
              <% } else { %>
                <span class="muted" style="font-size:0.85rem;"><%= run.status %></span>
              <% } %>
            </h1>
            <% if (run.status === 'draft') { %>
            <p class="admin-dashboard__subtitle muted">
              Frozen draft values for review. Based on current linkage, settings, and recorded events at snapshot creation. Not payroll or a payment promise.
            </p>
            <% } else if (run.status === 'locked') { %>
            <p class="admin-dashboard__subtitle muted">
              Locked runs are immutable — line items and period cannot change. Not final payment.
            </p>
            <% } else if (run.status === 'approved') { %>
            <p class="admin-dashboard__subtitle muted">
              System does not execute payments. Export is for manual processing. Marking as paid records completion in this system only.
            </p>
            <% } else if (run.status === 'paid') { %>
            <p class="admin-dashboard__subtitle muted">
              This run is closed. Amounts remain frozen. No further changes.
            </p>
            <% } else { %>
            <p class="admin-dashboard__subtitle muted">Read-only snapshot.</p>
            <% } %>
          </div>
        </header>

        <% if (typeof flashLocked !== 'undefined' && flashLocked) { %>
          <p class="admin-gate-success" role="status">Snapshot locked — values frozen.</p>
        <% } %>
        <% if (typeof flashApproved !== 'undefined' && flashApproved) { %>
          <p class="admin-gate-success" role="status">Pay run approved for processing (not yet paid).</p>
        <% } %>
        <% if (typeof flashPaid !== 'undefined' && flashPaid) { %>
          <p class="admin-gate-success" role="status">Recorded as paid in this system (not a bank confirmation).</p>
        <% } %>
        <% if (typeof flashPaymentRecorded !== 'undefined' && flashPaymentRecorded) { %>
          <p class="admin-gate-success" role="status">Payment event recorded in reconciliation ledger.</p>
        <% } %>
        <% if (typeof flashAdjustment !== 'undefined' && flashAdjustment) { %>
          <p class="admin-gate-success" role="status">Adjustment recorded. Original snapshot rows were not changed.</p>
        <% } %>

        <p><a href="/admin/field-agent-pay-runs<% if (typeof embed !== 'undefined' && embed) { %>?embed=1<% } %>">← Back to list</a></p>
        <% if (typeof tenantId !== 'undefined') { %>
        <p class="muted" style="margin-top:0.25rem;"><a href="/admin/field-agent-adjustments<% var _aq = []; if (typeof embed !== 'undefined' && embed) _aq.push('embed=1'); if (typeof isSuper !== 'undefined' && isSuper) _aq.push('tenant_id=' + tenantId); if (_aq.length) { %>?<%= _aq.join('&') %><% } %>">View all adjustments</a> for this region.</p>
        <% } %>

        <section class="card card--mb-xl">
          <p><strong>Status:</strong> <%= run.status %></p>
          <p><strong>Period:</strong> <%= run.period_start ? new Date(run.period_start).toISOString().slice(0, 10) : '—' %> — <%= run.period_end ? new Date(run.period_end).toISOString().slice(0, 10) : '—' %></p>
          <p><strong>Created:</strong> <%= run.created_at ? new Date(run.created_at).toLocaleString() : '—' %>
            <% if (run.created_by_admin_user_id && typeof actorLabels !== 'undefined' && actorLabels[run.created_by_admin_user_id]) { %>
              <span class="muted">(<%= actorLabels[run.created_by_admin_user_id] %>)</span>
            <% } %>
          </p>
          <% if (run.locked_at) { %>
          <p><strong>Locked:</strong> <%= new Date(run.locked_at).toLocaleString() %>
            <% if (run.locked_by_admin_user_id && typeof actorLabels !== 'undefined' && actorLabels[run.locked_by_admin_user_id]) { %>
              <span class="muted">(<%= actorLabels[run.locked_by_admin_user_id] %>)</span>
            <% } %>
          </p>
          <% } %>
          <% if (run.approved_at) { %>
          <p><strong>Approved:</strong> <%= new Date(run.approved_at).toLocaleString() %>
            <% if (run.approved_by_admin_user_id && typeof actorLabels !== 'undefined' && actorLabels[run.approved_by_admin_user_id]) { %>
              <span class="muted">(<%= actorLabels[run.approved_by_admin_user_id] %>)</span>
            <% } %>
          </p>
          <% } %>
          <% if (run.paid_at) { %>
          <p><strong>Paid (record):</strong> <%= new Date(run.paid_at).toLocaleString() %>
            <% if (run.paid_by_admin_user_id && typeof actorLabels !== 'undefined' && actorLabels[run.paid_by_admin_user_id]) { %>
              <span class="muted">(<%= actorLabels[run.paid_by_admin_user_id] %>)</span>
            <% } %>
          </p>
          <% } %>
          <% if (run.payout_reference) { %><p><strong>Payout reference:</strong> <%= run.payout_reference %></p><% } %>
          <% if (run.payout_notes) { %><p><strong>Payout notes:</strong> <%= run.payout_notes %></p><% } %>
          <% if (run.export_generated_at) { %>
          <p class="muted"><strong>Last export:</strong> <%= new Date(run.export_generated_at).toLocaleString() %> <% if (run.export_format) { %>(<%= run.export_format %>)<% } %></p>
          <% } %>
          <% if (run.notes) { %><p><strong>Notes:</strong> <%= run.notes %></p><% } %>
        </section>

        <% var _rec = (typeof reconciliation !== 'undefined' && reconciliation) ? reconciliation : null; %>
        <% var _payments = (typeof payments !== 'undefined' && payments) ? payments : []; %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Reconciliation ledger</h2>
          <% if (_rec) { %>
          <div class="admin-table-wrap" style="margin-bottom:0.75rem;">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Frozen payable total</th>
                  <th>Total paid</th>
                  <th>Outstanding</th>
                  <th>Reconciliation status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong><%= Number(_rec.run_payable_total || 0).toFixed(2) %></strong></td>
                  <td><strong><%= Number(_rec.total_paid_amount || 0).toFixed(2) %></strong></td>
                  <td><strong><%= Number(_rec.outstanding_amount || 0).toFixed(2) %></strong></td>
                  <td><span style="font-weight:600;"><%= _rec.reconciliation_status %></span></td>
                </tr>
              </tbody>
            </table>
          </div>
          <% } %>

          <% if (run.status === 'approved' || run.status === 'paid') { %>
          <details style="margin-bottom:0.9rem;">
            <summary style="cursor:pointer;font-weight:600;">Record payment event</summary>
            <form method="post" action="/admin/field-agent-pay-runs/<%= run.id %>/payments" style="margin-top:0.6rem;">
              <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
              <div class="admin-filter-form admin-filter-form__grid">
                <div class="input-field">
                  <label class="input-field__label" for="payment_date">Payment date</label>
                  <input id="payment_date" class="input-field__control" name="payment_date" type="date" required />
                </div>
                <div class="input-field">
                  <label class="input-field__label" for="payment_amount">Amount</label>
                  <input id="payment_amount" class="input-field__control" name="amount" type="number" min="0.01" step="0.01" required />
                </div>
                <div class="input-field">
                  <label class="input-field__label" for="payment_method">Method</label>
                  <input id="payment_method" class="input-field__control" name="payment_method" type="text" maxlength="200" placeholder="Bank transfer / cash / mobile money" />
                </div>
                <div class="input-field">
                  <label class="input-field__label" for="payment_reference">Reference</label>
                  <input id="payment_reference" class="input-field__control" name="payment_reference" type="text" maxlength="2000" placeholder="Transaction ID / batch reference" />
                </div>
              </div>
              <div class="input-field" style="margin:0.5rem 0;">
                <label class="input-field__label" for="payment_notes">Notes (optional)</label>
                <textarea id="payment_notes" class="input-field__control" name="notes" rows="2" maxlength="4000"></textarea>
              </div>
              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Add payment event' }) %>
            </form>
          </details>
          <% } else { %>
          <p class="muted" style="margin:0 0 0.75rem 0;">Payment events can be recorded only for approved or paid runs.</p>
          <% } %>

          <h3 class="section-title section-title--flush" style="font-size:1rem;">Payment history</h3>
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Amount</th>
                  <th>Method</th>
                  <th>Reference</th>
                  <th>Notes</th>
                  <th>Recorded by</th>
                  <th>Created at</th>
                </tr>
              </thead>
              <tbody>
                <% if (!_payments.length) { %>
                <tr><td colspan="7" class="muted">No payment events recorded.</td></tr>
                <% } %>
                <% _payments.forEach(function (p) { %>
                <tr>
                  <td><%= p.payment_date ? new Date(p.payment_date).toISOString().slice(0, 10) : '—' %></td>
                  <td><strong><%= Number(p.amount || 0).toFixed(2) %></strong></td>
                  <td><%= p.payment_method || '—' %></td>
                  <td><%= p.payment_reference || '—' %></td>
                  <td><%= p.notes || '—' %></td>
                  <td><%= (p.created_by_admin_user_id && actorLabels && actorLabels[p.created_by_admin_user_id]) ? actorLabels[p.created_by_admin_user_id] : (p.created_by_admin_user_id ? ('#' + p.created_by_admin_user_id) : '—') %></td>
                  <td><%= p.created_at ? new Date(p.created_at).toLocaleString() : '—' %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>

        <% if (run.status === 'draft' && items && items.length) { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Lock snapshot</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Locking freezes all line items. You cannot edit amounts or period after lock.</p>
          <form method="post" action="/admin/field-agent-pay-runs/<%= run.id %>/lock">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Lock snapshot' }) %>
          </form>
        </section>
        <% } %>

        <% if (run.status === 'locked') { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Approve pay run</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Approval marks this run ready for export or payment workflows in later steps. Does not record a bank transfer.</p>
          <form method="post" action="/admin/field-agent-pay-runs/<%= run.id %>/approve">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Approve pay run' }) %>
          </form>
        </section>
        <% } %>

        <% if (run.status === 'approved') { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Payout file</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Download payout file (CSV). Uses frozen snapshot values only.</p>
          <p style="margin-bottom:0.75rem;">
            <%- include('../partials/components/button', { variant: 'primary', href: '/admin/field-agent-pay-runs/' + run.id + '/export', label: 'Download CSV' }) %>
          </p>
        </section>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Mark as paid</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Record that payout was completed outside this system (e.g. bank transfer). This cannot be undone.</p>
          <form method="post" action="/admin/field-agent-pay-runs/<%= run.id %>/mark-paid" onsubmit="return confirm('This will mark the run as paid and cannot be undone.');">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <div class="input-field" style="margin-bottom:0.75rem;">
              <label class="input-field__label" for="payout_reference">Payout reference (optional)</label>
              <input class="input-field__control" type="text" id="payout_reference" name="payout_reference" maxlength="2000" placeholder="Bank ref, transfer ID, batch ID" />
            </div>
            <div class="input-field" style="margin-bottom:0.75rem;">
              <label class="input-field__label" for="payout_notes">Payout notes (optional)</label>
              <textarea class="input-field__control" id="payout_notes" name="payout_notes" rows="2" maxlength="4000" placeholder="Internal notes"></textarea>
            </div>
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Mark as paid' }) %>
          </form>
        </section>
        <% } %>

        <% if (run.status === 'paid') { %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Payout file</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Re-download frozen snapshot (CSV). System does not execute payments.</p>
          <p style="margin-bottom:0.75rem;">
            <%- include('../partials/components/button', { variant: 'primary', href: '/admin/field-agent-pay-runs/' + run.id + '/export', label: 'Download CSV' }) %>
          </p>
        </section>
        <% } %>

        <section class="card">
          <h2 class="section-title section-title--flush">Frozen line items</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Adjustments are recorded separately and carried into this pay run. SP/EC/recruitment columns are the original snapshot; applied adjustments and net payable are frozen on this line.</p>
          <div class="admin-table-wrap" style="overflow-x: auto;">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Agent</th>
                  <th>Rating used</th>
                  <th>Low / high</th>
                  <th>Bonus %</th>
                  <th>Earned SP</th>
                  <th>SP bonus</th>
                  <th>SP wh.</th>
                  <th>SP pay.</th>
                  <th>Earned EC</th>
                  <th>EC wh.</th>
                  <th>EC pay.</th>
                  <th>Recr.</th>
                  <th>Base payable</th>
                  <th>Applied adj.</th>
                  <th>Net payable</th>
                  <th>SP label</th>
                  <th>EC label</th>
                  <th>Statement</th>
                  <th>Ledger / add</th>
                </tr>
              </thead>
              <tbody>
                <% (items || []).forEach(function (it) { %>
                <tr>
                  <td><%= it.field_agent_label_snapshot %></td>
                  <td><%= it.sp_rating_value_used != null ? Number(it.sp_rating_value_used).toFixed(4) : '—' %></td>
                  <td><%= it.sp_rating_low_threshold_used %> / <%= it.sp_rating_high_threshold_used %></td>
                  <td><%= it.sp_high_rating_bonus_percent_used != null ? it.sp_high_rating_bonus_percent_used : '—' %></td>
                  <td><%= it.earned_sp_commission %></td>
                  <td><%= it.sp_bonus_amount %></td>
                  <td><%= it.sp_withheld_amount %></td>
                  <td><%= it.sp_payable_amount %></td>
                  <td><%= it.earned_ec_commission %></td>
                  <td><%= it.ec_withheld_amount %></td>
                  <td><%= it.ec_payable_amount %></td>
                  <td><%= it.recruitment_commission_amount %></td>
                  <% var _bp = (Number(it.sp_payable_amount)||0) + (Number(it.ec_payable_amount)||0) + (Number(it.recruitment_commission_amount)||0); %>
                  <td><%= _bp %></td>
                  <td><%= it.applied_adjustment_amount != null ? it.applied_adjustment_amount : 0 %></td>
                  <td><strong><%= it.net_payable_amount != null ? it.net_payable_amount : _bp %></strong></td>
                  <td class="muted"><%= it.quality_status_label_sp %></td>
                  <td class="muted"><%= it.quality_status_label_ec %></td>
                  <td><a href="/admin/field-agent-pay-runs/<%= run.id %>/statements/<%= it.field_agent_id %><% if (typeof embed !== 'undefined' && embed) { %>?embed=1<% } %>" target="_blank" rel="noopener">Print view</a></td>
                  <td style="vertical-align:top;min-width:12rem;">
                    <% var _adjs = (typeof adjustmentsByItemId !== 'undefined' && adjustmentsByItemId[it.id]) ? adjustmentsByItemId[it.id] : []; %>
                    <% var _carried = (typeof carriedAdjustmentsByFieldAgentId !== 'undefined' && carriedAdjustmentsByFieldAgentId[it.field_agent_id]) ? carriedAdjustmentsByFieldAgentId[it.field_agent_id] : []; %>
                    <% if (_adjs.length || _carried.length) { %>
                      <ul class="muted" style="margin:0 0 0.5rem 1rem;padding:0;font-size:0.85rem;">
                        <% _carried.forEach(function (adj) { %>
                          <li>Carried: <%= adj.adjustment_amount > 0 ? '+' : '' %><%= adj.adjustment_amount %> — <a href="/admin/field-agent-adjustments?original_pay_run_id=<%= adj.original_pay_run_id %><% if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') { %>&amp;tenant_id=<%= tenantId %><% } %><% if (typeof embed !== 'undefined' && embed) { %>&amp;embed=1<% } %>">Adj #<%= adj.id %></a></li>
                        <% }); %>
                        <% _adjs.forEach(function (adj) { %>
                          <li>Line: <%= adj.adjustment_amount > 0 ? '+' : '' %><%= adj.adjustment_amount %> — <%= String(adj.reason || '').slice(0, 40) %><%= String(adj.reason || '').length > 40 ? '…' : '' %></li>
                        <% }); %>
                      </ul>
                    <% } else { %>
                      <span class="muted" style="font-size:0.85rem;">—</span>
                    <% } %>
                    <% if (typeof canAddAdjustment !== 'undefined' && canAddAdjustment) { %>
                    <details style="margin-top:0.35rem;">
                      <summary style="cursor:pointer;font-size:0.9rem;">Add adjustment</summary>
                      <form method="post" action="/admin/field-agent-adjustments" style="margin-top:0.5rem;padding:0.5rem;background:#f9f9f9;border-radius:4px;">
                        <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
                        <% if (typeof isSuper !== 'undefined' && isSuper && typeof tenantId !== 'undefined') { %><input type="hidden" name="tenant_id" value="<%= tenantId %>" /><% } %>
                        <input type="hidden" name="original_pay_run_item_id" value="<%= it.id %>" />
                        <input type="hidden" name="redirect_pay_run_id" value="<%= run.id %>" />
                        <div class="input-field" style="margin-bottom:0.5rem;">
                          <label class="input-field__label" for="adj_amt_<%= it.id %>">Amount (+ or −)</label>
                          <input class="input-field__control" id="adj_amt_<%= it.id %>" name="adjustment_amount" type="text" required placeholder="-10.50 or 25.00" />
                        </div>
                        <div class="input-field" style="margin-bottom:0.5rem;">
                          <label class="input-field__label" for="adj_reason_<%= it.id %>">Reason (required)</label>
                          <input class="input-field__control" id="adj_reason_<%= it.id %>" name="reason" type="text" required maxlength="4000" />
                        </div>
                        <div class="input-field" style="margin-bottom:0.5rem;">
                          <label class="input-field__label" for="adj_type_<%= it.id %>">Type</label>
                          <select class="input-field__control" id="adj_type_<%= it.id %>" name="adjustment_type">
                            <option value="manual">Manual</option>
                            <option value="sp">SP</option>
                            <option value="ec">EC</option>
                            <option value="recruitment">Recruitment</option>
                          </select>
                        </div>
                        <div class="input-field" style="margin-bottom:0.5rem;">
                          <label class="input-field__label" for="adj_notes_<%= it.id %>">Admin notes (optional)</label>
                          <textarea class="input-field__control" id="adj_notes_<%= it.id %>" name="admin_notes" rows="2" maxlength="8000"></textarea>
                        </div>
                        <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Add adjustment' }) %>
                      </form>
                    </details>
                    <% } %>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </main>
  </body>
</html>
