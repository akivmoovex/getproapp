<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Categories | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app">
    <%- include('../partials/admin_nav', { navTitle: 'Categories', activeNav: 'categories' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
      <div class="admin-toolbar">
        <a class="btn btn-primary" href="/admin/categories/new">New category</a>
      </div>

      <h1 class="section-title" style="margin-top:0;">Categories</h1>
      <div class="card">
        <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Slug</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% categories.forEach(function(cat) { %>
              <tr>
                <td><%= cat.name %></td>
                <td class="muted"><%= cat.slug %></td>
                <td class="muted"><%= cat.created_at %></td>
                <td>
                  <div style="display:flex;gap:10px;flex-wrap:wrap;">
                    <a class="btn" href="/admin/categories/<%= cat.id %>/edit">Edit</a>
                    <form method="post" action="/admin/categories/<%= cat.id %>/delete" onsubmit="return confirm('Delete category? Companies will be uncategorized.');">
                      <button class="btn" type="submit">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      </div>
    </main>
  </body>
</html>

