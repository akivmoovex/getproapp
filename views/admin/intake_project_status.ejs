<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Client Lead Status | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Client Lead Status', activeNav: 'client_lead_status' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <div class="admin-toolbar">
          <%- include('../partials/components/button', { variant: 'default', href: '/admin/projects', label: 'Intake projects (CRM)' }) %>
        </div>
        <h1 class="section-title section-title--flush">Client Lead Status</h1>
        <% var _showPriceSt = typeof adminNav !== 'undefined' && adminNav.canViewIntakePriceEstimation; %>
        <% var _twLead = typeof adminNav !== 'undefined' && adminNav.canViewTenantWideLeadProgress; %>
        <p class="muted admin-intro">Intake projects (client leads), company assignments, and portal response summary for this region. Sorting, filters, and pagination use the query string only.<% if (_twLead) { %> <strong>Tenant-wide</strong> lead progress for administrators.<% } %></p>

        <% var f = typeof filters !== 'undefined' && filters ? filters : {}; %>
        <% var hasFilters = !!(f.q || f.project_status || f.assignment_status || f.city || f.company_id || f.date_from || f.date_to); %>
        <% if (hasFilters) { %>
        <p class="admin-status-active-filters muted">
          Active filters
          <% if (f.q) { %><span class="admin-status-chip">q: <%= f.q %></span><% } %>
          <% if (f.project_status) { %><span class="admin-status-chip">project: <%= f.project_status %></span><% } %>
          <% if (f.assignment_status) { %><span class="admin-status-chip">assignment: <%= f.assignment_status %></span><% } %>
          <% if (f.city) { %><span class="admin-status-chip">city: <%= f.city %></span><% } %>
          <% if (f.company_id) { %><span class="admin-status-chip">company id: <%= f.company_id %></span><% } %>
          <% if (f.date_from || f.date_to) { %><span class="admin-status-chip">dates: <%= f.date_from || '…' %> – <%= f.date_to || '…' %></span><% } %>
          <%- include('../partials/components/button', { variant: 'text', href: (typeof resetHref !== 'undefined' ? resetHref : '/admin/client-lead-status'), label: 'Clear filters' }) %>
        </p>
        <% } %>

        <div class="card admin-form-card card--mb-block">
          <h2 class="admin-form-card__title">Filters</h2>
          <form method="get" action="/admin/client-lead-status" class="form admin-status-filters">
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="sort" value="<%= typeof sort !== 'undefined' ? sort : 'created_at' %>" />
            <input type="hidden" name="dir" value="<%= typeof dir !== 'undefined' ? dir : 'desc' %>" />
            <div class="admin-status-filter-grid">
              <div class="input-field">
                <label class="input-field__label" for="f_q">Search (project or client code)</label>
                <input id="f_q" name="q" class="input-field__control" value="<%= f.q || '' %>" />
              </div>
              <div class="input-field">
                <label class="input-field__label" for="f_ps">Project status</label>
                <input id="f_ps" name="project_status" class="input-field__control" placeholder="e.g. new" value="<%= f.project_status || '' %>" />
              </div>
              <div class="input-field">
                <label class="input-field__label" for="f_as">Assignment status</label>
                <select id="f_as" name="assignment_status" class="input-field__control">
                  <option value="">Any</option>
                  <option value="pending" <%= f.assignment_status === 'pending' ? 'selected' : '' %>>pending</option>
                  <option value="allocated" <%= f.assignment_status === 'allocated' ? 'selected' : '' %>>allocated</option>
                  <option value="viewed" <%= f.assignment_status === 'viewed' ? 'selected' : '' %>>viewed</option>
                  <option value="interested" <%= f.assignment_status === 'interested' ? 'selected' : '' %>>interested</option>
                  <option value="declined" <%= f.assignment_status === 'declined' ? 'selected' : '' %>>declined</option>
                  <option value="callback_requested" <%= f.assignment_status === 'callback_requested' ? 'selected' : '' %>>callback_requested</option>
                  <option value="timed_out" <%= f.assignment_status === 'timed_out' ? 'selected' : '' %>>timed_out</option>
                  <option value="expired" <%= f.assignment_status === 'expired' ? 'selected' : '' %>>expired</option>
                </select>
              </div>
              <div class="input-field">
                <label class="input-field__label" for="f_city">City (exact)</label>
                <select id="f_city" name="city" class="input-field__control">
                  <option value="">Any</option>
                  <% (cities || []).forEach(function (ct) { %>
                    <option value="<%= ct %>" <%= f.city === ct ? 'selected' : '' %>><%= ct %></option>
                  <% }); %>
                </select>
              </div>
              <div class="input-field">
                <label class="input-field__label" for="f_co">Assigned company</label>
                <select id="f_co" name="company_id" class="input-field__control">
                  <option value="">Any</option>
                  <% (companies || []).forEach(function (co) { %>
                    <option value="<%= co.id %>" <%= String(f.company_id) === String(co.id) ? 'selected' : '' %>><%= co.name %> (@<%= co.subdomain %>)</option>
                  <% }); %>
                </select>
              </div>
              <div class="input-field">
                <label class="input-field__label" for="f_df">Created from (YYYY-MM-DD)</label>
                <input id="f_df" name="date_from" class="input-field__control" value="<%= f.date_from || '' %>" />
              </div>
              <div class="input-field">
                <label class="input-field__label" for="f_dt">Created to (YYYY-MM-DD)</label>
                <input id="f_dt" name="date_to" class="input-field__control" value="<%= f.date_to || '' %>" />
              </div>
            </div>
            <div class="form-step__actions">
              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Apply' }) %>
              <%- include('../partials/components/button', { variant: 'text', href: (typeof resetHref !== 'undefined' ? resetHref : '/admin/client-lead-status'), label: 'Reset' }) %>
            </div>
          </form>
        </div>

        <div class="table-wrap card">
          <table class="table admin-status-table">
            <thead>
              <tr>
                <th><a href="<%= sortToggleHref('project_code') %>" class="admin-status-sort">Project code<% if (sort === 'project_code') { %> <span class="muted"><%= dir %></span><% } %></a></th>
                <th>Client code</th>
                <th>Client name</th>
                <th><a href="<%= sortToggleHref('city') %>" class="admin-status-sort">City<% if (sort === 'city') { %> <span class="muted"><%= dir %></span><% } %></a></th>
                <th>Neighborhood</th>
                <th><% if (_showPriceSt) { %><a href="<%= sortToggleHref('estimated_budget_value') %>" class="admin-status-sort">Budget<% if (sort === 'estimated_budget_value') { %> <span class="muted"><%= dir %></span><% } %></a><% } else { %>Budget<% } %></th>
                <th><a href="<%= sortToggleHref('status') %>" class="admin-status-sort">Project status<% if (sort === 'status') { %> <span class="muted"><%= dir %></span><% } %></a></th>
                <th>Company responses</th>
                <th>Assigned #</th>
                <th><a href="<%= sortToggleHref('created_at') %>" class="admin-status-sort">Created<% if (sort === 'created_at') { %> <span class="muted"><%= dir %></span><% } %></a></th>
                <th><a href="<%= sortToggleHref('updated_at') %>" class="admin-status-sort">Updated<% if (sort === 'updated_at') { %> <span class="muted"><%= dir %></span><% } %></a></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if (!rows || rows.length === 0) { %>
                <tr><td colspan="12" class="muted">No projects match the current filters.</td></tr>
              <% } %>
              <% (rows || []).forEach(function (r) { %>
                <tr>
                  <td class="u-text-strong"><%= r.project_code %></td>
                  <td><%= r.client_code %></td>
                  <td><%= r.client_display_name %></td>
                  <td><%= r.city || '—' %></td>
                  <td><%= r.neighborhood || '—' %></td>
                  <td>
                    <% if (_showPriceSt) { %>
                      <% if (r.estimated_budget_value != null && r.estimated_budget_value !== '') { %>
                        <%= typeof budget !== 'undefined' && budget ? budget.displayPrefix + ' ' : '' %><%= r.estimated_budget_value %> <%= r.estimated_budget_currency || '' %>
                      <% } else { %>—<% } %>
                    <% } else { %><span class="muted">—</span><% } %>
                  </td>
                  <td><%= typeof intakeProjectStatusLabel === 'function' ? intakeProjectStatusLabel(r.project_status) : r.project_status %></td>
                  <td class="muted admin-status-summary"><%= r.assign_summary %></td>
                  <td><%= r.assign_count != null ? r.assign_count : 0 %></td>
                  <td class="muted"><%- include('../partials/event_time', { at: r.created_at }) %></td>
                  <td class="muted"><%- include('../partials/event_time', { at: r.updated_at }) %></td>
                  <td><%- include('../partials/components/button', { variant: 'default', href: '/admin/projects/' + r.id, label: 'Open' }) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% var _tot = typeof total !== 'undefined' ? total : 0; %>
        <% var _pg = typeof page !== 'undefined' ? page : 1; %>
        <% var _mp = typeof maxPage !== 'undefined' ? maxPage : 1; %>
        <% var _ps = typeof pageSize !== 'undefined' ? pageSize : 50; %>
        <% if (typeof projectStatusPageHref === 'function' && _mp > 1) { %>
        <nav class="admin-status-pagination muted" aria-label="Results pages">
          <% if (_pg > 1) { %>
            <%- include('../partials/components/button', { variant: 'text', href: projectStatusPageHref(_pg - 1), label: '← Previous' }) %>
          <% } %>
          <span class="admin-status-pagination__meta">Page <%= _pg %> of <%= _mp %></span>
          <% if (_pg < _mp) { %>
            <%- include('../partials/components/button', { variant: 'text', href: projectStatusPageHref(_pg + 1), label: 'Next →' }) %>
          <% } %>
        </nav>
        <% } %>
        <p class="muted u-mt-note"><%= _tot %> project(s) match; showing <%= _ps %> per page. Assignment summary is a count of statuses across assigned companies.</p>
      </div>
    </main>
  </body>
</html>
