<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Month-close reconciliation | Pay run #<%= run.id %> | <%= _bn %> Admin</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-app<%- bodyEmbedClass %>">
    <%- include('../partials/admin_nav', { navTitle: 'Month-close reconciliation', activeNav: 'field_agent_pay_runs' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <header class="admin-dashboard__header">
          <div>
            <h1 class="admin-dashboard__title">Month-close reconciliation view</h1>
            <p class="admin-dashboard__subtitle muted">
              Frozen pay-run values and payment ledger totals only. No historical values are recalculated here.
            </p>
          </div>
        </header>

        <p>
          <a href="/admin/field-agent-pay-runs/<%= run.id %><% if (typeof embed !== 'undefined' && embed) { %>?embed=1<% } %>">← Pay run detail</a>
          ·
          <a href="/admin/field-agent-pay-runs/<%= run.id %>/accounting-export.csv<% if (typeof embed !== 'undefined' && embed) { %>?embed=1<% } %>">Download accounting CSV</a>
        </p>

        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Pay run summary</h2>
          <p><strong>Tenant:</strong> <%= typeof tenantLabel !== 'undefined' ? tenantLabel : '—' %></p>
          <p><strong>Pay run ID:</strong> <%= run.id %></p>
          <p><strong>Period:</strong> <%= run.period_start ? new Date(run.period_start).toISOString().slice(0, 10) : '—' %> — <%= run.period_end ? new Date(run.period_end).toISOString().slice(0, 10) : '—' %></p>
          <p><strong>Status:</strong> <%= run.status %></p>
          <p><strong>Created:</strong> <%= run.created_at ? new Date(run.created_at).toLocaleString() : '—' %>
            <% if (run.created_by_admin_user_id && typeof actorLabels !== 'undefined' && actorLabels[run.created_by_admin_user_id]) { %>
              <span class="muted">(<%= actorLabels[run.created_by_admin_user_id] %>)</span>
            <% } %>
          </p>
          <% if (run.locked_at) { %>
          <p><strong>Locked:</strong> <%= new Date(run.locked_at).toLocaleString() %>
            <% if (run.locked_by_admin_user_id && typeof actorLabels !== 'undefined' && actorLabels[run.locked_by_admin_user_id]) { %>
              <span class="muted">(<%= actorLabels[run.locked_by_admin_user_id] %>)</span>
            <% } %>
          </p>
          <% } %>
          <% if (run.approved_at) { %>
          <p><strong>Approved:</strong> <%= new Date(run.approved_at).toLocaleString() %>
            <% if (run.approved_by_admin_user_id && typeof actorLabels !== 'undefined' && actorLabels[run.approved_by_admin_user_id]) { %>
              <span class="muted">(<%= actorLabels[run.approved_by_admin_user_id] %>)</span>
            <% } %>
          </p>
          <% } %>
          <% if (run.paid_at) { %>
          <p><strong>Paid (record):</strong> <%= new Date(run.paid_at).toLocaleString() %>
            <% if (run.paid_by_admin_user_id && typeof actorLabels !== 'undefined' && actorLabels[run.paid_by_admin_user_id]) { %>
              <span class="muted">(<%= actorLabels[run.paid_by_admin_user_id] %>)</span>
            <% } %>
          </p>
          <% } %>
        </section>

        <% var _rec = (typeof reconciliation !== 'undefined' && reconciliation) ? reconciliation : null; %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Reconciliation summary</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Payment ledger totals are the sum of recorded payment events for this pay run.</p>
          <% if (_rec) { %>
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Frozen payable total</th>
                  <th>Total paid (ledger)</th>
                  <th>Outstanding</th>
                  <th>Overpaid</th>
                  <th>Reconciliation status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong><%= Number(_rec.run_payable_total || 0).toFixed(2) %></strong></td>
                  <td><strong><%= Number(_rec.total_paid_amount || 0).toFixed(2) %></strong></td>
                  <td><strong><%= Number(typeof signedOutstanding !== 'undefined' ? signedOutstanding : (_rec.outstanding_amount || 0)).toFixed(2) %></strong></td>
                  <td><strong><%= Number(typeof overpaidAmount !== 'undefined' ? overpaidAmount : 0).toFixed(2) %></strong></td>
                  <td><span style="font-weight:600;"><%= _rec.reconciliation_status %></span></td>
                </tr>
              </tbody>
            </table>
          </div>
          <% if (typeof signedOutstanding !== 'undefined' && signedOutstanding < 0) { %>
          <p class="muted" style="margin-top:0.75rem;">Outstanding is negative when the ledger shows more paid than the frozen payable total (overpayment).</p>
          <% } %>
          <% } else { %>
          <p class="muted">No reconciliation data.</p>
          <% } %>
        </section>

        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Field-agent line items (frozen)</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Values are stored snapshot columns from the pay run; components are not recomputed from live ratings or thresholds.</p>
          <form method="get" action="/admin/field-agent-pay-runs/<%= run.id %>/month-close" style="margin-bottom:0.75rem;display:flex;gap:0.5rem;flex-wrap:wrap;align-items:flex-end;">
            <% if (typeof embed !== 'undefined' && embed) { %><input type="hidden" name="embed" value="1" /><% } %>
            <div class="input-field">
              <label class="input-field__label" for="agent_q">Filter by agent name</label>
              <input id="agent_q" class="input-field__control" name="agent_q" type="search" value="<%= typeof agentQ !== 'undefined' ? agentQ : '' %>" placeholder="Snapshot label contains…" />
            </div>
            <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Apply' }) %>
          </form>
          <div class="admin-table-wrap" style="overflow-x:auto;">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Agent</th>
                  <th>SP pay.</th>
                  <th>EC pay.</th>
                  <th>Recr.</th>
                  <th>Applied adj.</th>
                  <th>Net payable</th>
                  <th>SP quality</th>
                  <th>EC quality</th>
                </tr>
              </thead>
              <tbody>
                <% if (!(items || []).length) { %>
                <tr><td colspan="8" class="muted">No line items match this filter.</td></tr>
                <% } %>
                <% (items || []).forEach(function (it) { %>
                <% var _bp = (Number(it.sp_payable_amount)||0) + (Number(it.ec_payable_amount)||0) + (Number(it.recruitment_commission_amount)||0); %>
                <tr>
                  <td><%= it.field_agent_label_snapshot %> <span class="muted">(#<%= it.field_agent_id %>)</span></td>
                  <td><%= it.sp_payable_amount %></td>
                  <td><%= it.ec_payable_amount %></td>
                  <td><%= it.recruitment_commission_amount %></td>
                  <td><%= it.applied_adjustment_amount != null ? it.applied_adjustment_amount : 0 %></td>
                  <td><strong><%= it.net_payable_amount != null ? it.net_payable_amount : _bp %></strong></td>
                  <td class="muted"><%= it.quality_status_label_sp || '—' %></td>
                  <td class="muted"><%= it.quality_status_label_ec || '—' %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>

        <% var _payments = (typeof payments !== 'undefined' && payments) ? payments : []; %>
        <section class="card card--mb-xl">
          <h2 class="section-title section-title--flush">Payment ledger</h2>
          <p class="muted" style="margin-bottom:0.75rem;">Chronological list of recorded payment events (append-only ledger).</p>
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Amount</th>
                  <th>Method</th>
                  <th>Reference</th>
                  <th>Notes</th>
                  <th>Recorded by</th>
                  <th>Created at</th>
                </tr>
              </thead>
              <tbody>
                <% if (!_payments.length) { %>
                <tr><td colspan="7" class="muted">No payment events recorded.</td></tr>
                <% } %>
                <% _payments.forEach(function (p) { %>
                <tr>
                  <td><%= p.payment_date ? new Date(p.payment_date).toISOString().slice(0, 10) : '—' %></td>
                  <td><strong><%= Number(p.amount || 0).toFixed(2) %></strong></td>
                  <td><%= p.payment_method || '—' %></td>
                  <td><%= p.payment_reference || '—' %></td>
                  <td><%= p.notes || '—' %></td>
                  <td><%= (p.created_by_admin_user_id && actorLabels && actorLabels[p.created_by_admin_user_id]) ? actorLabels[p.created_by_admin_user_id] : (p.created_by_admin_user_id ? ('#' + p.created_by_admin_user_id) : '—') %></td>
                  <td><%= p.created_at ? new Date(p.created_at).toLocaleString() : '—' %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="card">
          <h2 class="section-title section-title--flush">Accounting copy</h2>
          <ul class="muted" style="margin:0;padding-left:1.25rem;">
            <li><strong>Frozen pay-run values</strong> — line-item amounts are the stored snapshot at lock/approval; this report does not re-derive commissions.</li>
            <li><strong>Payment ledger totals</strong> — sums of <code>field_agent_pay_run_payments</code> for this pay run only.</li>
            <li><strong>Month-close reconciliation view</strong> — compares frozen payable to ledger payments; outstanding may be negative when overpaid.</li>
            <li><strong>No historical values are recalculated here.</strong></li>
          </ul>
        </section>
      </div>
    </main>
  </body>
</html>
