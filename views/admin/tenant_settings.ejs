<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Region settings | GetPro Admin</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-app">
    <%- include('../partials/admin_nav', { navTitle: 'Region settings', activeNav: 'settings' }) %>
    <main class="admin-main">
      <div class="container admin-main__pad">
        <% if (mode === 'super') { %>
        <h1 class="section-title" style="margin-top: 0">All regions — contact &amp; business</h1>
        <p class="muted" style="margin: -8px 0 20px; max-width: 62ch; line-height: 1.55">
          Per-tenant defaults for listing phone, support line, WhatsApp, and call-center email. Empty fields fall back to platform env defaults on save (same as Super admin region form).
        </p>
        <% tenants.forEach(function (t) { %>
        <div class="card admin-form-card" style="margin-bottom: 20px">
          <h2 class="section-title" style="margin: 0 0 16px; font-size: 1.15rem">
            <%= t.name %>
            <span class="muted" style="font-weight: 600; font-size: 14px">(<%= t.slug %> · id <%= t.id %>)</span>
          </h2>
          <form method="post" action="/admin/settings/tenant/<%= t.id %>" class="form">
            <div>
              <label for="ts_call_<%= t.id %>">Customer listing phone</label>
              <input
                id="ts_call_<%= t.id %>"
                name="callcenter_phone"
                type="text"
                value="<%= t.callcenter_phone ? t.callcenter_phone : '+260211000101' %>"
                placeholder="+260211000101"
              />
            </div>
            <div>
              <label for="ts_sup_<%= t.id %>">Support help line</label>
              <input
                id="ts_sup_<%= t.id %>"
                name="support_help_phone"
                type="text"
                value="<%= t.support_help_phone ? t.support_help_phone : '+260211000101' %>"
                placeholder="+260211000101"
              />
            </div>
            <div>
              <label for="ts_wa_<%= t.id %>">WhatsApp phone</label>
              <input
                id="ts_wa_<%= t.id %>"
                name="whatsapp_phone"
                type="text"
                value="<%= t.whatsapp_phone ? t.whatsapp_phone : '+260211000102' %>"
                placeholder="+260211000102"
              />
            </div>
            <div>
              <label for="ts_em_<%= t.id %>">Call center email</label>
              <input
                id="ts_em_<%= t.id %>"
                name="callcenter_email"
                type="email"
                value="<%= t.callcenter_email ? t.callcenter_email : 'info@getproapp.org' %>"
                placeholder="info@getproapp.org"
              />
            </div>
            <div class="admin-gate-actions">
              <button class="btn btn-primary" type="submit">Save <%= t.slug %></button>
            </div>
          </form>
        </div>
        <% }); %>
        <% } else { %>
        <h1 class="section-title" style="margin-top: 0">Region settings</h1>
        <p class="muted" style="margin: -8px 0 20px; max-width: 62ch; line-height: 1.55">
          Default numbers and email for your region’s directory and company mini-sites.
        </p>
        <div class="card admin-form-card">
          <form method="post" action="/admin/settings/tenant/<%= tenant.id %>" class="form">
            <div>
              <label for="ts_call">Customer listing phone</label>
              <input
                id="ts_call"
                name="callcenter_phone"
                type="text"
                value="<%= tenant.callcenter_phone ? tenant.callcenter_phone : '+260211000101' %>"
                placeholder="+260211000101"
              />
            </div>
            <div>
              <label for="ts_sup">Support help line</label>
              <input
                id="ts_sup"
                name="support_help_phone"
                type="text"
                value="<%= tenant.support_help_phone ? tenant.support_help_phone : '+260211000101' %>"
                placeholder="+260211000101"
              />
            </div>
            <div>
              <label for="ts_wa">WhatsApp phone</label>
              <input
                id="ts_wa"
                name="whatsapp_phone"
                type="text"
                value="<%= tenant.whatsapp_phone ? tenant.whatsapp_phone : '+260211000102' %>"
                placeholder="+260211000102"
              />
            </div>
            <div>
              <label for="ts_em">Call center email</label>
              <input
                id="ts_em"
                name="callcenter_email"
                type="email"
                value="<%= tenant.callcenter_email ? tenant.callcenter_email : 'info@getproapp.org' %>"
                placeholder="info@getproapp.org"
              />
            </div>
            <div class="admin-gate-actions">
              <button class="btn btn-primary" type="submit">Save</button>
            </div>
          </form>
        </div>
        <% } %>
      </div>
    </main>
  </body>
</html>
