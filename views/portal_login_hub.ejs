<!doctype html>
<%# Sign-in hub: home shell (hero) under the modal; same M3 overlay/backdrop pattern as join modal. %>
<% var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/seo_meta', {
      seoTitle: 'Sign in | ' + _bn,
      seoDescription: 'Choose how you want to sign in — clients, service providers, field agents, or internal tools.',
      canonicalUrl: '',
      ogUrl: '',
      ogType: 'website'
    }) %>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <% var _home = typeof tenantHomeHref !== 'undefined' ? tenantHomeHref : '/'; %>
  <body class="home-page home-page--launcher wf-home-layout portal-login-hub-page portal-login-hub-page--overlay-home join-modal-open <%= typeof tenant !== 'undefined' && tenant ? tenant.themeClass : 'tenant-zm' %>" data-screen-role="launcher">
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix }) %>

      <div class="app-layout__main">
    <% if (typeof showRegionPickerUi !== 'undefined' && showRegionPickerUi) { %>
    <div id="wf-region-m3-root" class="m3-modal-overlay wf-region-m3" hidden aria-hidden="true">
      <div class="m3-modal-overlay__backdrop" id="wf-region-overlay"></div>
      <div
        id="wf-region-sheet"
        class="m3-modal wf-region-sheet wf-region-sheet--picker"
        role="dialog"
        aria-modal="true"
        aria-labelledby="wf-region-title"
      >
        <header class="m3-modal__header wf-region-sheet__header">
          <h2 id="wf-region-title" class="m3-modal__title wf-region-title wf-region-title--picker">Choose region</h2>
          <button type="button" class="m3-modal__close wf-region-close-x" id="wf-region-close-x" aria-label="Close">×</button>
        </header>
        <div class="m3-modal__body wf-region-sheet__body">
          <div class="wf-region-actions wf-region-actions--grid">
        <% if (typeof regionChoices !== 'undefined' && regionChoices && regionChoices.length) { %>
          <% regionChoices.forEach(function (r) { %>
            <a class="wf-region-btn" href="<%= r.href %>">
              <span class="wf-region-btn-label" <%= r.slug === 'il' ? 'dir="rtl"' : '' %>><%= r.slug === 'il' ? 'ישראל' : r.name %></span>
              <span class="wf-region-btn-flag" aria-hidden="true"><%= r.flag %></span>
            </a>
          <% }); %>
        <% } else { %>
        <a class="wf-region-btn" href="<%= regionZmUrl || tenantHomeHref %>">
          <span class="wf-region-btn-label">Zambia</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇿🇲</span>
        </a>
        <% if (regionIlUrl) { %>
        <a class="wf-region-btn" href="<%= regionIlUrl %>">
          <span class="wf-region-btn-label" dir="rtl">ישראל</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇮🇱</span>
        </a>
        <% } %>
        <% } %>
          </div>
        </div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>
    <% } %>

    <main class="gp-home" role="main">
      <div class="gp-home-top-stack">
      <section class="gp-home-hero" aria-labelledby="gp-home-hero-title">
        <%- include('partials/components/container_start') %>
          <h1 id="gp-home-hero-title" class="visually-hidden"><%= _bn %> — professional directory</h1>
          <div class="gp-home-hero__top">
            <div class="gp-home-hero__search-shell">
              <div id="site-search-bar" class="c-search-bar-shell gp-home-search gp-home-search-card" aria-label="Project search">
                <%- include('partials/pro_search_form', {
                  variant: 'home',
                  tenantUrlPrefix,
                  formAction: typeof opsHref !== 'undefined' ? opsHref('/directory') : undefined,
                  showCategoryFilter: false,
                }) %>
              </div>
            </div>
          </div>
        <%- include('partials/components/container_close') %>
      </section>
      </div>
    </main>

        <%- include('partials/site_footer', { tenantUrlPrefix }) %>
      </div>
    </div>

    <div
      class="m3-modal-overlay join-modal-layer m3-modal-overlay--open"
      id="portal-login-hub-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="portal-login-hub-title"
    >
      <div class="m3-modal-overlay__backdrop" id="portal-login-hub-backdrop" aria-hidden="true"></div>
      <div class="m3-modal m3-modal--join join-modal join-modal--wide portal-login-hub-m3-modal">
        <header class="m3-modal__header">
          <h2 class="m3-modal__title join-modal-title" id="portal-login-hub-title">Sign in</h2>
          <button type="button" class="m3-modal__close" id="portal-login-hub-x" aria-label="Close">×</button>
        </header>
        <div class="m3-modal__body join-modal__scroll">
          <p class="muted portal-login-hub-lead" style="margin-top:0;">Choose your account type. Each area uses a separate session and menu — they are not combined.</p>
          <ul class="portal-login-hub-cards" role="list">
            <li>
              <a class="card portal-login-hub-card portal-login-hub-card--client" href="<%= typeof opsHref === 'function' ? opsHref('/client/login') : '/client/login' %>">
                <span class="portal-login-hub-card__label">Clients</span>
                <span class="portal-login-hub-card__desc muted">Place orders, get quotes from trusted service providers</span>
              </a>
            </li>
            <li>
              <a class="card portal-login-hub-card portal-login-hub-card--provider" href="<%= typeof opsHref === 'function' ? opsHref('/provider/login') : '/provider/login' %>">
                <span class="portal-login-hub-card__label">Service Providers</span>
                <span class="portal-login-hub-card__desc muted">See quality leads, improve your business.</span>
              </a>
            </li>
            <li>
              <a class="card portal-login-hub-card portal-login-hub-card--field" href="<%= typeof opsHref === 'function' ? opsHref('/field-agent/login') : '/field-agent/login' %>">
                <span class="portal-login-hub-card__label">Field Agents</span>
                <span class="portal-login-hub-card__desc muted">Capture new leads and support your clients.</span>
              </a>
            </li>
            <li class="portal-login-hub-card-wrap portal-login-hub-card-wrap--others">
              <a class="card portal-login-hub-card portal-login-hub-card--admin" href="<%= typeof opsHref === 'function' ? opsHref('/admin/login') : '/admin/login' %>">
                <span class="portal-login-hub-card__label">Others</span>
                <span class="portal-login-hub-card__desc muted">Access internal tools and support functions.</span>
              </a>
            </li>
          </ul>
        </div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>

    <script src="<%= asset('scripts') %>" defer></script>
    <%- include('partials/theme_prefs') %>
    <%- include('partials/autocomplete_defer_bootstrap') %>
    <script>
      (function () {
        var home = <%- JSON.stringify(_home) %>;
        var modal = document.getElementById("portal-login-hub-modal");
        function goHome() {
          window.location.href = home;
        }
        document.getElementById("portal-login-hub-x")?.addEventListener("click", goHome);
        modal?.addEventListener("click", function (e) {
          if (e.target.closest(".m3-modal-overlay__backdrop")) goHome();
        });
      })();
    </script>
  </body>
</html>
