<!doctype html>
<% var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>Monthly statements | <%= _bn %></title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="<%= tenant.themeClass %>" data-screen-role="support" data-tenant-prefix="<%= tenantUrlPrefix %>">
    <div class="app-layout">
      <%- include('../partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [], isFieldAgentConsole: true }) %>
      <%- include('../partials/app_navigation', { tenantUrlPrefix, isFieldAgentConsole: true, faActiveNav: typeof faActiveNav !== 'undefined' ? faActiveNav : 'statements', faIncludeFaq: true }) %>

      <div class="app-layout__main">
        <%- include('../partials/components/container_start', { extraClass: 'field-agent-page' }) %>

        <h1 class="gp-home-story__title" style="margin-top:0;">Monthly statements</h1>
        <p class="muted" style="margin-top:0;max-width:40rem;line-height:1.5;">
          This list is based on frozen pay-run snapshots. Rolling dashboard estimates may differ.
        </p>

        <% if (!statements || !statements.length) { %>
          <p class="muted">No statements yet. When a pay run is approved for your account, it will appear here.</p>
        <% } else { %>
          <div class="field-agent-metrics" style="display:block;">
            <% statements.forEach(function (st) { %>
              <a
                href="<%= tenantUrlPrefix %>/field-agent/statements/<%= st.pay_run_id %>"
                class="card field-agent-metric-card"
                style="display:block;text-decoration:none;color:inherit;margin-bottom:0.75rem;padding:1rem;"
              >
                <div style="display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;align-items:baseline;">
                  <div>
                    <div class="muted" style="font-size:0.875rem;">Period</div>
                    <div style="font-weight:600;"><%= st.periodLabel %></div>
                  </div>
                  <div>
                    <div class="muted" style="font-size:0.875rem;">Status</div>
                    <div>
                      <% if (st.status === 'approved') { %>Approved for processing<% } else if (st.status === 'paid') { %>Marked as paid<% } else { %><%= st.status %><% } %>
                    </div>
                  </div>
                  <div>
                    <div class="muted" style="font-size:0.875rem;">Total payable</div>
                    <div style="font-weight:600;"><%= st.totalPayableDisplay %></div>
                  </div>
                </div>
                <% if (st.approved_at) { %>
                  <p class="muted" style="margin:0.5rem 0 0;font-size:0.8125rem;">Approved <%= new Date(st.approved_at).toLocaleString() %><% if (st.paid_at) { %> · Paid <%= new Date(st.paid_at).toLocaleString() %><% } %></p>
                <% } %>
              </a>
            <% }); %>
          </div>
        <% } %>

        <p style="margin-top:1.5rem;">
          <a href="<%= tenantUrlPrefix %>/field-agent/dashboard">← Back to dashboard</a>
        </p>

        <%- include('../partials/components/container_close') %>
      </div>
    </div>
  </body>
</html>
