<!doctype html>
<% var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>Add contact | Field agent | <%= _bn %></title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="join-page <%= tenant.themeClass %>" data-screen-role="support">
    <div class="app-layout">
      <%- include('../partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [], isFieldAgentConsole: true }) %>
      <%- include('../partials/app_navigation', { tenantUrlPrefix, isFieldAgentConsole: true, faActiveNav: 'add_contact', faIncludeFaq: false }) %>

      <div class="app-layout__main">
        <%- include('../partials/components/container_start', { extraClass: 'field-agent-page' }) %>

        <section class="join-hero" style="padding-top:0;">
          <div class="ds-container join-hero-inner">
            <h1>Add service provider</h1>
            <p class="join-lead">Enter details in five steps. We will create a lead and notify the CRM team.</p>

            <div class="join-wizard-frame" id="join-wizard-frame">
              <section class="join-wizard" id="fa-wizard" aria-hidden="false">
                <div class="join-wizard-inner">
                  <div class="join-progress-wrap" id="join-progress-wrap">
                    <div class="join-progress" role="status" aria-live="polite">
                      Step <span id="fa-step-num">1</span> of 5
                    </div>
                    <div class="join-progress-track" aria-hidden="true">
                      <div class="join-progress-fill" id="fa-progress-fill" style="width:0%"></div>
                    </div>
                  </div>

                  <form
                    id="fa-submit-form"
                    method="post"
                    action="<%= tenantUrlPrefix %>/field-agent/add-contact/submit"
                    enctype="multipart/form-data"
                  >
                    <div id="fa-panels">
                      <div class="join-step-panel" id="fa-step-1" data-step="1">
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Phone number</h2>
                            <p class="form-step__subtitle">We check this against existing listings before you continue.</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-phone">Phone</label>
                              <input
                                id="fa-phone"
                                name="phone"
                                class="input-field__control"
                                type="tel"
                                autocomplete="tel"
                                required
                              />
                            </div>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-1' }) %>
                              <a class="c-button c-button--secondary" href="<%= tenantUrlPrefix %>/field-agent/dashboard">Cancel</a>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-1" hidden role="alert"></p>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-2" data-step="2" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Name and WhatsApp</h2>
                            <p class="form-step__subtitle">Copy the phone number into WhatsApp if they are the same.</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-first-name">First name</label>
                              <input id="fa-first-name" name="first_name" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-last-name">Last name</label>
                              <input id="fa-last-name" name="last_name" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-whatsapp">WhatsApp number</label>
                              <input id="fa-whatsapp" name="whatsapp" class="input-field__control" type="tel" autocomplete="tel" />
                            </div>
                            <p>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Copy phone → WhatsApp', id: 'fa-copy-phone-wa' }) %>
                            </p>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-2' }) %>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-2' }) %>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-2" hidden role="alert"></p>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-3" data-step="3" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Profession and address</h2>
                            <p class="form-step__subtitle">Use the same search suggestions as “Join us”.</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field join-field--ac input-field input-field--search">
                              <label for="fa-profession" class="input-field__label">Service or profession</label>
                              <div
                                class="pro-ac join-pro-ac input-field__control"
                                data-ac-list="service"
                                data-watermark-rotate="<%= typeof joinProfessionWatermarkRotate !== 'undefined' ? joinProfessionWatermarkRotate : 'Search:' %>"
                              >
                                <input
                                  id="fa-profession"
                                  name="profession"
                                  class="pro-ac-input input-field__control"
                                  type="text"
                                  autocomplete="off"
                                  required
                                />
                                <input type="hidden" class="pro-ac-hidden" id="fa-profession-hid" value="" />
                                <ul class="pro-ac-dropdown" role="listbox" hidden></ul>
                              </div>
                            </div>
                            <div class="join-field join-field--ac input-field input-field--search">
                              <label for="fa-city" class="input-field__label">Primary city</label>
                              <div
                                class="pro-ac join-pro-ac input-field__control"
                                data-ac-list="city"
                                data-watermark-rotate="<%= typeof joinCityWatermarkRotate !== 'undefined' ? joinCityWatermarkRotate : 'Search:' %>"
                              >
                                <input
                                  id="fa-city"
                                  name="city"
                                  class="pro-ac-input input-field__control"
                                  type="text"
                                  autocomplete="off"
                                  required
                                />
                                <input type="hidden" class="pro-ac-hidden" id="fa-city-hid" value="" />
                                <ul class="pro-ac-dropdown" role="listbox" hidden></ul>
                              </div>
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-pacra">PACRA / business ID (optional)</label>
                              <input id="fa-pacra" name="pacra" class="input-field__control" type="text" />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-address-street">Street address</label>
                              <input id="fa-address-street" name="address_street" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-address-landmarks">Landmarks</label>
                              <input id="fa-address-landmarks" name="address_landmarks" class="input-field__control" type="text" />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-address-neighbourhood">Neighbourhood</label>
                              <input id="fa-address-neighbourhood" name="address_neighbourhood" class="input-field__control" type="text" />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-address-city">Address city</label>
                              <input id="fa-address-city" name="address_city" class="input-field__control" type="text" required />
                            </div>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-3' }) %>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-3' }) %>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-3" hidden role="alert"></p>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-4" data-step="4" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">NRC and profile photo</h2>
                            <p class="form-step__subtitle">Upload one clear profile image (JPEG/PNG/WebP).</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-nrc">NRC number</label>
                              <input id="fa-nrc" name="nrc_number" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-profile">Profile photo</label>
                              <input id="fa-profile" name="profile" class="input-field__control" type="file" accept="image/jpeg,image/png,image/webp,image/gif" required />
                            </div>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-4' }) %>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-4' }) %>
                            </div>
                          </div>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-5" data-step="5" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Work photos</h2>
                            <p class="form-step__subtitle">Upload between 2 and 10 images of completed work.</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-works">Work photos</label>
                              <input
                                id="fa-works"
                                name="works"
                                class="input-field__control"
                                type="file"
                                accept="image/jpeg,image/png,image/webp,image/gif"
                                multiple
                                required
                              />
                            </div>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Send', id: 'fa-send' }) %>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-5' }) %>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-5" hidden role="alert"></p>
                        </div>
                      </div>
                    </div>
                  </form>
                </div>
              </section>
            </div>
          </div>
        </section>

        <%- include('../partials/site_footer', { tenantUrlPrefix }) %>
        <%- include('../partials/components/container_close') %>
      </div>
    </div>

    <script>
      window.__GETPRO_TENANT_SLUG__ = "<%= tenant.slug %>";
      window.__GETPRO_TENANT_ID__ = <%= tenant.id %>;
      window.__GETPRO_HOME__ = "<%= typeof fieldAgentExitHomeHref !== 'undefined' ? fieldAgentExitHomeHref : '/login' %>";
      window.__GETPRO_TENANT_CITIES__ = <%- JSON.stringify(typeof joinTenantCities !== 'undefined' ? joinTenantCities : []) %>;
      window.__FA_CHECK_PHONE_URL__ = <%- JSON.stringify((tenantUrlPrefix || '') + '/field-agent/api/check-phone') %>;
      window.__GETPRO_PHONE_RULES__ = <%- JSON.stringify(typeof phoneRulesPublic !== 'undefined' ? phoneRulesPublic : { slug: tenant.slug, strict: false, regex: null, normalizationMode: 'generic_digits', regexBroken: false }) %>;
    </script>
    <script src="<%= asset('autocomplete') %>" defer></script>
    <script src="<%= asset('field-agent-contact') %>" defer></script>
    <script src="<%= asset('scripts') %>" defer></script>
    <%- include('../partials/theme_prefs') %>
  </body>
</html>
