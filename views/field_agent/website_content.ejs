<!doctype html>
<% var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<% var _sub = typeof submission !== 'undefined' ? submission : {}; %>
<% var _d = typeof websiteDraft !== 'undefined' && websiteDraft ? websiteDraft : {}; %>
<% var _ro = typeof websiteReadOnly !== 'undefined' && websiteReadOnly; %>
<% var _rev = typeof reviewRequestedAt !== 'undefined' && reviewRequestedAt != null ? reviewRequestedAt : null; %>
<% var _wrs = typeof websiteReviewStatus !== 'undefined' ? String(websiteReviewStatus || '').trim() : ''; %>
<% var _wrc = typeof websiteReviewComment !== 'undefined' ? String(websiteReviewComment || '').trim() : ''; %>
<% var _sp = Array.isArray(websiteSpecialities) ? websiteSpecialities : []; %>
<% var _spv = Array.isArray(websiteVerifiedSpecialities) ? websiteVerifiedSpecialities : []; %>
<% var _wh = typeof websiteWeeklyHours !== 'undefined' && websiteWeeklyHours ? websiteWeeklyHours : {}; %>
<% var _sg = Array.isArray(specialitySuggestions) ? specialitySuggestions : []; %>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>Website details | Field agent | <%= _bn %></title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="<%= tenant.themeClass %>" data-screen-role="support" data-tenant-prefix="<%= tenantUrlPrefix %>">
    <div class="app-layout">
      <%- include('../partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [], isFieldAgentConsole: true }) %>
      <%- include('../partials/app_navigation', { tenantUrlPrefix, isFieldAgentConsole: true, faActiveNav: 'sp_websites', faIncludeFaq: typeof faIncludeFaq !== 'undefined' ? faIncludeFaq : true }) %>
      <div class="app-layout__main">
        <%- include('../partials/components/container_start', { extraClass: 'field-agent-page' }) %>
        <h1 class="gp-home-story__title" style="margin-top:0;">Website details</h1>
        <% var _leadName = [String(_sub.first_name || '').trim(), String(_sub.last_name || '').trim()].filter(Boolean).join(' ').trim(); %>
        <% var _leadCategory = String(_sub.profession || '').trim(); %>
        <% var _leadCity = String(_sub.city || '').trim(); %>
        <p class="join-lead">
          Approved lead:
          <strong><%= _leadName || '—' %></strong>
          -
          <%= _leadCategory || '—' %>
          -
          <%= _leadCity || '—' %>
        </p>
        <% if (typeof linkedCompanyId !== 'undefined' && linkedCompanyId != null) { %>
          <p class="admin-gate-success" role="status">
            This submission is already linked to a directory listing (company #<%= linkedCompanyId %>). Listing text is read-only here; further setup continues in the admin console.
          </p>
        <% } else { %>
          <p class="muted" style="max-width:42rem;line-height:1.5;margin:0 0 1rem;">
            Private draft.
          </p>
        <% } %>
        <% if (_rev && !_ro) { %>
          <p class="admin-gate-success" id="fa-wc-review-banner" role="status">
            Submitted for staff review (<%= String(_rev) %>).
          </p>
        <% } %>
        <% if (_wrs === 'changes_requested') { %>
          <p class="input-field__error" role="alert" style="margin-bottom:0.75rem;">
            Review outcome: changes requested.<% if (_wrc) { %> <%= _wrc %><% } %>
          </p>
        <% } %>
        <% if (_wrs === 'published') { %>
          <p class="admin-gate-success" role="status" style="margin-bottom:0.75rem;">Review outcome: published.</p>
        <% } %>
        <p class="input-field__error" id="fa-wc-error" hidden role="alert" style="margin-bottom:0.75rem;"></p>
        <p class="admin-gate-success" id="fa-wc-save-ok" hidden role="status">Draft saved.</p>
        <p class="admin-gate-success" id="fa-wc-submit-ok" hidden role="status">Submitted for review.</p>

        <form id="fa-website-content-form" class="card" style="padding:1rem;max-width:42rem;" data-submission-id="<%= _sub.id %>">
          <h2 class="form-step__title" style="margin-top:0;font-size:1.125rem;display:flex;align-items:center;gap:0.4rem;">
            <span>Listing text</span>
            <span
              class="muted"
              title="These fields mirror what will eventually power the public profile. Save a draft anytime; use Submit for review when the text is ready for staff."
              aria-label="Listing text helper"
              style="font-size:0.9rem;cursor:help;"
            >ⓘ</span>
          </h2>

          <div class="input-field">
            <label class="input-field__label" for="wc-listing-name">Business name</label>
            <input id="wc-listing-name" name="listing_name" class="input-field__control" type="text" value="<%= _d.listing_name || '' %>" maxlength="200" <%= _ro ? 'readonly' : '' %> />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-headline">Headline</label>
            <input id="wc-headline" name="headline" class="input-field__control" type="text" value="<%= _d.headline || '' %>" maxlength="500" <%= _ro ? 'readonly' : '' %> />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-about">About</label>
            <textarea id="wc-about" name="about" class="input-field__control" rows="5" maxlength="12000" <%= _ro ? 'readonly' : '' %>><%= _d.about || '' %></textarea>
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-services">Services</label>
            <textarea id="wc-services" name="services" class="input-field__control" rows="4" maxlength="12000" <%= _ro ? 'readonly' : '' %>><%= _d.services || '' %></textarea>
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-location">Location</label>
            <input id="wc-location" name="location" class="input-field__control" type="text" value="<%= _d.location || '' %>" maxlength="500" <%= _ro ? 'readonly' : '' %> />
          </div>
          <div class="input-field">
            <label class="input-field__label">Specialities</label>
            <datalist id="wc-speciality-options">
              <% _sg.forEach(function(s) { %><option value="<%= s %>"></option><% }); %>
            </datalist>
            <div id="wc-specialities-wrap" style="display:flex;flex-direction:column;gap:0.4rem;">
              <% var _rows = _sp.length ? _sp : ['']; %>
              <% _rows.forEach(function(sp) { %>
              <% var _isV = _spv.map(function(v){ return String(v || '').trim().toLowerCase(); }).includes(String(sp || '').trim().toLowerCase()); %>
              <div class="wc-speciality-row" style="display:flex;gap:0.4rem;align-items:center;">
                <input class="input-field__control wc-speciality-input" type="text" list="wc-speciality-options" value="<%= sp %>" maxlength="120" <%= _ro ? 'readonly' : '' %> />
                <% if (_isV) { %><span class="muted" style="font-weight:600;">Verified ✓</span><% } %>
                <% if (!_ro) { %><button type="button" class="btn btn--secondary wc-speciality-remove">−</button><% } %>
              </div>
              <% }); %>
            </div>
            <% if (!_ro) { %><p style="margin-top:0.4rem;"><button type="button" class="btn btn--secondary" id="wc-speciality-add">+ Add speciality</button></p><% } %>
          </div>
          <div class="input-field">
            <label class="input-field__label">Business hours (24-hour)</label>
            <% var _days = [['sunday','Sunday'],['monday','Monday'],['tuesday','Tuesday'],['wednesday','Wednesday'],['thursday','Thursday'],['friday','Friday'],['saturday','Saturday']]; %>
            <div style="display:grid;gap:0.35rem;">
              <% _days.forEach(function(day) { var k = day[0]; var lbl = day[1]; var r = _wh[k] || { closed: true, from: '', to: '' }; %>
              <div style="display:grid;grid-template-columns:110px 90px 1fr 1fr;gap:0.4rem;align-items:center;">
                <div><%= lbl %></div>
                <label style="display:flex;gap:0.3rem;align-items:center;"><input type="checkbox" class="wc-hours-closed" data-day="<%= k %>" <%= r.closed ? 'checked' : '' %> <%= _ro ? 'disabled' : '' %> /> Closed</label>
                <input class="input-field__control wc-hours-from" data-day="<%= k %>" type="time" value="<%= r.from || '' %>" <%= r.closed ? 'disabled' : '' %> <%= _ro ? 'disabled' : '' %> />
                <input class="input-field__control wc-hours-to" data-day="<%= k %>" type="time" value="<%= r.to || '' %>" <%= r.closed ? 'disabled' : '' %> <%= _ro ? 'disabled' : '' %> />
              </div>
              <% }); %>
            </div>
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-email">Email</label>
            <input id="wc-email" name="email" class="input-field__control" type="email" value="<%= _d.email || '' %>" maxlength="320" autocomplete="email" <%= _ro ? 'readonly' : '' %> />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-listing-phone">Phone</label>
            <input id="wc-listing-phone" name="listing_phone" class="input-field__control" type="tel" value="<%= (_d.listing_phone != null && String(_d.listing_phone).trim() !== '') ? _d.listing_phone : (_sub.phone_raw || '') %>" maxlength="120" autocomplete="tel" readonly disabled />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-cta-label">Featured CTA label</label>
            <input id="wc-cta-label" name="featured_cta_label" class="input-field__control" type="text" value="<%= _d.featured_cta_label || '' %>" maxlength="120" placeholder="e.g. Call us" <%= _ro ? 'readonly' : '' %> />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-cta-phone">Featured CTA phone</label>
            <input id="wc-cta-phone" name="featured_cta_phone" class="input-field__control" type="tel" value="<%= _d.featured_cta_phone || '' %>" maxlength="120" <%= _ro ? 'readonly' : '' %> />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-years">Years of experience (optional)</label>
            <input id="wc-years" name="years_experience" class="input-field__control" type="number" min="0" max="999" step="1" value="<%= (_d.years_experience != null && _d.years_experience !== '') ? _d.years_experience : '' %>" <%= _ro ? 'readonly' : '' %> />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="wc-established-year">Established in year (optional)</label>
            <input id="wc-established-year" name="established_year" class="input-field__control" type="number" min="1800" max="<%= new Date().getUTCFullYear() %>" step="1" value="<%= (_d.established_year != null && _d.established_year !== '') ? _d.established_year : '' %>" <%= _ro ? 'readonly' : '' %> />
          </div>

          <% if (!_ro) { %>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:1rem;">
              <button type="button" class="btn btn--secondary" id="fa-wc-save-btn">Save draft</button>
              <button type="button" class="btn" id="fa-wc-submit-btn">Submit for review</button>
              <a class="btn btn--secondary" href="<%= tenantUrlPrefix %>/field-agent/submissions/<%= _sub.id %>/website-content/preview">Preview</a>
            </div>
          <% } %>
        </form>

        <p style="margin-top:1rem;">
          <a href="<%= tenantUrlPrefix %>/field-agent/sp-websites">← SP Websites</a>
        </p>
        <%- include('../partials/site_footer', { tenantUrlPrefix }) %>
        <%- include('../partials/components/container_close') %>
      </div>
    </div>
    <script src="<%= asset('scripts') %>" defer></script>
    <% if (!_ro) { %>
    <script>
      (function () {
        var form = document.getElementById("fa-website-content-form");
        if (!form) return;
        var sid = form.getAttribute("data-submission-id");
        var saveBtn = document.getElementById("fa-wc-save-btn");
        var submitBtn = document.getElementById("fa-wc-submit-btn");
        var errEl = document.getElementById("fa-wc-error");
        var saveOk = document.getElementById("fa-wc-save-ok");
        var submitOk = document.getElementById("fa-wc-submit-ok");
        function prefix() {
          var el = document.body && document.body.getAttribute("data-tenant-prefix");
          return el != null ? String(el) : "";
        }
        function api(path) {
          var p = prefix();
          return (p ? p : "") + path;
        }
        function showErr(msg) {
          if (errEl) {
            errEl.textContent = msg || "";
            errEl.hidden = !msg;
          }
          if (saveOk) saveOk.hidden = true;
          if (submitOk) submitOk.hidden = true;
        }
        function gatherDraft() {
          var fd = new FormData(form);
          var o = {};
          fd.forEach(function (v, k) {
            o[k] = typeof v === "string" ? v : String(v);
          });
          var y = document.getElementById("wc-years");
          if (y && y.value !== "") o.years_experience = y.value;
          else o.years_experience = null;
          var spInputs = form.querySelectorAll(".wc-speciality-input");
          o.specialities = [];
          spInputs.forEach(function (el) {
            var v = String(el.value || "").trim();
            if (v) o.specialities.push(v);
          });
          var days = ["sunday", "monday", "tuesday", "wednesday", "thursday", "friday", "saturday"];
          o.weekly_hours = {};
          days.forEach(function (d) {
            var c = form.querySelector('.wc-hours-closed[data-day="' + d + '"]');
            var f = form.querySelector('.wc-hours-from[data-day="' + d + '"]');
            var t = form.querySelector('.wc-hours-to[data-day="' + d + '"]');
            var closed = !!(c && c.checked);
            o.weekly_hours[d] = {
              closed: closed,
              from: closed ? "" : (f && f.value ? String(f.value) : ""),
              to: closed ? "" : (t && t.value ? String(t.value) : ""),
            };
          });
          return o;
        }
        var addSp = document.getElementById("wc-speciality-add");
        var spWrap = document.getElementById("wc-specialities-wrap");
        if (addSp && spWrap) {
          addSp.addEventListener("click", function () {
            var count = spWrap.querySelectorAll(".wc-speciality-input").length;
            if (count >= 10) return;
            var row = document.createElement("div");
            row.className = "wc-speciality-row";
            row.style.display = "flex";
            row.style.gap = "0.4rem";
            row.style.alignItems = "center";
            row.innerHTML =
              '<input class="input-field__control wc-speciality-input" type="text" list="wc-speciality-options" maxlength="120" />' +
              '<button type="button" class="btn btn--secondary wc-speciality-remove">−</button>';
            spWrap.appendChild(row);
          });
          spWrap.addEventListener("click", function (e) {
            var t = e.target;
            if (!t || !t.classList || !t.classList.contains("wc-speciality-remove")) return;
            var row = t.closest(".wc-speciality-row");
            if (!row) return;
            var rows = spWrap.querySelectorAll(".wc-speciality-row");
            if (rows.length <= 1) {
              var inp = row.querySelector(".wc-speciality-input");
              if (inp) inp.value = "";
              return;
            }
            row.remove();
          });
        }
        var closedInputs = form.querySelectorAll(".wc-hours-closed");
        closedInputs.forEach(function (c) {
          c.addEventListener("change", function () {
            var d = c.getAttribute("data-day");
            var f = form.querySelector('.wc-hours-from[data-day="' + d + '"]');
            var t = form.querySelector('.wc-hours-to[data-day="' + d + '"]');
            var closed = !!c.checked;
            if (f) {
              f.disabled = closed;
              if (closed) f.value = "";
            }
            if (t) {
              t.disabled = closed;
              if (closed) t.value = "";
            }
          });
        });
        function showSaveOk() {
          if (saveOk) saveOk.hidden = false;
          if (submitOk) submitOk.hidden = true;
          if (errEl) errEl.hidden = true;
        }
        function showSubmitOk() {
          if (submitOk) submitOk.hidden = false;
          if (saveOk) saveOk.hidden = true;
          if (errEl) errEl.hidden = true;
          var ban = document.getElementById("fa-wc-review-banner");
          if (ban) ban.hidden = false;
        }
        if (saveBtn) {
          saveBtn.addEventListener("click", function () {
            showErr("");
            fetch(api("/field-agent/api/submissions/" + encodeURIComponent(sid) + "/website-content-draft"), {
              method: "POST",
              credentials: "same-origin",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              body: JSON.stringify({ draft: gatherDraft() }),
            })
              .then(function (r) {
                return r.json().then(function (j) {
                  return { ok: r.ok, j: j };
                });
              })
              .then(function (x) {
                if (!x.ok || !x.j || x.j.ok !== true) {
                  showErr((x.j && x.j.error) || "Could not save draft.");
                  return;
                }
                showSaveOk();
              })
              .catch(function () {
                showErr("Could not save draft. Try again.");
              });
          });
        }
        if (submitBtn) {
          submitBtn.addEventListener("click", function () {
            showErr("");
            fetch(api("/field-agent/api/submissions/" + encodeURIComponent(sid) + "/website-content-submit-review"), {
              method: "POST",
              credentials: "same-origin",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              body: JSON.stringify({ draft: gatherDraft() }),
            })
              .then(function (r) {
                return r.json().then(function (j) {
                  return { ok: r.ok, j: j };
                });
              })
              .then(function (x) {
                if (!x.ok || !x.j || x.j.ok !== true) {
                  showErr((x.j && x.j.error) || "Could not submit for review.");
                  return;
                }
                showSubmitOk();
              })
              .catch(function () {
                showErr("Could not submit for review. Try again.");
              });
          });
        }
      })();
    </script>
    <% } %>
    <%- include('../partials/theme_prefs') %>
  </body>
</html>
