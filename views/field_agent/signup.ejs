<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('../partials/theme_boot') %>
    <title>Field agent registration | <%= _bn %></title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-gate-page <%= tenant.themeClass %>">
    <% var _hub = typeof opsHref === 'function' ? opsHref('/login') : '/login'; %>
    <div class="container admin-gate-wrap">
      <div class="card admin-gate-card">
        <a href="<%= _hub %>" class="admin-gate-brand">
          <div class="logo" aria-hidden="true"></div>
          <div>
            <div class="admin-gate-brand__title"><%= _bn %> · Field agent</div>
            <div class="admin-gate-brand__subtitle">Create an account to submit verified directory leads.</div>
          </div>
        </a>
        <% var _gateErr = typeof error !== 'undefined' && error != null && String(error).trim() !== '' ? String(error).trim() : ''; %>
        <% if (_gateErr) { %>
          <div class="flash" role="alert"><%= _gateErr %></div>
        <% } %>
        <form method="post" action="<%= (typeof tenantUrlPrefix !== 'undefined' && tenantUrlPrefix ? String(tenantUrlPrefix) : '') %>/field-agent/signup" class="form admin-gate-form">
          <div class="form-step form-step--admin">
            <div class="form-step__body">
              <%- include('../partials/components/input', {
                id: 'fa_signup_username',
                name: 'username',
                type: 'text',
                label: 'Username',
                required: true,
                autocomplete: 'username',
                extraAttrs: 'minlength="2"',
              }) %>
              <%- include('../partials/components/input', {
                id: 'fa_signup_display',
                name: 'display_name',
                type: 'text',
                label: 'Display name (optional)',
                autocomplete: 'name',
              }) %>
              <%- include('../partials/components/input', {
                id: 'fa_signup_password',
                name: 'password',
                type: 'password',
                label: 'Password',
                required: true,
                autocomplete: 'new-password',
                extraAttrs: 'minlength="4"',
              }) %>
            </div>
            <div class="form-step__actions admin-gate-actions">
              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Create account' }) %>
              <%- include('../partials/components/button', { variant: 'text', href: (typeof tenantUrlPrefix !== 'undefined' && tenantUrlPrefix ? String(tenantUrlPrefix) : '') + '/field-agent/login', label: 'Sign in' }) %>
            </div>
          </div>
        </form>
        <p class="muted admin-gate-alt" style="margin:0.75rem 0 0;font-size:0.9rem;">
          <a href="<%= _hub %>">Sign-in hub</a>
        </p>
      </div>
    </div>
    <%- include('../partials/theme_prefs') %>
  </body>
</html>
