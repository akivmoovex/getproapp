<!doctype html>
<% var _bn = typeof brandProductName !== 'undefined' ? brandProductName : 'Pro-online'; %>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>Add contact | Field agent | <%= _bn %></title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="join-page <%= tenant.themeClass %>" data-screen-role="support">
    <div class="app-layout">
      <%- include('../partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [], isFieldAgentConsole: true }) %>
      <%- include('../partials/app_navigation', { tenantUrlPrefix, isFieldAgentConsole: true, faActiveNav: 'add_contact', faIncludeFaq: false }) %>

      <div class="app-layout__main">
        <%- include('../partials/components/container_start', { extraClass: 'field-agent-page' }) %>

        <section class="join-hero" style="padding-top:0;">
          <div class="ds-container join-hero-inner">
            <h1>Add service provider</h1>
            <p class="join-lead">Enter details in six steps. We will create a lead and notify the CRM team.</p>

            <div class="join-wizard-frame" id="join-wizard-frame">
              <section class="join-wizard" id="fa-wizard" aria-hidden="false">
                <div class="join-wizard-inner">
                  <div class="join-progress-wrap" id="join-progress-wrap">
                    <div class="join-progress" role="status" aria-live="polite">
                      Step <span id="fa-step-num">1</span> of 6
                    </div>
                    <div class="join-progress-track" aria-hidden="true">
                      <div class="join-progress-fill" id="fa-progress-fill" style="width:0%"></div>
                    </div>
                  </div>

                  <form
                    id="fa-submit-form"
                    method="post"
                    action="<%= tenantUrlPrefix %>/field-agent/add-contact/submit"
                    enctype="multipart/form-data"
                  >
                    <div id="fa-panels">
                      <div class="join-step-panel" id="fa-step-1" data-step="1">
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Phone number</h2>
                            <p class="form-step__subtitle">We check this against existing listings before you continue.</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-phone"
                                >Phone <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input
                                id="fa-phone"
                                name="phone"
                                class="input-field__control"
                                type="tel"
                                autocomplete="tel"
                                required
                              />
                            </div>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-1' }) %>
                              <a class="c-button c-button--secondary" href="<%= tenantUrlPrefix %>/field-agent/dashboard">Cancel</a>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-1" hidden role="alert"></p>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-2" data-step="2" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Name and WhatsApp</h2>
                            <p class="form-step__subtitle">Copy the phone number into WhatsApp if they are the same.</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-first-name"
                                >First name <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input id="fa-first-name" name="first_name" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-last-name"
                                >Last name <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input id="fa-last-name" name="last_name" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-whatsapp">WhatsApp number (optional)</label>
                              <input id="fa-whatsapp" name="whatsapp" class="input-field__control" type="tel" autocomplete="tel" />
                            </div>
                            <p>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Copy phone → WhatsApp', id: 'fa-copy-phone-wa' }) %>
                            </p>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-2' }) %>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-2' }) %>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-2" hidden role="alert"></p>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-3" data-step="3" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Profession and address</h2>
                            <p class="form-step__subtitle">Use the same search suggestions as “Join us”.</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field join-field--ac input-field input-field--search">
                              <label for="fa-profession" class="input-field__label"
                                >Service or profession <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <div
                                class="pro-ac join-pro-ac input-field__control"
                                data-ac-list="service"
                                data-watermark-rotate="<%= typeof joinProfessionWatermarkRotate !== 'undefined' ? joinProfessionWatermarkRotate : 'Search:' %>"
                              >
                                <input
                                  id="fa-profession"
                                  name="profession"
                                  class="pro-ac-input input-field__control"
                                  type="text"
                                  autocomplete="off"
                                  required
                                />
                                <input type="hidden" class="pro-ac-hidden" id="fa-profession-hid" value="" />
                                <ul class="pro-ac-dropdown" role="listbox" hidden></ul>
                                <p class="pro-ac-msg input-field__error" id="fa-profession-msg" hidden></p>
                              </div>
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-pacra"
                                >PACRA / business ID <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input id="fa-pacra" name="pacra" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-address-street"
                                >Street address <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input id="fa-address-street" name="address_street" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-address-landmarks"
                                >Landmarks <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input id="fa-address-landmarks" name="address_landmarks" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-address-neighbourhood"
                                >Neighbourhood <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input
                                id="fa-address-neighbourhood"
                                name="address_neighbourhood"
                                class="input-field__control"
                                type="text"
                                required
                              />
                            </div>
                            <div class="join-field join-field--ac input-field input-field--search">
                              <label for="fa-address-city" class="input-field__label"
                                >Address city <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <div
                                class="pro-ac join-pro-ac input-field__control"
                                data-ac-list="city"
                                data-watermark-rotate="<%= typeof joinCityWatermarkRotate !== 'undefined' ? joinCityWatermarkRotate : 'Search:' %>"
                              >
                                <input
                                  id="fa-address-city"
                                  name="address_city"
                                  class="pro-ac-input input-field__control"
                                  type="text"
                                  autocomplete="off"
                                  required
                                />
                                <input type="hidden" class="pro-ac-hidden" id="fa-address-city-hid" value="" />
                                <ul class="pro-ac-dropdown" role="listbox" hidden></ul>
                                <p class="pro-ac-msg input-field__error" id="fa-address-city-msg" hidden></p>
                              </div>
                            </div>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-3' }) %>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-3' }) %>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-3" hidden role="alert"></p>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-4" data-step="4" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">NRC and profile photo</h2>
                            <p class="form-step__subtitle">Upload one clear profile image (JPEG, PNG, WebP, or GIF).</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-nrc"
                                >NRC number <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input id="fa-nrc" name="nrc_number" class="input-field__control" type="text" required />
                            </div>
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-profile"
                                >Profile photo <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input
                                id="fa-profile"
                                name="profile"
                                class="input-field__control"
                                type="file"
                                accept="image/jpeg,image/png,image/webp,image/gif"
                                required
                              />
                            </div>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-4' }) %>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-4' }) %>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-4" hidden role="alert"></p>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-5" data-step="5" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Work photos</h2>
                            <p class="form-step__subtitle">Upload 2–10 images of completed work (JPEG, PNG, WebP, or GIF).</p>
                          </div>
                          <div class="form-step__body">
                            <div class="join-field input-field">
                              <label class="input-field__label" for="fa-works"
                                >Work photos <span class="fa-req-asterisk" aria-hidden="true">*</span></label
                              >
                              <input
                                id="fa-works"
                                name="works"
                                class="input-field__control"
                                type="file"
                                accept="image/jpeg,image/png,image/webp,image/gif"
                                multiple
                              />
                            </div>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'button', label: 'Continue', id: 'fa-next-5' }) %>
                              <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-5' }) %>
                            </div>
                          </div>
                          <p class="input-field__error" id="fa-error-5" hidden role="alert"></p>
                        </div>
                      </div>

                      <div class="join-step-panel" id="fa-step-6" data-step="6" hidden>
                        <div class="form-step">
                          <div class="form-step__header">
                            <h2 class="form-step__title">Review</h2>
                            <p class="form-step__subtitle">Check all details before sending to the CRM team.</p>
                          </div>
                          <div class="form-step__body">
                            <ul class="field-agent-dash-list" role="list">
                              <li class="field-agent-dash-list__item">
                                <div class="field-agent-dash-list-card field-agent-dash-list-card--static">
                                  <div class="field-agent-dash-list-card__title">Application summary</div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-phone"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-name"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-whatsapp"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-profession"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-pacra"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-street"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-landmarks"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-neighbourhood"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-city"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-nrc"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-profile"></div>
                                  <div class="muted field-agent-dash-list-card__contact" id="fa-rev-line-works"></div>
                                </div>
                              </li>
                            </ul>
                            <p class="input-field__error" id="fa-error-submit" hidden role="alert"></p>
                          </div>
                          <div class="form-step__actions">
                            <div class="join-wizard-actions join-wizard-actions--split">
                              <%- include('../partials/components/button', { variant: 'primary', type: 'submit', label: 'Submit', id: 'fa-send' }) %>
                              <div class="join-wizard-actions-right">
                                <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Back', id: 'fa-back-6' }) %>
                                <%- include('../partials/components/button', { variant: 'secondary', type: 'button', label: 'Cancel', id: 'fa-cancel-6' }) %>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </form>

                  <div
                    id="fa-submit-success-overlay"
                    class="m3-modal-overlay fa-submit-success-overlay"
                    hidden
                    aria-hidden="true"
                  >
                    <div class="m3-modal-overlay__backdrop" data-fa-submit-success-dismiss tabindex="-1"></div>
                    <div
                      id="fa-submit-success-dialog"
                      class="m3-modal m3-modal--join fa-submit-success-dialog"
                      role="dialog"
                      aria-modal="true"
                      aria-labelledby="fa-submit-success-title"
                      tabindex="-1"
                    >
                      <div class="fa-submit-success-countdown-wrap" aria-hidden="true">
                        <div class="fa-submit-success-countdown" id="fa-submit-success-countdown"></div>
                      </div>
                      <header class="m3-modal__header">
                        <h2 id="fa-submit-success-title" class="m3-modal__title">Submission received</h2>
                        <button type="button" class="m3-modal__close" data-fa-submit-success-dismiss aria-label="Close">
                          ×
                        </button>
                      </header>
                      <div class="m3-modal__body">
                        <p class="muted" style="margin: 0">You will return to your dashboard shortly.</p>
                      </div>
                    </div>
                  </div>
                </div>
              </section>
            </div>
          </div>
        </section>

        <%- include('../partials/site_footer', { tenantUrlPrefix }) %>
        <%- include('../partials/components/container_close') %>
      </div>
    </div>

    <script>
      window.__GETPRO_TENANT_SLUG__ = "<%= tenant.slug %>";
      window.__GETPRO_TENANT_ID__ = <%= tenant.id %>;
      window.__GETPRO_HOME__ = "<%= typeof fieldAgentExitHomeHref !== 'undefined' ? fieldAgentExitHomeHref : '/login' %>";
      window.__GETPRO_TENANT_CITIES__ = <%- JSON.stringify(typeof joinTenantCities !== 'undefined' ? joinTenantCities : []) %>;
      window.__FA_CHECK_PHONE_URL__ = <%- JSON.stringify((tenantUrlPrefix || '') + '/field-agent/api/check-phone') %>;
      window.__GETPRO_PHONE_RULES__ = <%- JSON.stringify(typeof phoneRulesPublic !== 'undefined' ? phoneRulesPublic : { slug: tenant.slug, strict: false, regex: null, normalizationMode: 'generic_digits', regexBroken: false }) %>;
    </script>
    <script src="<%= asset('autocomplete') %>" defer></script>
    <script src="<%= asset('field-agent-contact') %>" defer></script>
    <script src="<%= asset('scripts') %>" defer></script>
    <%- include('../partials/theme_prefs') %>
  </body>
</html>
