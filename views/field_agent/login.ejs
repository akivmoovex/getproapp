<!doctype html>
<html lang="en">
  <head>
    <%- include('../partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('../partials/theme_boot') %>
    <title>Field agent sign in | <%= _bn %></title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="admin-gate-page <%= tenant.themeClass %>">
    <div class="container admin-gate-wrap">
      <div class="card admin-gate-card">
        <a href="/login" class="admin-gate-brand">
          <div class="logo" aria-hidden="true"></div>
          <div>
            <div class="admin-gate-brand__title"><%= _bn %> · Field agent</div>
            <div class="admin-gate-brand__subtitle">Sign in to submit leads and view your dashboard.</div>
          </div>
        </a>
        <%- include('../partials/admin_gate_form', {
          formAction: (typeof tenantUrlPrefix !== 'undefined' && tenantUrlPrefix ? String(tenantUrlPrefix) : '') + '/field-agent/login',
          error: typeof error !== 'undefined' ? error : null,
          cancelHref: '/login',
        }) %>
        <p class="muted admin-gate-alt" style="margin:0.75rem 0 0;font-size:0.9rem;">
          <a href="<%= (typeof tenantUrlPrefix !== 'undefined' && tenantUrlPrefix ? String(tenantUrlPrefix) : '') %>/field-agent/signup">Create account</a>
        </p>
      </div>
    </div>
    <%- include('../partials/theme_prefs') %>
  </body>
</html>
