<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>GetPro Admin · Sign in</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="admin-gate-page">
    <div class="container" style="padding: 40px 0;">
      <div class="card admin-gate-card" style="max-width: 520px; margin: 0 auto;">
        <div class="brand" style="justify-content: flex-start; margin-bottom: 12px;">
          <div class="logo" aria-hidden="true"></div>
          <div>
            <div style="font-weight: 900;">GetPro Admin</div>
            <div class="muted" style="font-size: 13px; line-height: 1.5;">Sign in to manage directory data and leads.</div>
          </div>
        </div>
        <%- include('partials/admin_gate_form', { formAction: '/admin/login', error: typeof error !== 'undefined' ? error : null, cancelHref: tenantHomeHref }) %>
      </div>
    </div>
  </body>
</html>
