<!doctype html>
<html lang="en">
  <head>
    <%- include('partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/theme_boot') %>
    <title>New request | <%= _bn %> Client</title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <% var _hub = typeof opsHref === 'function' ? opsHref('/login') : '/login'; %>
  <body class="admin-gate-page <%= typeof tenant !== 'undefined' && tenant ? tenant.themeClass : '' %>">
    <div class="container admin-gate-wrap">
      <div class="card admin-gate-card" style="max-width: 36rem;">
        <a href="<%= _hub %>" class="admin-gate-brand">
          <div class="logo" aria-hidden="true"></div>
          <div>
            <div class="admin-gate-brand__title"><%= _bn %> Client</div>
            <div class="admin-gate-brand__subtitle">Submit a new service request</div>
          </div>
        </a>
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="flash" role="alert"><%= error %></div>
        <% } %>
        <form method="post" action="<%= clientPortalBasePath %>/deals" class="form" enctype="multipart/form-data">
          <div class="input-field">
            <label class="input-field__label" for="full_name">Full name</label>
            <input id="full_name" name="full_name" class="input-field__control" required maxlength="200" value="<%= typeof form !== 'undefined' && form.full_name ? form.full_name : '' %>" />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="phone">Phone</label>
            <input id="phone" name="phone" class="input-field__control" required value="<%= typeof form !== 'undefined' && form.phone ? form.phone : '' %>" />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="intake_category_id">Profession / category</label>
            <select id="intake_category_id" name="intake_category_id" class="input-field__control" required>
              <option value="">Select profession</option>
              <% (typeof intakeCategories !== 'undefined' ? intakeCategories : []).forEach(function (cat) { %>
                <option value="<%= cat.id %>"<%= typeof form !== 'undefined' && String(form.intake_category_id) === String(cat.id) ? ' selected' : '' %>><%= cat.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="input-field">
            <label class="input-field__label" for="urgency">Urgency</label>
            <select id="urgency" name="urgency" class="input-field__control">
              <% (typeof urgencyOptions !== 'undefined' ? urgencyOptions : []).forEach(function (uo) { %>
                <option value="<%= uo.value %>"<%= typeof form !== 'undefined' && String(form.urgency || 'not_urgent') === String(uo.value) ? ' selected' : '' %>><%= uo.label %></option>
              <% }); %>
            </select>
          </div>
          <div class="input-field">
            <label class="input-field__label" for="city">City</label>
            <select id="city" name="city" class="input-field__control" required>
              <option value="">Select city</option>
              <% (typeof cities !== 'undefined' ? cities : []).forEach(function (c) { %>
                <option value="<%= c.name %>"<%= typeof form !== 'undefined' && form.city === c.name ? ' selected' : '' %>><%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="input-field">
            <label class="input-field__label" for="neighborhood">Neighborhood</label>
            <input id="neighborhood" name="neighborhood" class="input-field__control" maxlength="120" value="<%= typeof form !== 'undefined' && form.neighborhood ? form.neighborhood : '' %>" />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="street_name">Street name</label>
            <input id="street_name" name="street_name" class="input-field__control" maxlength="200" value="<%= typeof form !== 'undefined' && form.street_name ? form.street_name : '' %>" />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="house_number">House number</label>
            <input id="house_number" name="house_number" class="input-field__control" maxlength="40" value="<%= typeof form !== 'undefined' && form.house_number ? form.house_number : '' %>" />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="apartment_number">Apartment number</label>
            <input id="apartment_number" name="apartment_number" class="input-field__control" maxlength="40" value="<%= typeof form !== 'undefined' && form.apartment_number ? form.apartment_number : '' %>" />
          </div>
          <h3 class="input-field__label" style="margin-top:0.5rem;">Address on file (optional)</h3>
          <div class="input-field">
            <input name="client_address_street" class="input-field__control" placeholder="Street name" value="<%= typeof form !== 'undefined' && form.client_address_street ? form.client_address_street : '' %>" />
          </div>
          <div class="input-field">
            <input name="client_address_house_number" class="input-field__control" placeholder="House number" value="<%= typeof form !== 'undefined' && form.client_address_house_number ? form.client_address_house_number : '' %>" />
          </div>
          <div class="input-field">
            <input name="client_address_apartment_number" class="input-field__control" placeholder="Apartment number" value="<%= typeof form !== 'undefined' && form.client_address_apartment_number ? form.client_address_apartment_number : '' %>" />
          </div>
          <div class="input-field">
            <label class="input-field__label" for="estimated_budget">Rough budget (optional)</label>
            <input id="estimated_budget" name="estimated_budget" class="input-field__control" inputmode="decimal" value="<%= typeof form !== 'undefined' && form.estimated_budget ? form.estimated_budget : '' %>" />
            <p class="input-field__help muted">If you have a rough idea — staff may use a separate internal estimate.</p>
          </div>
          <div class="input-field">
            <label class="input-field__label" for="images">Pictures (optional)</label>
            <input id="images" name="images" type="file" class="input-field__control" accept="image/jpeg,image/png,image/webp,image/gif" multiple />
            <p class="input-field__help muted">Up to 5 images, 5 MB each.</p>
          </div>
          <div class="form-step__actions admin-gate-actions">
            <%- include('partials/components/button', { variant: 'primary', type: 'submit', label: 'Submit request' }) %>
            <%- include('partials/components/button', { variant: 'text', href: clientPortalBasePath + '/login', label: 'Cancel' }) %>
          </div>
        </form>
      </div>
    </div>
    <%- include('partials/theme_prefs') %>
  </body>
</html>
