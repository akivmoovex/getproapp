<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <%- include('partials/seo_meta', { seoTitle, seoDescription, canonicalUrl, ogUrl, ogImage, ogType: 'article' }) %>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
    <% if (typeof jsonLdArticle !== 'undefined' && jsonLdArticle) { %>
    <script type="application/ld+json"><%- jsonLdArticle %></script>
    <% } %>
  </head>
  <body class="page-support-content <%= tenant.themeClass %>" data-screen-role="support">
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix }) %>

      <div class="app-layout__main">
        <main class="ds-container content-article-page">
      <% if (typeof previewBanner !== 'undefined' && previewBanner) { %>
        <p class="card" style="padding: 0.75rem 1rem; margin-bottom: 1rem; background: var(--color-surface-container-high, #eee)">
          <strong>Draft preview</strong> — this page is not published to the public yet.
        </p>
      <% } %>
      <nav class="pro-company-profile__breadcrumb" aria-label="Breadcrumb" style="margin-bottom: 1rem">
        <a href="<%= tenantHomeHref %>">Home</a>
        <span class="pro-company-profile__bc-sep" aria-hidden="true">/</span>
        <a href="<%= segmentIndexHref %>"><%= segmentLabel %></a>
        <span class="pro-company-profile__bc-sep" aria-hidden="true">/</span>
        <span class="pro-company-profile__bc-current"><%= row.title %></span>
      </nav>

      <% var hero = typeof heroImage !== 'undefined' ? heroImage : ''; %>
      <% if (hero) { %>
      <div class="content-article-hero" style="margin-bottom: 1.25rem; border-radius: 12px; overflow: hidden">
        <img
          src="<%= hero %>"
          alt="<%= row.hero_image_alt || row.title %>"
          width="960"
          height="540"
          loading="eager"
          decoding="async"
          style="width: 100%; height: auto; display: block; aspect-ratio: 16/9; object-fit: cover"
        />
      </div>
      <% } %>

      <article class="content-prose">
        <h1 class="section-title section-title--flush" style="font-size: 1.75rem"><%= row.title %></h1>
        <% if (row.excerpt) { %>
          <p class="lead muted" style="font-size: 1.05rem; margin-bottom: 1.25rem"><%= row.excerpt %></p>
        <% } %>
        <div class="content-prose__body"><%- bodyHtml %></div>
      </article>

      <p style="margin-top: 2rem">
        <a href="<%= tenantUrlPrefix %>/directory">Browse professionals →</a>
      </p>
        </main>

        <%- include('partials/site_footer', { tenantUrlPrefix }) %>
      </div>
    </div>
    <script src="<%= asset('scripts') %>" defer></script>
    <%- include('partials/theme_prefs') %>
  </body>
</html>
