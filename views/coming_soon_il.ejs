<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <%- include('partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>בקרוב · <%= _bn %> ישראל</title>
    <meta name="robots" content="noindex,follow" />
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <body class="coming-soon-il tenant-il">
    <main class="coming-soon-il-inner">
      <div class="coming-soon-il-icon-wrap" aria-hidden="true">
        <svg class="coming-soon-il-crane" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" fill="none">
          <path
            class="coming-soon-il-hook"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            d="M60 18v52"
          />
          <path stroke="currentColor" stroke-width="3" stroke-linecap="round" d="M28 32h64" />
          <path stroke="currentColor" stroke-width="3" stroke-linecap="round" d="M44 32V18h32v14" />
          <rect
            class="coming-soon-il-block"
            x="42"
            y="74"
            width="36"
            height="28"
            rx="4"
            stroke="currentColor"
            stroke-width="3"
          />
        </svg>
      </div>
      <h1 class="coming-soon-il-title">בקרוב</h1>
      <p class="coming-soon-il-lead">אתר <%= _bn %> לישראל בבנייה. נחזור בקרוב עם חוויית שירות מלאה.</p>
      <p class="coming-soon-il-en muted" lang="en" dir="ltr">Israel directory — coming soon.</p>
      <p class="coming-soon-il-actions">
        <%- include('partials/components/button', { variant: 'primary', href: typeof apexUrl !== 'undefined' ? apexUrl : tenantHomeHref, label: typeof apexHostLabel !== 'undefined' ? apexHostLabel : 'getproapp.org', extraAttrs: 'dir="ltr"' }) %>
      </p>
    </main>
    <%- include('partials/page_nav_loading') %>
  </body>
</html>
