<!doctype html>
<html lang="en">
  <head>
    <%- include('partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>Provider portal · Sign in | <%= _bn %></title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <% var _pb = typeof providerPortalBasePath !== 'undefined' && providerPortalBasePath ? String(providerPortalBasePath).replace(/\/$/, '') : '/company'; %>
  <body class="company-login-page <%= typeof tenant !== 'undefined' && tenant ? tenant.themeClass : 'tenant-zm' %>">
    <main class="company-login-main">
      <p class="company-login-back muted"><%- include('partials/components/button', { variant: 'text', href: '/login', label: '← All sign-in options' }) %></p>
      <div class="card company-login-card">
        <h1 class="company-login-card__title">Provider portal</h1>
        <p class="muted company-login-card__lead">Sign in with your phone number or portal username and password (as set by your administrator).</p>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flash" role="alert"><%= error %></div>
        <% } %>
        <form method="post" action="<%= _pb %>/login" class="form">
          <%- include('partials/components/input', {
            id: 'cp_login',
            name: 'login',
            type: 'text',
            label: 'Phone or username',
            required: true,
            autocomplete: 'username',
            extraAttrs: 'autocapitalize="none"',
          }) %>
          <%- include('partials/components/input', {
            id: 'cp_password',
            name: 'password',
            type: 'password',
            label: 'Password',
            required: true,
            autocomplete: 'current-password',
          }) %>
          <div class="form-step__actions">
            <%- include('partials/components/button', { variant: 'primary', type: 'submit', label: 'Sign in' }) %>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
