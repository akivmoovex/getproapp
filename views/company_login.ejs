<!doctype html>
<%# Provider portal login: intentionally mirrors views/admin/login.ejs (admin-gate-wrap / admin-gate-card / admin-gate-brand / form-step--admin). %>
<html lang="en">
  <head>
    <%- include('partials/brand_resolve') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/theme_boot') %>
    <title>Provider portal · Sign in | <%= _bn %></title>
    <link rel="stylesheet" href="<%= asset('styles') %>" />
  </head>
  <% var _pb = typeof providerPortalBasePath !== 'undefined' && providerPortalBasePath ? String(providerPortalBasePath).replace(/\/$/, '') : '/company'; %>
  <% var _hub = typeof opsHref === 'function' ? opsHref('/login') : '/login'; %>
  <body class="admin-gate-page <%= typeof tenant !== 'undefined' && tenant ? tenant.themeClass : '' %>">
    <div class="container admin-gate-wrap">
      <div class="card admin-gate-card">
        <a href="<%= _hub %>" class="admin-gate-brand">
          <div class="logo" aria-hidden="true"></div>
          <div>
            <div class="admin-gate-brand__title"><%= _bn %> Provider</div>
            <div class="admin-gate-brand__subtitle">Sign in with your phone number or portal username and password (as set by your administrator).</div>
          </div>
        </a>
        <% var _gateErr = typeof error !== 'undefined' && error != null && String(error).trim() !== '' ? String(error).trim() : ''; %>
        <% if (_gateErr) { %>
          <div class="flash" role="alert"><%= _gateErr %></div>
        <% } %>
        <form method="post" action="<%= _pb %>/login" class="form admin-gate-form">
          <div class="form-step form-step--admin">
            <div class="form-step__body">
              <%- include('partials/components/input', {
                id: 'cp_login',
                name: 'login',
                type: 'text',
                label: 'Phone or username',
                required: true,
                autocomplete: 'username',
                extraAttrs: 'autocapitalize="none"',
              }) %>
              <%- include('partials/components/input', {
                id: 'cp_password',
                name: 'password',
                type: 'password',
                label: 'Password',
                required: true,
                autocomplete: 'current-password',
              }) %>
            </div>
            <div class="form-step__actions admin-gate-actions">
              <%- include('partials/components/button', { variant: 'primary', type: 'submit', label: 'Sign in' }) %>
              <%- include('partials/components/button', { variant: 'text', href: _hub, label: 'Cancel' }) %>
            </div>
          </div>
        </form>
      </div>
    </div>
    <%- include('partials/theme_prefs') %>
  </body>
</html>
