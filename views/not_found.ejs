<% var tp = typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : ''; %>
<% var tpHome = typeof tenantHomeHref !== 'undefined' ? tenantHomeHref : (tp ? tp + '/' : '/'); %>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Not Found | GetPro</title>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body>
    <%- include('partials/site_header', { tenantUrlPrefix: tp, tenant: typeof tenant !== 'undefined' ? tenant : null, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>
    <div class="container u-pad-y-notfound">
      <div class="card">
        <div class="not-found-title">Page not found</div>
        <div class="muted muted--relaxed u-mt-sm">
          <% if (typeof subdomain !== 'undefined' && subdomain) { %>
            No company page exists for <span class="kbd"><%= subdomain %></span>.
          <% } else if (typeof kind !== 'undefined' && kind === 'mini-site' && typeof slug !== 'undefined' && slug) { %>
            No company with mini-site path <span class="kbd">/<%= slug %></span> in this region.
          <% } else if (typeof kind !== 'undefined' && kind === 'company' && typeof slug !== 'undefined' && slug) { %>
            No company profile in this region for id <span class="kbd"><%= slug %></span>.
          <% } else if (typeof slug !== 'undefined' && slug) { %>
            The <span class="kbd"><%= slug %></span> category does not exist.
          <% } %>
        </div>
        <div class="not-found-actions">
          <a class="btn btn-primary" href="<%= tpHome %>">Go to homepage</a>
        </div>
      </div>
    </div>
    <%- include('partials/site_footer', { tenantUrlPrefix: tp }) %>
  </body>
</html>
