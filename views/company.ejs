<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/seo_meta', {
      seoTitle: typeof seoTitle !== 'undefined' ? seoTitle : (company.name + ' | Pro-online'),
      seoDescription: typeof seoDescription !== 'undefined' ? seoDescription : ((company.headline || company.name || '').replace(/"/g, '') + ' · Verified directory listing on Pro-online.'),
      canonicalUrl: typeof canonicalUrl !== 'undefined' ? canonicalUrl : '',
      ogUrl: typeof ogUrl !== 'undefined' ? ogUrl : '',
      ogType: 'website'
    }) %>
    <% if (typeof jsonLdCompany !== 'undefined' && jsonLdCompany) { %>
    <script type="application/ld+json"><%- jsonLdCompany %></script>
    <% } %>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <% var _cpPortal = typeof companyPortalLayout !== 'undefined' && companyPortalLayout; %>
  <% var _cpReadOnly = typeof companyPortalReadOnly !== 'undefined' && companyPortalReadOnly; %>
  <body class="page-company-profile <%= _cpPortal ? 'company-portal' : '' %> <%= typeof tenant !== 'undefined' && tenant ? tenant.themeClass : 'tenant-zm' %>" data-screen-role="<%= _cpPortal ? 'company-portal' : 'profile' %>">
    <% if (_cpPortal) { %>
    <%- include('partials/company_portal_shell_start', {
      activeCompanyNav: typeof activeCompanyNav !== 'undefined' ? activeCompanyNav : 'minisite',
      companyName: typeof company !== 'undefined' && company && company.name ? company.name : '',
      companyPortalPersonnel: typeof companyPortalPersonnel !== 'undefined' ? companyPortalPersonnel : null,
      providerPortalBasePath: typeof providerPortalBasePath !== 'undefined' ? providerPortalBasePath : '/company',
    }) %>
    <div class="company-portal-profile-embed">
    <% } else { %>
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix: typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : '', tenant: typeof tenant !== 'undefined' ? tenant : null, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [] }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix: typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : '' }) %>

      <div class="app-layout__main">
    <% } %>
        <div class="pro-company-profile__shell">
    <main class="pro-company-profile" dir="ltr" lang="en">
      <div class="container pro-company-profile__inner">
        <% var _gpPhone = typeof getproPhone !== 'undefined' ? String(getproPhone || '').trim() : ''; %>
        <% var _gpTel = typeof getproTelHref !== 'undefined' ? String(getproTelHref || '').trim() : ''; %>
        <% var _supPhone = typeof getproSupportPhone !== 'undefined' ? String(getproSupportPhone || '').trim() : ''; %>
        <% var _supTel = typeof getproSupportTelHref !== 'undefined' ? String(getproSupportTelHref || '').trim() : ''; %>
        <% var _gpWa = typeof getproWhatsappHref !== 'undefined' ? String(getproWhatsappHref || '').trim() : ''; %>
        <% var _gpWaLabel = typeof getproWhatsapp !== 'undefined' ? String(getproWhatsapp || '').trim() : ''; %>
        <% var _gpEmail = typeof getproEmail !== 'undefined' ? String(getproEmail || '').trim() : ''; %>
        <% var _bizPhone = company.phone ? String(company.phone).trim() : ''; %>
        <% var _featuredPhone = company.featured_cta_phone ? String(company.featured_cta_phone).trim() : ''; %>
        <% var _primaryCall = _featuredPhone || _bizPhone || ''; %>
        <% var _primaryTelHref = _primaryCall ? ('tel:' + _primaryCall.replace(/[^\d+]/g, '')) : ''; %>
        <% var _gpD = _gpPhone.replace(/\D/g, ''); %>
        <% var _bizD = _bizPhone.replace(/\D/g, ''); %>
        <% var _showBizPhone = _bizPhone && _bizD !== _gpD; %>
        <% var _primaryD = _primaryCall.replace(/\D/g, ''); %>
        <% var _showBizPhoneRow = _showBizPhone && _bizD !== _primaryD; %>
        <nav class="pro-company-profile__breadcrumb" aria-label="Breadcrumb">
          <a href="<%= typeof tenantHomeHref !== 'undefined' ? tenantHomeHref : '/' %>">Home</a>
          <span class="pro-company-profile__bc-sep" aria-hidden="true">/</span>
          <a href="<%= typeof directoryHref !== 'undefined' ? directoryHref : '/directory' %>">Directory</a>
          <% if (category && category.slug) { %>
            <span class="pro-company-profile__bc-sep" aria-hidden="true">/</span>
            <a href="<%= typeof tenantUrlPrefix !== 'undefined' && tenantUrlPrefix ? (tenantUrlPrefix.toString().replace(/\/$/, '') + '/directory?category=' + category.slug) : '/directory?category=' + category.slug %>"><%= category.name %></a>
          <% } %>
          <span class="pro-company-profile__bc-sep" aria-hidden="true">/</span>
          <span class="pro-company-profile__bc-current"><%= company.name %></span>
        </nav>

        <header class="pro-company-profile__hero pro-company-profile__hero-panel card">
          <div class="pro-company-profile__hero-main">
            <div class="pro-company-profile__badges">
              <% if (category) { %>
                <span class="pro-company-profile__pill"><%= category.name %></span>
              <% } %>
              <% if (company.location && String(company.location).trim()) { %>
                <span class="pro-company-profile__pill pro-company-profile__pill--muted"><%= company.location %></span>
              <% } %>
              <span class="pro-company-profile__pill pro-company-profile__pill--muted">Mini-site</span>
            </div>
            <div class="pro-company-profile__title-row">
              <% var logoU = company.logo_url && String(company.logo_url).trim(); %>
              <% if (logoU) { %>
                <%# PERF: Company logo is LCP candidate when present — do not lazy-load; see docs/performance-budgets.md §2.4 %>
                <div class="pro-company-profile__logo-wrap">
                  <img class="pro-company-profile__logo" src="<%= logoU %>" alt="<%= company.name %> logo" width="120" height="120" fetchpriority="high" decoding="async" />
                </div>
              <% } %>
              <div class="pro-company-profile__title-block">
                <h1 class="pro-company-profile__title"><%= company.name %></h1>
                <% if (company.headline) { %>
                  <p class="pro-company-profile__headline"><%= company.headline %></p>
                <% } %>
              </div>
            </div>
            <% var yoe = company.years_experience != null && company.years_experience !== '' ? Number(company.years_experience) : null; %>
            <% if (yoe != null && !isNaN(yoe) && yoe > 0) { %>
              <p class="pro-company-profile__meta-line"><strong><%= yoe %></strong> years in business</p>
            <% } %>
          </div>

          <% var rc = typeof review_count !== 'undefined' ? Number(review_count) : 0; %>
          <% var av = typeof avg_rating !== 'undefined' && avg_rating != null ? Number(avg_rating) : null; %>
          <% if (rc > 0 && av != null && !isNaN(av)) { %>
            <div class="pro-company-profile__score-card">
              <div class="pro-company-profile__score-num"><%= av.toFixed(2) %></div>
              <div class="pro-company-profile__score-star" aria-hidden="true">★</div>
              <div class="pro-company-profile__score-count"><%= rc %> verified reviews</div>
            </div>
          <% } %>
        </header>

        <div class="pro-company-profile__grid">
          <div class="pro-company-profile__primary">

            <% if (company.about && String(company.about).trim()) { %>
              <section class="pro-company-profile__section" aria-labelledby="about-heading">
                <h2 id="about-heading" class="pro-company-profile__h2">About</h2>
                <div class="pro-company-profile__prose"><%= company.about %></div>
              </section>
            <% } %>

            <% if (company.services && String(company.services).trim()) { %>
              <section class="pro-company-profile__section" aria-labelledby="spec-heading">
                <h2 id="spec-heading" class="pro-company-profile__h2">Specialisations &amp; services</h2>
                <ul class="pro-company-profile__bullets">
                  <% company.services.split('\n').filter(function(s){ return String(s).trim(); }).forEach(function(s) { %>
                    <li><%= String(s).trim() %></li>
                  <% }); %>
                </ul>
              </section>
            <% } %>

            <% var mediaItems = typeof mediaCarouselItems !== 'undefined' && mediaCarouselItems && mediaCarouselItems.length ? mediaCarouselItems : []; %>
            <% if (mediaItems.length) { %>
              <section class="pro-company-profile__section" aria-labelledby="gallery-heading">
                <h2 id="gallery-heading" class="pro-company-profile__h2">Photos</h2>
                <p class="muted pro-company-profile__gallery-intro">Swipe or use the arrows (or keyboard ← → when focused).</p>
                <div
                  class="pro-company-carousel"
                  data-company-carousel
                  tabindex="0"
                  role="region"
                  aria-roledescription="carousel"
                  aria-label="Company photos"
                >
                  <div class="pro-company-carousel__viewport" data-carousel-viewport>
                    <div class="pro-company-carousel__track" data-carousel-track>
                      <% mediaItems.forEach(function(g, gi) { %>
                        <% var isLogo = g.kind === 'logo'; %>
                        <figure class="pro-company-carousel__slide<%= isLogo ? ' pro-company-carousel__slide--logo' : '' %>" data-carousel-slide aria-label="Slide <%= gi + 1 %> of <%= mediaItems.length %>">
                          <div class="pro-company-carousel__img-wrap">
                            <img src="<%= g.url %>" alt="<%= isLogo ? (company.name + ' logo') : (g.caption ? g.caption.replace(/"/g, '') : 'Work photo') %>" loading="<%= gi === 0 ? 'eager' : 'lazy' %>" decoding="async" width="960" height="640" draggable="false" />
                          </div>
                          <% if (g.caption) { %>
                            <figcaption class="pro-company-carousel__cap"><%= g.caption %></figcaption>
                          <% } else if (isLogo) { %>
                            <figcaption class="pro-company-carousel__cap">Company logo</figcaption>
                          <% } %>
                        </figure>
                      <% }); %>
                    </div>
                  </div>
                  <% if (mediaItems.length > 1) { %>
                    <button type="button" class="pro-company-carousel__btn pro-company-carousel__btn--prev" data-carousel-prev aria-label="Previous photo">‹</button>
                    <button type="button" class="pro-company-carousel__btn pro-company-carousel__btn--next" data-carousel-next aria-label="Next photo">›</button>
                    <div class="pro-company-carousel__dots" data-carousel-dots aria-hidden="true"></div>
                  <% } %>
                </div>
              </section>
            <% } %>

            <% if (company.service_areas && String(company.service_areas).trim()) { %>
              <section class="pro-company-profile__section" aria-labelledby="areas-heading">
                <h2 id="areas-heading" class="pro-company-profile__h2">Service areas</h2>
                <div class="pro-company-profile__prose pro-company-profile__preline"><%= company.service_areas %></div>
              </section>
            <% } %>

            <% if (company.hours_text && String(company.hours_text).trim()) { %>
              <section class="pro-company-profile__section" aria-labelledby="hours-heading">
                <h2 id="hours-heading" class="pro-company-profile__h2">Hours</h2>
                <div class="pro-company-profile__prose pro-company-profile__preline"><%= company.hours_text %></div>
              </section>
            <% } %>

            <% if (rc > 0 && typeof star_distribution !== 'undefined' && typeof star_distribution_total !== 'undefined' && star_distribution_total > 0) { %>
              <section class="pro-company-profile__section" aria-labelledby="dist-heading">
                <h2 id="dist-heading" class="pro-company-profile__h2">Rating breakdown</h2>
                <div class="pro-company-profile__dist">
                  <% for (var star = 5; star >= 1; star--) { %>
                    <% var cnt = star_distribution[star] || 0; %>
                    <% var pct = Math.round((cnt / star_distribution_total) * 100); %>
                    <div class="pro-company-profile__dist-row">
                      <span class="pro-company-profile__dist-label"><%= star %>★</span>
                      <div class="pro-company-profile__dist-bar" role="presentation">
                        <span class="pro-company-profile__dist-fill" data-width-pct="<%= pct %>"></span>
                      </div>
                      <span class="pro-company-profile__dist-pct"><%= pct %>%</span>
                    </div>
                  <% } %>
                </div>
              </section>
            <% } %>

            <section class="pro-company-profile__section" aria-labelledby="reviews-heading">
              <h2 id="reviews-heading" class="pro-company-profile__h2">Customer reviews</h2>
              <% if (!reviews || !reviews.length) { %>
                <p class="muted">No reviews yet — be the first to leave feedback after you work with this business.</p>
              <% } else { %>
                <ul class="pro-company-profile__reviews">
                  <% reviews.forEach(function(r) { %>
                    <li class="pro-company-profile__review">
                      <div class="pro-company-profile__review-top">
                        <span class="pro-company-profile__review-score"><%= Number(r.rating).toFixed(2) %> ★</span>
                        <span class="pro-company-profile__review-author"><%= r.author_name || 'Customer' %></span>
                        <span class="pro-company-profile__review-date"><%= r.dateLabel || '' %></span>
                      </div>
                      <blockquote class="pro-company-profile__review-body">“<%= r.body %>”</blockquote>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </section>

            <% if (!_cpReadOnly) { %>
            <section class="pro-company-profile__section" aria-labelledby="lead-heading">
              <h2 id="lead-heading" class="pro-company-profile__h2">Request contact</h2>
              <div class="card pro-company-profile__lead-card">
                <form id="lead_form" class="form">
                  <input type="hidden" name="company_id" value="<%= company.id %>" />

                  <div class="form-step">
                    <div class="form-step__body">
                      <%- include('partials/components/input', { id: 'lead_name', name: 'name', required: true, autocomplete: 'name', placeholder: 'e.g. Chanda Phiri', label: 'Full name' }) %>
                      <%- include('partials/components/input', { id: 'lead_phone', name: 'phone', required: true, autocomplete: 'tel', placeholder: 'e.g. 0977 123 456', label: 'Phone number' }) %>
                      <%- include('partials/components/input', { id: 'lead_email', name: 'email', type: 'text', autocomplete: 'email', placeholder: 'e.g. chanda@example.com', label: 'Email address (optional)', extraAttrs: 'inputmode="email"' }) %>
                      <div class="input-field">
                        <label for="lead_message" class="input-field__label">How can we help?</label>
                        <textarea id="lead_message" name="message" required placeholder="Tell us what service you need and when you need it" class="input-field__control"></textarea>
                      </div>
                      <p
                        id="lead_status"
                        class="form-status-message status-message muted pro-company-profile__lead-status"
                        role="status"
                        aria-live="polite"
                      ></p>
                    </div>
                    <div class="form-step__actions">
                      <div class="card__actions">
                        <%- include('partials/components/button', { variant: 'primary', type: 'submit', label: 'Send request' }) %>
                      </div>
                    </div>
                  </div>
                </form>
              </div>
            </section>
            <% } %>
          </div>

          <aside class="pro-company-profile__aside card">
            <h2 class="pro-company-profile__aside-title">Contact</h2>
            <% if (_primaryTelHref) { %>
              <%- include('partials/components/button', { variant: 'primary', href: _primaryTelHref, label: 'Call ' + _primaryCall, ariaLabel: 'Call ' + _primaryCall, className: 'pro-company-profile__cta' }) %>
            <% } %>
            <ul class="pro-company-profile__contact-list">
              <% if (_showBizPhoneRow) { %>
                <li><span class="muted">Business phone</span><br /><%- include('partials/components/button', { variant: 'text', href: 'tel:' + String(_bizPhone).replace(/[^\d+]/g, ''), label: _bizPhone }) %></li>
              <% } %>
              <% if (_gpWa) { %>
                <li>
                  <span class="muted">WhatsApp</span><br />
                  <%- include('partials/components/button', { variant: 'text', href: _gpWa, label: _gpWaLabel || 'Open WhatsApp chat', extraAttrs: 'rel="noopener noreferrer" target="_blank"' }) %>
                </li>
              <% } %>
              <% if (company.email) { %>
                <% var _mail = String(company.email || '').trim(); %>
                <li><span class="muted">Email</span><br /><%- include('partials/components/button', { variant: 'text', href: 'mailto:' + _mail, label: _mail }) %></li>
              <% } %>
              <% if (company.location) { %>
                <li><span class="muted">Location</span><br /><%= company.location %></li>
              <% } %>
              <% if (_gpPhone && _gpTel) { %>
                <li><span class="muted">Directory help</span><br /><%- include('partials/components/button', { variant: 'text', href: _gpTel, label: _gpPhone }) %></li>
              <% } %>
            </ul>

            <% if (typeof companyUrl !== 'undefined' && companyUrl && companyUrl !== '#') { %>
              <p class="muted pro-company-profile__mini-hint">Mini-site URL</p>
              <p class="pro-company-profile__mini-url">
                <%- include('partials/components/button', { variant: 'text', href: companyUrl, label: (typeof miniSiteLabel !== 'undefined' && miniSiteLabel ? miniSiteLabel : companyUrl) }) %>
              </p>
            <% } %>

            <% if (typeof qrMiniSiteDataUrl !== 'undefined' && qrMiniSiteDataUrl) { %>
              <div class="pro-company-profile__qr-block">
                <div class="pro-company-profile__qr-heading">Mini-site QR code</div>
                <p class="muted pro-company-profile__qr-hint">Scan to open this page on a phone.</p>
                <div class="pro-company-profile__qr-single">
                  <img src="<%= qrMiniSiteDataUrl %>" alt="QR code for this mini-site URL" width="168" height="168" class="pro-company-profile__qr-img" data-qr-image loading="lazy" decoding="async" />
                </div>
                <div class="pro-company-profile__qr-actions card__actions">
                  <%- include('partials/components/button', { variant: 'text', type: 'button', label: 'Copy QR image', className: 'pro-company-profile__qr-copy' }) %>
                  <span class="muted pro-company-profile__qr-copy-status" data-qr-copy-status hidden aria-live="polite"></span>
                </div>
              </div>
            <% } %>

            <div class="pro-company-profile__support">
              <div class="pro-company-profile__support-title">Pro-online support</div>
              <p class="muted pro-company-profile__support-intro">Questions about the directory? Reach your region’s call center below.</p>
              <div class="pro-company-profile__support-actions" role="group" aria-label="Region call center">
                <% if (_supPhone && _supTel) { %>
                  <%- include('partials/components/button', { variant: 'primary', href: _supTel, label: 'Call', ariaLabel: 'Call region call center', className: 'pro-company-profile__support-pill' }) %>
                <% } %>
                <% if (_gpEmail) { %>
                  <%- include('partials/components/button', { variant: 'secondary', href: 'mailto:' + _gpEmail, label: 'Email', ariaLabel: 'Email region call center', className: 'pro-company-profile__support-pill' }) %>
                <% } %>
                <% if (_gpWa) { %>
                  <%- include('partials/components/button', { variant: 'secondary', href: _gpWa, label: 'WhatsApp', ariaLabel: 'WhatsApp region call center', className: 'pro-company-profile__support-pill', extraAttrs: 'rel="noopener noreferrer" target="_blank"' }) %>
                <% } %>
              </div>
            </div>
          </aside>
        </div>
        </div>
    </main>
    <% if (!_cpReadOnly && (_primaryTelHref || _gpWa)) { %>
    <div class="pro-company-sticky-cta" role="region" aria-label="Quick contact">
      <% if (_primaryTelHref) { %>
      <%- include('partials/components/button', { variant: 'primary', href: _primaryTelHref, label: 'Call ' + _primaryCall, ariaLabel: 'Call ' + _primaryCall, className: 'pro-company-sticky-cta__btn pro-company-sticky-cta__btn--call' }) %>
      <% } %>
      <% if (_gpWa) { %>
      <%- include('partials/components/button', { variant: 'secondary', href: _gpWa, label: 'WhatsApp', className: 'pro-company-sticky-cta__btn', extraAttrs: 'rel="noopener noreferrer" target="_blank"' }) %>
      <% } %>
    </div>
    <% } %>
    </div>

    <% if (_cpPortal) { %>
    </div>
    <%- include('partials/company_portal_shell_end') %>
    <% } else { %>
    <%- include('partials/site_footer', { tenantUrlPrefix: typeof tenantUrlPrefix !== 'undefined' ? tenantUrlPrefix : '' }) %>
      </div>
    </div>
    <% } %>
    <script src="/scripts.js?v=<%= stylesVersion %>" defer></script>
    <%- include('partials/theme_prefs') %>
    <script src="/company-profile.js?v=<%= stylesVersion %>" defer></script>
  </body>
</html>
