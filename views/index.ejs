<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>GetPro · Trusted professional directory | getproapp.org</title>
    <meta
      name="description"
      content="GetPro connects you with professionals. Search the directory, browse categories, and contact businesses directly."
    />
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="home-page wf-home-layout <%= tenant.themeClass %>">
    <div class="wf-home-topbar-brandrow">
      <a href="<%= tenantHomeHref %>" class="wf-home-topbar-brand" aria-label="GetPro home">
        <div class="logo" aria-hidden="true"></div>
        <span class="wf-home-topbar-title">GetPro</span>
      </a>
      <%- include('partials/region_strip', { regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [], tenant, regionStripModifier: 'wf-region-strip--home' }) %>
    </div>
    <div class="wf-home-topbar-actions">
      <a class="wf-home-join-btn" href="<%= tenantUrlPrefix %>/join">Join us</a>
      <% if (typeof isApexHost !== 'undefined' && isApexHost) { %>
      <button
        type="button"
        class="wf-home-region-trigger"
        id="wf-region-open"
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="wf-region-sheet"
      >
        <svg
          class="wf-home-region-globe"
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
        </svg>
        <span class="wf-home-region-label">Region</span>
      </button>
      <% } %>
      <button
        type="button"
        class="wf-menu-toggle"
        id="wf-menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="wf-home-sidebar"
      >
        <svg class="wf-menu-icon wf-menu-icon--hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="wf-menu-icon wf-menu-icon--close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>
    <div class="wf-menu-backdrop" id="wf-menu-backdrop" hidden></div>
    <% if (typeof isApexHost !== 'undefined' && isApexHost) { %>
    <div id="wf-region-overlay" class="wf-region-overlay" hidden aria-hidden="true"></div>
    <div
      id="wf-region-sheet"
      class="wf-region-sheet wf-region-sheet--picker"
      role="dialog"
      aria-modal="true"
      aria-labelledby="wf-region-title"
      hidden
    >
      <button type="button" class="wf-region-close-x" id="wf-region-close-x" aria-label="Close">×</button>
      <h2 id="wf-region-title" class="wf-region-title wf-region-title--picker">Choose region</h2>
      <div class="wf-region-actions wf-region-actions--grid">
        <% if (typeof regionChoices !== 'undefined' && regionChoices && regionChoices.length) { %>
          <% regionChoices.forEach(function (r) { %>
            <a class="wf-region-btn" href="<%= r.href %>">
              <span class="wf-region-btn-label" <%= r.slug === 'il' ? 'dir="rtl"' : '' %>><%= r.slug === 'il' ? 'ישראל' : r.name %></span>
              <span class="wf-region-btn-flag" aria-hidden="true"><%= r.flag %></span>
            </a>
          <% }); %>
        <% } else { %>
        <a class="wf-region-btn" href="<%= regionZmUrl || tenantHomeHref %>">
          <span class="wf-region-btn-label">Zambia</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇿🇲</span>
        </a>
        <% if (regionIlUrl) { %>
        <a class="wf-region-btn" href="<%= regionIlUrl %>">
          <span class="wf-region-btn-label" dir="rtl">ישראל</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇮🇱</span>
        </a>
        <% } %>
        <% } %>
      </div>
    </div>
    <% } %>
    <%- include('partials/home_sidebar', { tenantUrlPrefix }) %>

    <div class="wf-home-shell">
      <div class="wf-home-main">
        <section class="pro-home-hero" aria-labelledby="pro-home-hero-heading">
          <div class="pro-home-hero-visual">
            <!-- Service / trade professional — replace src with your own asset if preferred (pro.co.il–style hero). -->
            <img
              class="pro-home-hero-photo"
              src="https://images.unsplash.com/photo-1621905251918-48416bd8575a?auto=format&amp;fit=crop&amp;w=1920&amp;q=80"
              width="1920"
              height="800"
              alt="Professional providing a home service"
              loading="eager"
              decoding="async"
            />
            <div class="pro-home-hero-scrim" aria-hidden="true"></div>

            <div class="pro-home-hero-panel">
              <div class="pro-home-hero-caption">
                <p id="pro-home-hero-heading" class="pro-home-hero-tagline">Our recommended professionals</p>
              </div>
              <div class="pro-home-search-wrap pro-home-search-wrap--hero">
            <form class="pro-home-dual-search" action="<%= tenantUrlPrefix %>/directory" method="get" role="search" aria-label="Search by field and city">
              <div class="pro-home-search-fields">
                <div class="pro-ac" data-ac-list="service" data-watermark-text="Search: Electrician">
                  <label class="visually-hidden" for="home-search-q">Field</label>
                  <input
                    id="home-search-q"
                    class="pro-ac-input"
                    type="text"
                    placeholder=""
                    autocomplete="off"
                    role="combobox"
                    aria-autocomplete="list"
                    aria-expanded="false"
                    aria-controls="home-search-q-dropdown"
                  />
                  <input type="hidden" class="pro-ac-hidden" name="q" id="home-search-q-value" value="" />
                  <ul class="pro-ac-dropdown" id="home-search-q-dropdown" role="listbox" hidden></ul>
                  <p class="pro-ac-msg" hidden></p>
                </div>
                <div class="pro-ac" data-ac-list="city" data-watermark-text="Search: Lusaka">
                  <label class="visually-hidden" for="home-search-city">City</label>
                  <input
                    id="home-search-city"
                    class="pro-ac-input"
                    type="text"
                    placeholder=""
                    autocomplete="off"
                    role="combobox"
                    aria-autocomplete="list"
                    aria-expanded="false"
                    aria-controls="home-search-city-dropdown"
                  />
                  <input type="hidden" class="pro-ac-hidden" name="city" id="home-search-city-value" value="" />
                  <ul class="pro-ac-dropdown" id="home-search-city-dropdown" role="listbox" hidden></ul>
                  <p class="pro-ac-msg" hidden></p>
                </div>
              </div>
              <button class="pro-home-search-submit" type="submit">
                <span class="pro-home-search-submit-text">Search Professionals</span>
                <svg class="pro-home-search-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="11" cy="11" r="7" />
                  <path d="m21 21-4.3-4.3" />
                </svg>
              </button>
            </form>
              </div>
            </div>
          </div>
        </section>

    <section class="wf-stats" aria-label="Highlights">
      <div class="container wf-stats-grid">
        <div class="wf-stat">
          <div class="wf-stat-value">Live</div>
          <p class="wf-stat-label">search across the directory</p>
        </div>
        <div class="wf-stat wf-stat-divider" aria-hidden="true"></div>
        <div class="wf-stat">
          <div class="wf-stat-value">Categories</div>
          <p class="wf-stat-label">organized for faster discovery</p>
        </div>
        <div class="wf-stat wf-stat-divider" aria-hidden="true"></div>
        <div class="wf-stat">
          <div class="wf-stat-value">One-page</div>
          <p class="wf-stat-label">profiles with clear contact options</p>
        </div>
      </div>
    </section>

    <section class="pro-section">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title"><a href="<%= tenantUrlPrefix %>/directory">Leading categories</a></h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/directory">All categories →</a>
        </div>
        <div class="pro-cat-grid">
          <% categories.forEach(function(cat) { %>
            <a href="<%= tenantUrlPrefix %>/category/<%= cat.slug %>"><%= cat.name %></a>
          <% }) %>
          <% if (categories.length === 0) { %>
            <p class="muted" style="grid-column: 1 / -1;">No categories yet. Add them in the admin panel.</p>
          <% } %>
        </div>
      </div>
    </section>

    <section class="pro-section" id="about">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title"><a href="#about">How we do it</a></h2>
        </div>
        <div class="pro-pillars">
          <div class="pro-pillar">
            <h3>Curated listings</h3>
            <ul>
              <li>Businesses are organized by category for faster discovery.</li>
              <li>Each profile stays focused: services, contact, and a simple lead form.</li>
            </ul>
          </div>
          <div class="pro-pillar">
            <h3>Clear information</h3>
            <ul>
              <li>Headlines and descriptions help you compare professionals quickly.</li>
              <li>Direct phone and email when the business chooses to publish them.</li>
            </ul>
          </div>
          <div class="pro-pillar">
            <h3>Support through the platform</h3>
            <ul>
              <li>Request contact without hunting for forms across random sites.</li>
              <li>Reach our team during business hours if you need help navigating the directory.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="pro-section" id="pricing">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title">Sample pricing awareness</h2>
          <span class="muted" style="font-size:14px;">Illustrative ranges — always confirm with the professional.</span>
        </div>
        <div class="pro-price-row">
          <div class="pro-price-card">
            <h4>Standard service visit</h4>
            <p class="desc">Typical on-site assessment or small repair visit.</p>
            <div class="amt">from local rates</div>
          </div>
          <div class="pro-price-card">
            <h4>Planned installation</h4>
            <p class="desc">Larger jobs depend on materials and access — get a written quote.</p>
            <div class="amt">quote per job</div>
          </div>
          <div class="pro-price-card">
            <h4>Emergency call-out</h4>
            <p class="desc">After-hours premiums may apply; ask upfront.</p>
            <div class="amt">varies</div>
          </div>
        </div>
      </div>
    </section>

    <section class="pro-section">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title">Recent feedback</h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/directory">Browse listings →</a>
        </div>
        <div class="pro-reviews">
          <div class="pro-review">
            <div class="pro-stars">★★★★★</div>
            <div class="pro-review-meta">Dana · last week</div>
            <q>Found a specialist in minutes and booked straight from the profile. Clear and fast.</q>
          </div>
          <div class="pro-review">
            <div class="pro-stars">★★★★★</div>
            <div class="pro-review-meta">Yossi · March 2026</div>
            <q>The lead form worked on mobile. The business called back the same day.</q>
          </div>
          <div class="pro-review">
            <div class="pro-stars">★★★★★</div>
            <div class="pro-review-meta">Michal · March 2026</div>
            <q>Nice to have categories laid out like the big pro directories — but lightweight.</q>
          </div>
        </div>
      </div>
    </section>

    <section class="pro-section" id="services">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title">Popular jobs &amp; topics</h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/directory">View professionals →</a>
        </div>
        <div class="pro-articles">
          <article class="pro-article">
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/directory">Before you book a renovation</a></h4>
              <p>What to clarify with a contractor: scope, timeline, and payment milestones.</p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/directory">Read more →</a>
            </div>
          </article>
          <article class="pro-article">
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/directory">HVAC checks homeowners skip</a></h4>
              <p>Simple maintenance questions to ask before peak season demand.</p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/directory">Read more →</a>
            </div>
          </article>
          <article class="pro-article">
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/directory">Electrical safety at home</a></h4>
              <p>When to call a licensed professional instead of DIY troubleshooting.</p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/directory">Read more →</a>
            </div>
          </article>
          <article class="pro-article">
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/directory">Plumbing emergencies</a></h4>
              <p>Shutoffs, damage control, and how to describe the issue when you call.</p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/directory">Read more →</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="pro-section" id="guide">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title">Pro guide</h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/directory">All topics →</a>
        </div>
        <div class="pro-articles">
          <article class="pro-article">
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/directory">Choosing the right category</a></h4>
              <p>How we group trades so customers land on the right specialists.</p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/directory">Read more →</a>
            </div>
          </article>
          <article class="pro-article">
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/directory">What belongs on your one-page site</a></h4>
              <p>Headline, proof points, and a single strong call to action.</p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/directory">Read more →</a>
            </div>
          </article>
          <article class="pro-article">
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/directory">Responding to leads quickly</a></h4>
              <p>Templates and timing that improve conversion from directory inquiries.</p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/directory">Read more →</a>
            </div>
          </article>
          <article class="pro-article">
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/directory">Photo and brand basics</a></h4>
              <p>Keep your profile credible with consistent naming and contact details.</p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/directory">Read more →</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="pro-section" id="qa">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title">Questions &amp; answers</h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/directory">More →</a>
        </div>
        <div class="pro-qa-list">
          <div class="pro-qa-item">
            <p class="pro-qa-q"><a href="<%= tenantUrlPrefix %>/directory">How do I contact a business?</a></p>
            <p class="pro-qa-a">Open the listing and use the phone, email, or lead form shown on their page.</p>
            <div class="pro-qa-meta">Updated · <%= new Date().getFullYear() %></div>
          </div>
          <div class="pro-qa-item">
            <p class="pro-qa-q"><a href="<%= tenantUrlPrefix %>/join">How can my company appear here?</a></p>
            <p class="pro-qa-a">Professionals sign in to the partner area to create a category and subdomain profile.</p>
            <div class="pro-qa-meta">For businesses</div>
          </div>
          <div class="pro-qa-item">
            <p class="pro-qa-q"><a href="<%= tenantUrlPrefix %>/directory">Is search available?</a></p>
            <p class="pro-qa-a">Yes — use the search bar above or browse categories to narrow results.</p>
            <div class="pro-qa-meta">Directory</div>
          </div>
        </div>
      </div>
    </section>

    <section class="pro-section">
      <div class="container">
        <div class="card cta-card wf-cta-card" style="text-align:center;max-width:640px;margin:0 auto;">
          <h2 class="section-title" style="margin-top:0;">Your next professional is a search away</h2>
          <p class="subtitle" style="margin-bottom:18px;">Browse the directory or list your business on GetPro.</p>
          <div class="hero-actions wf-cta-actions" style="justify-content:center;">
            <a class="btn btn-primary" href="<%= tenantUrlPrefix %>/directory">Open directory</a>
            <a class="btn btn-secondary-wf" href="/getpro-admin">GetPro admin</a>
          </div>
        </div>
      </div>
    </section>

      </div>
    </div>

    <%- include('partials/site_footer', { tenantUrlPrefix }) %>

    <script src="/scripts.js?v=20260329b"></script>
    <script src="/autocomplete.js?v=20260329a"></script>
  </body>
</html>
