<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <%- include('partials/seo_meta', {
      seoTitle: typeof seoTitle !== 'undefined' ? seoTitle : 'GetPro · Trusted professional directory',
      seoDescription: typeof seoDescription !== 'undefined' ? seoDescription : 'Find trusted professionals near you. Search by service and city, compare profiles, and contact the right business quickly.',
      canonicalUrl: typeof canonicalUrl !== 'undefined' ? canonicalUrl : '',
      ogUrl: typeof ogUrl !== 'undefined' ? ogUrl : '',
      ogImage: typeof ogImage !== 'undefined' ? ogImage : '',
      ogType: 'website'
    }) %>
    <% if (typeof orgJsonLd !== 'undefined' && orgJsonLd) { %>
    <script type="application/ld+json"><%- orgJsonLd %></script>
    <% } %>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="home-page home-page--launcher wf-home-layout <%= tenant.themeClass %>" data-screen-role="launcher">
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [], renderRegionPickerTrigger: true }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix }) %>

      <div class="app-layout__main">
    <% if (typeof showRegionPickerUi !== 'undefined' && showRegionPickerUi) { %>
    <div id="wf-region-m3-root" class="m3-modal-overlay wf-region-m3" hidden aria-hidden="true">
      <div class="m3-modal-overlay__backdrop" id="wf-region-overlay"></div>
      <div
        id="wf-region-sheet"
        class="m3-modal wf-region-sheet wf-region-sheet--picker"
        role="dialog"
        aria-modal="true"
        aria-labelledby="wf-region-title"
      >
        <header class="m3-modal__header wf-region-sheet__header">
          <h2 id="wf-region-title" class="m3-modal__title wf-region-title wf-region-title--picker">Choose region</h2>
          <button type="button" class="m3-modal__close wf-region-close-x" id="wf-region-close-x" aria-label="Close">×</button>
        </header>
        <div class="m3-modal__body wf-region-sheet__body">
          <div class="wf-region-actions wf-region-actions--grid">
        <% if (typeof regionChoices !== 'undefined' && regionChoices && regionChoices.length) { %>
          <% regionChoices.forEach(function (r) { %>
            <a class="wf-region-btn" href="<%= r.href %>">
              <span class="wf-region-btn-label" <%= r.slug === 'il' ? 'dir="rtl"' : '' %>><%= r.slug === 'il' ? 'ישראל' : r.name %></span>
              <span class="wf-region-btn-flag" aria-hidden="true"><%= r.flag %></span>
            </a>
          <% }); %>
        <% } else { %>
        <a class="wf-region-btn" href="<%= regionZmUrl || tenantHomeHref %>">
          <span class="wf-region-btn-label">Zambia</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇿🇲</span>
        </a>
        <% if (regionIlUrl) { %>
        <a class="wf-region-btn" href="<%= regionIlUrl %>">
          <span class="wf-region-btn-label" dir="rtl">ישראל</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇮🇱</span>
        </a>
        <% } %>
        <% } %>
          </div>
        </div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>
    <% } %>


    <div class="wf-home-shell">
      <div class="wf-home-main">
        <section class="pro-home-hero" aria-labelledby="pro-home-hero-heading">
          <div class="pro-home-hero-visual">
            <div class="pro-home-hero-media">
              <picture>
                <source
                  type="image/avif"
                  srcset="/images/hero/home-hero-640.avif 640w"
                  sizes="100vw"
                />
                <source
                  type="image/webp"
                  srcset="/images/hero/home-hero-640.webp 640w, /images/hero/home-hero-960.webp 960w, /images/hero/home-hero-1280.webp 1280w"
                  sizes="100vw"
                />
                <img
                  class="pro-home-hero-photo"
                  src="/images/hero/home-hero-640.webp"
                  srcset="/images/hero/home-hero-640.webp 640w, /images/hero/home-hero-960.webp 960w, /images/hero/home-hero-1280.webp 1280w"
                  sizes="100vw"
                  width="1280"
                  height="720"
                  alt="Professional providing a home service"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                />
              </picture>
              <div class="pro-home-hero-scrim"></div>
            </div>

            <div class="pro-home-hero-panel">
              <div class="pro-home-hero-caption">
                <h1 id="pro-home-hero-heading" class="pro-home-hero-title">Find trusted professionals near you</h1>
                <p class="pro-home-hero-lead">
                  <span class="home-hero-lead-full">Search by service and city to compare local professionals, view profiles, and contact the right one quickly.</span>
                  <span class="home-hero-lead-short">Search by service and city — then call or message a professional.</span>
                </p>
              </div>
              <div class="pro-home-search-wrap pro-home-search-wrap--hero">
                <%- include('partials/pro_search_form', {
                  variant: 'home',
                  tenantUrlPrefix,
                  showCategoryFilter: false,
                }) %>
              </div>
            </div>
          </div>
        </section>

    <div class="home-page__desktop-only" data-home-desktop-only>
    <section class="wf-stats" aria-label="Highlights">
      <div class="container wf-stats-grid">
        <div class="wf-stat">
          <div class="wf-stat-value">Verified listings</div>
          <p class="wf-stat-label">Browse active professional profiles</p>
        </div>
        <div class="wf-stat wf-stat-divider" aria-hidden="true"></div>
        <div class="wf-stat">
          <div class="wf-stat-value">Popular categories</div>
          <p class="wf-stat-label">Explore services faster by category</p>
        </div>
        <div class="wf-stat wf-stat-divider" aria-hidden="true"></div>
        <div class="wf-stat">
          <div class="wf-stat-value">Direct contact</div>
          <p class="wf-stat-label">View profiles and contact businesses directly</p>
        </div>
      </div>
    </section>
    </div>

    <section class="pro-section">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title"><a href="<%= tenantUrlPrefix %>/directory">Leading categories</a></h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/directory">All categories →</a>
        </div>
        <div id="home-categories" class="pro-cat-grid">
          <% categories.forEach(function(cat) { %>
            <a href="<%= tenantUrlPrefix %>/category/<%= cat.slug %>"><%= cat.name %></a>
          <% }) %>
          <% if (categories.length === 0) { %>
            <p class="muted pro-cat-grid__full-span">No categories yet. Add them in the admin panel.</p>
          <% } %>
        </div>
      </div>
    </section>

    <section class="home-m3-cta home-m3-cta--help" aria-labelledby="home-help-cta-heading">
      <div class="container">
        <div class="home-m3-cta__card">
          <h2 id="home-help-cta-heading" class="home-m3-cta__title">Need help finding the right professional?</h2>
          <p class="home-m3-cta__text muted">Tell us what you need — our team can point you to the right category or service.</p>
          <div class="home-m3-cta__actions">
            <% if (typeof getproTelHref !== 'undefined' && getproTelHref && typeof getproPhone !== 'undefined' && getproPhone) { %>
            <a class="btn btn-primary home-m3-cta__btn" href="<%= getproTelHref %>">Call <%= getproPhone %></a>
            <% } %>
            <a class="btn btn-secondary-wf home-m3-cta__btn" href="<%= tenantUrlPrefix %>/directory">Open directory</a>
          </div>
        </div>
      </div>
    </section>

    <div class="home-page__desktop-only" data-home-desktop-only>
    <section class="pro-section" id="about">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title"><a href="#about">How we do it</a></h2>
        </div>
        <div class="pro-pillars">
          <div class="pro-pillar">
            <h3>Curated professionals</h3>
            <ul>
              <li>Businesses are organized by category for faster discovery.</li>
              <li>Each profile stays focused: services, contact, and a simple lead form.</li>
            </ul>
          </div>
          <div class="pro-pillar">
            <h3>Clear information</h3>
            <ul>
              <li>Headlines and descriptions help you compare professionals quickly.</li>
              <li>Direct phone and email when the business chooses to publish them.</li>
            </ul>
          </div>
          <div class="pro-pillar">
            <h3>Support through the platform</h3>
            <ul>
              <li>Request contact without hunting for forms across random sites.</li>
              <li>Reach our team during business hours if you need help navigating the directory.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="pro-section" id="pricing">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title">Sample pricing awareness</h2>
          <span class="muted pro-section-head__aside">Illustrative ranges — always confirm with the professional.</span>
        </div>
        <div class="pro-price-row">
          <div class="pro-price-card">
            <h4>Standard service visit</h4>
            <p class="desc">Typical on-site assessment or small repair visit.</p>
            <div class="amt">from local rates</div>
          </div>
          <div class="pro-price-card">
            <h4>Planned installation</h4>
            <p class="desc">Larger jobs depend on materials and access — get a written quote.</p>
            <div class="amt">quote per job</div>
          </div>
          <div class="pro-price-card">
            <h4>Emergency call-out</h4>
            <p class="desc">After-hours premiums may apply; ask upfront.</p>
            <div class="amt">varies</div>
          </div>
        </div>
      </div>
    </section>

    <section class="pro-section">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title">Recent feedback</h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/directory">Browse professionals →</a>
        </div>
        <div class="pro-reviews">
          <div class="pro-review">
            <div class="pro-stars">★★★★★</div>
            <div class="pro-review-meta">Dana · last week</div>
            <q>Found a specialist in minutes and booked straight from the profile. Clear and fast.</q>
          </div>
          <div class="pro-review">
            <div class="pro-stars">★★★★★</div>
            <div class="pro-review-meta">Yossi · March 2026</div>
            <q>The lead form worked on mobile. The business called back the same day.</q>
          </div>
          <div class="pro-review">
            <div class="pro-stars">★★★★★</div>
            <div class="pro-review-meta">Michal · March 2026</div>
            <q>Nice to have categories laid out like the big pro directories — but lightweight.</q>
          </div>
        </div>
      </div>
    </section>

    <section class="pro-section" id="services">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title"><a href="<%= tenantUrlPrefix %>/articles">Popular jobs &amp; topics</a></h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/articles">All articles →</a>
        </div>
        <div class="pro-articles">
          <% if (typeof contentArticles !== 'undefined' && contentArticles && contentArticles.length) { %>
            <% contentArticles.forEach(function (a) { %>
          <article class="pro-article">
            <% if (a.hero_image_url) { %>
            <div class="pro-article-thumb pro-article-thumb--img" aria-hidden="true">
              <img src="<%= a.hero_image_url %>" alt="" width="120" height="80" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover" />
            </div>
            <% } else { %>
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <% } %>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/articles/<%= encodeURIComponent(a.slug) %>"><%= a.title %></a></h4>
              <p><%= a.excerpt || '' %></p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/articles/<%= encodeURIComponent(a.slug) %>">Read more →</a>
            </div>
          </article>
            <% }); %>
          <% } else { %>
            <p class="muted pro-cat-grid__full-span">Editorial articles will appear here when published in admin.</p>
          <% } %>
        </div>
      </div>
    </section>

    <section class="pro-section" id="guide">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title"><a href="<%= tenantUrlPrefix %>/guides">Pro guide</a></h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/guides">All guides →</a>
        </div>
        <div class="pro-articles">
          <% if (typeof contentGuides !== 'undefined' && contentGuides && contentGuides.length) { %>
            <% contentGuides.forEach(function (g) { %>
          <article class="pro-article">
            <% if (g.hero_image_url) { %>
            <div class="pro-article-thumb pro-article-thumb--img" aria-hidden="true">
              <img src="<%= g.hero_image_url %>" alt="" width="120" height="80" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover" />
            </div>
            <% } else { %>
            <div class="pro-article-thumb" aria-hidden="true"></div>
            <% } %>
            <div class="pro-article-body">
              <h4><a href="<%= tenantUrlPrefix %>/guides/<%= encodeURIComponent(g.slug) %>"><%= g.title %></a></h4>
              <p><%= g.excerpt || '' %></p>
              <a class="pro-readmore" href="<%= tenantUrlPrefix %>/guides/<%= encodeURIComponent(g.slug) %>">Read more →</a>
            </div>
          </article>
            <% }); %>
          <% } else { %>
            <p class="muted pro-cat-grid__full-span">Pro guides will appear here when published in admin.</p>
          <% } %>
        </div>
      </div>
    </section>

    <section class="pro-section" id="qa">
      <div class="container">
        <div class="pro-section-head">
          <h2 class="pro-section-title"><a href="<%= tenantUrlPrefix %>/answers">Questions &amp; answers</a></h2>
          <a class="pro-link-all" href="<%= tenantUrlPrefix %>/answers">All answers →</a>
        </div>
        <div class="pro-qa-list">
          <% if (typeof contentFaqs !== 'undefined' && contentFaqs && contentFaqs.length) { %>
            <% contentFaqs.forEach(function (f) { %>
          <div class="pro-qa-item">
            <p class="pro-qa-q"><a href="<%= tenantUrlPrefix %>/answers/<%= encodeURIComponent(f.slug) %>"><%= f.title %></a></p>
            <p class="pro-qa-a"><%= (f.excerpt && f.excerpt.trim()) ? f.excerpt : (f.body_preview ? String(f.body_preview).replace(/\s+/g, ' ').trim() : '') %></p>
            <div class="pro-qa-meta">Updated · <%= new Date().getFullYear() %></div>
          </div>
            <% }); %>
          <% } else { %>
            <p class="muted">Q&amp;A items will appear here when published in admin.</p>
          <% } %>
        </div>
      </div>
    </section>

    <section class="pro-section">
      <div class="container">
        <div class="card cta-card wf-cta-card cta-card--center">
          <h2 class="section-title section-title--flush">Your next professional is a search away</h2>
          <p class="subtitle subtitle--cta">Browse the directory or list your business on GetPro.</p>
          <div class="hero-actions wf-cta-actions wf-cta-actions--single">
            <a class="btn btn-primary" href="<%= tenantUrlPrefix %>/directory">Start Search</a>
          </div>
        </div>
      </div>
    </section>

      </div>
    </div>

    <%- include('partials/site_footer', { tenantUrlPrefix }) %>
    </div>
  </div>

    <script src="/scripts.js?v=<%= stylesVersion %>" defer></script>
    <%- include('partials/autocomplete_defer_bootstrap') %>
  </body>
</html>
