<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/seo_meta', {
      seoTitle: typeof seoTitle !== 'undefined' ? seoTitle : 'GetPro · Trusted professional directory',
      seoDescription: typeof seoDescription !== 'undefined' ? seoDescription : 'Find trusted professionals near you. Search by service and city, compare profiles, and contact the right business quickly.',
      canonicalUrl: typeof canonicalUrl !== 'undefined' ? canonicalUrl : '',
      ogUrl: typeof ogUrl !== 'undefined' ? ogUrl : '',
      ogImage: typeof ogImage !== 'undefined' ? ogImage : '',
      ogType: 'website'
    }) %>
    <% if (typeof orgJsonLd !== 'undefined' && orgJsonLd) { %>
    <script type="application/ld+json"><%- orgJsonLd %></script>
    <% } %>
    <link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" />
  </head>
  <body class="home-page home-page--launcher wf-home-layout <%= tenant.themeClass %>" data-screen-role="launcher">
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [], renderRegionPickerTrigger: true }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix }) %>

      <div class="app-layout__main">
    <% if (typeof showRegionPickerUi !== 'undefined' && showRegionPickerUi) { %>
    <div id="wf-region-m3-root" class="m3-modal-overlay wf-region-m3" hidden aria-hidden="true">
      <div class="m3-modal-overlay__backdrop" id="wf-region-overlay"></div>
      <div
        id="wf-region-sheet"
        class="m3-modal wf-region-sheet wf-region-sheet--picker"
        role="dialog"
        aria-modal="true"
        aria-labelledby="wf-region-title"
      >
        <header class="m3-modal__header wf-region-sheet__header">
          <h2 id="wf-region-title" class="m3-modal__title wf-region-title wf-region-title--picker">Choose region</h2>
          <button type="button" class="m3-modal__close wf-region-close-x" id="wf-region-close-x" aria-label="Close">×</button>
        </header>
        <div class="m3-modal__body wf-region-sheet__body">
          <div class="wf-region-actions wf-region-actions--grid">
        <% if (typeof regionChoices !== 'undefined' && regionChoices && regionChoices.length) { %>
          <% regionChoices.forEach(function (r) { %>
            <a class="wf-region-btn" href="<%= r.href %>">
              <span class="wf-region-btn-label" <%= r.slug === 'il' ? 'dir="rtl"' : '' %>><%= r.slug === 'il' ? 'ישראל' : r.name %></span>
              <span class="wf-region-btn-flag" aria-hidden="true"><%= r.flag %></span>
            </a>
          <% }); %>
        <% } else { %>
        <a class="wf-region-btn" href="<%= regionZmUrl || tenantHomeHref %>">
          <span class="wf-region-btn-label">Zambia</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇿🇲</span>
        </a>
        <% if (regionIlUrl) { %>
        <a class="wf-region-btn" href="<%= regionIlUrl %>">
          <span class="wf-region-btn-label" dir="rtl">ישראל</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇮🇱</span>
        </a>
        <% } %>
        <% } %>
          </div>
        </div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>
    <% } %>

    <main class="gp-home" role="main">
      <!-- 1) HERO: search shell + orange band (first product story) -->
      <section class="gp-home-hero" aria-labelledby="gp-home-hero-title">
        <div class="gp-home-hero__top">
          <div class="gp-home-hero__search-shell">
            <div id="gp-home-search" class="gp-home-search" aria-label="Project search">
              <%- include('partials/pro_search_form', {
                variant: 'home',
                tenantUrlPrefix,
                showCategoryFilter: false,
              }) %>
            </div>
          </div>
        </div>

        <div class="gp-home-hero__band">
          <div class="gp-home-hero__band-inner">
            <div class="gp-home-hero__copy">
              <span class="gp-home-hero__eyebrow">Why use GetPro</span>
              <h1 id="gp-home-hero-title" class="gp-home-hero__title">Find the right pro, faster</h1>
              <p class="gp-home-hero__subtitle">
                Search by service and city—compare profiles and contact the best fit in one flow.
              </p>
            </div>
            <div class="gp-home-hero__mockup">
              <div class="gp-home-hero__mockup-card">
                <div class="gp-home-hero__mockup-header">Suggested providers</div>
                <div class="gp-home-hero__mockup-row">
                  <div class="gp-home-hero__mockup-name">Northside Electric</div>
                  <div class="gp-home-hero__mockup-meta">4.9 · Open now</div>
                </div>
                <div class="gp-home-hero__mockup-row">
                  <div class="gp-home-hero__mockup-name">Urban HVAC Co.</div>
                  <div class="gp-home-hero__mockup-meta">4.8 · Same-day</div>
                </div>
                <div class="gp-home-hero__mockup-row">
                  <div class="gp-home-hero__mockup-name">QuickFix Plumbing</div>
                  <div class="gp-home-hero__mockup-meta">5.0 · Emergency</div>
                </div>
                <div class="gp-home-hero__mockup-footer">Compare details and contact the best fit</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Auto-advancing product story -->
      <section
        class="gp-home-story gp-home-story--t1"
        data-gp-home-story
        aria-labelledby="gp-home-story-title"
      >
        <div class="container gp-home-story__inner">
          <div class="gp-home-story__content" id="gp-home-story-region" aria-live="polite">
            <span class="gp-home-story__eyebrow">Why use GetPro</span>
            <h2 id="gp-home-story-title" class="gp-home-story__title">Find the right local pro</h2>
            <p class="gp-home-story__text">
              Search by service and city to discover relevant providers near you and contact the best fit faster.
            </p>
          </div>

          <div class="gp-home-story__visual" aria-hidden="true">
            <div class="gp-home-story-panel is-active" data-story-panel="0" aria-hidden="false">
              <div class="gp-home-story-mock gp-home-story-mock--list">
                <div class="gp-home-story-mock__label">Near you</div>
                <ul class="gp-home-story-mock__list">
                  <li><span class="gp-home-story-mock__name">Apex Plumbing</span><span class="gp-home-story-mock__sub">4.9 · Today</span></li>
                  <li><span class="gp-home-story-mock__name">City Electric</span><span class="gp-home-story-mock__sub">4.8 · Open</span></li>
                  <li><span class="gp-home-story-mock__name">Pro HVAC</span><span class="gp-home-story-mock__sub">5.0 · Fast</span></li>
                </ul>
              </div>
            </div>
            <div class="gp-home-story-panel" data-story-panel="1" aria-hidden="true">
              <div class="gp-home-story-mock gp-home-story-mock--reviews">
                <div class="gp-home-story-mock__stars" aria-hidden="true">★★★★★</div>
                <p class="gp-home-story-mock__quote">“Clear ratings helped us pick fast.”</p>
                <div class="gp-home-story-mock__chips">
                  <span>Verified</span><span>12 reviews</span><span>4.9 avg</span>
                </div>
              </div>
            </div>
            <div class="gp-home-story-panel" data-story-panel="2" aria-hidden="true">
              <div class="gp-home-story-mock gp-home-story-mock--profile">
                <div class="gp-home-story-mock__avatar" aria-hidden="true"></div>
                <div class="gp-home-story-mock__profile-name">Summit Services</div>
                <div class="gp-home-story-mock__profile-meta">Profile complete · In search</div>
                <div class="gp-home-story-mock__bar"><span></span></div>
              </div>
            </div>
          </div>

          <div class="gp-home-story__dots" role="group" aria-label="Story slides">
            <button type="button" class="gp-home-story__dot is-active" data-story-dot="0" aria-label="Slide 1 of 3" aria-current="true"></button>
            <button type="button" class="gp-home-story__dot" data-story-dot="1" aria-label="Slide 2 of 3"></button>
            <button type="button" class="gp-home-story__dot" data-story-dot="2" aria-label="Slide 3 of 3"></button>
          </div>
        </div>
      </section>

      <!-- Product benefits (Moovit-style storytelling) -->
      <section class="gp-home-benefits" aria-label="Why GetPro">
        <div class="container">
          <section class="gp-home-feature gp-home-feature--reverse" aria-labelledby="gp-home-benefit-2-title">
            <div class="gp-home-feature__text">
              <span class="gp-home-feature__eyebrow">Make better choices</span>
              <h2 id="gp-home-benefit-2-title" class="gp-home-feature__title">Compare before you decide</h2>
              <p class="gp-home-feature__desc">View profiles, availability, and details so you can choose the best fit with confidence.</p>
              <a class="gp-home-feature__cta btn btn--primary" href="#gp-home-search">Search providers</a>
            </div>
            <div class="gp-home-feature__visual" aria-hidden="true">
              <div class="gp-home-feature-mock gp-home-feature-mock--compare">
                <div class="gp-home-feature-mock__compare">
                  <div class="gp-home-feature-mock__profile">
                    <span class="gp-home-feature-mock__profile-avatar" aria-hidden="true"></span>
                    <span class="gp-home-feature-mock__profile-name">Studio Build</span>
                    <span class="gp-home-feature-mock__profile-tag">Next slot · Tue</span>
                    <ul class="gp-home-feature-mock__profile-lines">
                      <li>Verified</li>
                      <li>12 reviews</li>
                    </ul>
                  </div>
                  <div class="gp-home-feature-mock__profile">
                    <span class="gp-home-feature-mock__profile-avatar" aria-hidden="true"></span>
                    <span class="gp-home-feature-mock__profile-name">Craft &amp; Co.</span>
                    <span class="gp-home-feature-mock__profile-tag">Next slot · Wed</span>
                    <ul class="gp-home-feature-mock__profile-lines">
                      <li>Verified</li>
                      <li>28 reviews</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="gp-home-feature" aria-labelledby="gp-home-benefit-3-title">
            <div class="gp-home-feature__text">
              <span class="gp-home-feature__eyebrow">Take action</span>
              <h2 id="gp-home-benefit-3-title" class="gp-home-feature__title">Contact with confidence</h2>
              <p class="gp-home-feature__desc">Reach out directly to providers that match your needs without guesswork.</p>
              <a class="gp-home-feature__cta btn btn--primary" href="#gp-home-search">Search providers</a>
            </div>
            <div class="gp-home-feature__visual" aria-hidden="true">
              <div class="gp-home-feature-mock gp-home-feature-mock--contact">
                <div class="gp-home-feature-mock__contact-bar">
                  <span class="gp-home-feature-mock__contact-avatar" aria-hidden="true"></span>
                  <span class="gp-home-feature-mock__contact-info">
                    <span class="gp-home-feature-mock__contact-name">BrightView Cleaning</span>
                    <span class="gp-home-feature-mock__contact-sub">Responds in ~1h</span>
                  </span>
                </div>
                <div class="gp-home-feature-mock__contact-body">
                  <span class="gp-home-feature-mock__line"></span>
                  <span class="gp-home-feature-mock__line gp-home-feature-mock__line--short"></span>
                </div>
                <div class="gp-home-feature-mock__contact-actions">
                  <span class="gp-home-feature-mock__pill">Message</span>
                </div>
              </div>
            </div>
          </section>
        </div>
      </section>

      <!-- 2) HOW IT WORKS -->
      <section class="gp-home-steps" aria-labelledby="gp-home-steps-title">
        <div class="container gp-home-steps__inner">
          <header class="gp-home-section-head">
            <h2 id="gp-home-steps-title" class="gp-home-section-title">How it works</h2>
          </header>

          <ol class="gp-home-steps__list">
            <li class="gp-home-step">
              <h3 class="gp-home-step__title">Tell us what you need</h3>
              <p class="gp-home-step__text">Choose a service and add your city.</p>
            </li>
            <li class="gp-home-step">
              <h3 class="gp-home-step__title">See matching providers</h3>
              <p class="gp-home-step__text">Browse profiles and availability details.</p>
            </li>
            <li class="gp-home-step">
              <h3 class="gp-home-step__title">Contact with confidence</h3>
              <p class="gp-home-step__text">Compare options, then reach out to the best fit.</p>
            </li>
          </ol>
        </div>
      </section>

      <!-- Platform accomplishments -->
      <section class="gp-home-metrics" aria-labelledby="gp-home-metrics-title">
        <div class="container gp-home-metrics__inner">
          <header class="gp-home-metrics__head">
            <span class="gp-home-metrics__eyebrow">Platform growth</span>
            <h2 id="gp-home-metrics-title" class="gp-home-metrics__title">Built to help customers and providers connect</h2>
          </header>

          <div class="gp-home-metrics__grid">
            <article class="gp-home-metric-circle">
              <div class="gp-home-metric-circle__ring">
                <div class="gp-home-metric-circle__value">2000+</div>
              </div>
              <div class="gp-home-metric-circle__label">Deals</div>
            </article>
            <article class="gp-home-metric-circle">
              <div class="gp-home-metric-circle__ring">
                <div class="gp-home-metric-circle__value">300+</div>
              </div>
              <div class="gp-home-metric-circle__label">Service providers</div>
            </article>
            <article class="gp-home-metric-circle">
              <div class="gp-home-metric-circle__ring">
                <div class="gp-home-metric-circle__value">10+</div>
              </div>
              <div class="gp-home-metric-circle__label">Locations in Zambia</div>
            </article>
            <article class="gp-home-metric-circle">
              <div class="gp-home-metric-circle__ring">
                <div class="gp-home-metric-circle__value">4.3</div>
              </div>
              <div class="gp-home-metric-circle__label">Service rating</div>
            </article>
          </div>
        </div>
      </section>

      <!-- 3) TRUST / SOCIAL PROOF -->
      <section class="gp-home-trust" aria-labelledby="gp-home-trust-title">
        <div class="container gp-home-trust__inner">
          <header class="gp-home-section-head">
            <h2 id="gp-home-trust-title" class="gp-home-section-title">Trusted at a glance</h2>
            <p class="gp-home-section-subtitle">Real providers. Clear profiles. Quick decisions.</p>
          </header>

          <ul class="gp-home-trust__stats" aria-label="Key stats">
            <li class="gp-home-stat">
              <div class="gp-home-stat__value">10+</div>
              <div class="gp-home-stat__label">Locations</div>
            </li>
            <li class="gp-home-stat">
              <div class="gp-home-stat__value">200+</div>
              <div class="gp-home-stat__label">Service providers</div>
            </li>
            <li class="gp-home-stat">
              <div class="gp-home-stat__value">2000+</div>
              <div class="gp-home-stat__label">Served customers</div>
            </li>
            <li class="gp-home-stat">
              <div class="gp-home-stat__value">4.3</div>
              <div class="gp-home-stat__label">Customer rating</div>
            </li>
          </ul>

          <div class="gp-home-trust__quotes" aria-label="Recent feedback">
            <figure class="gp-home-quote">
              <blockquote class="gp-home-quote__text">Found the right specialist in minutes.</blockquote>
              <figcaption class="gp-home-quote__meta">Dana · last week</figcaption>
            </figure>
            <figure class="gp-home-quote">
              <blockquote class="gp-home-quote__text">Easy to compare on mobile and contact right away.</blockquote>
              <figcaption class="gp-home-quote__meta">Yossi · March 2026</figcaption>
            </figure>
          </div>
        </div>
      </section>

      <!-- 4) SERVICE PROVIDER CTA -->
      <section class="gp-home-provider" aria-labelledby="gp-home-provider-title">
        <div class="container gp-home-provider__inner">
          <div class="gp-home-section gp-home-section--split">
            <header class="gp-home-section-head">
              <h2 id="gp-home-provider-title" class="gp-home-section-title">Are you a service provider?</h2>
              <p class="gp-home-section-subtitle">Get discovered by customers searching in your city.</p>
            </header>
            <div class="gp-home-provider__actions">
              <a class="btn btn--secondary" href="https://getproapp.org/join" target="_blank" rel="noopener noreferrer">Join as a provider</a>
            </div>
          </div>
        </div>
      </section>

      <!-- 5) FINAL CTA -->
      <section class="gp-home-final" aria-labelledby="gp-home-final-title">
        <div class="container gp-home-final__inner">
          <h2 id="gp-home-final-title" class="gp-home-final__title">Ready to find the right pro?</h2>
          <p class="gp-home-final__text">Search now—pick a service and city to get started.</p>
          <a class="gp-home-final__cta btn btn--primary" href="#gp-home-search">Start searching</a>
        </div>
      </section>
    </main>

      </div>
    </div>

    <%- include('partials/site_footer', { tenantUrlPrefix }) %>
    </div>
  </div>

    <script src="/scripts.js?v=<%= stylesVersion %>" defer></script>
    <%- include('partials/autocomplete_defer_bootstrap') %>
    <script>
(function () {
  var root = document.querySelector('.gp-home-story[data-gp-home-story]');
  if (!root) return;

  var slides = [
    {
      theme: 1,
      title: 'Find the right local pro',
      text: 'Search by service and city to discover relevant providers near you and contact the best fit faster.'
    },
    {
      theme: 2,
      title: 'See ratings and reviews',
      text: 'Browse verified details, service ratings, and review signals so you can choose with more confidence.'
    },
    {
      theme: 3,
      title: 'Build an online presence',
      text: 'Service providers can create a stronger presence, appear in more searches, and be discovered by more customers.'
    }
  ];

  var titleEl = root.querySelector('.gp-home-story__title');
  var textEl = root.querySelector('.gp-home-story__text');
  var panels = root.querySelectorAll('[data-story-panel]');
  var dots = root.querySelectorAll('[data-story-dot]');
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var i = 0;
  var timer;

  function apply(n) {
    i = n;
    var s = slides[i];
    if (titleEl) titleEl.textContent = s.title;
    if (textEl) textEl.textContent = s.text;
    root.classList.remove('gp-home-story--t1', 'gp-home-story--t2', 'gp-home-story--t3');
    root.classList.add('gp-home-story--t' + s.theme);

    panels.forEach(function (p, idx) {
      var on = idx === i;
      p.classList.toggle('is-active', on);
      p.setAttribute('aria-hidden', on ? 'false' : 'true');
    });

    dots.forEach(function (d, idx) {
      var on = idx === i;
      d.classList.toggle('is-active', on);
      d.setAttribute('aria-current', on ? 'true' : 'false');
    });
  }

  function next() {
    apply((i + 1) % slides.length);
  }

  function arm() {
    if (reduced) return;
    if (timer) window.clearInterval(timer);
    timer = window.setInterval(next, 4500);
  }

  function disarm() {
    if (timer) {
      window.clearInterval(timer);
      timer = null;
    }
  }

  dots.forEach(function (d) {
    d.addEventListener('click', function () {
      var idx = parseInt(d.getAttribute('data-story-dot'), 10);
      if (isNaN(idx)) return;
      disarm();
      apply(idx);
      arm();
    });
  });

  apply(0);
  arm();
})();
    </script>
  </body>
</html>
