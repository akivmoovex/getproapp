<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <%- include('partials/seo_meta', {
      seoTitle: typeof seoTitle !== 'undefined' ? seoTitle : 'GetPro · Trusted professional directory',
      seoDescription: typeof seoDescription !== 'undefined' ? seoDescription : 'Find trusted professionals near you. Search by service and city, compare profiles, and contact the right business quickly.',
      canonicalUrl: typeof canonicalUrl !== 'undefined' ? canonicalUrl : '',
      ogUrl: typeof ogUrl !== 'undefined' ? ogUrl : '',
      ogImage: typeof ogImage !== 'undefined' ? ogImage : '',
      ogType: 'website'
    }) %>
    <% if (typeof orgJsonLd !== 'undefined' && orgJsonLd) { %>
    <script type="application/ld+json"><%- orgJsonLd %></script>
    <% } %>
    <%# PERF NOTE: Homepage hero is LCP-sensitive — keep preload imagesrcset aligned with <picture> srcset; avoid blocking ATF JS (docs/performance-budgets.md §2.1). %>
    <%- include('partials/critical_css_home') %>
    <link
      rel="preload"
      as="image"
      type="image/avif"
      href="/images/hero/home-hero-640.avif"
      imagesrcset="/images/hero/home-hero-640.avif 640w, /images/hero/home-hero-960.avif 960w, /images/hero/home-hero-1280.avif 1280w"
      imagesizes="100vw"
    />
    <link
      rel="preload"
      as="style"
      href="/styles.css?v=<%= stylesVersion %>"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link rel="stylesheet" href="/styles.css?v=<%= stylesVersion %>" /></noscript>
  </head>
  <body class="home-page home-page--launcher wf-home-layout <%= tenant.themeClass %>" data-screen-role="launcher">
    <div class="app-layout">
      <%- include('partials/site_header', { tenantUrlPrefix, tenant, regionChoices: typeof regionChoices !== 'undefined' ? regionChoices : [], renderRegionPickerTrigger: true }) %>
      <%- include('partials/app_navigation', { tenantUrlPrefix }) %>

      <div class="app-layout__main">
    <% if (typeof showRegionPickerUi !== 'undefined' && showRegionPickerUi) { %>
    <div id="wf-region-m3-root" class="m3-modal-overlay wf-region-m3" hidden aria-hidden="true">
      <div class="m3-modal-overlay__backdrop" id="wf-region-overlay"></div>
      <div
        id="wf-region-sheet"
        class="m3-modal wf-region-sheet wf-region-sheet--picker"
        role="dialog"
        aria-modal="true"
        aria-labelledby="wf-region-title"
      >
        <header class="m3-modal__header wf-region-sheet__header">
          <h2 id="wf-region-title" class="m3-modal__title wf-region-title wf-region-title--picker">Choose region</h2>
          <button type="button" class="m3-modal__close wf-region-close-x" id="wf-region-close-x" aria-label="Close">×</button>
        </header>
        <div class="m3-modal__body wf-region-sheet__body">
          <div class="wf-region-actions wf-region-actions--grid">
        <% if (typeof regionChoices !== 'undefined' && regionChoices && regionChoices.length) { %>
          <% regionChoices.forEach(function (r) { %>
            <a class="wf-region-btn" href="<%= r.href %>">
              <span class="wf-region-btn-label" <%= r.slug === 'il' ? 'dir="rtl"' : '' %>><%= r.slug === 'il' ? 'ישראל' : r.name %></span>
              <span class="wf-region-btn-flag" aria-hidden="true"><%= r.flag %></span>
            </a>
          <% }); %>
        <% } else { %>
        <a class="wf-region-btn" href="<%= regionZmUrl || tenantHomeHref %>">
          <span class="wf-region-btn-label">Zambia</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇿🇲</span>
        </a>
        <% if (regionIlUrl) { %>
        <a class="wf-region-btn" href="<%= regionIlUrl %>">
          <span class="wf-region-btn-label" dir="rtl">ישראל</span>
          <span class="wf-region-btn-flag" aria-hidden="true">🇮🇱</span>
        </a>
        <% } %>
        <% } %>
          </div>
        </div>
        <footer class="m3-modal__footer m3-modal__footer--empty" aria-hidden="true"></footer>
      </div>
    </div>
    <% } %>


    <main class="gp-home" role="main">
      <section class="gp-home-hero" aria-labelledby="gp-home-hero-title">
        <div class="gp-home-hero__bg" aria-hidden="true">
          <picture>
            <source
              type="image/avif"
              srcset="/images/hero/home-hero-640.avif 640w, /images/hero/home-hero-960.avif 960w, /images/hero/home-hero-1280.avif 1280w"
              sizes="100vw"
            />
            <source
              type="image/webp"
              srcset="/images/hero/home-hero-640.webp 640w, /images/hero/home-hero-960.webp 960w, /images/hero/home-hero-1280.webp 1280w"
              sizes="100vw"
            />
            <img
              class="gp-home-hero__photo"
              src="/images/hero/home-hero-640.webp"
              srcset="/images/hero/home-hero-640.webp 640w, /images/hero/home-hero-960.webp 960w, /images/hero/home-hero-1280.webp 1280w"
              sizes="100vw"
              width="1280"
              height="720"
              style="width:100%;height:auto;aspect-ratio:16/9;object-fit:cover"
              alt="Professional providing a home service"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </picture>
          <div class="gp-home-hero__scrim"></div>
        </div>

        <div class="container gp-home-hero__content">
          <h1 id="gp-home-hero-title" class="gp-home-hero__title">Find the right pro, fast.</h1>
          <p class="gp-home-hero__subtext">Search by service and city to connect with trusted providers near you.</p>

          <div class="gp-home-search-card" aria-label="Search">
            <%- include('partials/pro_search_form', {
              variant: 'home',
              tenantUrlPrefix,
              showCategoryFilter: false,
            }) %>
          </div>
        </div>
      </section>

      <section class="gp-home-features" aria-label="Features">
        <div class="container">
          <header class="gp-home-section-head">
            <h2 class="gp-home-section-title">Built for quick decisions</h2>
            <p class="gp-home-section-subtitle">A lightweight directory experience that feels like an app.</p>
          </header>

          <div class="gp-home-feature-list">
            <article class="gp-home-feature" aria-label="Find services fast">
              <div class="gp-home-feature__media">
                <img class="gp-home-feature__img" src="/images/mobile/feature-find.svg" alt="" width="560" height="360" loading="lazy" decoding="async" />
              </div>
              <div class="gp-home-feature__body">
                <h3 class="gp-home-feature__title">Find services fast</h3>
                <p class="gp-home-feature__desc">Search and discover trusted providers near you.</p>
              </div>
            </article>

            <article class="gp-home-feature gp-home-feature--reverse" aria-label="Track project updates">
              <div class="gp-home-feature__media">
                <img class="gp-home-feature__img" src="/images/mobile/feature-track.svg" alt="" width="560" height="360" loading="lazy" decoding="async" />
              </div>
              <div class="gp-home-feature__body">
                <h3 class="gp-home-feature__title">Track project updates</h3>
                <p class="gp-home-feature__desc">Stay updated from request to completion.</p>
              </div>
            </article>

            <article class="gp-home-feature" aria-label="Compare providers">
              <div class="gp-home-feature__media">
                <img class="gp-home-feature__img" src="/images/mobile/feature-compare.svg" alt="" width="560" height="360" loading="lazy" decoding="async" />
              </div>
              <div class="gp-home-feature__body">
                <h3 class="gp-home-feature__title">Compare providers</h3>
                <p class="gp-home-feature__desc">Review options before choosing the right expert.</p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="gp-home-stats" aria-label="Trust stats">
        <div class="container">
          <header class="gp-home-section-head">
            <h2 class="gp-home-section-title">Trusted at a glance</h2>
            <p class="gp-home-section-subtitle">Key numbers that reflect real usage across the directory.</p>
          </header>

          <div class="gp-home-stats-grid" role="list">
            <div class="gp-home-stat" role="listitem">
              <span class="gp-home-stat__icon" aria-hidden="true">📍</span>
              <div class="gp-home-stat__value">10+</div>
              <div class="gp-home-stat__label">Locations</div>
            </div>
            <div class="gp-home-stat" role="listitem">
              <span class="gp-home-stat__icon" aria-hidden="true">🧰</span>
              <div class="gp-home-stat__value">200+</div>
              <div class="gp-home-stat__label">Service providers</div>
            </div>
            <div class="gp-home-stat" role="listitem">
              <span class="gp-home-stat__icon" aria-hidden="true">👥</span>
              <div class="gp-home-stat__value">2000+</div>
              <div class="gp-home-stat__label">Served customers</div>
            </div>
            <div class="gp-home-stat" role="listitem">
              <span class="gp-home-stat__icon" aria-hidden="true">⭐</span>
              <div class="gp-home-stat__value">4.3</div>
              <div class="gp-home-stat__label">Customer rating</div>
            </div>
          </div>
        </div>
      </section>

      <section class="gp-home-lite" aria-label="Get started">
        <div class="container">
          <div class="gp-home-lite-card">
            <h2 class="gp-home-lite-title">Ready to start?</h2>
            <p class="gp-home-lite-text">Open the directory or list your business—GetPro keeps it simple.</p>
            <div class="gp-home-lite-actions">
              <a class="btn btn--primary" href="<%= tenantUrlPrefix %>/directory">Open directory</a>
              <a class="btn btn--secondary" href="https://getproapp.org/join" target="_blank" rel="noopener noreferrer">Join as a provider</a>
            </div>
          </div>
        </div>
      </section>
    </main>

      </div>
    </div>

    <%- include('partials/site_footer', { tenantUrlPrefix }) %>
    </div>
  </div>

    <script src="/scripts.js?v=<%= stylesVersion %>" defer></script>
    <%- include('partials/autocomplete_defer_bootstrap') %>
  </body>
</html>
