# getproapp.org — real production only (not pronline.org).
# Set these in Hostinger (Website → Environment variables), not as a committed `.env`.
# When NODE_ENV=production, the app does not load repo-root `.env`. Optional disk fallbacks include
# /home/u549637099/getpro/.env.production for getproapp paths and /home/u549637099/pronline/.env.production for pronline (see bootstrap).
#
# Admin → DB seed/clear: leave GETPRO_ALLOW_DB_FIXTURES and GETPRO_ALLOW_DB_FIXTURES_IN_PRODUCTION **unset**
# (or not "1"). Real production stays blocked; use `.env.development.example` for pronline.org demo flags.

NODE_ENV=production
BASE_DOMAIN=getproapp.org
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
ADMIN_PASSWORD=REPLACE_ME
PUBLIC_SCHEME=https
PORT=3000
HOST=0.0.0.0
GETPRO_PG_SSL=no-verify
TRUST_PROXY=1

# Branding (getproapp.org — show GetPro lockup + indigo tokens)
GETPRO_PRODUCT_NAME=Pro-online
GETPRO_PRODUCT_NAME_GETPRO=GetPro
GETPRO_HTML_DATA_BRAND=getpro

# Never set these on getproapp.org (Admin → DB tools must stay off). See src/admin/dbFixturesEnv.js.
# GETPRO_ALLOW_DB_FIXTURES=1
# GETPRO_ALLOW_DB_FIXTURES_IN_PRODUCTION=1
