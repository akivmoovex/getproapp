# Reference values for production — set these in Hostinger (Website → Environment variables), not as a committed `.env`.
# When NODE_ENV=production, the app does not load a `.env` file from disk.

NODE_ENV=production
BASE_DOMAIN=getproapp.org
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
ADMIN_PASSWORD=REPLACE_ME
PUBLIC_SCHEME=https
PORT=3000
HOST=0.0.0.0
GETPRO_PG_SSL=no-verify
TRUST_PROXY=1
