# Copy to `.env` for local development (never commit `.env`).
# Production (e.g. Hostinger): set the same keys in the panel environment — `.env` is often not deployed.

# --- PostgreSQL (required) ---
# Prefer DATABASE_URL. If unset, GETPRO_DATABASE_URL is used.
# Supabase: Project Settings → Database → Connection string → URI (direct :5432 or pooler :6543).
DATABASE_URL=
GETPRO_DATABASE_URL=

# Pool tuning (optional)
GETPRO_PG_POOL_MAX=10
GETPRO_PG_IDLE_MS=30000
GETPRO_PG_CONNECT_TIMEOUT_MS=10000

# SSL for node-pg: strict | no-verify | off (Hostinger + Supabase: use no-verify if you see self-signed certificate errors)
GETPRO_PG_SSL=no-verify

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Production domain (no scheme): e.g. getproapp.org
BASE_DOMAIN=
PUBLIC_SCHEME=https

# Behind nginx / Hostinger: default trust proxy is on (1). Set TRUST_PROXY=0 only if Node is reached directly.
TRUST_PROXY=1

# Required for production sessions; use a long random string locally too if you test prod-like cookies.
SESSION_SECRET=

# First-boot admin (required: ADMIN_PASSWORD)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# ADMIN_ROLE=super_admin
# ADMIN_TENANT_ID=

# Optional branding / contact
# GETPRO_PRODUCT_NAME=
# GETPRO_PRODUCT_NAME_GETPRO=
# GETPRO_PUBLIC_TAGLINE=
# GETPRO_EMAIL=
# GETPRO_ADDRESS=
# CALL_CENTER_PHONE=

# Built-in demo accounts on boot (set to 0 in production if undesired)
# SEED_BUILTIN_USERS=0
# SEED_MANAGER_USERS=0

# Assets / caching
# GETPRO_STYLES_V=
# GETPRO_USE_BUILD_ASSETS=

# Super admin default tenant scope after login
# GETPRO_SUPER_ADMIN_DEFAULT_TENANT_SLUG=

# Debug (do not leave on in production)
# DEBUG_HOST=1
# GETPRO_PG_HEALTH_ROUTE=1

# Israel “coming soon” gate
# ISRAEL_COMING_SOON=true

# Regional / dev overrides
# GETPRO_FORCE_CLIENT_COUNTRY=
