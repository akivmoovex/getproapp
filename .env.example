# --- Required for first boot (admin user is created from this) ---
ADMIN_PASSWORD=

# Optional: admin login username (default: admin)
# ADMIN_USERNAME=admin

# --- Production hygiene ---
NODE_ENV=development
# NODE_ENV=production

# Random secret for express-session (required in production; dev falls back to a weak default)
# SESSION_SECRET=

# --- Server bind ---
# PORT=3000
# HOST=0.0.0.0

# --- Public URLs (subdomain routing & company profile links) ---
# Apex domain only, no scheme — e.g. getproapp.org
BASE_DOMAIN=
# Links to company sites use this scheme (default: https)
# PUBLIC_SCHEME=https

# --- SQLite ---
# App database (default: data/getpro.sqlite relative to project root)
# SQLITE_PATH=data/getpro.sqlite

# --- Sessions (SQLite store) ---
# SESSION_DIR defaults to ./data
# SESSION_DIR=/var/lib/getpro
# Optional explicit path for session DB (default: $SESSION_DIR/sessions.db)
# SESSION_DB_PATH=/var/lib/getpro/sessions.db

# --- Site / footer contact (shown on public pages) ---
# CALL_CENTER_PHONE=
GETPRO_EMAIL=
GETPRO_ADDRESS=

# Legacy fallbacks (still read if GETPRO_* unset)
# PRO_ONLINE_EMAIL=
# PRO_ONLINE_ADDRESS=
# NETRA_EMAIL=
# NETRA_ADDRESS=

# --- Seed script only (npm run seed) ---
# DEMO_COMPANY_SUBDOMAIN=demo
