# GetPro — environment template (no secrets here)
#
# Quick start (local): copy this file to `.env` and fill in values.
#
# Two hosted environments (recommended):
#   - Development / staging on pronline.org  → see `.env.development.example`
#   - Production on getproapp.org            → see `.env.production.example`
#
# Hostinger production: set variables in the panel only (NODE_ENV=production does not load this file).
# See docs/CONFIG_AND_DEPLOYMENT.md. Local dev: copy this file to `.env` when NODE_ENV is not production.

# --- PostgreSQL (required at runtime) ---
DATABASE_URL=
GETPRO_DATABASE_URL=

GETPRO_PG_SSL=no-verify
GETPRO_PG_POOL_MAX=10
GETPRO_PG_IDLE_MS=30000
GETPRO_PG_CONNECT_TIMEOUT_MS=10000

# GETPRO_SKIP_DOTENV=0

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# No scheme; must match the site’s public apex (e.g. pronline.org vs getproapp.org)
BASE_DOMAIN=
PUBLIC_SCHEME=https

TRUST_PROXY=1

SESSION_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- Field agent rate limits (optional; IP-based; authed POST cap is per client IP, not per user — shared NAT/office egress uses one bucket; see docs/CONFIG_AND_DEPLOYMENT.md) ---
# GETPRO_LOGIN_RATE_WINDOW_MS=900000
# GETPRO_FIELD_AGENT_LOGIN_RATE_MAX=30
# GETPRO_FIELD_AGENT_AUTHED_POST_RATE_MAX=30

# Visible product names + tagline (required for correct deployment branding; defaults exist)
GETPRO_PRODUCT_NAME=Pro-online
GETPRO_PRODUCT_NAME_GETPRO=GetPro
# GETPRO_PUBLIC_TAGLINE=

# Which lockup line + theme tokens: getpro | proonline (optional; omit = client prefs / default Pro-online line)
# Alias: APP_BRAND (same values as GETPRO_HTML_DATA_BRAND)
# GETPRO_HTML_DATA_BRAND=
# GETPRO_EMAIL=
# GETPRO_ADDRESS=
# CALL_CENTER_PHONE=

# GETPRO_MARKETING_OPERATIONS_SLUG=zm
# SEED_BUILTIN_USERS=0
# SEED_MANAGER_USERS=0
# GETPRO_STYLES_V=
# GETPRO_USE_BUILD_ASSETS=
# GETPRO_SUPER_ADMIN_DEFAULT_TENANT_SLUG=
# DEBUG_HOST=1
# GETPRO_PG_HEALTH_ROUTE=1
# ISRAEL_COMING_SOON=true
# GETPRO_FORCE_CLIENT_COUNTRY=

# --- Admin → DB tools (seed/clear) — see src/admin/dbFixturesEnv.js ---
# pronline.org (test/demo): either NODE_ENV=development (or staging), with BASE_DOMAIN=pronline.org — tools on;
#   OR NODE_ENV=production with BOTH flags below set to 1 — tools on.
# getproapp.org (real production): NODE_ENV=production — do NOT set the two flags; tools stay off.
# GETPRO_ALLOW_DB_FIXTURES=1
# GETPRO_ALLOW_DB_FIXTURES_IN_PRODUCTION=1
