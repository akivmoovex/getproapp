{
  "name": "getpro",
  "version": "1.0.0",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "node scripts/ensure-apple-touch-icon.js",
    "start": "node server.js",
    "dev": "nodemon --watch \"server.js\" --exec \"node server.js\"",
    "build-search-lists": "node scripts/build-search-lists.js",
    "build:assets": "vite build",
    "dev:assets": "vite build --watch",
    "build": "npm run build:assets && npm run build-search-lists",
    "lint:components": "node scripts/check-components.js",
    "lint:components:baseline": "node scripts/check-components.js --json > .ui-baseline.json",
    "lint:components:ci": "node scripts/check-components.js --compare-baseline .ui-baseline.json",
    "lint:components:enforce-btn": "node scripts/check-components.js --enforce-legacy-btn",
    "lint:css": "stylelint \"public/**/*.css\" --max-warnings 0",
    "lint:css-boundaries": "node scripts/check-css-boundaries.js",
    "lint:css-boundaries:baseline": "node scripts/check-css-boundaries.js --json > .css-boundaries-baseline.json",
    "lint:css-boundaries:ci": "node scripts/check-css-boundaries.js --compare-baseline .css-boundaries-baseline.json",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "inline-ds-framework": "node scripts/inline-ds-framework.js",
    "sync-inlined-theme": "node scripts/sync-inlined-theme.js",
    "test:pg": "node scripts/test-pg-connection.js",
    "test:pg:repos": "node scripts/test-pg-repos.js",
    "check:pg": "node scripts/check-pg-readiness.js",
    "test": "node --test tests",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Pro-online — professional directory for self-employed and small businesses",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "slugify": "^1.6.8",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/html": "^8.6.18",
    "@storybook/html-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "nodemon": "^3.1.14",
    "postcss-selector-parser": "^7.1.1",
    "storybook": "^8.6.18",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1"
  }
}
